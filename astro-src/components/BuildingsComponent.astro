---
// Refactored BuildingsComponent.astro - Now uses modular components with lazy loading
import _ from 'lodash';
import BuildingsList from './BuildingsList.astro';
import AddBuildingForm from './AddBuildingForm.astro';
import BuildingManager from './BuildingManager.astro';
import { Resource } from 'sst';
import type { BuildingData, UnitData, UnitTypeData } from '../../src/types/index.ts';

// Fetch all data in a single API call for optimal performance
const _apiURL = Resource.API.url;
if(!_apiURL) {
    throw new Error('API URL not configured');
} // Validate and mark as used for TypeScript

interface AllDataResponse {
    buildings:           BuildingData[]
    unitsByBuilding:     Record<string, UnitData[]>
    unitTypesByBuilding: Record<string, UnitTypeData[]>
}

let buildings: BuildingData[] = [];
let unitsByBuilding: Record<string, UnitData[]> = {};
let unitTypesByBuilding: Record<string, UnitTypeData[]> = {};
let error: string | null = null;

try {
    const response = await fetch(`${_.replace(_apiURL, /\/$/, '')}/all-data`);
    if(!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    const allData: AllDataResponse = await response.json();
    buildings = allData.buildings || [];
    unitsByBuilding = allData.unitsByBuilding || {};
    unitTypesByBuilding = allData.unitTypesByBuilding || {};
} catch (err) {
    error = _.isError(err) ? err.message : 'Failed to load apartment data';
    buildings = [];
    unitsByBuilding = {};
    unitTypesByBuilding = {};
}
---

<div
  x-data="buildingsComponentData()"
  x-init="buildings = $el.dataset.buildings ? JSON.parse($el.dataset.buildings) : []; apiURL = $el.dataset.apiUrl || ''; init()"
  @building-tab-changed="handleTabChange($event)"
  @show-toast="showAndHideToast($event.detail.message, $event.detail.type)"
  @toast:show="showAndHideToast($event.detail.message, $event.detail.type)"
  @building-data-loaded="handleBuildingDataLoaded($event)"
  @building:updated="handleBuildingUpdated($event)"
  data-buildings={JSON.stringify(buildings)}
  data-api-url={_apiURL}
>

    <!-- Error Display -->
    {error && (
        <div class="alert alert-error mb-6" data-testid="error-message">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 w-6 h-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>{error}</span>
        </div>
    )}

    <!-- Toast notifications now handled by global Layout.astro toast system -->

    <!-- Building navigation tabs -->
    <BuildingsList buildings={buildings} />

    <!-- Individual building managers with lazy loading -->
    <div class="building-managers-container">
        {_.map(buildings, (building, i) => (
            <BuildingManager
              building={building}
              units={unitsByBuilding[building.buildingID] || []}
              unitTypes={unitTypesByBuilding[building.buildingID] || []}
              apiURL={_apiURL}
              data-building-id={building.buildingID}
              data-api-url={_apiURL}
              data-tab-index={i}
              x-show={`activeBuildingTab === ${i}`}
              :class={`{ 'hidden': activeBuildingTab !== ${i} }`}
                x-ref={`manager-${i}`}
                x-cloak
            />
        ))}
    </div>

    <!-- Add building form -->
    <div x-show="activeBuildingTab === buildings.length" x-cloak data-api-url={_apiURL}>
        <AddBuildingForm />
    </div>
</div>

<!-- BuildingsComponent now uses centralized Alpine registry -->

<style>

/* Smooth loading transitions */
[x-cloak] {
    display: none !important;
}

/* Hide inactive tabs */
.hidden {
    display: none !important;
}

</style>
