---
// Refactored BuildingsComponent.astro - Now uses modular components with lazy loading
import _ from 'lodash';
import BuildingsList from './BuildingsList.astro';
import AddBuildingForm from './AddBuildingForm.astro';
import BuildingManager from './BuildingManager.astro';
import { Resource } from 'sst';
import type { BuildingData, UnitData, UnitTypeData } from '../types';

// Fetch all data in a single API call for optimal performance
const _apiURL = Resource.API.url;
if(!_apiURL) {
    throw new Error('API URL not configured');
} // Validate and mark as used for TypeScript

interface AllDataResponse {
    buildings: BuildingData[]
    unitsByBuilding: Record<string, UnitData[]>
    unitTypesByBuilding: Record<string, UnitTypeData[]>
}

let buildings: BuildingData[] = [];
let unitsByBuilding: Record<string, UnitData[]> = {};
let unitTypesByBuilding: Record<string, UnitTypeData[]> = {};
let error: string | null = null;

try {
    const response = await fetch(`${_.replace(_apiURL, /\/$/, '')}/all-data`);
    if(!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    const allData: AllDataResponse = await response.json();
    buildings = allData.buildings || [];
    unitsByBuilding = allData.unitsByBuilding || {};
    unitTypesByBuilding = allData.unitTypesByBuilding || {};
} catch(err) {
    error = _.isError(err) ? err.message : 'Failed to load apartment data';
    buildings = [];
    unitsByBuilding = {};
    unitTypesByBuilding = {};
}
---

<div
  x-data="buildingsComponentData()"
  x-init="init()"
  @building-tab-changed="handleTabChange($event)"
  @show-toast="showAndHideToast($event.detail.message, $event.detail.type)"
  @toast:show="showAndHideToast($event.detail.message, $event.detail.type)"
  @building-data-loaded="handleBuildingDataLoaded($event)"
  @building:updated="handleBuildingUpdated($event)"
  data-buildings={JSON.stringify(buildings)}
  data-api-url={_apiURL}
>

    <!-- Error Display -->
    {error && (
        <div class="alert alert-error mb-6" data-testid="error-message">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 w-6 h-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>{error}</span>
        </div>
    )}

    <!-- Toast notifications now handled by global Layout.astro toast system -->

    <!-- Building navigation tabs -->
    <BuildingsList buildings={buildings} />

    <!-- Individual building managers with lazy loading -->
    <div class="building-managers-container">
        {_.map(buildings, (building, i) => (
            <BuildingManager
              building={building}
              units={unitsByBuilding[building.buildingID] || []}
              unitTypes={unitTypesByBuilding[building.buildingID] || []}
              apiURL={_apiURL}
              data-building-id={building.buildingID}
              data-api-url={_apiURL}
              data-tab-index={i}
              x-show={`activeBuildingTab === ${i}`}
              :class={`{ 'hidden': activeBuildingTab !== ${i} }`}
                x-ref={`manager-${i}`}
                x-cloak
            />
        ))}
    </div>

    <!-- Add building form -->
    <div x-show="activeBuildingTab === buildings.length" x-cloak data-api-url={_apiURL}>
        <AddBuildingForm />
    </div>
</div>

<script>
import _ from 'lodash';
import type { AlpineComponent } from '../types/alpine';

import type { BuildingData, Building } from '../types';

type BuildingsComponentData = AlpineComponent<{
    activeBuildingTab: number
    // Toast properties removed - now uses global toast system
    buildings: BuildingData[]
    apiURL: string
    init(): void
    handleTabChange(event: CustomEvent<{ tabIndex: number, buildingID?: string }>): void
    handleBuildingDataLoaded(event: CustomEvent<{ buildingID: string, building: BuildingData, units: unknown[], unitTypes: unknown[] }>): void
    handleBuildingUpdated(event: CustomEvent<{ building: BuildingData }>): void
    showAndHideToast(message: string, type: string): void
}>;

function buildingsComponentData(): BuildingsComponentData {
    return {
        activeBuildingTab: 0,
        // Toast properties removed - now uses global toast system
        buildings: [] as BuildingData[],
        apiURL: '',

        init() {
            this.buildings = JSON.parse(this.$el.dataset.buildings || '[]');
            this.apiURL = this.$el.dataset.apiUrl || '';

            // Restore active tab from session or URL hash
            const stored = sessionStorage.getItem('activeBuildingTab');
            if(stored) {
                if(stored === 'add-new-building') {
                    this.activeBuildingTab = this.buildings.length;
                } else {
                    const idx = _.findIndex(this.buildings, { buildingID: stored });
                    if(idx !== -1) {
                        this.activeBuildingTab = idx;
                    }
                }
            } else {
                const hash = decodeURIComponent(window.location.hash.substring(1));
                if(hash) {
                    const index = _.findIndex(this.buildings, { buildingID: hash });
                    if(index !== -1) {
                        this.activeBuildingTab = index;
                    } else if(hash === 'add-new-building') {
                        this.activeBuildingTab = this.buildings.length;
                    }
                }
            }

            // Sync URL and session storage with active tab
            if(this.activeBuildingTab < this.buildings.length) {
                const id = this.buildings[this.activeBuildingTab].buildingID;
                history.replaceState(null, '', `#${id}`);
                sessionStorage.setItem('activeBuildingTab', id);
            } else {
                history.replaceState(null, '', '#add-new-building');
                sessionStorage.setItem('activeBuildingTab', 'add-new-building');
            }

            // Trigger lazy loading for the initially active building tab
            if(this.activeBuildingTab < this.buildings.length) {
                // Use setTimeout to ensure DOM and Alpine are ready
                setTimeout(() => {
                    const refs = (this as unknown as { $refs: Record<string, HTMLElement | undefined> }).$refs;
                    const manager = refs[`manager-${this.activeBuildingTab}`];
                    manager?.dispatchEvent(new CustomEvent('trigger-load'));
                }, 200);  // Slightly longer delay to ensure Alpine components are initialized
            }
        },

        handleTabChange(event: CustomEvent<{ tabIndex: number, buildingID?: string }>) {
            const { tabIndex, buildingID } = event.detail;
            this.activeBuildingTab = tabIndex;

            if(buildingID && tabIndex < this.buildings.length) {
                history.pushState(null, '', `#${buildingID}`);
                sessionStorage.setItem('activeBuildingTab', buildingID);
                const refs = (this as unknown as { $refs: Record<string, HTMLElement | undefined> }).$refs;
                const manager = refs[`manager-${tabIndex}`];
                manager?.dispatchEvent(new CustomEvent('trigger-load'));
            } else if(tabIndex === this.buildings.length) {
                history.pushState(null, '', '#add-new-building');
                sessionStorage.setItem('activeBuildingTab', 'add-new-building');
            }
        },

        handleBuildingDataLoaded(event: CustomEvent<{ buildingID: string, building: Building, units: unknown[], unitTypes: unknown[] }>) {
            const { buildingID, building, units: _units, unitTypes: _unitTypes } = event.detail;
            // Data loaded successfully for building

            // Update the building in our local state
            const index = _.findIndex(this.buildings, { buildingID: buildingID });
            if(index !== -1 && building) {
                this.buildings[index] = building;
            }
        },

        handleBuildingUpdated(event: CustomEvent<{ building: Building }>) {
            const updatedBuilding = event.detail.building;
            if(updatedBuilding) {
                // Update the building in our local state
                const index = _.findIndex(this.buildings, { buildingID: updatedBuilding.buildingID });
                if(index !== -1) {
                    // Update the building data to trigger reactivity
                    this.buildings[index] = { ...this.buildings[index], ...updatedBuilding };
                }
            }
        },

        showAndHideToast(message: string, type: string) {
            // Use global toast system instead of local toast
            // Ensure type is valid for showToast function
            const validType = (type === 'error' || type === 'success' || type === 'warning' || type === 'info') ? type as ('error' | 'success' | 'warning' | 'info') : 'info';
            window.showToast(message, validType);
        }
    } as BuildingsComponentData;
}

// Register with Alpine
document.addEventListener('alpine:init', () => {
    Alpine.data('buildingsComponentData', buildingsComponentData);
});
</script>

<style>

/* Smooth loading transitions */
[x-cloak] {
    display: none !important;
}

/* Hide inactive tabs */
.hidden {
    display: none !important;
}

</style>
