---
import BuildingCard from './BuildingCard.astro';
import { getBuildings } from '../../data/buildings';
import { Resource } from 'sst';

import _ from 'lodash';

const buildings = await getBuildings();
const apiURL = Resource.API.url;
const newBuildingData = JSON.stringify({
    buildingID: '',
    street: '',
    city: '',
    state: '',
    zip: '',
    description: '',
    apiURL
});
---
<div x-data="{ activeTab: -1, init() {
        const buildingsData = JSON.parse(this.$el.dataset.buildings);
        const hash = decodeURIComponent(window.location.hash.substring(1));
        if (hash) {
            const index = buildingsData.findIndex(b => b.buildingID === hash);
            if (index !== -1) {
                this.activeTab = index;
            } else if(hash === 'add-new-building') {
                this.activeTab = buildingsData.length;
            } else {
                this.activeTab = 0;
            }
        }
    } }" data-buildings={JSON.stringify(buildings)}>
    {buildings && (
        <div role="tablist" class="tabs tabs-lift">
        {_.map(buildings, (building, i) => (
            <a role="tab" class="tab" :class={`{ 'tab-active': activeTab === ${i} }`}
                x-on:click={`activeTab = ${i}; window.location.hash = '${building.buildingID}'`}
            >{building.buildingID}</a>
            <div class="tab-content bg-base-100 border-base-300">
                <BuildingCard buildingID={building.buildingID} />
            </div>
        ))}
            <a role="tab" class="tab" :class={`{ 'tab-active': activeTab === ${buildings.length} }`}
                x-on:click={`activeTab = ${buildings.length}`}
            >+</a>
            <div class="tab-content bg-base-100 border-base-300 p-4" x-data={newBuildingData}>
                <form @submit.prevent="addBuilding">
                    <label class="input input-lg">
                        <span class="label">Building Name</span>
                        <input type="text" x-model="buildingID" required />
                        <span class="badge badge-neutral badge-xs">Required</span>
                    </label>
                    <label class="input">
                        <span class="label">Street</span>
                        <input type="text" x-model="street" />
                    </label>
                    <label class="input">
                        <span class="label">City</span>
                        <input type="text" x-model="city" />
                    </label>
                    <label class="input">
                        <span class="label">State</span>
                        <input type="text" x-model="state" />
                    </label>
                    <label class="input">
                        <span class="label">Zip</span>
                        <input type="text" x-model="zip" />
                    </label>
                    <textarea class="textarea" placeholder="Description" x-model="description" />
                </form>
                <div class="mt-2 space-x-2">
                    <button class="btn btn-primary"
                        x-on:click="if(!buildingID) {
                            alert('Building ID is required.');
                            return;
                        }
                        const response = await fetch(`${apiURL}buildings`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                buildingID,
                                street,
                                city,
                                state,
                                zip,
                                description,
                            }),
                        });
                        if(response.ok) {
                            window.location.hash = buildingID;
                            window.location.reload(); // Reload to show the new building tab
                        } else {
                            alert('Failed to add building.');
                        }
                    ">Add</button>
                    <button class="btn btn-accent"
                    x-on:click="buildingID = '';
                            street = '';
                            city = '';
                            state = '';
                            zip = '';
                            description = '';
                    ">Cancel</button>
                </div>
            </div>
        </div>
    )}
</div>
