---
// Refactored BuildingsComponent.astro - Now uses modular components with lazy loading
import BuildingsList from './BuildingsList.astro';
import AddBuildingForm from './AddBuildingForm.astro';
import BuildingManager from './BuildingManager.astro';

import { getBuildings } from '../../data/buildings';
import { Resource } from 'sst';

// Only fetch basic building list - units/unit types loaded lazily
const buildings = await getBuildings();
const apiURL = Resource.API.url;
---

<div x-data="buildingsComponentData()" 
     x-init="init()"
     @building-tab-changed="handleTabChange($event)"
     @show-toast="showAndHideToast($event.detail.message, $event.detail.type)"
     @toast:show="showAndHideToast($event.detail.message, $event.detail.toastType)"
     @building-data-loaded="handleBuildingDataLoaded($event)"
     data-buildings={JSON.stringify(buildings)}
     data-api-url={apiURL}>
     
    <!-- Toast notifications -->
    <div class="toast toast-center toast-middle" x-show="showToast" x-transition.opacity>
        <div class="alert" :class="{ 'alert-error': toastType === 'error', 'alert-success': toastType === 'success' }">
            <span x-text="toastMessage"></span>
        </div>
    </div>
    
    <!-- Building navigation tabs -->
    <div data-buildings={JSON.stringify(buildings)}>
        <BuildingsList buildings={buildings} />
    </div>
    
    <!-- Individual building managers with lazy loading -->
    {buildings.map((building, i) => (
        <div x-show={`activeBuildingTab === ${i}`} 
             x-cloak 
             data-building-id={building.buildingID}
             data-api-url={apiURL}
             data-should-load="false">
            <BuildingManager 
                building={building}
                apiURL={apiURL}
            />
        </div>
    ))}
    
    <!-- Add building form -->
    <div x-show="activeBuildingTab === buildings.length" x-cloak data-api-url={apiURL}>
        <AddBuildingForm />
    </div>
</div>

<script>
// Alpine.js magic properties type
type AlpineComponent<T = {}> = T & {
    $dispatch: (event: string, detail?: any) => void;
    $root: HTMLElement;
    $el: HTMLElement;
    $watch: (expression: string, callback: (value: any) => void) => void;
};

type Building = {
    buildingID: string;
    street?: string;
    city?: string;
    state?: string;
    [key: string]: any;
};

type BuildingsComponentData = AlpineComponent<{
    activeBuildingTab: number;
    showToast: boolean;
    toastMessage: string;
    toastType: string;
    buildings: Building[];
    apiURL: string;
    init(): void;
    handleTabChange(event: CustomEvent<{ tabIndex: number; buildingID?: string }>): void;
    handleBuildingDataLoaded(event: CustomEvent<{ buildingID: string; units: any[]; unitTypes: any[] }>): void;
    showAndHideToast(message: string, type: string): void;
}>;

function buildingsComponentData(): BuildingsComponentData {
    return {
        activeBuildingTab: 0,
        showToast: false,
        toastMessage: '',
        toastType: '',
        buildings: [] as Building[],
        apiURL: '',
        
        init() {
            this.buildings = JSON.parse(this.$el.dataset.buildings || '[]');
            this.apiURL = this.$el.dataset.apiUrl || '';
            
            // Initialize from URL hash if present
            const hash = decodeURIComponent(window.location.hash.substring(1));
            if (hash) {
                const index = this.buildings.findIndex((b: Building) => b.buildingID === hash);
                if (index !== -1) {
                    this.activeBuildingTab = index;
                } else if (hash === 'add-new-building') {
                    this.activeBuildingTab = this.buildings.length;
                } else {
                    this.activeBuildingTab = 0;
                }
            }
        },
        
        handleTabChange(event: CustomEvent<{ tabIndex: number; buildingID?: string }>) {
            const { tabIndex, buildingID } = event.detail;
            this.activeBuildingTab = tabIndex;
            
            // Trigger lazy loading for the selected building
            if (buildingID && tabIndex < this.buildings.length) {
                const buildingElement = document.querySelector(`[data-building-id="${buildingID}"]`) as HTMLElement;
                if (buildingElement) {
                    buildingElement.dataset.shouldLoad = 'true';
                }
            }
        },
        
        handleBuildingDataLoaded(event: CustomEvent<{ buildingID: string; units: any[]; unitTypes: any[] }>) {
            const { buildingID, units, unitTypes } = event.detail;
            console.log(`Loaded data for building ${buildingID}:`, { units: units.length, unitTypes: unitTypes.length });
        },
        
        showAndHideToast(message: string, type: string) {
            this.toastMessage = message;
            this.toastType = type;
            this.showToast = true;
            setTimeout(() => {
                this.showToast = false;
            }, 3000);
        }
    } as BuildingsComponentData;
}

// Make available globally for Alpine.js
declare global {
    interface Window {
        buildingsComponentData: typeof buildingsComponentData;
    }
}

window.buildingsComponentData = buildingsComponentData;
</script>

<style>
/* Smooth loading transitions */
[x-cloak] { 
    display: none !important; 
}
</style>