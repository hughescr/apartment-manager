---
// BuildingsList.astro - Handles building navigation tabs
export interface Props {
    buildings: {
        buildingID:    string
        buildingName?: string
        street?:       string
        city?:         string
        state?:        string
        propertyType?: string
    }[]
}

// Buildings passed as prop for static data
---

<div class="buildings-list" x-data="buildingsListData()" x-init="buildings = $el.dataset.buildings ? JSON.parse($el.dataset.buildings) : []; init()" data-buildings={JSON.stringify(Astro.props.buildings)}>
    <!-- Main Building Selector - Distinguished from within-building tabs -->
    <div class="bg-gradient-to-r from-primary/10 to-secondary/10 border border-primary/20 rounded-xl p-4 mb-6">
        <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 bg-primary/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
            </div>
            <h2 class="text-lg font-semibold text-base-content">Select Building</h2>
        </div>

        <div role="tablist" class="flex flex-wrap gap-2">
            <!-- Building tabs -->
            <template x-for="(building, index) in buildings" :key="building.buildingID">
                <button
                  role="tab"
                  class="btn btn-sm transition-all duration-200"
                  :class="{ 'btn-primary shadow-md': activeBuildingTab === index, 'btn-outline btn-primary hover:btn-primary': activeBuildingTab !== index }"
                    @click="setActiveTab(index, building.buildingID)"
                >
                    <span x-html="getPropertyTypeIcon(building.propertyType)"></span>
                    <span x-text="building.buildingName || building.buildingID"></span>
                </button>
            </template>

            <!-- Add building tab -->
            <button
              role="tab"
              class="btn btn-sm transition-all duration-200"
              :class="{ 'btn-accent shadow-md': activeBuildingTab === buildings.length, 'btn-outline btn-accent hover:btn-accent': activeBuildingTab !== buildings.length }"
                @click="setActiveTab(buildings.length)"
            >
                <svg class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="16"></line>
                    <line x1="8" y1="12" x2="16" y2="12"></line>
                </svg>
                <span>Add Building</span>
            </button>
        </div>
    </div>
</div>

<!-- BuildingsList now uses centralized Alpine registry -->

<style>

.buildings-list {
    margin-bottom: 1rem;
}

</style>
