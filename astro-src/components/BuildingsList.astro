---
// BuildingsList.astro - Handles building navigation tabs
export interface Props {
    buildings: {
        buildingID: string
        buildingName?: string
        street?: string
        city?: string
        state?: string
    }[]
}

// Buildings passed as prop for static data
---

<div class="buildings-list" x-data="buildingsListData()" x-init="init()" data-buildings={JSON.stringify(Astro.props.buildings)}>
    <!-- Main Building Selector - Distinguished from within-building tabs -->
    <div class="bg-gradient-to-r from-primary/10 to-secondary/10 border border-primary/20 rounded-xl p-4 mb-6">
        <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 bg-primary/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
            </div>
            <h2 class="text-lg font-semibold text-base-content">Select Building</h2>
        </div>

        <div role="tablist" class="flex flex-wrap gap-2">
            <!-- Building tabs -->
            <template x-for="(building, index) in buildings" :key="building.buildingID">
                <button
                  role="tab"
                  class="btn btn-sm transition-all duration-200"
                  :class="{ 'btn-primary shadow-md': activeBuildingTab === index, 'btn-outline btn-primary hover:btn-primary': activeBuildingTab !== index }"
                    @click="setActiveTab(index, building.buildingID)"
                >
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5a2 2 0 012-2h4a2 2 0 012 2v1H8V5z"></path>
                    </svg>
                    <span x-text="building.buildingName || building.buildingID"></span>
                </button>
            </template>

            <!-- Add building tab -->
            <button
              role="tab"
              class="btn btn-sm transition-all duration-200"
              :class="{ 'btn-accent shadow-md': activeBuildingTab === buildings.length, 'btn-outline btn-accent hover:btn-accent': activeBuildingTab !== buildings.length }"
                @click="setActiveTab(buildings.length)"
            >
                <svg class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="16"></line>
                    <line x1="8" y1="12" x2="16" y2="12"></line>
                </svg>
                <span>Add Building</span>
            </button>
        </div>
    </div>
</div>

<script>
import type { AlpineComponent } from '../types/alpine';

interface Building {
    buildingID: string
    buildingName?: string
    street?: string
    city?: string
    state?: string
    [key: string]: unknown
}

type BuildingsListData = AlpineComponent<{
    activeBuildingTab: number
    buildings: Building[]
    init(): void
    setActiveTab(tabIndex: number, buildingID?: string | null): void
}>;

function buildingsListData(): BuildingsListData {
    return {
        activeBuildingTab: 0,
        buildings: [] as Building[],

        init() {
            this.buildings = this.$root.dataset.buildings ? JSON.parse(this.$root.dataset.buildings) : [];

            // Restore tab from session or URL hash
            const stored = sessionStorage.getItem('activeBuildingTab');
            if(stored) {
                if(stored === 'add-new-building') {
                    this.activeBuildingTab = this.buildings.length;
                } else {
                    const idx = this.buildings.findIndex(building => building.buildingID === stored);
                    if(idx !== -1) {
                        this.activeBuildingTab = idx;
                    }
                }
            } else {
                const hash = decodeURIComponent(window.location.hash.substring(1));
                if(hash) {
                    const index = this.buildings.findIndex(building => building.buildingID === hash);
                    if(index !== -1) {
                        this.activeBuildingTab = index;
                    } else if(hash === 'add-new-building') {
                        this.activeBuildingTab = this.buildings.length;
                    }
                }
            }

            // Dispatch initial selection
            this.$dispatch('building-tab-changed', {
                tabIndex: this.activeBuildingTab,
                buildingID: this.activeBuildingTab < this.buildings.length ? this.buildings[this.activeBuildingTab].buildingID : null
            });
        },

        setActiveTab(tabIndex: number, buildingID: string | null = null) {
            this.activeBuildingTab = tabIndex;

            this.$dispatch('building-tab-changed', {
                tabIndex: tabIndex,
                buildingID: buildingID
            });
        }
    } as BuildingsListData;
}

// Make available globally for Alpine.js
declare global {
    interface Window {
        buildingsListData: typeof buildingsListData
    }
}

window.buildingsListData = buildingsListData;
</script>

<style>

.buildings-list {
    margin-bottom: 1rem;
}

</style>
