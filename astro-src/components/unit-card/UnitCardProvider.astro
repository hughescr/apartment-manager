---
// astro-src/components/unit-card/UnitCardProvider.astro
import Saving from '../Saving.astro';
import { Resource } from 'sst';
import type { UnitData, UnitTypeData } from '../../types';
import { PhotoUploader } from '../forms';
// These imports are used in the inline script section but TypeScript/ESLint can't detect them
// Prefixed with _ to satisfy ESLint's unused variable rule
import { isArray as _isArray, isNumber as _isNumber, isObject as _isObject, find as _find, some as _some, map as _map, trim as _trim, keys as _keys } from 'lodash';

// Import all sub-components
import UnitBasicInfo from './UnitBasicInfo.astro';
import UnitDetailsGrid from './UnitDetailsGrid.astro';
import UnitDepositSection from './UnitDepositSection.astro';
import UnitVacancyStatus from './UnitVacancyStatus.astro';
import UnitDescriptions from './UnitDescriptions.astro';
import UnitRentSpecial from './UnitRentSpecial.astro';
import UnitAmenitiesSection from './UnitAmenitiesSection.astro';
import UnitWebsiteStatus from './UnitWebsiteStatus.astro';

const { unit, unitTypes = [] } = Astro.props as { unit: UnitData, unitTypes: UnitTypeData[] };

const _apiURL = Resource.API.url;
if(!_apiURL) {
    throw new Error('API URL not configured');
} // Validate and mark as used for TypeScript

// Initialize missing properties
if(!unit.unitAmenities) {
    unit.unitAmenities = [];
}
if(!unit.photos) {
    unit.photos = [];
}
if(!unit.feedInclusion) {
    unit.feedInclusion = {};
}
if(!unit.manualReferences) {
    unit.manualReferences = {};
}
// Initialize vacancy status fields
if(!unit.vacancyClass) {
    unit.vacancyClass = undefined;
}
if(!unit.vacateDate) {
    unit.vacateDate = '';
}
if(!unit.madeReadyDate) {
    unit.madeReadyDate = '';
}
---

<!-- Alpine registration handled by unitCardState.ts -->

<li
  x-data="unitCardData()"
  x-init="init(); $watch('unit', () => saveUnit(this))"
  class="card bg-base-100 shadow-xl mb-4"
  class="{'opacity-50': saving}"
  data-unit={JSON.stringify(unit)}
  data-unit-types={JSON.stringify(unitTypes)}
  data-api-url={_apiURL}
>
    <div class="card-body">
        <!-- Error Summary -->
        <div x-show="Object.keys(errors).length > 0" class="alert alert-error mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
                <span x-show="errors.submit" x-text="errors.submit"></span>
                <span x-show="!errors.submit">Please fix the validation errors below before saving.</span>
            </div>
        </div>

        <!-- Header with Unit Number, Model Selection, and Actions -->
        <div class="flex justify-between items-start mb-4">
            <div class="flex-1">
                <UnitBasicInfo />
            </div>
            <div class="flex items-center gap-2">
                <Saving />
                <!-- Assign Unit Type button - only show for units without modelID -->
                <button
                  x-show="!unit.modelID"
                  class="btn btn-secondary btn-sm"
                  x-on:click="$root.openAssignUnitTypeDialog(unit)"
                  data-testid="assign-unit-type-btn"
                >
                    Assign Unit Type
                </button>
                <button class="btn btn-error btn-sm" x-on:click="deleteUnit()">Delete</button>
            </div>
        </div>

        <!-- Main Details Grid -->
        <div class="mb-6">
            <UnitDetailsGrid />
        </div>

        <!-- Deposit Section -->
        <div class="mb-6">
            <UnitDepositSection />
        </div>

        <!-- Vacancy Status -->
        <div class="mb-6">
            <UnitVacancyStatus />
        </div>

        <!-- Descriptions -->
        <div class="mb-6">
            <UnitDescriptions />
        </div>

        <!-- Unit Rent Special -->
        <div class="mb-6">
            <UnitRentSpecial />
        </div>

        <!-- Unit Amenities Section -->
        <div class="collapse collapse-arrow bg-base-200 mb-4">
            <input type="checkbox" x-model="expandedSections.amenities" />
            <div class="collapse-title text-lg font-medium">
                Unit Amenities
                <span class="badge badge-primary badge-sm ml-2" x-text="getEffectiveAmenities().length"></span>
            </div>
            <div class="collapse-content">
                <div class="pt-4">
                    <UnitAmenitiesSection />
                </div>
            </div>
        </div>

        <!-- Photos Section -->
        <div class="collapse collapse-arrow bg-base-200 mb-4">
            <input type="checkbox" x-model="expandedSections.photos" />
            <div class="collapse-title text-lg font-medium">
                Photos
                <span class="badge badge-primary badge-sm ml-2" x-text="unit.photos?.length || 0"></span>
            </div>
            <div class="collapse-content">
                <div class="pt-4">
                    <PhotoUploader
                      name="photos"
                      label="Unit photos"
                      xModel="unit.photos"
                      buildingId={unit.buildingID}
                      unitId={unit.unitID}
                    />
                </div>
            </div>
        </div>

        <!-- Website Status & Listing IDs Section -->
        <div class="collapse collapse-arrow bg-base-200">
            <input type="checkbox" x-model="expandedSections.websites" />
            <div class="collapse-title text-lg font-medium">
                Website Status
                <span class="badge badge-primary badge-sm ml-2" x-text="Object.keys(unit.feedInclusion || {}).length"></span>
            </div>
            <div class="collapse-content">
                <div class="pt-4">
                    <UnitWebsiteStatus />
                </div>
            </div>
        </div>
    </div>
</li>

<style>

    /* Ensure smooth transitions */
    .collapse-content {
        transition: all 0.3s ease;
    }

    /* Style for inherited value indicator */
    .input-ghost {
        background-color: transparent;
        border-style: dashed;
        opacity: 0.7;
    }

    .input-ghost:focus {
        opacity: 1;
        border-style: solid;
    }

    /* Badge styling for inheritance indicators */
    .badge-ghost {
        background-color: transparent;
        border: 1px dashed currentColor;
        opacity: 0.7;
    }

    /* Inheritance chain styling */
    .inheritance-chain {
        padding: 0.5rem;
        border-radius: 0.5rem;
        background: linear-gradient(90deg,
            hsl(var(--b2)) 0%,
            hsl(var(--b3)) 50%,
            hsl(var(--b2)) 100%);
    }

    /* Hide number input spinners */
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    input[type="number"] {
        -moz-appearance: textfield;
    }

    /* Smooth transitions for inheritance indicators */
    [x-transition] {
        transition: all 0.2s ease;
    }

</style>
