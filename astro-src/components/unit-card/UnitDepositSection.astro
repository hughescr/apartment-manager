---
export interface Props {
    xModelPrefix?: string
}
---

<div class="space-y-4">
    <div class="flex items-center gap-2">
        <h3 class="text-lg font-semibold">Deposit Details</h3>
        <span x-show="isInherited('deposit')" class="badge badge-info badge-xs">inherited</span>
    </div>

    <div class="border border-base-300 rounded-lg p-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- Deposit Amount -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Amount ($)</span>
                </label>
                <div class="flex gap-2">
                    <input
                      name="depositAmount"
                      x-model="tempDepositAmount"
                      @input="setDepositAmount($event.target.value)"
                      x-init="tempDepositAmount = getDepositAmount(unit.deposit)"
                      type="number"
                      min="0"
                      step="1"
                      placeholder="getInheritedValue(selectedUnitType, 'deposit') ? 'Inherited: $' + getInheritedValue(selectedUnitType, 'deposit') : ''"
                      class="input input-bordered w-full flex-1"
                      class="errors.deposit ? 'input-error' : ''"
                    />
                    <button
                      type="button"
                      x-show="!isInherited('deposit')"
                      @click="resetFieldToInherited('deposit'); tempDepositAmount = null"
                      class="btn btn-ghost btn-sm"
                      title="Reset to inherited value"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Refundable Toggle -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Refundable</span>
                </label>
                <div class="flex items-center h-12">
                    <input
                      type="checkbox"
                      class="toggle toggle-success"
                      x-model="tempDepositRefundable"
                      x-init="tempDepositRefundable = getDepositRefundable(unit.deposit)"
                      @change="setDepositRefundable($event.target.checked)"
                    />
                    <span class="ml-2 text-sm" x-text="tempDepositRefundable ? 'Yes' : 'No'"></span>
                </div>
            </div>

            <!-- Partial Refund Percentage -->
            <div x-show="!tempDepositRefundable && getDepositAmount(unit.deposit) > 0" class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Partial Refund %</span>
                </label>
                <div class="flex items-center gap-2">
                    <input
                      type="range"
                      class="range range-primary flex-1"
                      min="0"
                      max="100"
                      step="5"
                      x-model="tempPartialRefundPercentage"
                      x-init="tempPartialRefundPercentage = getDepositPartialRefundPercentage(unit.deposit) || 0"
                      @input="setDepositPartialRefundPercentage($event.target.value)"
                    />
                    <span class="text-sm font-medium w-12" x-text="tempPartialRefundPercentage + '%'"></span>
                </div>
            </div>
        </div>

        <!-- Deposit Summary -->
        <div x-show="getDepositAmount(unit.deposit) > 0" class="mt-4 p-3 bg-base-200 rounded-lg">
            <div class="text-sm">
                <span class="font-semibold">Deposit Summary:</span>
                <span x-text="formatDepositDisplay(unit.deposit)"></span>
            </div>
        </div>
    </div>
</div>
