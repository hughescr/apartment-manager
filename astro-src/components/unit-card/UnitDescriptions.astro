---
export interface Props {
    xModelPrefix?: string;
}

const { xModelPrefix = 'unit' } = Astro.props;
---

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h3 class="text-lg font-semibold">Unit Descriptions</h3>
        <div class="badge badge-info badge-outline">Internal vs Public Content</div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Internal Description -->
        <div class="form-control">
            <div x-data="{ 
                get charCount() { 
                    return (unit.description || '').length; 
                },
                get isOverLimit() {
                    return this.charCount > 500;
                },
                get charCountColor() {
                    if (this.charCount > 500) return 'text-error';
                    if (this.charCount > 450) return 'text-warning';
                    return 'text-base-content/70';
                }
            }">
                <!-- Label with Internal Indicator -->
                <label class="label">
                    <span class="label-text flex items-center gap-2">
                        Internal Description
                        <div class="badge badge-secondary badge-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            Internal
                        </div>
                    </span>
                    <span class="label-text-alt" :class="charCountColor" x-text="`${charCount}/500`"></span>
                </label>
                
                <!-- Textarea -->
                <textarea
                    name="description"
                    placeholder="Unit 2A - North-facing corner unit. Note: bathroom faucet replaced 2024. Hardwood floors original to building. AC unit serviced annually."
                    class="textarea textarea-bordered w-full resize-vertical"
                    :class="{ 'textarea-error': isOverLimit }"
                    x-model={`${xModelPrefix}.description`}
                    rows="4"
                    maxlength="500"
                ></textarea>
                
                <!-- Enhanced Help Text -->
                <label class="label">
                    <span class="label-text-alt text-base-content/70">
                        <div class="space-y-1">
                            <div class="font-medium">🔒 Maintenance & Administrative Notes</div>
                            <div class="text-xs space-y-0.5">
                                <div>• <strong>Purpose:</strong> Maintenance history, special conditions, internal notes</div>
                                <div>• <strong>Visibility:</strong> Property managers and maintenance staff only</div>
                                <div>• <strong>Content:</strong> Unit condition, recent repairs, access notes</div>
                                <div>• <strong>Format:</strong> Plain text only (no HTML/Markdown)</div>
                            </div>
                        </div>
                    </span>
                    <span class="label-text-alt" :class="isOverLimit ? 'text-error' : 'text-base-content/50'" x-show="isOverLimit">
                        Exceeds 500 character limit
                    </span>
                </label>
            </div>
            
            <span x-show="errors.description" class="label-text-alt text-error" x-text="errors.description"></span>
        </div>

        <!-- Marketing Description -->
        <div class="form-control">
            <div x-data="{ 
                get charCount() { 
                    return (unit.marketingDescription || '').length; 
                },
                get isOverLimit() {
                    return this.charCount > 1000;
                },
                get charCountColor() {
                    if (this.charCount > 1000) return 'text-error';
                    if (this.charCount > 900) return 'text-warning';
                    return 'text-base-content/70';
                }
            }">
                <!-- Label with Public Indicator -->
                <label class="label">
                    <span class="label-text flex items-center gap-2">
                        Marketing Description
                        <div class="badge badge-info badge-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Public
                        </div>
                    </span>
                    <span class="label-text-alt" :class="charCountColor" x-text="`${charCount}/1000`"></span>
                </label>
                
                <!-- Textarea -->
                <textarea
                    name="marketingDescription"
                    placeholder="Bright and spacious 2-bedroom corner unit with stunning city views! Features hardwood floors, updated kitchen with granite countertops, in-unit washer/dryer, and private balcony. Master bedroom includes walk-in closet and en-suite bathroom. Perfect for professionals or small families!"
                    class="textarea textarea-bordered w-full resize-vertical"
                    :class="{ 'textarea-error': isOverLimit }"
                    x-model={`${xModelPrefix}.marketingDescription`}
                    rows="4"
                    maxlength="1000"
                ></textarea>
                
                <!-- Enhanced Help Text -->
                <label class="label">
                    <span class="label-text-alt text-base-content/70">
                        <div class="space-y-1">
                            <div class="font-medium">📋 Public unit listing description</div>
                            <div class="text-xs space-y-0.5">
                                <div>• <strong>Appears on:</strong> Unit listings, rental websites, marketing materials</div>
                                <div>• <strong>MITS feeds:</strong> Exported as UnitDescription in syndication feeds</div>
                                <div>• <strong>Content:</strong> Layout, features, views, unique selling points</div>
                                <div>• <strong>Format:</strong> Plain text only (no HTML/Markdown)</div>
                                <div>• <strong>Tip:</strong> Focus on lifestyle benefits and standout features</div>
                            </div>
                        </div>
                    </span>
                    <span class="label-text-alt" :class="isOverLimit ? 'text-error' : 'text-base-content/50'" x-show="isOverLimit">
                        Exceeds 1000 character limit
                    </span>
                </label>
            </div>
            
            <span x-show="errors.marketingDescription" class="label-text-alt text-error" x-text="errors.marketingDescription"></span>
        </div>
    </div>
</div>