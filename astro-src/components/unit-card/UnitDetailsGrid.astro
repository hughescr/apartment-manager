---
import InheritableField from '../forms/InheritableField.astro';

export interface Props {
    xModelPrefix?: string
}

const { xModelPrefix = 'unit' } = Astro.props;

// Field configurations for inheritable fields
const inheritableFields = [
    { name: 'beds', label: 'Bedrooms', type: 'number' as const, min: 0, max: 10, step: 1 },
    { name: 'baths', label: 'Bathrooms', type: 'number' as const, min: 0, max: 10, step: 0.5 },
    { name: 'sqft', label: 'Square Feet', type: 'number' as const, min: 0, max: 10000, step: 1 },
    { name: 'rent', label: 'Rent ($)', type: 'number' as const, min: 0, step: 1 },
    { name: 'maxOccupants', label: 'Max Occupants', type: 'number' as const, min: 1, max: 20, step: 1 },
    { name: 'perPersonRent', label: 'Per Person Rent ($)', type: 'number' as const, min: 0, step: 1 },
    { name: 'minLeaseTerm', label: 'Min Lease (months)', type: 'number' as const, min: 1, max: 24, step: 1 },
    { name: 'maxLeaseTerm', label: 'Max Lease (months)', type: 'number' as const, min: 1, max: 24, step: 1 }
];
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {inheritableFields.map(field => (
        <InheritableField
          fieldName={field.name}
          label={field.label}
          type={field.type}
          xModel={`${xModelPrefix}.${field.name}`}
          inheritanceCheck={`isInherited('${field.name}')`}
          inheritedValue={`getInheritedValue(selectedUnitType, '${field.name}')`}
          error={`errors.${field.name}`}
          min={field.min}
          max={field.max}
          step={field.step}
          onReset={`resetFieldToInherited('${field.name}')`}
        />
    ))}
</div>
