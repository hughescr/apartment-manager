---
// astro-src/components/UnitTypeCard.astro
import Saving from './Saving.astro';
import { Resource } from 'sst';
import type { UnitTypeData, Amenity } from '../types';
import { AmenitySelector } from './forms';

const { unitType, buildingAmenities: _buildingAmenities = [] } = Astro.props as {
    unitType: UnitTypeData
    buildingAmenities?: Amenity[]
};

const _apiURL = Resource.API.url;
if(!_apiURL) {
    throw new Error('API URL not configured');
} // Validate and mark as used for TypeScript

if(!unitType.modelAmenities) {
    unitType.modelAmenities = [];
}

---
<script is:inline>
// Used by Alpine.js x-data attribute
function unitTypeCardData(unitTypeData, buildingAmenitiesData, apiUrlData) {
    return {
        unitType: unitTypeData,
        originalUnitType: JSON.parse(JSON.stringify(unitTypeData)), // Deep copy for original state
        apiURL: apiUrlData,
        saving: false,
        expandedAmenities: false,
        buildingAmenities: buildingAmenitiesData || [], // Use passed building amenities

        init() {
            // Initialize enhanced deposit structure
            this.initializeDeposit();
        },

        getEffectiveAmenities() {
            // If floorplan has amenities defined, use them (override)
            if(this.unitType.modelAmenities && this.unitType.modelAmenities.length > 0) {
                return this.unitType.modelAmenities;
            }
            // Otherwise, use building amenities if available
            if(this.buildingAmenities && this.buildingAmenities.length > 0) {
                return this.buildingAmenities;
            }
            return [];
        },

        resetToInheritedAmenities() {
            if(confirm('This will reset floorplan amenities to match the building amenities. Continue?')) {
                this.unitType.modelAmenities = [];
            }
        },

        isDirty() {
            return JSON.stringify(this.unitType) !== JSON.stringify(this.originalUnitType);
        },

        async saveUnitType(myThis) {
            const context = myThis || this;
            if(!context.isDirty()) {
                return;
            }

            this.saving = true;
            try {
                const response = await fetch(context.apiURL + 'buildings/' + context.unitType.buildingID + '/unit-types/' + context.unitType.modelID, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(context.unitType),
                });
                if(response.ok) {
                    context.originalUnitType = { ...context.unitType };
                } else {
                    // Revert to original value on save failure
                    context.unitType = { ...context.originalUnitType };
                }
            } catch{
                // Revert to original value on network error
                context.unitType = { ...context.originalUnitType };
            } finally {
                context.saving = false;
            }
        },

        async deleteUnitType() {
            // Dispatch event to parent BuildingProvider to handle deletion
            // The parent has proper state management and will update the UI correctly
            this.$dispatch('delete-unit-type', {
                modelID: this.unitType.modelID
            });
        },

        formatCurrency(value) {
            if(!value) {
                return '';
            }
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                minimumFractionDigits: 0,
                maximumFractionDigits: 0
            }).format(value);
        },

        formatDate(dateString) {
            if(!dateString) {
                return 'Not set';
            }
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
            });
        },

        // Deposit handling functions
        initializeDeposit() {
            // Convert legacy number deposits to enhanced object format
            if(typeof this.unitType.deposit === 'number' && !isNaN(this.unitType.deposit)) {
                this.unitType.deposit = {
                    amount: this.unitType.deposit,
                    refundable: true
                };
            }
            // Initialize empty deposit object if not present
            if(!this.unitType.deposit) {
                this.unitType.deposit = null;
            }
        },

        getDepositAmount() {
            if(!this.unitType.deposit) {
                return null;
            }
            if(typeof this.unitType.deposit === 'number' && !isNaN(this.unitType.deposit)) {
                return this.unitType.deposit;
            }
            return this.unitType.deposit.amount;
        },

        setDepositAmount(value) {
            if(!value || value === '') {
                this.unitType.deposit = null;
                return;
            }

            const amount = parseFloat(value);
            if(isNaN(amount) || amount < 0) {
                return;
            }

            if(!this.unitType.deposit) {
                this.unitType.deposit = {
                    amount: amount,
                    refundable: true
                };
            } else if(typeof this.unitType.deposit === 'number' && !isNaN(this.unitType.deposit)) {
                this.unitType.deposit = {
                    amount: amount,
                    refundable: true
                };
            } else {
                this.unitType.deposit.amount = amount;
            }
        },

        getDepositRefundable() {
            if(!this.unitType.deposit) {
                return true;
            }
            if(typeof this.unitType.deposit === 'number' && !isNaN(this.unitType.deposit)) {
                return true;
            }
            return this.unitType.deposit.refundable !== false;
        },

        setDepositRefundable(value) {
            if(!this.unitType.deposit || (typeof this.unitType.deposit === 'number' && !isNaN(this.unitType.deposit))) {
                return;
            }
            this.unitType.deposit.refundable = value;
            if(value) {
                // Clear partial refund percentage when fully refundable
                delete this.unitType.deposit.partialRefundPercentage;
            }
        },

        getDepositPartialRefundPercentage() {
            if(!this.unitType.deposit || (typeof this.unitType.deposit === 'number' && !isNaN(this.unitType.deposit))) {
                return null;
            }
            return this.unitType.deposit.partialRefundPercentage || null;
        },

        setDepositPartialRefundPercentage(value) {
            if(!this.unitType.deposit || (typeof this.unitType.deposit === 'number' && !isNaN(this.unitType.deposit))) {
                return;
            }
            const percentage = parseFloat(value);
            if(isNaN(percentage) || percentage < 0 || percentage > 100) {
                delete this.unitType.deposit.partialRefundPercentage;
                return;
            }
            this.unitType.deposit.partialRefundPercentage = percentage;
        }
    };
}

document.addEventListener('alpine:init', () => {
    Alpine.data('unitTypeCardData', unitTypeCardData);
});
</script>

<div x-data="unitTypeCardData(unitType, _buildingAmenities, _apiURL)" x-init="init(); $watch('unitType', () => saveUnitType(this))" class="card bg-base-100 shadow-xl" :class="{'opacity-50': saving}" data-testid="unit-type-card">
        <!-- Header -->
        <div class="flex justify-between items-start mb-4">
            <div class="flex-1">
                <h3 class="card-title text-2xl">
                    <input
                      type="text"
                      x-model="unitType.modelName"
                      class="input input-ghost input-lg font-bold w-full"
                      placeholder="Model Name"
                    />
                </h3>
                <div class="text-sm text-base-content/70 mt-1">
                    Model ID:
{' '}
<span x-text="unitType.modelID"></span>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <Saving />
                <button class="btn btn-error btn-sm" x-on:click="deleteUnitType()">Delete</button>
            </div>
        </div>

        <!-- Main Details Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
            <!-- Availability Info -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Units Available</span>
                </label>
                <input
                  type="number"
                  x-model.number.lazy="unitType.countAvailable"
                  class="input input-bordered"
                  min="0"
                  placeholder="0"
                />
            </div>

            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Available From</span>
                </label>
                <input
                  type="date"
                  x-model.lazy="unitType.dateAvailable"
                  class="input input-bordered"
                />
            </div>

            <!-- Unit Details -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Configuration</span>
                </label>
                <div class="flex gap-2">
                    <input
                      type="number"
                      x-model.number.lazy="unitType.beds"
                      class="input input-bordered w-20"
                      min="0"
                      max="10"
                      placeholder="Beds"
                    />
                    <span class="self-center">beds</span>
                    <input
                      type="number"
                      x-model.number.lazy="unitType.baths"
                      class="input input-bordered w-20"
                      min="0"
                      max="10"
                      step="0.5"
                      placeholder="Baths"
                    />
                    <span class="self-center">baths</span>
                </div>
            </div>

            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Max Occupants</span>
                </label>
                <input
                  type="number"
                  x-model.number.lazy="unitType.maxOccupants"
                  class="input input-bordered"
                  min="1"
                  max="20"
                  placeholder="Not specified"
                />
            </div>

            <!-- Pricing -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Rent Range</span>
                </label>
                <div class="flex gap-2 items-center">
                    <input
                      type="number"
                      x-model.number.lazy="unitType.minRent"
                      class="input input-bordered w-24"
                      min="0"
                      placeholder="Min"
                    />
                    <span>-</span>
                    <input
                      type="number"
                      x-model.number.lazy="unitType.maxRent"
                      class="input input-bordered w-24"
                      min="0"
                      placeholder="Max"
                    />
                </div>
            </div>

            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Per Person Rent</span>
                </label>
                <input
                  type="number"
                  x-model.number.lazy="unitType.perPersonRent"
                  class="input input-bordered"
                  min="0"
                  placeholder="Not specified"
                />
            </div>

            <!-- Enhanced Deposit Section -->
            <div class="form-control col-span-1 md:col-span-2 lg:col-span-3">
                <label class="label">
                    <span class="label-text font-semibold">Deposit Details</span>
                    <div class="tooltip tooltip-left" data-tip="Security deposit amount and refundability terms">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-4 h-4 stroke-info">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                </label>
                <div class="border border-base-300 rounded-lg p-4">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <!-- Deposit Amount -->
                        <div class="form-control">
                            <label class="label">
                                <span class="label-text text-sm">Amount ($)</span>
                            </label>
                            <input
                              type="number"
                              :value="getDepositAmount()"
                                x-on:input="setDepositAmount($event.target.value)"
                                class="input input-bordered w-full"
                                min="0"
                                placeholder="Not specified"
                            />
                        </div>

                        <!-- Refundable Toggle -->
                        <div class="form-control">
                            <label class="label">
                                <span class="label-text text-sm">Refundable</span>
                                <div class="tooltip tooltip-top" data-tip="Whether the deposit can be returned to tenants">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-4 h-4 stroke-info">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                            </label>
                            <input
                              type="checkbox"
                              class="toggle toggle-success"
                              :checked="getDepositRefundable()"
                                x-on:change="setDepositRefundable($event.target.checked)"
                                :disabled="!unitType.deposit"
                            />
                            <div class="text-xs text-base-content/70 mt-1">
                                <span x-show="getDepositRefundable()">Fully refundable</span>
                                <span x-show="!getDepositRefundable()">Non-refundable or partial</span>
                            </div>
                        </div>

                        <!-- Partial Refund Percentage -->
                        <div class="form-control" x-show="unitType.deposit && !getDepositRefundable()">
                            <label class="label">
                                <span class="label-text text-sm">Partial Refund %</span>
                                <div class="tooltip tooltip-top" data-tip="Percentage that may be refunded (e.g., 70% means $700 of a $1000 deposit)">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-4 h-4 stroke-info">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                            </label>
                            <input
                              type="range"
                              class="range range-sm range-primary"
                              min="0"
                              max="100"
                              step="5"
                              :value="getDepositPartialRefundPercentage() || 0"
                                x-on:input="setDepositPartialRefundPercentage($event.target.value)"
                            />
                            <div class="flex justify-between text-xs text-base-content/70 px-2">
                                <span>0%</span>
                                <span class="font-medium" x-text="(getDepositPartialRefundPercentage() || 0) + '%'"></span>
                                <span>100%</span>
                            </div>
                            <div class="text-xs text-base-content/70 mt-1" x-show="getDepositPartialRefundPercentage()">
                                May refund up to
{' '}
<span x-text="formatCurrency((getDepositAmount() || 0) * (getDepositPartialRefundPercentage() || 0) / 100)"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Square Footage -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Square Footage</span>
                </label>
                <div class="flex gap-2 items-center">
                    <input
                      type="number"
                      x-model.number.lazy="unitType.minSqft"
                      class="input input-bordered w-24"
                      min="0"
                      placeholder="Min"
                    />
                    <span>-</span>
                    <input
                      type="number"
                      x-model.number.lazy="unitType.maxSqft"
                      class="input input-bordered w-24"
                      min="0"
                      placeholder="Max"
                    />
                </div>
            </div>

            <!-- Lease Terms -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Lease Terms (months)</span>
                </label>
                <div class="flex gap-2 items-center">
                    <input
                      type="number"
                      x-model.number.lazy="unitType.minLeaseTerm"
                      class="input input-bordered w-24"
                      min="1"
                      max="24"
                      placeholder="Min"
                    />
                    <span>-</span>
                    <input
                      type="number"
                      x-model.number.lazy="unitType.maxLeaseTerm"
                      class="input input-bordered w-24"
                      min="1"
                      max="24"
                      placeholder="Max"
                    />
                </div>
            </div>
        </div>

        <!-- Summary Display -->
        <div class="bg-base-200 rounded-lg p-4 mb-4">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 text-sm">
                <div>
                    <span class="font-semibold">Availability:</span>
                    <span x-text="unitType.countAvailable || 0"></span>
{' '}
units
<span x-show="unitType.dateAvailable">
                        from
{' '}
<span x-text="formatDate(unitType.dateAvailable)"></span>
</span>
                </div>
                <div x-show="unitType.minRent || unitType.maxRent">
                    <span class="font-semibold">Rent:</span>
                    <span x-text="unitType.minRent && unitType.maxRent ? formatCurrency(unitType.minRent) + ' - ' + formatCurrency(unitType.maxRent) : (unitType.minRent ? 'From ' + formatCurrency(unitType.minRent) : 'Up to ' + formatCurrency(unitType.maxRent))"></span>
                </div>
                <div x-show="unitType.minSqft || unitType.maxSqft">
                    <span class="font-semibold">Size:</span>
                    <span x-text="unitType.minSqft && unitType.maxSqft ? unitType.minSqft + ' - ' + unitType.maxSqft + ' sq ft' : (unitType.minSqft ? 'From ' + unitType.minSqft + ' sq ft' : 'Up to ' + unitType.maxSqft + ' sq ft')"></span>
                </div>
                <div x-show="getDepositAmount()">
                    <span class="font-semibold">Deposit:</span>
                    <span x-text="formatCurrency(getDepositAmount())"></span>
                    <span x-show="unitType.deposit && typeof unitType.deposit === 'object'" class="text-xs ml-1">
                        (
<span x-show="getDepositRefundable()">refundable</span>
<span x-show="!getDepositRefundable() && getDepositPartialRefundPercentage()">
partial:
<span x-text="getDepositPartialRefundPercentage()"></span>
%
</span>
<span x-show="!getDepositRefundable() && !getDepositPartialRefundPercentage()">non-refundable</span>
)
                    </span>
                </div>
                <div x-show="unitType.minLeaseTerm || unitType.maxLeaseTerm">
                    <span class="font-semibold">Lease Terms:</span>
                    <span x-text="unitType.minLeaseTerm && unitType.maxLeaseTerm ? unitType.minLeaseTerm + ' - ' + unitType.maxLeaseTerm + ' months' : (unitType.minLeaseTerm ? 'Min ' + unitType.minLeaseTerm + ' months' : 'Max ' + unitType.maxLeaseTerm + ' months')"></span>
                </div>
                <div x-show="unitType.perPersonRent">
                    <span class="font-semibold">Per Person:</span>
                    <span x-text="formatCurrency(unitType.perPersonRent) + '/month'"></span>
                </div>
            </div>
        </div>

        <!-- Model Amenities Section -->
        <div class="collapse collapse-arrow bg-base-200">
            <input type="checkbox" x-model="expandedAmenities" />
            <div class="collapse-title text-lg font-medium">
                Model Amenities
                <span class="badge badge-primary badge-sm ml-2" x-text="getEffectiveAmenities().length"></span>
                <span x-show="unitType.modelAmenities && unitType.modelAmenities.length > 0" class="badge badge-warning badge-sm ml-1">custom</span>
                <span x-show="!unitType.modelAmenities || unitType.modelAmenities.length === 0" class="badge badge-info badge-sm ml-1">inherited from building</span>
            </div>
            <div class="collapse-content">
                <div class="pt-4">
                    <!-- Inheritance Status Info -->
                    <div class="alert alert-info mb-4" x-show="_buildingAmenities && _buildingAmenities.length > 0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <div>
                            <span x-show="!unitType.modelAmenities || unitType.modelAmenities.length === 0">
                                This floorplan inherits
{' '}
<span x-text="_buildingAmenities.length"></span>
{' '}
amenities from the building. Add amenities here to customize this floorplan.
                            </span>
                            <span x-show="unitType.modelAmenities && unitType.modelAmenities.length > 0">
                                This floorplan has custom amenities that override the
{' '}
<span x-text="_buildingAmenities.length"></span>
{' '}
building-level amenities.
<button type="button" class="btn btn-ghost btn-xs ml-2" x-on:click="resetToInheritedAmenities()">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                    </svg>
                                    Reset to Building Amenities
</button>
                            </span>
                        </div>
                    </div>

                    <!-- Inherited Amenities Display -->
                    <div x-show="(!unitType.modelAmenities || unitType.modelAmenities.length === 0) && _buildingAmenities && _buildingAmenities.length > 0" class="mb-4">
                        <div class="text-sm text-base-content/70 mb-2">
                            <span class="font-semibold">Inherited from Building:</span>
{' '}
<span x-text="_buildingAmenities.length"></span>
{' '}
amenities
                        </div>
                        <div class="flex flex-wrap gap-2">
                            <template x-for="amenity in _buildingAmenities" :key="amenity.name + amenity.category">
                                <div class="badge badge-ghost badge-lg gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-info" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12" />
                                    </svg>
                                    <span x-text="amenity.name"></span>
                                </div>
                            </template>
                        </div>
                    </div>

                    <AmenitySelector
                      name="modelAmenities"
                      label="Floorplan-specific amenities (overrides building amenities)"
                      xModel="unitType.modelAmenities"
                      showLabel={false}
                    />
                </div>
            </div>
        </div>
</div>

<style>

    /* Ensure smooth transitions */
    .collapse-content {
        transition: all 0.3s ease;
    }

    /* Badge styling for inheritance indicators */
    .badge-ghost {
        background-color: transparent;
        border: 1px dashed currentColor;
        opacity: 0.7;
    }

    /* Inheritance display styling */
    .inheritance-display {
        padding: 0.5rem;
        border-radius: 0.5rem;
        background: linear-gradient(90deg,
            hsl(var(--b2)) 0%,
            hsl(var(--b3)) 50%,
            hsl(var(--b2)) 100%);
    }

    /* Style number inputs to hide spinners on hover */
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    input[type="number"] {
        -moz-appearance: textfield;
    }

    /* Smooth transitions for inheritance indicators */
    [x-transition] {
        transition: all 0.2s ease;
    }

</style>
