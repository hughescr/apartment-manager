---
export interface Props {
    fieldName: string
    errors: Record<string, string>
    'class'?: string
}

const {
    fieldName,
    errors: _errors,
    'class': additionalClass = ''
} = Astro.props;

// Generate Alpine.js directives based on field name complexity
const isComplexFieldName = fieldName.includes('[') || fieldName.includes('.') || /\d/.test(fieldName);
const xShowDirective = isComplexFieldName ? `errors['${fieldName}']` : `errors.${fieldName}`;
const xTextDirective = isComplexFieldName ? `errors['${fieldName}']` : `errors.${fieldName}`;
---

<span
  x-show={xShowDirective}
  x-text={xTextDirective}
  class={`label-text-alt text-error ${additionalClass}`}
  data-testid={`error-${fieldName}`}
  role="alert"
  aria-live="polite"
>
</span>
