---
// astro-src/components/ModelAmenitiesManager.astro
import { Resource } from "sst";
import type { UnitTypeData } from "../../src/types";
import { AmenitySelector } from "./forms";
import Saving from "./Saving.astro";

const { unitTypes, buildingID } = Astro.props as { 
    unitTypes: UnitTypeData[];
    buildingID: string;
};

const apiURL = Resource.API.url;

// Create a map of unit types for easy access
const unitTypesMap = Object.fromEntries(
    unitTypes.map(ut => [ut.modelID, ut])
);

// No longer need xData variable - moved to script tag
---

<script define:vars={{ apiURL, buildingID, unitTypesMap }} is:inline>
// Used by Alpine.js x-data attribute
window.modelAmenitiesManagerData = function modelAmenitiesManagerData(apiUrlData, buildingIdData, unitTypesMapData) {
    return {
        apiURL: apiUrlData,
        buildingID: buildingIdData,
        unitTypes: unitTypesMapData,
        selectedModel: '',
        saving: false,
        bulkEditMode: false,
        selectedModels: [],
        bulkAmenities: [],
        
        get currentModelAmenities() {
            if (!this.selectedModel || !this.unitTypes[this.selectedModel]) {
                return [];
            }
            return this.unitTypes[this.selectedModel].modelAmenities || [];
        },
        
        set currentModelAmenities(value) {
            if (!this.selectedModel || !this.unitTypes[this.selectedModel]) {
                return;
            }
            this.unitTypes[this.selectedModel].modelAmenities = value;
        },
        
        get availableModels() {
            return Object.entries(this.unitTypes).map(([modelID, unitType]) => ({
                value: modelID,
                label: unitType.modelName + ' (' + unitType.beds + 'BR/' + unitType.baths + 'BA)'
            }));
        },
        
        async saveModelAmenities(modelID) {
            const unitType = this.unitTypes[modelID];
            if (!unitType) return;
            
            this.saving = true;
            try {
                const response = await fetch(this.apiURL + 'buildings/' + this.buildingID + '/unit-types/' + modelID, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(unitType),
                });
                
                if (!response.ok) {
                    console.error('Save failed:', response.statusText);
                    alert('Failed to save amenities. Please try again.');
                }
            } catch (error) {
                console.error('Network error during save:', error);
                alert('Network error. Please check your connection and try again.');
            } finally {
                this.saving = false;
            }
        },
        
        toggleBulkEdit() {
            this.bulkEditMode = !this.bulkEditMode;
            if (!this.bulkEditMode) {
                this.selectedModels = [];
                this.bulkAmenities = [];
            }
        },
        
        selectAllModels() {
            this.selectedModels = Object.keys(this.unitTypes);
        },
        
        deselectAllModels() {
            this.selectedModels = [];
        },
        
        async applyBulkAmenities() {
            if (this.selectedModels.length === 0) {
                alert('Please select at least one model to update');
                return;
            }
            
            if (!confirm('Apply these amenities to ' + this.selectedModels.length + ' selected model(s)?')) {
                return;
            }
            
            this.saving = true;
            try {
                // Update each selected model
                const promises = this.selectedModels.map(modelID => {
                    const unitType = this.unitTypes[modelID];
                    unitType.modelAmenities = [...this.bulkAmenities]; // Clone the array
                    
                    return fetch(this.apiURL + 'buildings/' + this.buildingID + '/unit-types/' + modelID, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(unitType),
                    });
                });
                
                const results = await Promise.all(promises);
                const failures = results.filter(r => !r.ok).length;
                
                if (failures > 0) {
                    alert('Updated ' + (results.length - failures) + ' models successfully. ' + failures + ' failed.');
                } else {
                    alert('Successfully updated all ' + results.length + ' models!');
                    this.toggleBulkEdit();
                }
            } catch (error) {
                console.error('Network error during bulk update:', error);
                alert('Network error. Please check your connection and try again.');
            } finally {
                this.saving = false;
            }
        },
        
        copyAmenities(fromModelID) {
            const fromAmenities = this.unitTypes[fromModelID]?.modelAmenities || [];
            if (this.selectedModel && this.selectedModel !== fromModelID) {
                this.currentModelAmenities = [...fromAmenities];
                this.saveModelAmenities(this.selectedModel);
            }
        },
        
        getAmenityCount(modelID) {
            return this.unitTypes[modelID]?.modelAmenities?.length || 0;
        },
        
        getAmenitySummary(modelID) {
            const amenities = this.unitTypes[modelID]?.modelAmenities || [];
            if (amenities.length === 0) return 'No amenities';
            if (amenities.length <= 3) {
                return amenities.map(a => a.name).join(', ');
            }
            return amenities.slice(0, 3).map(a => a.name).join(', ') + ' +' + (amenities.length - 3) + ' more';
        }
    };
}
</script>

<div x-data="modelAmenitiesManagerData(apiURL, buildingID, unitTypesMap)" class="model-amenities-manager">
    <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <div class="flex justify-between items-center mb-6">
                <h3 class="card-title text-xl">Manage Model Amenities</h3>
                <div class="flex gap-2 items-center">
                    <Saving />
                    <button 
                        class="btn btn-outline btn-sm"
                        x-on:click="toggleBulkEdit()"
                        :class="{'btn-active': bulkEditMode}"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                        Bulk Edit
                    </button>
                </div>
            </div>

            <!-- Single Model Edit Mode -->
            <div x-show="!bulkEditMode" x-transition>
                <!-- Model Selector -->
                <div class="form-control mb-6">
                    <label class="label">
                        <span class="label-text font-semibold">Select Unit Type Model</span>
                    </label>
                    <select 
                        class="select select-bordered w-full"
                        x-model="selectedModel"
                    >
                        <option value="">Choose a model...</option>
                        <template x-for="model in availableModels" :key="model.value">
                            <option :value="model.value" x-text="model.label"></option>
                        </template>
                    </select>
                </div>

                <!-- Amenity Editor -->
                <div x-show="selectedModel" x-transition class="space-y-4">
                    <div class="alert alert-info">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <span>These amenities will be the default for all units of this type.</span>
                    </div>

                    <div x-effect="$watch('currentModelAmenities', () => saveModelAmenities(selectedModel))">
                        <AmenitySelector
                            name="modelAmenities"
                            label="Model Amenities"
                            xModel="currentModelAmenities"
                        />
                    </div>

                    <!-- Copy from Another Model -->
                    <div x-show="availableModels.length > 1" class="card bg-base-200">
                        <div class="card-body">
                            <h4 class="font-semibold mb-2">Copy amenities from another model</h4>
                            <div class="flex gap-2 flex-wrap">
                                <template x-for="model in availableModels.filter(m => m.value !== selectedModel)" :key="model.value">
                                    <button 
                                        class="btn btn-sm"
                                        x-on:click="copyAmenities(model.value)"
                                        :disabled="saving"
                                    >
                                        <span x-text="model.label"></span>
                                        <span class="badge badge-primary ml-1" x-text="getAmenityCount(model.value)"></span>
                                    </button>
                                </template>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bulk Edit Mode -->
            <div x-show="bulkEditMode" x-transition>
                <!-- Model Selection -->
                <div class="mb-6">
                    <div class="flex justify-between items-center mb-2">
                        <label class="label">
                            <span class="label-text font-semibold">Select Models to Update</span>
                        </label>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline" x-on:click="selectAllModels()">Select All</button>
                            <button class="btn btn-outline" x-on:click="deselectAllModels()">Clear</button>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                        <template x-for="model in availableModels" :key="model.value">
                            <label class="label cursor-pointer justify-start gap-3 p-3 rounded-lg hover:bg-base-200">
                                <input 
                                    type="checkbox" 
                                    class="checkbox checkbox-primary" 
                                    :value="model.value"
                                    x-model="selectedModels"
                                />
                                <div class="flex-1">
                                    <div class="font-medium" x-text="model.label"></div>
                                    <div class="text-sm text-base-content/70" x-text="getAmenitySummary(model.value)"></div>
                                </div>
                                <span class="badge badge-ghost" x-text="getAmenityCount(model.value) + ' amenities'"></span>
                            </label>
                        </template>
                    </div>
                </div>

                <!-- Bulk Amenity Selection -->
                <div x-show="selectedModels.length > 0" x-transition>
                    <div class="alert alert-warning mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        <span>This will replace all existing amenities for the selected models.</span>
                    </div>

                    <AmenitySelector
                        name="bulkAmenities"
                        label="Amenities to Apply"
                        xModel="bulkAmenities"
                    />

                    <div class="card-actions justify-end mt-6">
                        <button 
                            class="btn btn-ghost"
                            x-on:click="toggleBulkEdit()"
                            :disabled="saving"
                        >
                            Cancel
                        </button>
                        <button 
                            class="btn btn-primary"
                            x-on:click="applyBulkAmenities()"
                            :disabled="saving || selectedModels.length === 0"
                            :class="{'loading': saving}"
                        >
                            <span x-show="!saving">
                                Apply to <span x-text="selectedModels.length"></span> Model<span x-show="selectedModels.length !== 1">s</span>
                            </span>
                            <span x-show="saving">Updating...</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Model Overview Table -->
            <div class="mt-8" x-show="!bulkEditMode">
                <h4 class="font-semibold mb-4">Model Overview</h4>
                <div class="overflow-x-auto">
                    <table class="table table-zebra w-full">
                        <thead>
                            <tr>
                                <th>Model</th>
                                <th>Configuration</th>
                                <th>Amenities</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="model in availableModels" :key="model.value">
                                <tr>
                                    <td class="font-medium" x-text="unitTypes[model.value].modelName"></td>
                                    <td x-text="model.label.split('(')[1].replace(')', '')"></td>
                                    <td>
                                        <span class="badge badge-primary" x-text="getAmenityCount(model.value)"></span>
                                    </td>
                                    <td>
                                        <button 
                                            class="btn btn-ghost btn-xs"
                                            x-on:click="selectedModel = model.value"
                                        >
                                            Edit
                                        </button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @reference "../styles/global.css";
    
    /* Smooth transitions */
    [x-transition] {
        transition: all 0.3s ease;
    }
    
    /* Table styling */
    .table th {
        @apply font-semibold text-base-content/80;
    }
    
    /* Hover effects */
    .label:hover {
        @apply transition-colors;
    }
</style>