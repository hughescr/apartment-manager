---
import { BaseInput } from '../../forms';
import ValidationError from '../../common/ValidationError.astro';

// No props needed - uses shared state from parent BuildingProvider
export type Props = Record<string, never>;

const dialogId = 'bulk-create-units-dialog';
---

<dialog class="modal" :class="{'modal-open': showBulkCreateDialog}" data-testid={dialogId}>
    <div class="modal-box max-w-4xl">
        <h3 class="font-bold text-lg mb-4">Create Multiple Units from Floorplan</h3>
        <p class="mb-6 text-base-content/70">
            Create multiple units for
            <strong x-show="building">
                <span x-text="building?.street"></span>
,
<span x-text="building?.city"></span>
,
<span x-text="building?.state"></span>
            </strong>
            using the selected floorplan template.
        </p>

        <div
          class="space-y-6"
          x-data="{
                 errors: {},
                 get previewUnits() {
                     return this.getPreviewUnits();
                 },
                 get selectedUnitType() {
                     return unitTypes.find(ut => ut.modelID === bulkCreateData.modelID);
                 },
                 get showPreview() {
                     if (!bulkCreateData.modelID) return false;
                     if (bulkCreateData.patternType === 'custom') {
                         return bulkCreateData.customUnitNumbers && bulkCreateData.customUnitNumbers.trim().length > 0;
                     }
                     return bulkCreateData.count > 0;
                 },
                 getPreviewUnits() {
                     if (bulkCreateData.patternType === 'custom') {
                         if (!bulkCreateData.customUnitNumbers || !bulkCreateData.customUnitNumbers.trim()) return [];
                         const input = bulkCreateData.customUnitNumbers || '';
                         const unitNumbers = input
                             .split(/[,\\n\\r]+/)
                             .map(num => num.trim())
                             .filter(num => num.length > 0);
                         return unitNumbers.map((unitNumber, i) => ({ unitNumber, index: i + 1 }));
                     }
                     if (!bulkCreateData.count || bulkCreateData.count < 1) return [];
                     const units = [];
                     const count = Math.min(parseInt(bulkCreateData.count), 50);
                     for (let i = 0; i < count; i++) {
                         let unitNumber;
                         if (bulkCreateData.patternType === 'numeric') {
                             const startNum = parseInt(bulkCreateData.startingNumber) || 101;
                             unitNumber = (startNum + i).toString();
                         } else if (bulkCreateData.patternType === 'alpha-numeric') {
                             const prefix = bulkCreateData.prefix || 'A';
                             const startNum = parseInt(bulkCreateData.startingNumber) || 1;
                             unitNumber = prefix + (startNum + i);
                         }
                         units.push({ unitNumber, index: i + 1 });
                     }
                     return units;
                 },
                 async submitBulkCreateUnits() {
                     try {
                         bulkCreateData.unitNumbers = this.previewUnits.map(u => u.unitNumber);
                         await performBulkCreateUnits();
                         this.errors = {};
                     } catch (error) {
                         // eslint-disable-next-line no-console -- Need to log errors for debugging bulk create failures
                         console.error('Bulk create units error:', error);
                         this.errors.general = 'Failed to create units. Please try again.';
                         $dispatch('toast:show', {
                             message: 'Failed to create units. Please try again.',
                             type: 'error'
                         });
                     }
                 }
             }"
        >
            <!-- General Error Display -->
            <div x-show="errors.general" class="alert alert-error" data-testid="bulk-create-general-error">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span x-text="errors.general"></span>
            </div>

            <!-- Bulk Operation Results Display -->
            <div x-show="bulkOperation.errors && bulkOperation.errors.length > 0" class="card bg-base-200/50 p-4" data-testid="bulk-create-results">
                <h4 class="font-semibold mb-3 flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Creation Results
                </h4>

                <!-- Success Summary -->
                <div x-show="bulkOperation.successfulUnits && bulkOperation.successfulUnits.length > 0" class="mb-3">
                    <div class="alert alert-success">
                        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <div>
                            <span x-text="`Successfully created ${bulkOperation.successfulUnits?.length || 0} units`"></span>
                            <div x-show="bulkOperation.successfulUnits && bulkOperation.successfulUnits.length > 0" class="text-sm mt-1">
                                <strong>Created units:</strong>
                                <template x-for="unit in (bulkOperation.successfulUnits || []).slice(0, 10)" :key="unit">
                                    <span class="badge badge-success badge-sm ml-1" x-text="unit"></span>
                                </template>
                                <span x-show="(bulkOperation.successfulUnits?.length || 0) > 10" class="badge badge-ghost badge-sm ml-1" x-text="`+${(bulkOperation.successfulUnits?.length || 0) - 10} more`"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Error Details -->
                <div class="alert alert-error">
                    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div>
                        <span x-text="`${bulkOperation.errors?.length || 0} units failed to create`"></span>
                        <div class="mt-2 space-y-1 max-h-32 overflow-y-auto">
                            <template x-for="error in (bulkOperation.errors || [])" :key="error.unitNumber">
                                <div class="text-sm flex items-start justify-between bg-base-100/50 rounded p-2">
                                    <span class="font-medium" x-text="error.unitNumber"></span>
                                    <span class="text-right flex-1 ml-2" x-text="error.error"></span>
                                </div>
                            </template>
                        </div>
                        <div class="mt-2 text-sm">
                            <div class="flex items-start gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-info flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <div>
                                    <strong>Next Steps:</strong>
{' '}
Fix the errors above and click "Try Again" to create the units.
<span x-show="!bulkOperation.successfulUnits || bulkOperation.successfulUnits.length === 0">
                                        Your form data has been preserved for easy retry.
</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Clear Errors Button -->
                <div class="mt-3 flex justify-end">
                    <button
                      type="button"
                      class="btn btn-sm btn-ghost"
                      @click="bulkOperation.errors = undefined; bulkOperation.successfulUnits = undefined"
                      data-testid="clear-bulk-errors"
                    >
                        Clear Results
                    </button>
                </div>
            </div>

            <!-- Floorplan Selection and Count -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Floorplan Template</span>
                        <span class="label-text-alt text-error">*</span>
                    </label>
                    <select
                      class="select select-bordered"
                      class="{'select-error': errors.modelID}"
                      x-model="bulkCreateData.modelID"
                      data-testid="floorplan-select"
                    >
                        <option value="">Select a floorplan...</option>
                        <template x-for="unitType in unitTypes" :key="unitType.modelID">
                            <option
                              :value="unitType.modelID"
                                x-text="unitType.modelName + ' (' + unitType.beds + ' bed/' + unitType.baths + ' bath' + (unitType.sqft ? ', ' + unitType.sqft + ' sq ft' : '') + ')'"
                            >
                            </option>
                        </template>
                    </select>
                    <div class="label">
                        <span x-show="errors.modelID" class="label-text-alt text-error" x-text="errors.modelID"></span>
                        <span x-show="!errors.modelID" class="label-text-alt">All units will inherit properties from this floorplan</span>
                    </div>
                </div>

                <div x-show="bulkCreateData.patternType !== 'custom'">
                    <BaseInput
                      name="count"
                      label="Number of Units"
                      type="number"
                      xModel="bulkCreateData.count"
                      placeholder="e.g., 4 (number of floors)"
                      min="1"
                      max="50"
                      required={true}
                      helpText="How many units to create (maximum 50)"
                    />
                </div>
                <ValidationError fieldName="count" errors={{}} />
            </div>

            <!-- Unit Number Pattern Configuration -->
            <div class="card bg-base-200/50 p-4">
                <h4 class="font-semibold mb-4">Unit Number Pattern</h4>

                <div class="grid grid-cols-1 gap-4">
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Pattern Type</span>
                            <span class="label-text-alt text-error">*</span>
                        </label>
                        <select
                          class="select select-bordered w-full"
                          class="{'select-error': errors.patternType}"
                          x-model="bulkCreateData.patternType"
                          data-testid="pattern-type-select"
                        >
                            <option value="numeric">Sequential (101, 102, 103...)</option>
                            <option value="alpha-numeric">Floor-based (101, 201, 301...)</option>
                            <option value="custom">Custom (manually specify unit numbers)</option>
                        </select>
                        <div class="label">
                            <span x-show="errors.patternType" class="label-text-alt text-error" x-text="errors.patternType"></span>
                            <span x-show="!errors.patternType" class="label-text-alt">Choose how unit numbers will be generated</span>
                        </div>
                    </div>

                    <!-- Pattern explanations -->
                    <div class="text-sm text-base-content/70 mt-2">
                        <div x-show="bulkCreateData.patternType === 'numeric'" class="flex items-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-info" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>Units numbered consecutively (101, 102, 103...)</span>
                        </div>
                        <div x-show="bulkCreateData.patternType === 'alpha-numeric'" class="flex items-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-info" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>Units numbered by floor (101, 201, 301...)</span>
                        </div>
                        <div x-show="bulkCreateData.patternType === 'custom'" class="flex items-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-info" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>Manually specify unit numbers (for complex layouts, mixed-use buildings, or existing numbering)</span>
                        </div>
                    </div>

                    <!-- Automatic Pattern Inputs -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4" x-show="bulkCreateData.patternType !== 'custom'">
                        <div>
                            <BaseInput
                              name="startingNumber"
                              label="Starting Number"
                              xModel="bulkCreateData.startingNumber"
                              placeholder="101"
                              required={true}
                            />
                            <div class="text-xs text-base-content/60 mt-1">
                                <span x-show="bulkCreateData.patternType === 'numeric'">First unit number in sequence</span>
                                <span x-show="bulkCreateData.patternType === 'alpha-numeric'">Starting number for each floor (e.g., 01 for A01, B01, C01...)</span>
                            </div>
                            <ValidationError fieldName="startingNumber" errors={{}} />
                        </div>

                        <div x-show="bulkCreateData.patternType === 'alpha-numeric'">
                            <BaseInput
                              name="prefix"
                              label="Prefix"
                              xModel="bulkCreateData.prefix"
                              placeholder="A"
                              helpText="Letters/text before number"
                            />
                            <ValidationError fieldName="prefix" errors={{}} />
                        </div>
                    </div>

                    <!-- Custom Unit Numbers Input -->
                    <div class="grid grid-cols-1 gap-4" x-show="bulkCreateData.patternType === 'custom'">
                        <div class="form-control">
                            <label class="label">
                                <span class="label-text">Custom Unit Numbers</span>
                                <span class="label-text-alt text-error">*</span>
                            </label>
                            <textarea
                              class="textarea textarea-bordered"
                              :class="{'textarea-error': errors.customUnitNumbers}"
                                x-model="bulkCreateData.customUnitNumbers"
                                placeholder="Enter unit numbers separated by commas or new lines: 101, 102A, 203B OR 101 102A 203B"
                                rows="4"
                                data-testid="custom-unit-numbers"
                            >
                            </textarea>
                            <div class="label">
                                <span x-show="errors.customUnitNumbers" class="label-text-alt text-error" x-text="errors.customUnitNumbers"></span>
                                <span x-show="!errors.customUnitNumbers" class="label-text-alt">Enter unit numbers separated by commas or new lines (e.g., "101, 102A, 203B")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Initial Status -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Initial Status</span>
                        <span class="label-text-alt text-error">*</span>
                    </label>
                    <select
                      class="select select-bordered w-full"
                      :class="{'select-error': errors.vacancyClass}"
                        x-model="bulkCreateData.vacancyClass"
                        data-testid="vacancy-status-select"
                    >
                        <option value="Unoccupied">Unoccupied - Available for rent</option>
                        <option value="Occupied">Occupied - Currently rented</option>
                        <option value="Notice">Notice - Tenant gave notice</option>
                        <option value="Down">Down - Maintenance/renovation</option>
                    </select>
                    <div class="label">
                        <span x-show="errors.vacancyClass" class="label-text-alt text-error" x-text="errors.vacancyClass"></span>
                        <span x-show="!errors.vacancyClass" class="label-text-alt">Status for all newly created units</span>
                    </div>
                </div>
            </div>

            <!-- Preview Section -->
            <div x-show="showPreview && previewUnits.length > 0" class="card bg-base-100 border border-primary/20 p-4">
                <h4 class="font-semibold mb-3 flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    Preview
                    <span x-text="'(' + previewUnits.length + ' units)'"></span>
                </h4>

                <div x-show="selectedUnitType" class="mb-3 text-sm text-base-content/70">
                    <strong>Floorplan:</strong>
                    <span x-text="selectedUnitType?.modelName + ' (' + selectedUnitType?.beds + ' bed/' + selectedUnitType?.baths + ' bath)'"></span>
                </div>

                <div class="max-h-40 overflow-y-auto">
                    <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-2">
                        <template x-for="unit in previewUnits.slice(0, 24)" :key="unit.index">
                            <div class="badge badge-outline badge-sm" x-text="unit.unitNumber"></div>
                        </template>
                        <div x-show="previewUnits.length > 24" class="badge badge-ghost badge-sm" x-text="'+' + (previewUnits.length - 24) + ' more'"></div>
                    </div>
                </div>
            </div>

            <!-- Dialog Actions -->
            <div class="modal-action">
                <button
                  type="button"
                  class="btn"
                  @click="bulkOperation.errors && bulkOperation.errors.length > 0 ? closeBulkCreateDialogWithPreservedState() : (showBulkCreateDialog = false)"
                  :disabled="bulkOperation.loading"
                    data-testid="cancel-bulk-create"
                >
                    <span x-show="!bulkOperation.errors || bulkOperation.errors.length === 0">Cancel</span>
                    <span x-show="bulkOperation.errors && bulkOperation.errors.length > 0">Close</span>
                </button>
                <button
                  type="button"
                  class="btn btn-primary"
                  :disabled="bulkOperation.loading || !showPreview"
                    @click="submitBulkCreateUnits()"
                    data-testid="confirm-bulk-create"
                >
                    <span x-show="bulkOperation.loading" class="loading loading-spinner loading-sm"></span>
                    <span x-show="!bulkOperation.loading">
                        <span x-show="!bulkOperation.errors || bulkOperation.errors.length === 0">
                            Create
                            <span x-text="previewUnits.length"></span>
                            {' '}
                            Units
                        </span>
                        <span x-show="bulkOperation.errors && bulkOperation.errors.length > 0">
                            Try Again
                            <span x-text="`(${previewUnits.length} units)`"></span>
                        </span>
                    </span>
                </button>
            </div>
        </div>
    </div>
</dialog>
