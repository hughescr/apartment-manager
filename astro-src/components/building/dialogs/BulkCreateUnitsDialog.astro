---
import { BaseInput, BaseSelect } from '../../forms';
import ValidationError from '../../common/ValidationError.astro';

// No props needed - uses shared state from parent BuildingProvider
export type Props = Record<string, never>;

// Empty options - will use custom Alpine.js select instead

const dialogId = 'bulk-create-units-dialog';

// Status options for new units
const statusOptions = [
    { value: 'Unoccupied', label: 'Unoccupied - Available for rent' },
    { value: 'Occupied', label: 'Occupied - Currently rented' },
    { value: 'Notice', label: 'Notice - Tenant gave notice' },
    { value: 'Down', label: 'Down - Maintenance/renovation' }
];

// Unit number pattern types
const patternTypes = [
    { value: 'numeric', label: 'Numeric (101, 102, 103...)' },
    { value: 'alpha-numeric', label: 'Alpha-Numeric (A1, A2, A3...)' },
    { value: 'custom', label: 'Custom Pattern' }
];
---

<dialog class="modal" :class="{'modal-open': showBulkCreateDialog}" data-testid={dialogId}>
    <div class="modal-box max-w-4xl">
        <h3 class="font-bold text-lg mb-4">Create Multiple Units from Floorplan</h3>
        <p class="mb-6 text-base-content/70">
            Create multiple units for
            <strong x-show="building">
                <span x-text="building?.street"></span>
,
<span x-text="building?.city"></span>
,
<span x-text="building?.state"></span>
            </strong>
            using the selected floorplan template.
        </p>

        <form
          submit.prevent="submitBulkCreateUnits()"
          class="space-y-6"
          x-data="{
                bulkCreateData: {
                    modelID: '',
                    count: 5,
                    patternType: 'numeric',
                    startingNumber: '101',
                    prefix: '',
                    suffix: '',
                    vacancyClass: 'Unoccupied'
                },
                errors: {},
                loading: false,

                // Computed preview values
                get previewUnits() {
                    if (!this.bulkCreateData.count || this.bulkCreateData.count < 1) return [];

                    const units = [];
                    const count = Math.min(parseInt(this.bulkCreateData.count), 50); // Limit preview to 50

                    for (let i = 0; i < count; i++) {
                        let unitNumber;

                        if (this.bulkCreateData.patternType === 'numeric') {
                            const startNum = parseInt(this.bulkCreateData.startingNumber) || 101;
                            unitNumber = (startNum + i).toString();
                        } else if (this.bulkCreateData.patternType === 'alpha-numeric') {
                            const prefix = this.bulkCreateData.prefix || 'A';
                            const startNum = parseInt(this.bulkCreateData.startingNumber) || 1;
                            unitNumber = prefix + (startNum + i);
                        } else { // custom
                            const prefix = this.bulkCreateData.prefix || '';
                            const suffix = this.bulkCreateData.suffix || '';
                            const startNum = parseInt(this.bulkCreateData.startingNumber) || 1;
                            unitNumber = prefix + (startNum + i) + suffix;
                        }

                        units.push({
                            unitNumber,
                            index: i + 1
                        });
                    }

                    return units;
                },

                get selectedUnitType() {
                    return unitTypes.find(ut => ut.modelID === this.bulkCreateData.modelID);
                },

                get showPreview() {
                    return this.bulkCreateData.modelID && this.bulkCreateData.count > 0;
                },

                validateForm() {
                    this.errors = {};

                    if (!this.bulkCreateData.modelID) {
                        this.errors.modelID = 'Please select a floorplan';
                    }

                    const count = parseInt(this.bulkCreateData.count);
                    if (!count || count < 1) {
                        this.errors.count = 'Count must be at least 1';
                    } else if (count > 50) {
                        this.errors.count = 'Count cannot exceed 50 units at once';
                    }

                    if (!this.bulkCreateData.startingNumber.trim()) {
                        this.errors.startingNumber = 'Starting number is required';
                    }

                    if (this.bulkCreateData.patternType === 'alpha-numeric' && !this.bulkCreateData.prefix.trim()) {
                        this.errors.prefix = 'Prefix is required for alpha-numeric pattern';
                    }

                    return Object.keys(this.errors).length === 0;
                },

                async submitBulkCreateUnits() {
                    if (!this.validateForm()) {
                        return;
                    }

                    this.loading = true;

                    try {
                        // Use parent's bulk create method
                        $parent.bulkCreateData = {
                            ...this.bulkCreateData,
                            unitNumbers: this.previewUnits.map(u => u.unitNumber)
                        };
                        await $parent.performBulkCreateUnits();

                        // Reset form and close dialog
                        this.bulkCreateData = {
                            modelID: '',
                            count: 5,
                            patternType: 'numeric',
                            startingNumber: '101',
                            prefix: '',
                            suffix: '',
                            vacancyClass: 'Unoccupied'
                        };
                        this.errors = {};
                        $parent.showBulkCreateDialog = false;
                    } catch (error) {
                        console.error('Bulk create units error:', error);
                        this.errors.general = 'Failed to create units. Please try again.';
                        $dispatch('show-toast', {
                            message: 'Failed to create units. Please try again.',
                            type: 'error'
                        });
                    } finally {
                        this.loading = false;
                    }
                },

                unitTypes: JSON.parse($el.dataset.unitTypes || '[]')
            }"
        >
            <!-- General Error Display -->
            <div x-show="errors.general" class="alert alert-error" data-testid="bulk-create-general-error">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span x-text="errors.general"></span>
            </div>

            <!-- Floorplan Selection and Count -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Floorplan Template</span>
                        <span class="label-text-alt text-error">*</span>
                    </label>
                    <select
                      class="select select-bordered"
                      class="{'select-error': errors.modelID}"
                      x-model="bulkCreateData.modelID"
                      data-testid="floorplan-select"
                    >
                        <option value="">Select a floorplan...</option>
                        <template x-for="unitType in unitTypes" :key="unitType.modelID">
                            <option
                              value="unitType.modelID"
                              x-text="unitType.modelName + ' (' + unitType.beds + ' bed/' + unitType.baths + ' bath' + (unitType.sqft ? ', ' + unitType.sqft + ' sq ft' : '') + ')'"
                            >
                            </option>
                        </template>
                    </select>
                    <div class="label">
                        <span x-show="errors.modelID" class="label-text-alt text-error" x-text="errors.modelID"></span>
                        <span x-show="!errors.modelID" class="label-text-alt">All units will inherit properties from this floorplan</span>
                    </div>
                </div>

                <BaseInput
                  name="count"
                  label="Number of Units"
                  type="number"
                  xModel="bulkCreateData.count"
                  min="1"
                  max="50"
                  required={true}
                  helpText="How many units to create (maximum 50)"
                />
                <ValidationError fieldName="count" errors={{}} />
            </div>

            <!-- Unit Number Pattern Configuration -->
            <div class="card bg-base-200/50 p-4">
                <h4 class="font-semibold mb-4">Unit Number Pattern</h4>

                <div class="grid grid-cols-1 gap-4">
                    <BaseSelect
                      name="patternType"
                      label="Pattern Type"
                      xModel="bulkCreateData.patternType"
                      options={patternTypes}
                      required={true}
                    />

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <BaseInput
                          name="startingNumber"
                          label="Starting Number"
                          xModel="bulkCreateData.startingNumber"
                          placeholder="101"
                          required={true}
                          helpText="First unit number in sequence"
                        />
                        <ValidationError fieldName="startingNumber" errors={{}} />

                        <div x-show="bulkCreateData.patternType === 'alpha-numeric' || bulkCreateData.patternType === 'custom'">
                            <BaseInput
                              name="prefix"
                              label="Prefix"
                              xModel="bulkCreateData.prefix"
                              placeholder="A"
                              helpText="Letters/text before number"
                            />
                            <ValidationError fieldName="prefix" errors={{}} />
                        </div>

                        <div x-show="bulkCreateData.patternType === 'custom'">
                            <BaseInput
                              name="suffix"
                              label="Suffix"
                              xModel="bulkCreateData.suffix"
                              placeholder=""
                              helpText="Text after number"
                            />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Initial Status -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <BaseSelect
                  name="vacancyClass"
                  label="Initial Status"
                  xModel="bulkCreateData.vacancyClass"
                  options={statusOptions}
                  required={true}
                  helpText="Status for all newly created units"
                />
            </div>

            <!-- Preview Section -->
            <div x-show="showPreview && previewUnits.length > 0" class="card bg-base-100 border border-primary/20 p-4">
                <h4 class="font-semibold mb-3 flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    Preview
                    <span x-text="'(' + previewUnits.length + ' units)'"></span>
                </h4>

                <div x-show="selectedUnitType" class="mb-3 text-sm text-base-content/70">
                    <strong>Floorplan:</strong>
                    <span x-text="selectedUnitType?.modelName + ' (' + selectedUnitType?.beds + ' bed/' + selectedUnitType?.baths + ' bath)'"></span>
                </div>

                <div class="max-h-40 overflow-y-auto">
                    <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-2">
                        <template x-for="unit in previewUnits.slice(0, 24)" :key="unit.index">
                            <div class="badge badge-outline badge-sm" x-text="unit.unitNumber"></div>
                        </template>
                        <div x-show="previewUnits.length > 24" class="badge badge-ghost badge-sm" x-text="'+' + (previewUnits.length - 24) + ' more'"></div>
                    </div>
                </div>
            </div>

            <!-- Dialog Actions -->
            <div class="modal-action">
                <button
                  type="button"
                  class="btn"
                  @click="showBulkCreateDialog = false"
                  :disabled="loading"
                    data-testid="cancel-bulk-create"
                >
                    Cancel
                </button>
                <button
                  type="submit"
                  class="btn btn-primary"
                  :disabled="loading || !showPreview"
                    data-testid="confirm-bulk-create"
                >
                    <span x-show="loading" class="loading loading-spinner loading-sm"></span>
                    <span x-show="!loading">
Create
<span x-text="bulkCreateData.count"></span>
{' '}
Units
                    </span>
                </button>
            </div>
        </form>
    </div>
</dialog>
