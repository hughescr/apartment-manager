---
import { BaseInput } from '../../forms';
import ValidationError from '../../common/ValidationError.astro';

export interface Props {
    building: {
        buildingID: string
        street: string
        city: string
        state: string
    }
    apiUrl: string
    isOpen?: boolean
    dialogId?: string
}

const {
    building,
    isOpen: _isOpen = false,
    dialogId = 'add-unit-type-dialog'
} = Astro.props;
---

<dialog class="modal" :class="{'modal-open': showAddUnitTypeDialog}" data-testid={dialogId}>
    <div class="modal-box max-w-2xl">
        <h3 class="font-bold text-lg mb-4">Add New Floorplan (Unit Type)</h3>
        <p class="mb-6 text-base-content/70">
            Create a new unit type for
{' '}
<strong>
{building.street}
,
{' '}
{building.city}
,
{' '}
{building.state}
</strong>
.
            Unit types serve as templates that individual units can inherit from and customize.
        </p>

        <form
          submit.prevent="submitAddUnitType()"
          class="space-y-6"
          x-data="{
                newUnitType: {
                    modelID: '',
                    modelName: '',
                    beds: 1,
                    baths: 1,
                    minSqft: null,
                    maxSqft: null,
                    minRent: null,
                    maxRent: null,
                    buildingID: '{building.buildingID}'
                },
                errors: {},
                loading: false,

                generateModelID() {
                    if (this.newUnitType.modelName.trim()) {
                        // Generate a simple ID from the model name
                        const id = this.newUnitType.modelName
                            .toLowerCase()
                            .replace(/[^a-z0-9]+/g, '-')
                            .replace(/^-+|-+$/g, '');
                        this.newUnitType.modelID = id || '';
                    }
                },

                async submitAddUnitType() {
                    this.loading = true;
                    this.errors = {};

                    try {
                        // Client-side validation
                        if (!this.newUnitType.modelName.trim()) {
                            this.errors.modelName = 'Floorplan name is required';
                        }
                        if (!this.newUnitType.modelID.trim()) {
                            this.errors.modelID = 'Model ID is required';
                        }
                        if (this.newUnitType.beds < 0) {
                            this.errors.beds = 'Bedrooms must be 0 or greater';
                        }
                        if (this.newUnitType.baths < 0.5) {
                            this.errors.baths = 'Bathrooms must be 0.5 or greater';
                        }
                        if (this.newUnitType.minSqft && this.newUnitType.minSqft < 0) {
                            this.errors.minSqft = 'Minimum square feet must be 0 or greater';
                        }
                        if (this.newUnitType.maxSqft && this.newUnitType.maxSqft < 0) {
                            this.errors.maxSqft = 'Maximum square feet must be 0 or greater';
                        }
                        if (this.newUnitType.minSqft && this.newUnitType.maxSqft && this.newUnitType.minSqft > this.newUnitType.maxSqft) {
                            this.errors.maxSqft = 'Maximum square feet must be greater than minimum';
                        }
                        if (this.newUnitType.minRent && this.newUnitType.minRent < 0) {
                            this.errors.minRent = 'Minimum rent must be 0 or greater';
                        }
                        if (this.newUnitType.maxRent && this.newUnitType.maxRent < 0) {
                            this.errors.maxRent = 'Maximum rent must be 0 or greater';
                        }
                        if (this.newUnitType.minRent && this.newUnitType.maxRent && this.newUnitType.minRent > this.newUnitType.maxRent) {
                            this.errors.maxRent = 'Maximum rent must be greater than minimum';
                        }

                        if (Object.keys(this.errors).length > 0) {
                            this.loading = false;
                            return;
                        }

                        // Use parent's add unit type method
                        $parent.newUnitType = this.newUnitType;
                        await $parent.addUnitType();

                        // Reset form and close dialog
                        this.newUnitType = {
                            modelID: '',
                            modelName: '',
                            beds: 1,
                            baths: 1,
                            minSqft: null,
                            maxSqft: null,
                            minRent: null,
                            maxRent: null,
                            buildingID: '{building.buildingID}'
                        };
                        $parent.showAddUnitTypeDialog = false;
                    } catch (error) {
                        console.error('Add unit type error:', error);
                        this.errors.general = 'Failed to add floorplan. Please try again.';
                        $dispatch('show-toast', {
                            message: 'Failed to add floorplan. Please try again.',
                            type: 'error'
                        });
                    } finally {
                        this.loading = false;
                    }
                }
            }"
        >
            <!-- General Error Display -->
            <div x-show="errors.general" class="alert alert-error" data-testid="add-unit-type-general-error">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span x-text="errors.general"></span>
            </div>

            <!-- Basic Unit Type Information -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <BaseInput
                  name="modelName"
                  label="Floorplan Name"
                  xModel="newUnitType.modelName"
                  placeholder="1 Bedroom Classic"
                  required={true}
                  helpText="Descriptive name for this unit type"
                  input="generateModelID()"
                />
                <ValidationError fieldName="modelName" errors={{}} />

                <BaseInput
                  name="modelID"
                  label="Model ID"
                  xModel="newUnitType.modelID"
                  placeholder="1br-classic"
                  required={true}
                  helpText="Unique identifier (auto-generated from name)"
                />
                <ValidationError fieldName="modelID" errors={{}} />
            </div>

            <!-- Room Configuration -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <BaseInput
                  name="beds"
                  label="Bedrooms"
                  type="number"
                  xModel="newUnitType.beds"
                  min="0"
                  max="10"
                  required={true}
                  helpText="Number of bedrooms (0 for studio)"
                />
                <ValidationError fieldName="beds" errors={{}} />

                <BaseInput
                  name="baths"
                  label="Bathrooms"
                  type="number"
                  xModel="newUnitType.baths"
                  min="0.5"
                  max="10"
                  step="0.5"
                  required={true}
                />
                <ValidationError fieldName="baths" errors={{}} />
            </div>

            <!-- Square Footage Range -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <BaseInput
                  name="minSqft"
                  label="Minimum Square Feet"
                  type="number"
                  xModel="newUnitType.minSqft"
                  min="100"
                  max="10000"
                  placeholder="750"
                  helpText="Optional - smallest unit of this type"
                />
                <ValidationError fieldName="minSqft" errors={{}} />

                <BaseInput
                  name="maxSqft"
                  label="Maximum Square Feet"
                  type="number"
                  xModel="newUnitType.maxSqft"
                  min="100"
                  max="10000"
                  placeholder="950"
                  helpText="Optional - largest unit of this type"
                />
                <ValidationError fieldName="maxSqft" errors={{}} />
            </div>

            <!-- Rent Range -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <BaseInput
                  name="minRent"
                  label="Minimum Rent"
                  type="number"
                  xModel="newUnitType.minRent"
                  min="0"
                  max="25000"
                  placeholder="2000"
                  helpText="Optional - lowest rent for this type"
                />
                <ValidationError fieldName="minRent" errors={{}} />

                <BaseInput
                  name="maxRent"
                  label="Maximum Rent"
                  type="number"
                  xModel="newUnitType.maxRent"
                  min="0"
                  max="25000"
                  placeholder="2500"
                  helpText="Optional - highest rent for this type"
                />
                <ValidationError fieldName="maxRent" errors={{}} />
            </div>

            <!-- Dialog Actions -->
            <div class="modal-action">
                <button
                  type="button"
                  class="btn"
                  click="showAddUnitTypeDialog = false"
                  disabled="loading"
                  data-testid="cancel-add-unit-type"
                >
                    Cancel
                </button>
                <button
                  type="submit"
                  class="btn btn-primary"
                  disabled="loading"
                  data-testid="confirm-add-unit-type"
                >
                    <span x-show="loading" class="loading loading-spinner loading-sm"></span>
                    <span x-show="!loading">Add Floorplan</span>
                </button>
            </div>
        </form>
    </div>
</dialog>
