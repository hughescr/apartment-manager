---
import _ from 'lodash';

export interface Props {
    building: {
        buildingID: string
    }
    apiUrl: string
    isOpen?: boolean
    dialogId?: string
}

const {
    isOpen: _isOpen = false,
    dialogId = 'bulk-status-dialog'
} = Astro.props;

// Status options
const statusOptions = [
    { value: 'Occupied', label: 'Occupied - Currently rented' },
    { value: 'Unoccupied', label: 'Unoccupied - Available for rent' },
    { value: 'Notice', label: 'Notice - Tenant gave notice' },
    { value: 'Down', label: 'Down - Maintenance/renovation' }
];
---

<dialog class="modal" :class="{'modal-open': showBulkStatusDialog}" data-testid={dialogId}>
    <div class="modal-box">
        <h3 class="font-bold text-lg">Update Status for Selected Units</h3>
        <p class="py-4">
            Change the status for
{' '}
<span class="font-semibold" x-text="selectedUnits.size"></span>
{' '}
selected units:
        </p>
        <div
          x-data="{
                statusValue: '',
                loading: false,
                errors: {},

                async performBulkStatusUpdate() {
                    if (!this.statusValue) {
                        this.errors.status = 'Please select a status';
                        return;
                    }

                    this.loading = true;
                    this.errors = {};

                    try {
                        // Use parent's bulk operation method
                        $parent.bulkOperation.statusValue = this.statusValue;
                        await $parent.performBulkStatusUpdate();

                        // Reset and close
                        this.statusValue = '';
                        $parent.showBulkStatusDialog = false;
                    } catch (error) {
                        console.error('Bulk status update error:', error);
                        this.errors.general = 'Failed to update units. Please try again.';
                        $dispatch('show-toast', {
                            message: 'Failed to update units. Please try again.',
                            type: 'error'
                        });
                    } finally {
                        this.loading = false;
                    }
                }
            }"
          class="space-y-4"
        >
            <!-- General Error Display -->
            <div x-show="errors.general" class="alert alert-error" data-testid="bulk-status-general-error">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span x-text="errors.general"></span>
            </div>

            <!-- Status Selection -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text">New Status</span>
                </label>
                <select
                  class="select select-bordered"
                  class="{'select-error': errors.status}"
                  data-testid="bulk-status-select"
                  x-model="statusValue"
                >
                    <option value="">Select status...</option>
                    {_.map(statusOptions, option => (
                        <option value={option.value}>{option.label}</option>
                    ))}
                </select>
                <div x-show="errors.status" class="label">
                    <span class="label-text-alt text-error" x-text="errors.status"></span>
                </div>
            </div>

            <!-- Preview -->
            <div x-show="statusValue" class="alert alert-info">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                    <div class="font-bold">Preview</div>
                    <div class="text-xs">
                        <span x-text="selectedUnits.size"></span>
{' '}
units will be updated to:
<span class="font-semibold" x-text="statusValue"></span>
                    </div>
                </div>
            </div>

            <!-- Dialog Actions -->
            <div class="modal-action">
                <button
                  class="btn"
                  @click="showBulkStatusDialog = false; statusValue = ''; errors = {}"
                  disabled="loading"
                  data-testid="cancel-bulk-status"
                >
                    Cancel
                </button>
                <button
                  class="btn btn-primary"
                  data-testid="bulk-status-confirm"
                  disabled="!statusValue || loading"
                  @click="performBulkStatusUpdate()"
                >
                    <span x-show="loading" class="loading loading-spinner loading-sm"></span>
                    <span x-show="!loading">Update Status</span>
                </button>
            </div>
        </div>
    </div>
</dialog>
