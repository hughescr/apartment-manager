---
export interface Props {
    building: {
        buildingID: string
    }
    apiUrl: string
    isOpen?: boolean
    dialogId?: string
}

const {
    isOpen: _isOpen = false,
    dialogId = 'bulk-rent-dialog'
} = Astro.props;
---

<dialog class="modal" :class="{'modal-open': showBulkRentDialog}" data-testid={dialogId}>
    <div class="modal-box">
        <h3 class="font-bold text-lg">Update Rent for Selected Units</h3>
        <p class="py-4">
            Update rent for
{' '}
<span class="font-semibold" x-text="selectedUnits.size"></span>
{' '}
selected units:
        </p>

        <div
          x-data="{
                rentUpdateType: 'absolute',
                rentValue: '',
                loading: false,
                errors: {},

                // Computed preview values
                get previewValues() {
                    if (!this.rentValue || !selectedUnits || selectedUnits.size === 0) return [];

                    const values = [];
                    const unitsArray = Array.from(selectedUnits);

                    // Get first few units for preview (limit to 3 for display)
                    const previewUnits = unitsArray.slice(0, 3).map(unitID => {
                        const unit = units.find(u => u.unitID === unitID);
                        if (!unit) return null;

                        let newRent;
                        if (this.rentUpdateType === 'absolute') {
                            newRent = parseFloat(this.rentValue);
                        } else {
                            newRent = Math.round(unit.rent * (1 + parseFloat(this.rentValue) / 100));
                        }

                        return {
                            unitNumber: unit.unitNumber || unit.unitID,
                            currentRent: unit.rent,
                            newRent: newRent
                        };
                    }).filter(Boolean);

                    return previewUnits;
                },

                get hasMoreUnits() {
                    return selectedUnits && selectedUnits.size > 3;
                },

                validateInput() {
                    this.errors = {};
                    const value = parseFloat(this.rentValue);

                    if (!this.rentValue || isNaN(value)) {
                        this.errors.value = 'Please enter a valid number';
                        return false;
                    }

                    if (this.rentUpdateType === 'absolute') {
                        if (value < 0) {
                            this.errors.value = 'Rent cannot be negative';
                            return false;
                        }
                        if (value > 25000) {
                            this.errors.value = 'Rent must be less than $25,000';
                            return false;
                        }
                    } else { // percentage
                        if (value < -100) {
                            this.errors.value = 'Percentage decrease cannot exceed 100%';
                            return false;
                        }
                        if (value > 1000) {
                            this.errors.value = 'Percentage increase seems excessive (max 1000%)';
                            return false;
                        }
                    }

                    return true;
                },

                async performBulkRentUpdate() {
                    if (!this.validateInput()) {
                        return;
                    }

                    this.loading = true;

                    try {
                        // Use parent's bulk operation method
                        bulkOperation.rentUpdateType = this.rentUpdateType;
                        bulkOperation.rentValue = parseFloat(this.rentValue);
                        await performBulkRentUpdate();

                        // Reset and close
                        this.rentUpdateType = 'absolute';
                        this.rentValue = '';
                        this.errors = {};
                        showBulkRentDialog = false;
                    } catch (error) {
                        console.error('Bulk rent update error:', error);
                        this.errors.general = 'Failed to update rents. Please try again.';
                        $dispatch('show-toast', {
                            message: 'Failed to update rents. Please try again.',
                            type: 'error'
                        });
                    } finally {
                        this.loading = false;
                    }
                }
            }"
          class="space-y-4"
        >
            <!-- General Error Display -->
            <div x-show="errors.general" class="alert alert-error" data-testid="bulk-rent-general-error">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span x-text="errors.general"></span>
            </div>

            <!-- Update Type Selection -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Update Type</span>
                </label>
                <select
                  class="select select-bordered"
                  data-testid="rent-update-type"
                  x-model="rentUpdateType"
                >
                    <option value="absolute">Set to specific amount</option>
                    <option value="percentage">Percentage increase/decrease</option>
                </select>
            </div>

            <!-- Value Input -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text">
                        <span x-show="rentUpdateType === 'absolute'">New Rent Amount ($)</span>
                        <span x-show="rentUpdateType === 'percentage'">Percentage Change (%)</span>
                    </span>
                </label>
                <input
                  type="number"
                  class="input input-bordered"
                  class="{'input-error': errors.value}"
                  data-testid="rent-update-value"
                  x-model="rentValue"
                  min="rentUpdateType === 'absolute' ? 0 : -100"
                  max="rentUpdateType === 'absolute' ? 25000 : 1000"
                  placeholder="rentUpdateType === 'absolute' ? 'Enter rent amount' : 'Enter percentage (e.g., 10 for 10% increase, -5 for 5% decrease)'"
                  step="any"
                />
                <div class="label">
                    <span x-show="errors.value" class="label-text-alt text-error" x-text="errors.value"></span>
                    <span x-show="!errors.value && rentUpdateType === 'percentage' && parseFloat(rentValue) > 100" class="label-text-alt text-warning">
                        Large percentage increases will significantly raise rent prices
                    </span>
                </div>
            </div>

            <!-- Preview -->
            <div x-show="rentValue && !errors.value" class="alert alert-info">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div class="w-full">
                    <div class="font-bold mb-2">Preview</div>
                    <div class="space-y-1 text-sm">
                        <template x-for="preview in previewValues" :key="preview.unitNumber">
                            <div class="flex justify-between items-center">
                                <span x-text="'Unit ' + preview.unitNumber"></span>
                                <span>
                                    <span class="text-base-content/60" x-text="'$' + preview.currentRent"></span>
                                    <span class="mx-1">→</span>
                                    <span class="font-semibold" x-text="'$' + preview.newRent"></span>
                                </span>
                            </div>
                        </template>
                        <div x-show="hasMoreUnits" class="text-center text-base-content/60 text-xs pt-1">
                            <span x-text="'+ ' + (selectedUnits.size - 3) + ' more units'"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dialog Actions -->
            <div class="modal-action">
                <button
                  class="btn"
                  @click="showBulkRentDialog = false; rentUpdateType = 'absolute'; rentValue = ''; errors = {}"
                  :disabled="loading"
                    data-testid="cancel-bulk-rent"
                >
                    Cancel
                </button>
                <button
                  class="btn btn-primary"
                  data-testid="bulk-rent-confirm"
                  :disabled="!rentValue || !!errors.value || loading"
                    @click="performBulkRentUpdate()"
                >
                    <span x-show="loading" class="loading loading-spinner loading-sm"></span>
                    <span x-show="!loading">Update Rent</span>
                </button>
            </div>
        </div>
    </div>
</dialog>
