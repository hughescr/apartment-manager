---
import { BaseInput, BaseSelect } from '../../forms';

// No props needed - uses shared state from parent BuildingProvider
export type Props = Record<string, never>;

const dialogId = 'edit-unit-dialog';

// Status options
const statusOptions = [
    { value: 'Unoccupied', label: 'Unoccupied - Available for rent' },
    { value: 'Occupied', label: 'Occupied - Currently rented' },
    { value: 'Notice', label: 'Notice - Tenant gave notice' },
    { value: 'Down', label: 'Down - Maintenance/renovation' }
];
---

<dialog class="modal" :class="{'modal-open': showEditUnitDialog}" data-testid={dialogId}>
    <div class="modal-box max-w-2xl">
        <h3 class="font-bold text-lg mb-4">Edit Unit</h3>
        <p class="mb-6 text-base-content/70" x-show="editingUnit">
            Edit unit
            <span class="font-bold" x-text="editingUnit?.unitNumber || editingUnit?.unitID"></span>
            in
            <strong x-show="building">
                <span x-text="building?.street"></span>
                <span x-text="building?.city"></span>
                <span x-text="building?.state"></span>
            </strong>
.
            Units can inherit properties from a unit type or be configured independently.
        </p>

        <form
          x-show="editingUnit"
          @submit.prevent="submitEditUnit()"
          class="space-y-6"
        >
            <!-- General Error Display -->
            <div x-show="editUnitErrors.general" class="alert alert-error" data-testid="edit-unit-general-error">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span x-text="editUnitErrors.general"></span>
            </div>

            <!-- Basic Unit Information -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <BaseInput
                  name="unitNumber"
                  label="Unit Number"
                  xModel="editUnit.unitNumber"
                  placeholder="101"
                  required={true}
                  helpText="Unique identifier for this unit"
                />

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Unit Type (Optional)</span>
                    </label>
                    <select
                      class="select select-bordered"
                      :class="{'select-error': editUnitErrors.modelID}"
                        x-model="editUnit.modelID"
                        @change="if (previewEditUnitTypeChange($event.target.value)) { onEditUnitTypeChange(); } else { $event.target.value = editUnit.modelID; }"
                        data-testid="unit-type-select"
                    >
                        <option value="">None (Custom Unit)</option>
                        <template x-for="unitType in unitTypes" :key="unitType.modelID">
                            <option :value="unitType.modelID" x-text="unitType.modelName + ' (' + unitType.beds + ' bed/' + unitType.baths + ' bath' + (unitType.sqft ? ', ' + unitType.sqft + ' sq ft' : '') + ')'"></option>
                        </template>
                    </select>
                    <div class="label">
                        <span class="label-text-alt">Choose to inherit properties from a unit type</span>
                        <span x-show="editUnitErrors.modelID" class="label-text-alt text-error" x-text="editUnitErrors.modelID"></span>
                    </div>
                </div>
            </div>

            <!-- Unit Specifications -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Bedrooms</span>
                        <div class="flex items-center gap-2">
                            <span
                              x-show="getEditInheritanceBadge('beds')"
                              class="badge badge-sm"
                              :class="{ 'badge-info': isEditFieldInherited('beds'), 'badge-warning': !isEditFieldInherited('beds') && getEditInheritanceBadge('beds') }"
                                x-text="getEditInheritanceBadge('beds')"
                            >
                            </span>
                            <button
                              x-show="!isEditFieldInherited(&#39;beds&#39;) && editFormSelectedUnitType && getEditInheritanceBadge(&#39;beds&#39;)"
                              type="button"
                              class="btn btn-ghost btn-xs"
                              @click="clearEditOverride('beds')"
                              title="Use floorplan value"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                                </svg>
                                Use floorplan
                            </button>
                        </div>
                    </label>
                    <input
                      type="number"
                      name="beds"
                      x-model="editUnit.beds"
                      :placeholder="getEditFieldPlaceholder('beds', '1')"
                        class="input input-bordered"
                        :class="{'input-error': editUnitErrors.beds}"
                          min="0"
                          max="10"
                          required
                          data-testid="beds-input"
                    />
                    <div class="label">
                        <span class="label-text-alt">Number of bedrooms (0 for studio)</span>
                        <span x-show="editUnitErrors.beds" class="label-text-alt text-error" x-text="editUnitErrors.beds"></span>
                    </div>
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Bathrooms</span>
                        <div class="flex items-center gap-2">
                            <span
                              x-show="getEditInheritanceBadge('baths')"
                              class="badge badge-sm"
                              :class="{ 'badge-info': isEditFieldInherited('baths'), 'badge-warning': !isEditFieldInherited('baths') && getEditInheritanceBadge('baths') }"
                                x-text="getEditInheritanceBadge('baths')"
                            >
                            </span>
                            <button
                              x-show="!isEditFieldInherited(&#39;baths&#39;) && editFormSelectedUnitType && getEditInheritanceBadge(&#39;baths&#39;)"
                              type="button"
                              class="btn btn-ghost btn-xs"
                              @click="clearEditOverride('baths')"
                              title="Use floorplan value"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                                </svg>
                                Use floorplan
                            </button>
                        </div>
                    </label>
                    <input
                      type="number"
                      name="baths"
                      x-model="editUnit.baths"
                      :placeholder="getEditFieldPlaceholder('baths', '1')"
                        class="input input-bordered"
                        :class="{'input-error': editUnitErrors.baths}"
                          min="0.5"
                          max="10"
                          step="0.5"
                          required
                          data-testid="baths-input"
                    />
                    <div class="label">
                        <span class="label-text-alt">Number of bathrooms</span>
                        <span x-show="editUnitErrors.baths" class="label-text-alt text-error" x-text="editUnitErrors.baths"></span>
                    </div>
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Square Feet</span>
                        <div class="flex items-center gap-2">
                            <span
                              x-show="getEditInheritanceBadge('sqft')"
                              class="badge badge-sm"
                              :class="{ 'badge-info': isEditFieldInherited('sqft'), 'badge-warning': !isEditFieldInherited('sqft') && getEditInheritanceBadge('sqft') }"
                                x-text="getEditInheritanceBadge('sqft')"
                            >
                            </span>
                            <button
                              x-show="!isEditFieldInherited(&#39;sqft&#39;) && editFormSelectedUnitType && getEditInheritanceBadge(&#39;sqft&#39;)"
                              type="button"
                              class="btn btn-ghost btn-xs"
                              @click="clearEditOverride('sqft')"
                              title="Use floorplan value"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                                </svg>
                                Use floorplan
                            </button>
                        </div>
                    </label>
                    <input
                      type="number"
                      name="sqft"
                      x-model="editUnit.sqft"
                      :placeholder="getEditFieldPlaceholder('sqft', '750')"
                        class="input input-bordered"
                        :class="{'input-error': editUnitErrors.sqft}"
                          min="100"
                          max="10000"
                          data-testid="sqft-input"
                    />
                    <div class="label">
                        <span class="label-text-alt">Optional - unit size</span>
                        <span x-show="editUnitErrors.sqft" class="label-text-alt text-error" x-text="editUnitErrors.sqft"></span>
                    </div>
                </div>
            </div>

            <!-- Rent and Status -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Monthly Rent</span>
                        <div class="flex items-center gap-2">
                            <span
                              x-show="getEditInheritanceBadge('rent')"
                              class="badge badge-sm"
                              :class="{ 'badge-info': isEditFieldInherited('rent'), 'badge-warning': !isEditFieldInherited('rent') && getEditInheritanceBadge('rent') }"
                                x-text="getEditInheritanceBadge('rent')"
                            >
                            </span>
                            <button
                              x-show="!isEditFieldInherited(&#39;rent&#39;) && editFormSelectedUnitType && getEditInheritanceBadge(&#39;rent&#39;)"
                              type="button"
                              class="btn btn-ghost btn-xs"
                              @click="clearEditOverride('rent')"
                              title="Use floorplan value"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                                </svg>
                                Use floorplan
                            </button>
                        </div>
                    </label>
                    <input
                      type="number"
                      name="rent"
                      x-model="editUnit.rent"
                      :placeholder="getEditFieldPlaceholder('rent', '2500')"
                        class="input input-bordered"
                        :class="{'input-error': editUnitErrors.rent}"
                          min="0"
                          max="25000"
                          required
                          data-testid="rent-input"
                    />
                    <div class="label">
                        <span class="label-text-alt">Monthly rental amount in USD</span>
                        <span x-show="editUnitErrors.rent" class="label-text-alt text-error" x-text="editUnitErrors.rent"></span>
                    </div>
                </div>

                <BaseSelect
                  name="vacancyClass"
                  label="Status"
                  xModel="editUnit.vacancyClass"
                  options={statusOptions}
                  required={true}
                />
            </div>

            <!-- Unit Description -->
            <div>
                <label class="label">
                    <span class="label-text">Unit Description (Optional)</span>
                </label>
                <textarea
                  name="description"
                  x-model="editUnit.description"
                  class="textarea textarea-bordered w-full"
                  rows="3"
                  placeholder="Unit-specific details, features, or notes..."
                  data-testid="unit-description-input"
                >
                </textarea>
            </div>

            <!-- Bulk Override Actions -->
            <div x-show="editFormSelectedUnitType && hasEditOverriddenFields()" class="border-t pt-4">
                <div class="flex items-center justify-between">
                    <div class="text-sm text-base-content/70">
                        Some fields have custom values that override the floorplan.
                    </div>
                    <button
                      type="button"
                      class="btn btn-outline btn-sm"
                      @click="resetEditAllToFloorplan()"
                      :disabled="editUnitLoading"
                        data-testid="reset-all-to-floorplan"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                        Reset all to floorplan
                    </button>
                </div>
            </div>

            <!-- Dialog Actions -->
            <div class="modal-action justify-between">
                <button
                  type="button"
                  class="btn btn-error"
                  @click="confirmEditDeleteUnit()"
                  :disabled="editUnitLoading"
                    data-testid="delete-unit"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1-1H8a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    Delete Unit
                </button>

                <div class="flex gap-2">
                    <button
                      type="button"
                      class="btn"
                      @click="$dispatch('close-edit-unit-dialog')"
                      :disabled="editUnitLoading"
                        data-testid="cancel-edit-unit"
                    >
                        Cancel
                    </button>
                    <button
                      type="submit"
                      class="btn btn-primary"
                      :disabled="editUnitLoading"
                        data-testid="confirm-edit-unit"
                    >
                        <span x-show="editUnitLoading" class="loading loading-spinner loading-sm"></span>
                        <span x-show="!editUnitLoading">Save Changes</span>
                    </button>
                </div>
            </div>
        </form>
    </div>
</dialog>
