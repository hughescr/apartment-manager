---
import { BaseInput } from '../../forms';
import OfficeHoursEditor from '../editors/OfficeHoursEditor.astro';

import type { BuildingData } from '../../../types';

export interface Props {
    building: BuildingData
    errors?: Record<string, string>
}

const { building: _building, errors: _errors = {} } = Astro.props;
---

<!-- Management Contact Information -->
<div class="card bg-base-200 shadow-lg mt-6">
    <div class="card-body">
        <h3 class="card-title text-xl font-bold mb-6">Management Contact</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <BaseInput
              name="contactName"
              label="Contact Name"
              xModel="building.contactInfo.name"
              placeholder="John Doe"
            />
            <BaseInput
              name="contactPhone"
              label="Phone Number"
              type="tel"
              xModel="building.contactInfo.phone"
              placeholder="(555) 123-4567"
            />
            <span x-show="errors.contactPhone" class="label-text-alt text-error" x-text="errors.contactPhone"></span>
            <BaseInput
              name="contactEmail"
              label="Email Address"
              type="email"
              xModel="building.contactInfo.email"
              placeholder="contact@property.com"
            />
            <span x-show="errors.contactEmail" class="label-text-alt text-error" x-text="errors.contactEmail"></span>
        </div>

        <!-- Website Fields Section -->
        <div class="mt-6">
            <h4 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <span>Website Information</span>
                <div class="dropdown dropdown-hover dropdown-right">
                    <label tabindex="0" class="cursor-help">
                        <svg class="w-4 h-4 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </label>
                    <div tabindex="0" class="dropdown-content z-[1] card card-compact w-80 p-4 shadow-lg bg-base-100 border border-base-300">
                        <div class="space-y-2 text-sm">
                            <div>
                                <p class="font-semibold text-base-content">Property Website</p>
                                <p class="text-base-content/80">Specific to this building/property. Shows on rental listings for prospective tenants.</p>
                            </div>
                            <div>
                                <p class="font-semibold text-base-content">Management Website</p>
                                <p class="text-base-content/80">Your company's main website for corporate information and branding.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </h4>

            <div class="grid grid-cols-1 gap-4">
                <BaseInput
                  name="contactPropertyWebsite"
                  label="Property Website"
                  type="url"
                  xModel="building.contactInfo.propertyWebsite"
                  placeholder="https://property-specific-site.com"
                  helpText="Main website for this specific property/building - used in listings"
                />
                <span x-show="errors.contactPropertyWebsite" class="label-text-alt text-error" x-text="errors.contactPropertyWebsite"></span>

                <BaseInput
                  name="contactManagementWebsite"
                  label="Management Company Website (Optional)"
                  type="url"
                  xModel="building.contactInfo.managementWebsite"
                  placeholder="https://your-management-company.com"
                  helpText="Your property management company's main website - for corporate information"
                />
                <span x-show="errors.contactManagementWebsite" class="label-text-alt text-error" x-text="errors.contactManagementWebsite"></span>
            </div>
        </div>

        <!-- Office Hours -->
        <div class="mt-6">
            <OfficeHoursEditor
              xModel="building.contactInfo.officeHours"
              title="Office Hours"
            />
        </div>
    </div>
</div>
