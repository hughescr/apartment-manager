---
import {
    PetPolicyEditor,
    ScreeningCriteriaForm
} from '../../forms';
import { BuildingData } from '../../../types';

export interface Props {
    building: BuildingData
}

const { building: _building } = Astro.props;
// Variable intentionally unused - accessed via Alpine.js global context in template
void _building;
---

<!-- Policies Section -->
<div class="card bg-base-200">
    <div class="card-body p-4 sm:p-6">
        <h3 class="card-title text-xl font-bold mb-6">Policies</h3>

        <!-- Pet Policies -->
        <div class="mb-6">
            <h4 class="text-lg font-semibold mb-4">Pet Policies</h4>
            <PetPolicyEditor
              name="petPolicies"
              xModel="building.petPolicies"
            />
        </div>

        <!-- Screening Criteria -->
        <div class="border-t border-base-200 pt-4 mt-4">
            <h4 class="text-lg font-semibold mb-4">Screening Criteria</h4>
            <ScreeningCriteriaForm
              name="screeningCriteria"
              xModel="building.screeningCriteria"
            />
        </div>
    </div>
</div>
