---
import _ from 'lodash';
import {
    FeeListEditor
} from '../../forms';
import {
    UtilityType,
    FeeType,
    BuildingData
} from '../../../types';

export interface Props {
    building: BuildingData
}

const { building: _building } = Astro.props;

// Utility type options
const utilityTypes = _.values(UtilityType);
---

<!-- Application & Fees Section -->
<div class="card bg-base-100">
    <div class="card-body">
        <h3 class="card-title text-lg mb-4">Application & Fees</h3>

        <!-- Utilities Included -->
        <div class="mb-6">
            <h4 class="font-semibold mb-4">Utilities Included</h4>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                {_.map(utilityTypes, utility => (
                    <div class="form-control">
                        <label class="label cursor-pointer">
                            <span class="label-text capitalize">{_.replace(utility as string, '-', ' ')}</span>
                            <input
                              type="checkbox"
                              class="checkbox checkbox-primary"
                              x-model={`building.utilitiesIncluded['${utility}']`}
                            />
                        </label>
                    </div>
                ))}
            </div>
        </div>

        <!-- One-Time Fees -->
        <div class="border-t border-base-200 pt-4 mt-4 mb-6">
            <h4 class="font-semibold mb-4">One-Time Fees</h4>
            <FeeListEditor
              name="oneTimeFees"
              xModel="building.oneTimeFees"
              feeTypes={[FeeType.SECURITY_DEPOSIT, FeeType.PET_DEPOSIT, FeeType.MOVE_IN, FeeType.KEY_DEPOSIT, FeeType.CLEANING]}
            />
        </div>

        <!-- Monthly Fees -->
        <div class="border-t border-base-200 pt-4 mt-4">
            <h4 class="font-semibold mb-4">Monthly Fees</h4>
            <FeeListEditor
              name="monthlyFees"
              xModel="building.monthlyFees"
              feeTypes={[FeeType.PET_FEE, FeeType.PARKING, FeeType.STORAGE, FeeType.ADMIN]}
            />
        </div>
    </div>
</div>
