---
// astro-src/components/building/tabs/FloorplansUnitsTab.astro
// Uses shared state from BuildingProvider

import SimpleUnitsSection from '../units/SimpleUnitsSection.astro';
import BulkCreateUnitsDialog from '../dialogs/BulkCreateUnitsDialog.astro';
import AssignUnitTypeDialog from '../dialogs/AssignUnitTypeDialog.astro';

// No props needed - uses shared state from parent BuildingProvider
export interface Props { slot?: string }
---

<!-- Floorplans & Units Tab (integrates unit types with units list) -->
<div x-show="activeSectionTab === 'floorplans-units'" class="space-y-6">
    <!-- Floorplans Section -->
    <div class="card bg-base-100 shadow-lg">
        <div class="card-body p-4 sm:p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="card-title text-xl">Floorplans (Unit Types)</h3>
                <div class="flex items-center gap-2">
                    <div class="badge badge-primary badge-lg" x-text="(unitTypes?.length || 0) + ' types'"></div>
                    <button @click="openAddUnitTypeDialog()" class="btn btn-primary btn-sm" x-show="(unitTypes?.length || 0) > 0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        Add Floorplan
                    </button>
                </div>
            </div>
            <div class="text-base-content/70 mb-4">
                Define unit types that serve as templates for individual units. Units can inherit settings from their floorplan and override them as needed.
            </div>

            <!-- Unit Types List -->
            <div class="grid grid-cols-1 gap-4" data-testid="unit-types-list">
                <template x-for="unitType in unitTypes" :key="unitType.modelID">
                    <div class="card bg-base-100 border border-base-300">
                        <div class="card-body p-4">
                            <div class="flex justify-between items-start mb-3">
                                <div>
                                    <h4 class="card-title text-lg" x-text="unitType.modelName"></h4>
                                    <div class="text-sm text-base-content/70">
                                        <span x-text="unitType.beds + ' bed, ' + unitType.baths + ' bath'"></span>
                                        <span x-show="unitType.sqft" x-text="' • ' + unitType.sqft + ' sq ft'"></span>
                                    </div>
                                </div>
                                <div class="dropdown dropdown-end">
                                    <label tabindex="0" class="btn btn-ghost btn-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                                        </svg>
                                    </label>
                                    <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-52">
                                        <li>
<a @click="$dispatch('edit-unit-type', unitType)">Edit</a>
                                        </li>
                                        <li>
<a @click="$dispatch('delete-unit-type', unitType)" class="text-error">Delete</a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <div x-show="unitType.rent" class="mb-2">
                                <span class="text-sm text-base-content/70">Base Rent: </span>
                                <span class="font-semibold" x-text="formatCurrency(unitType.rent)"></span>
                            </div>
                            <div x-show="unitType.description" class="text-sm text-base-content/80 mb-2" x-text="unitType.description"></div>

                            <!-- Units using this type -->
                            <div class="mt-3 pt-3 border-t border-base-200">
                                <div class="flex justify-between items-center mb-2">
                                    <div class="text-xs text-base-content/60">Units using this floorplan:</div>
                                    <button
                                      @click="openBulkCreateDialog(unitType.modelID)"
                                      class="btn btn-xs btn-primary"
                                      data-testid="create-multiple-units-btn"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                        </svg>
                                        Create Multiple Units
                                    </button>
                                </div>
                                <div class="flex flex-wrap gap-1" x-data="{ unitsOfType: units.filter(u => u.modelID === unitType.modelID) }">
                                    <template x-for="unit in unitsOfType.slice(0, 5)" :key="unit.unitID">
                                        <span class="badge badge-sm badge-outline" x-text="unit.unitNumber || unit.unitID"></span>
                                    </template>
                                    <span x-show="unitsOfType.length > 5" class="badge badge-sm badge-ghost" x-text="'+' + (unitsOfType.length - 5) + ' more'"></span>
                                    <span x-show="unitsOfType.length === 0" class="text-xs text-base-content/50">No units assigned</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </template>

                <!-- Empty State -->
                <div x-show="unitTypes.length === 0" class="text-center py-8 text-base-content/60">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                    <p class="text-lg mb-2 font-semibold">No floorplans defined yet</p>
                    <p class="mb-4">Create unit types to serve as templates for your units. This helps maintain consistency and makes unit management easier.</p>
                    <button @click="openAddUnitTypeDialog()" class="btn btn-primary btn-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        Add Your First Floorplan
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Visual Divider -->
    <div class="divider divider-primary">
        <span class="text-lg font-medium">Individual Units</span>
    </div>

    <!-- Units Section with Listing Management -->
    <div class="card bg-base-100 shadow-lg">
        <div class="card-body p-4 sm:p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="card-title text-xl">Units & Listing Management</h3>
                <div class="badge badge-primary badge-lg" x-text="(units?.length || 0) + ' units'"></div>
            </div>
            <div class="text-base-content/70 mb-4">
                Manage individual units, set availability status, and update rental pricing all in one place.
            </div>

            <SimpleUnitsSection />
        </div>
    </div>

    <!-- Bulk Create Units Dialog -->
    <BulkCreateUnitsDialog />

    <!-- Assign Unit Type Dialog -->
    <AssignUnitTypeDialog />
</div>
