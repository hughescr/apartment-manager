---
import BasicInformationSection from "../info/BasicInformationSection.astro";
import ManagementContactSection from "../info/ManagementContactSection.astro";
import BuildingAmenitiesSection from "../info/BuildingAmenitiesSection.astro";

export interface Props {
    building: any; // Building object from the data layer
    apiUrl: string;
    errors?: Record<string, string>;
    onBuildingUpdate?: string; // Alpine.js expression to emit building updates
}

const { 
    building,
    apiUrl, 
    errors,
    onBuildingUpdate: _onBuildingUpdate = "console.log('Building updated:', building)" 
} = Astro.props;
---

<div class="building-info-tab space-y-6">
    <BasicInformationSection apiUrl={apiUrl} errors={errors} />
    
    <ManagementContactSection building={building} errors={errors} />
    
    <BuildingAmenitiesSection building={building} />
</div>