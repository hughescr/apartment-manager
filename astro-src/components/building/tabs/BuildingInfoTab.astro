---
import BasicInformationSection from '../info/BasicInformationSection.astro';
import ManagementContactSection from '../info/ManagementContactSection.astro';
import BuildingAmenitiesSection from '../info/BuildingAmenitiesSection.astro';
import type { BuildingData } from '../../../types';

export interface Props {
    building: BuildingData // Building object from the data layer
    apiUrl: string
    errors?: Record<string, string>
    onBuildingUpdate?: string // Alpine.js expression to emit building updates
}

const {
    building,
    apiUrl,
    errors,
    onBuildingUpdate: _onBuildingUpdate = "console.log('Building updated:', building)"
} = Astro.props;
---

<div class="building-info-tab space-y-6">
    <BasicInformationSection apiUrl={apiUrl} errors={errors} />

    <ManagementContactSection building={building} errors={errors} />

    <BuildingAmenitiesSection building={building} />

    <!-- Danger Zone -->
    <div class="card bg-base-100 shadow-lg border-2 border-error/20">
        <div class="card-body p-4 sm:p-6">
            <h3 class="card-title text-lg mb-4 text-error">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0l-5.898 8.5c-.77.833.192 2.5 1.732 2.5z"></path>
                </svg>
                Danger Zone
            </h3>
            <div class="alert alert-warning mb-4">
                <svg class="w-6 h-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0l-5.898 8.5c-.77.833.192 2.5 1.732 2.5z"></path>
                </svg>
                <div>
                    <div class="font-bold">This action cannot be undone</div>
                    <div class="text-sm">Deleting this building will permanently remove all associated units, floorplans, and data.</div>
                </div>
            </div>
            <button
              class="btn btn-error btn-outline"
              @click="deleteBuilding()"
              :disabled="saving"
                data-testid="delete-building-btn"
            >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                Delete Building
            </button>
        </div>
    </div>
</div>
