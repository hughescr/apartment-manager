---
import type { BuildingData, UnitData, UnitTypeData } from '../../types';

export interface Props {
    building: BuildingData
    units: UnitData[]
    unitTypes: UnitTypeData[]
    apiURL: string
}

const { building, units, unitTypes, apiURL: _apiURL } = Astro.props;
if(!_apiURL) {
    throw new Error('API URL not configured');
} // Validate and mark as used for TypeScript

// Initialize any missing nested objects with proper defaults to prevent null reference errors
if(!building.oneTimeFees) {
    building.oneTimeFees = [];
}
if(!building.monthlyFees) {
    building.monthlyFees = [];
}
if(!building.parkingOptions) {
    building.parkingOptions = [];
}
if(!building.storageOptions) {
    building.storageOptions = [];
}
if(!building.propertyAmenities) {
    building.propertyAmenities = [];
}
if(!building.rentSpecials) {
    building.rentSpecials = [];
}
if(!building.photos) {
    building.photos = [];
}

// Utilities included - initialize with all utility types set to false
if(!building.utilitiesIncluded) {
    building.utilitiesIncluded = {};
}

// Pet policies - ensure it has the required structure
if(!building.petPolicies) {
    building.petPolicies = { allowed: false, petTypes: [] };
} else {
    if(!building.petPolicies.petTypes) {
        building.petPolicies.petTypes = [];
    }
}

// Screening criteria - initialize with sensible defaults
if(!building.screeningCriteria) {
    building.screeningCriteria = {
        incomeRatio: 3,
        minCreditScore: 600,
        maxOccupantsPerBedroom: 2,
        backgroundCheckRequired: true,
        evictionHistory: true,
        criminalHistory: true,
        references: 2,
        employmentVerification: true,
        rentalHistory: true
    };
}

// Contact info - ensure nested objects exist
if(!building.contactInfo) {
    building.contactInfo = {};
}
if(!building.contactInfo.officeHours) {
    building.contactInfo.officeHours = {};
}

// Tour availability - ensure nested objects exist
if(!building.tourAvailability) {
    building.tourAvailability = {};
}
if(!building.tourAvailability.tourHours) {
    building.tourAvailability.tourHours = {};
}

// Income restrictions - initialize with sensible defaults
if(!building.incomeRestrictions) {
    building.incomeRestrictions = {
        amiLimit: undefined,
        maxIncomeByHouseholdSize: {}
    };
}

// Ensure units and unitTypes are arrays
const safeUnits = units || [];
const safeUnitTypes = unitTypes || [];
---

<script>
// Import the state management function directly
import { createBuildingState } from '../../lib/building/state';

// Declare global type for Alpine.js
declare global {
    interface Window {
        createBuildingState: typeof createBuildingState
    }
}

// Make the state creation function available globally for Alpine.js
if(typeof window !== 'undefined') {
    window.createBuildingState = createBuildingState;
}
</script>

<div
  class="building-provider"
  x-data="createBuildingState()"
  class="{'opacity-50': saving}"
  data-building-data={JSON.stringify(building)}
  data-initial-units={JSON.stringify(safeUnits)}
  data-initial-unit-types={JSON.stringify(safeUnitTypes)}
  data-api-url={_apiURL}
>
    <!-- Provider passes state down to child components through Alpine.js context -->
    <slot />
</div>
