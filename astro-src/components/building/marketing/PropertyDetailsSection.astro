---
export interface Props {
    building: any;
    errors?: Record<string, string>;
}

const { building: _building, errors: _errors = {} } = Astro.props;
---

<!-- Property Details Section -->
<div class="card bg-base-100 shadow-lg">
    <div class="card-body">
        <div class="flex justify-between items-center mb-4">
            <h3 class="card-title text-xl">Property Details & Marketing</h3>
            <div class="badge badge-info badge-outline">How your property is presented</div>
        </div>
        <div class="text-base-content/70 mb-6">
            Marketing descriptions and highlights that will be shown to prospective tenants on listing sites.
        </div>
        
        <!-- Marketing Description and Property Highlights within same x-data scope -->
        <div x-data="{ 
            get charCount() { 
                return (building.propertyDescription || '').length; 
            },
            get isOverLimit() {
                return this.charCount > 2000;
            },
            get charCountColor() {
                if (this.charCount > 2000) return 'text-error';
                if (this.charCount > 1800) return 'text-warning';
                return 'text-base-content/70';
            },
            addHighlight() { 
                if (!building.propertyHighlights) building.propertyHighlights = []; 
                building.propertyHighlights.push({ id: Date.now() + Math.random(), highlight: '' }); 
            }, 
            removeHighlight(index) { 
                building.propertyHighlights.splice(index, 1); 
            } 
        }">
            <!-- Marketing Description -->
            <div class="mb-6">
                <!-- Label with Public Indicator -->
                <label class="label">
                    <span class="label-text flex items-center gap-2">
                        Marketing Description
                        <span class="text-error">*</span>
                        <div class="badge badge-info badge-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Public
                        </div>
                    </span>
                    <span class="label-text-alt" :class="charCountColor" x-text="`${charCount}/2000`"></span>
                </label>
                
                <!-- Textarea -->
                <textarea
                    name="propertyDescription"
                    placeholder="Discover luxury living at its finest! This stunning property offers spacious floor plans with premium finishes, state-of-the-art amenities, and an unbeatable location just minutes from downtown. Residents enjoy resort-style living with a sparkling pool, fitness center, and concierge services. Each home features gourmet kitchens, walk-in closets, and private balconies with breathtaking city views."
                    class="textarea textarea-bordered w-full resize-vertical"
                    :class="{ 'textarea-error': isOverLimit }"
                    x-model="building.propertyDescription"
                    rows="6"
                    maxlength="2000"
                    required
                ></textarea>
                
                <!-- Enhanced Help Text -->
                <label class="label">
                    <span class="label-text-alt text-base-content/70">
                        <div class="space-y-1">
                            <div class="font-medium">📋 Public marketing content for rental listings</div>
                            <div class="text-xs space-y-0.5">
                                <div>• <strong>Appears on:</strong> Apartments.com, Zillow, Rent.com, and other listing sites</div>
                                <div>• <strong>MITS feeds:</strong> Exported as LongDescription field</div>
                                <div>• <strong>Format:</strong> Plain text only (no HTML/Markdown)</div>
                                <div>• <strong>Content tips:</strong> Highlight amenities, lifestyle benefits, neighborhood features</div>
                            </div>
                        </div>
                    </span>
                    <span class="label-text-alt" :class="isOverLimit ? 'text-error' : 'text-base-content/50'" x-show="isOverLimit">
                        Exceeds 2000 character limit
                    </span>
                </label>
            </div>
            
            <!-- Property Highlights -->
            <div class="mb-6">
                <h4 class="font-semibold mb-4">Property Highlights</h4>
                <template x-for="(item, index) in building.propertyHighlights || []" :key="item.id || ('highlight-' + index)">
                    <div class="flex gap-2 items-center mb-2">
                        <input
                            type="text"
                            x-model="item.highlight"
                            placeholder="Prime downtown location"
                            class="input input-bordered flex-1"
                        />
                        <button 
                            @click="removeHighlight(index)"
                            class="btn btn-ghost btn-sm text-error"
                            title="Remove highlight"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </template>
                <button 
                    @click="addHighlight()"
                    class="btn btn-primary btn-sm mt-2"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    Add Highlight
                </button>
            </div>
            
            <!-- Hidden input for propertyHighlights serialization -->
            <input type="hidden" name="propertyHighlights" :value="JSON.stringify(building.propertyHighlights || [])" />
        </div>
    </div>
</div>