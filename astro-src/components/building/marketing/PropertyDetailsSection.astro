---
import type { BuildingData } from '../../../types';
import { BaseTextarea } from '../../forms';

export interface Props {
    building: BuildingData
    errors?:  Record<string, string>
}

const { building: _building, errors: _errors = {} } = Astro.props;
---

<!-- Property Details Section -->
<div class="card bg-base-200 shadow-lg">
    <div class="card-body p-4 sm:p-6">
        <div class="flex justify-between items-center mb-4">
            <h3 class="card-title text-xl">Property Details & Marketing</h3>
            <div class="badge badge-info badge-outline">How your property is presented</div>
        </div>
        <div class="text-base-content/70 mb-6">
            Marketing descriptions and highlights that will be shown to prospective tenants on listing sites.
        </div>

        <!-- Property Highlights x-data scope -->
        <div x-data="{
            addHighlight() {
                if (!building.propertyHighlights) building.propertyHighlights = [];
                building.propertyHighlights.push({ id: Date.now() + Math.random(), highlight: '' });
            },
            removeHighlight(index) {
                building.propertyHighlights.splice(index, 1);
            }
        }"
        >
            <!-- Marketing Description -->
            <div class="mb-6">
                <BaseTextarea
                  name="propertyDescription"
                  label="Marketing Description"
                  placeholder="Discover luxury living at its finest! This stunning property offers spacious floor plans with premium finishes, state-of-the-art amenities, and an unbeatable location just minutes from downtown. Residents enjoy resort-style living with a sparkling pool, fitness center, and concierge services. Each home features gourmet kitchens, walk-in closets, and private balconies with breathtaking city views."
                  xModel="building.propertyDescription"
                  rows={24}
                  maxlength={2000}
                  required={true}
                  showCharacterCount={true}
                  characterCountInside={true}
                  resize="vertical"
                />

                <!-- Custom Help Text -->
                <div class="mt-2 text-sm text-base-content/70 space-y-2">
                    <div>
                        <strong class="text-base-content/80">Where it appears:</strong>
{' '}
Apartments.com, Zillow, Rent.com, and other rental listing sites as the main property description
                    </div>
                    <div>
                        <strong class="text-base-content/80">MITS Integration:</strong>
{' '}
Exported as the 'LongDescription' field in MITS data feeds that syndicate your listings across multiple platforms
                    </div>
                    <div>
                        <strong class="text-base-content/80">Content Guidelines:</strong>
{' '}
Focus on lifestyle benefits, unique amenities, and neighborhood highlights that attract prospective tenants. Use plain text only (no HTML/Markdown formatting)
                    </div>
                    <div>
                        <strong class="text-base-content/80">Best Practices:</strong>
{' '}
Start with your strongest selling points, mention nearby attractions, transportation, and what makes living here special
                    </div>
                </div>
            </div>

            <!-- Property Highlights -->
            <div class="mb-6">
                <div class="flex items-center gap-3 mb-4">
                    <h4 class="font-semibold">Property Highlights</h4>
                    <div class="badge badge-info badge-outline badge-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Public
                    </div>
                </div>
                <div class="text-sm text-base-content/70 mb-4">
                    Key selling points displayed as bullet points on listing sites. Most platforms show 5-10 highlights prominently.
                </div>
                <template x-for="(item, index) in building.propertyHighlights || []" :key="item.id || ('highlight-' + index)">
                    <div class="flex gap-2 items-center mb-2">
                        <input
                          type="text"
                          x-model="item.highlight"
                          placeholder="Prime downtown location"
                          class="input input-bordered flex-1"
                        />
                        <button
                          @click="removeHighlight(index)"
                          class="btn btn-ghost btn-sm text-error"
                          title="Remove highlight"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </template>
                <button
                  @click="addHighlight()"
                  class="btn btn-primary btn-sm mt-2"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    Add Highlight
                </button>
            </div>

            <!-- Hidden input for propertyHighlights serialization -->
            <input type="hidden" name="propertyHighlights" :value="JSON.stringify(building.propertyHighlights || [])" />
        </div>
    </div>
</div>
