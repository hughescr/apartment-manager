---
// BuildingManager.astro - Handles individual building management with lazy loading
import BuildingProvider from './building/BuildingProvider.astro';
import TabNavigator from './building/TabNavigator.astro';
import TabPanels from './building/TabPanels.astro';
import SaveIndicator from './building/SaveIndicator.astro';

// Tab components
import BuildingInfoTab from './building/tabs/BuildingInfoTab.astro';
import FloorplansUnitsTab from './building/tabs/FloorplansUnitsTab.astro';
import PricingPoliciesTab from './building/tabs/PricingPoliciesTab.astro';
import MarketingTab from './building/tabs/MarketingTab.astro';

// Dialog components
import AddUnitDialog from './building/dialogs/AddUnitDialog.astro';
import AddUnitTypeDialog from './building/dialogs/AddUnitTypeDialog.astro';

// Types
import type { BuildingData, UnitData, UnitTypeData } from '../types';

export interface Props {
    building: BuildingData
    apiURL: string
    'class'?: string
    style?: string
}

const { building, apiURL } = Astro.props;

// Note: For lazy loading, we'll initially pass empty arrays and load data client-side
const emptyUnits: UnitData[] = [];
const emptyUnitTypes: UnitTypeData[] = [];
---

<div
  class="building-manager"
  x-data="buildingManagerData()"
  x-init="init()"
  {...Astro.props}
>

    <!-- Loading state -->
    <div x-show="loading" class="flex justify-center items-center py-8">
        <div class="loading loading-spinner loading-lg"></div>
        <span class="ml-2">Loading building data...</span>
    </div>

    <!-- Building management interface -->
    <div x-show="!loading && dataLoaded" x-transition.opacity.duration.300ms>
        <BuildingProvider
          building={building}
          units={emptyUnits}
          unitTypes={emptyUnitTypes}
          apiURL={apiURL}
          x-bind:data-building-data="JSON.stringify(building)"
          x-bind:data-initial-units="JSON.stringify(units)"
          x-bind:data-initial-unit-types="JSON.stringify(unitTypes)"
        >
            <!-- Save indicator at the top -->
            <div class="mb-4">
                <SaveIndicator />
            </div>

            <!-- Tab navigation -->
            <TabNavigator />

            <!-- Tab content panels -->
            <TabPanels>
                <BuildingInfoTab
                  slot="building-info"
                  building={building}
                  apiUrl={apiURL}
                />
                <FloorplansUnitsTab />
                <PricingPoliciesTab
                  slot="pricing-policies"
                  building={building}
                  errors={{}}
                />
                <MarketingTab
                  slot="marketing"
                  building={building}
                  apiUrl={apiURL}
                />
            </TabPanels>

            <!-- Dialogs -->
            <AddUnitDialog
              building={{
                    buildingID: building.buildingID,
                    street: building.street || '',
                    city: building.city || '',
                    state: building.state || ''
                }}
              unitTypes={emptyUnitTypes}
              apiUrl={apiURL}
            />
            <AddUnitTypeDialog
              building={{
                    buildingID: building.buildingID,
                    street: building.street || '',
                    city: building.city || '',
                    state: building.state || ''
                }}
              apiUrl={apiURL}
            />
        </BuildingProvider>
    </div>

    <!-- Error state -->
    <div x-show="error" class="alert alert-error">
        <svg class="w-6 h-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span x-text="`Failed to load building data: ${errorMessage}`"></span>
        <button class="btn btn-sm" @click="retryLoad()">Retry</button>
    </div>
</div>

<script>
import type { AlpineComponent } from '../types/alpine';
import type { BuildingData, UnitData, UnitTypeData } from '../types';
import { createClientLogger } from '../lib/utils/client-logger';

// Simple noop function replacement for lodash.noop
// eslint-disable-next-line lodash/prefer-noop, @typescript-eslint/no-empty-function -- Replacing lodash.noop for browser compatibility
const noop = () => {};

const logger = createClientLogger('BuildingManager');

type BuildingManagerData = AlpineComponent<{
    loading: boolean
    dataLoaded: boolean
    error: boolean
    errorMessage: string
    buildingID: string
    apiURL: string
    building: BuildingData | null
    units: UnitData[]
    unitTypes: UnitTypeData[]
    init(): void
    loadBuildingData(): Promise<void>
    retryLoad(): void
}>;

function buildingManagerData(): BuildingManagerData {
    return {
        loading: false,
        dataLoaded: false,
        error: false,
        errorMessage: '',
        buildingID: '',
        apiURL: '',
        building: null,
        units: [],
        unitTypes: [],

        init() {
            this.buildingID = this.$root.dataset.buildingId || '';
            this.apiURL = this.$root.dataset.apiUrl || '';

            // Listen for Alpine events to trigger loading
            this.$root.addEventListener('trigger-load', () => {
                if(!this.dataLoaded && !this.loading) {
                    this.loadBuildingData();
                }
            });

            // Check if we should load immediately (for initially visible tab)
            // Use a small delay to ensure Alpine is fully initialized
            setTimeout(() => {
                const isVisible = this.$root.style.display !== 'none';
                if(isVisible && !this.dataLoaded && !this.loading) {
                    this.loadBuildingData();
                }
            }, 100);
        },

        async loadBuildingData() {
            if(this.dataLoaded || this.loading) {
                return;
            }

            this.loading = true;
            this.error = false;

            try {
                // Load full building data, units and unit types in parallel
                const [buildingResponse, unitsResponse, unitTypesResponse] = await Promise.all([
                    fetch(`${this.apiURL}buildings/${this.buildingID}`),
                    fetch(`${this.apiURL}buildings/${this.buildingID}/units`),
                    fetch(`${this.apiURL}buildings/${this.buildingID}/unit-types`)
                ]);

                if(!buildingResponse.ok || !unitsResponse.ok || !unitTypesResponse.ok) {
                    throw new Error('Failed to fetch building data');
                }

                const [building, units, unitTypes] = await Promise.all([
                    buildingResponse.json(),
                    unitsResponse.json(),
                    unitTypesResponse.json()
                ]);

                this.building = building;
                this.units = units;
                this.unitTypes = unitTypes;
                this.dataLoaded = true;
                this.loading = false;

                // Update the BuildingProvider component with new data
                this.$dispatch('building-data-loaded', {
                    buildingID: this.buildingID,
                    building: building,
                    units: units,
                    unitTypes: unitTypes
                });
            } catch(error) {
                this.loading = false;
                this.error = true;
                this.errorMessage = (error as Error).message;
                logger.error('Failed to load building data', error);
            }
        },

        retryLoad() {
            this.error = false;
            this.errorMessage = '';
            this.loadBuildingData();
        },

        // Add Alpine magic properties
        $dispatch: noop as AlpineComponent['$dispatch'],
        $root: null as unknown as HTMLElement,
        $el: null as unknown as HTMLElement,
        $watch: noop as AlpineComponent['$watch']
    } as BuildingManagerData;
}

// Make available globally for Alpine.js
declare global {
    interface Window {
        buildingManagerData: typeof buildingManagerData
    }
}

window.buildingManagerData = buildingManagerData;
</script>

<style>

.building-manager {
    min-height: 200px;
}

/* Smooth loading transitions */
[x-cloak] {
    display: none !important;
}

</style>
