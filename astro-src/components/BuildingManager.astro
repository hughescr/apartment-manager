---
// BuildingManager.astro - Handles individual building management with lazy loading
import BuildingProvider from './building/BuildingProvider.astro';
import TabNavigator from './building/TabNavigator.astro';
import TabPanels from './building/TabPanels.astro';
import FloatingControls from './building/FloatingControls.astro';

// Tab components
import BuildingInfoTab from './building/tabs/BuildingInfoTab.astro';
import FloorplansUnitsTab from './building/tabs/FloorplansUnitsTab.astro';
import PricingPoliciesTab from './building/tabs/PricingPoliciesTab.astro';
import MarketingTab from './building/tabs/MarketingTab.astro';

// Dialog components
import AddUnitDialog from './building/dialogs/AddUnitDialog.astro';
import AddUnitTypeDialog from './building/dialogs/AddUnitTypeDialog.astro';

// Types
import type { BuildingData, UnitData, UnitTypeData } from '../types';

export interface Props {
    building: BuildingData
    units: UnitData[]
    unitTypes: UnitTypeData[]
    apiURL: string
    'class'?: string
    style?: string
}

const { building, units, unitTypes, apiURL } = Astro.props;

// Data is now pre-loaded from parent component - no SSR API calls needed
const buildingData = building;
const initialDataLoaded = true;
---

<div
  class="building-manager"
  x-data="buildingManagerData()"
  x-init="init()"
  data-building-id={building.buildingID}
  data-api-url={apiURL}
  data-initial-building={JSON.stringify(buildingData)}
  data-initial-units={JSON.stringify(units)}
  data-initial-unit-types={JSON.stringify(unitTypes)}
  data-initial-loaded={true}
  {...Astro.props}
>

    {!initialDataLoaded && (
        <div x-show="loading" class="flex justify-center items-center py-8">
            <div class="loading loading-spinner loading-lg"></div>
            <span class="ml-2">Loading building data...</span>
        </div>
    )}

    <div x-show="!loading && dataLoaded" x-transition.opacity.duration.300ms x-cloak>
        <BuildingProvider
          building={buildingData}
          units={units}
          unitTypes={unitTypes}
          apiURL={apiURL}
          x-bind:data-building-data="JSON.stringify(building)"
          x-bind:data-initial-units="JSON.stringify(units)"
          x-bind:data-initial-unit-types="JSON.stringify(unitTypes)"
        >
            <!-- Floating Controls -->
            <FloatingControls />

            <!-- Tab navigation -->
            <TabNavigator />

            <!-- Tab content panels -->
            <TabPanels>
                <BuildingInfoTab
                  slot="building-info"
                  building={buildingData}
                  apiUrl={apiURL}
                />
                <FloorplansUnitsTab slot="floorplans-units" />
                <PricingPoliciesTab
                  slot="pricing-policies"
                  building={buildingData}
                  errors={{}}
                />
                <MarketingTab
                  slot="marketing"
                  building={buildingData}
                  apiUrl={apiURL}
                />
            </TabPanels>

            <!-- Dialogs -->
            <AddUnitDialog
              building={{
                    buildingID: buildingData.buildingID,
                    street: buildingData.street || '',
                    city: buildingData.city || '',
                    state: buildingData.state || ''
                }}
              unitTypes={unitTypes}
              apiUrl={apiURL}
            />
            <AddUnitTypeDialog
              building={{
                    buildingID: buildingData.buildingID,
                    street: buildingData.street || '',
                    city: buildingData.city || '',
                    state: buildingData.state || ''
                }}
              apiUrl={apiURL}
            />
        </BuildingProvider>
    </div>

    <!-- Error state -->
    <div x-show="error" class="alert alert-error">
        <svg class="w-6 h-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span x-text="`Failed to load building data: ${errorMessage}`"></span>
        <button class="btn btn-sm" @click="retryLoad()">Retry</button>
    </div>
</div>

<!-- BuildingManager component now uses centralized Alpine registry -->

<style>

.building-manager {
    min-height: 200px;
}

/* Smooth loading transitions */
[x-cloak] {
    display: none !important;
}

</style>
