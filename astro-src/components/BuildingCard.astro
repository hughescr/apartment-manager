---
import { getBuilding } from "../../data/buildings";
import { getUnits } from "../../data/units";
import UnitCard from "./UnitCard.astro";
import { Resource } from "sst";

const { buildingID } = Astro.props as { buildingID: string };

const building = await getBuilding(buildingID);
const units = await getUnits(buildingID);

const apiURL = Resource.API.url;
const xData = JSON.stringify({
    original: building,
    building,
    units,
    apiURL,
    showSave: false,
});
---

<div
    class="tab-content bg-base-100 border-base-300 building-card p-4"
    x-data={xData}
    x-effect="showSave = JSON.stringify(building) !== JSON.stringify(original)"
>
    <fieldset class="fieldset w-xl">
        <label class="floating-label mb-6">
            <input
                disabled
                type="text"
                x-model="building.buildingID"
                placeholder="Building Name (required)"
                class="input input-xl w-full"
                required
            />
        </label>
        <label class="floating-label mb-2">
            <span>Street</span>
            <input
                type="text"
                placeholder="Street"
                class="input w-full"
                x-model="building.street"
            />
        </label>
        <label class="floating-label mb-2">
            <span>City</span>
            <input
                type="text"
                placeholder="City"
                class="input w-full"
                x-model="building.city"
            />
        </label>
        <label class="floating-label mb-2">
            <span>State</span>
            <input
                type="text"
                placeholder="State"
                class="input w-full"
                x-model="building.state"
            />
        </label>
        <label class="floating-label mb-2">
            <span>Zip</span>
            <input
                type="text"
                placeholder="Zip"
                class="input w-full"
                x-model="building.zip"
            />
        </label>
        <label class="floating-label mt-4">
            <span>Description</span>
            <textarea
                placeholder="Description"
                class="textarea w-full"
                x-model="building.description"></textarea>
        </label>
    </fieldset>
    <div class="mt-2 space-x-2 w-xl">
        <button class="btn btn-primary"
            x-on:click="const id = prompt('New unit number?');
            if (!id) return;
            await fetch(`${apiURL}buildings/${building.buildingID}/units`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ unitID: id, buildingID: building.buildingID }),
            });
            window.location.reload();
            "
            >Add Unit</button>
        <button class="btn btn-error"
            x-on:click="if (!confirm('Are you sure you want to delete this building and all its units?')) return;
            await fetch(`${apiURL}buildings/${building.buildingID}`, { method: 'DELETE' });
            window.location.reload();
            "
            >Delete Building</button>
        <button class="btn btn-secondary float-right ml-2"
            x-show="showSave"
            x-on:click="await fetch(`${apiURL}buildings/${building.buildingID}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', },
                body: JSON.stringify(building),
            })
            original = { ...building };
            showSave = false;
            "
            >Save</button>
        <button class="btn btn-soft float-right ml-2"
            x-show="showSave"
            x-on:click="building={...original}">Undo</button>
    </div>
    <div class="mt-4">
        <table class="table table-zebra table-pin-rows w-full">
            <thead>
                <tr>
                    <th class="py-2 px-4 border-b">Unit ID</th>
                    <th class="py-2 px-4 border-b">Description</th>
                    <th class="py-2 px-4 border-b">Beds</th>
                    <th class="py-2 px-4 border-b">Baths</th>
                    <th class="py-2 px-4 border-b">Sqft</th>
                    <th class="py-2 px-4 border-b">Rent</th>
                    <th class="py-2 px-4 border-b">Occupied</th>
                    <th class="py-2 px-4 border-b">Available Date</th>
                    <th class="py-2 px-4 border-b">Actions</th>
                </tr>
            </thead>
            <tbody>
                {units?.map((u) => <UnitCard unit={u} />)}
            </tbody>
        </table>
    </div>
</div>
