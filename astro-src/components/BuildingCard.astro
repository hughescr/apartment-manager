---
import { getBuilding } from "../../data/buildings";
import { getUnits } from "../../data/units";
import { getUnitTypes } from "../../data/unitTypes";
import Saving from "./Saving.astro";
import UnitTypeForm from "./UnitTypeForm.astro";
import { Resource } from "sst";
import {
    BaseInput,
    BaseSelect,
    BaseTextarea,
    PhotoUploader,
    AmenitySelector,
    FeeListEditor,
    PetPolicyEditor,
    ScreeningCriteriaForm,
    LocationMapPicker
} from "./forms";
import { 
    PropertyType, 
    UtilityType, 
    FeeType, 
    DayOfWeek
} from "../../src/types";

const { buildingID } = Astro.props as { buildingID: string };

const building = await getBuilding(buildingID);
if (!building) {
    throw new Error(`Building ${buildingID} not found`);
}

// TypeScript now knows building is defined after the throw

// Fetch data with validation to ensure arrays
const units = (await getUnits(buildingID)) || [];
const unitTypes = (await getUnitTypes(buildingID)) || [];

// Log for debugging
console.log(`Building ${buildingID}: ${units.length} units, ${unitTypes.length} unit types`);

const apiURL = Resource.API.url;

// Initialize any missing nested objects with proper defaults
// This prevents null reference errors when Alpine.js accesses nested properties

// Array properties - ensure they exist as empty arrays
if (!building.oneTimeFees) building.oneTimeFees = [];
if (!building.monthlyFees) building.monthlyFees = [];
if (!building.parkingOptions) building.parkingOptions = [];
if (!building.storageOptions) building.storageOptions = [];
if (!building.propertyAmenities) building.propertyAmenities = [];
if (!building.rentSpecials) building.rentSpecials = [];
if (!building.photos) building.photos = [];
if (!building.propertyAmenities) building.propertyAmenities = [];

// Utilities included - initialize with all utility types set to false
if (!building.utilitiesIncluded) {
    building.utilitiesIncluded = {
        [UtilityType.WATER]: false,
        [UtilityType.SEWER]: false,
        [UtilityType.TRASH]: false,
        [UtilityType.GAS]: false,
        [UtilityType.ELECTRICITY]: false,
        [UtilityType.CABLE]: false,
        [UtilityType.INTERNET]: false,
        [UtilityType.HEAT]: false,
        [UtilityType.AIR_CONDITIONING]: false
    };
}

// Pet policies - ensure it has the required structure with enhanced fields
if (!building.petPolicies) {
    building.petPolicies = { allowed: false, petTypes: [] };
} else {
    // Ensure petTypes array exists for advanced settings
    if (!building.petPolicies.petTypes) {
        building.petPolicies.petTypes = [];
    }
}

// Screening criteria - initialize with sensible defaults
if (!building.screeningCriteria) {
    building.screeningCriteria = {
        incomeRatio: 3,
        minCreditScore: 600,
        maxOccupantsPerBedroom: 2,
        backgroundCheckRequired: true,
        evictionHistory: true,
        criminalHistory: true,
        references: 2,
        employmentVerification: true,
        rentalHistory: true
    };
}

// Contact info - ensure nested objects exist
if (!building.contactInfo) building.contactInfo = {};
if (!building.contactInfo.officeHours) building.contactInfo.officeHours = {};


// Tour availability - ensure nested objects exist
if (!building.tourAvailability) building.tourAvailability = {};
if (!building.tourAvailability.tourHours) building.tourAvailability.tourHours = {};
// Initialize tour availability booleans if they don't exist
if (building.tourAvailability.selfGuidedTours === undefined) building.tourAvailability.selfGuidedTours = false;
if (building.tourAvailability.virtualTours === undefined) building.tourAvailability.virtualTours = false;
if (building.tourAvailability.inPersonTours === undefined) building.tourAvailability.inPersonTours = false;

// Initialize specialty type with default if not set
if (!building.specialtyType) {
    building.specialtyType = 'market-rate';
}

// Initialize coordinate fields
if (building.latitude === undefined) building.latitude = undefined;
if (building.longitude === undefined) building.longitude = undefined;  
if (building.coordinatesVerified === undefined) building.coordinatesVerified = false;

// Initialize marketing description fields
if (!building.propertyDescription) building.propertyDescription = '';
if (!building.description) building.description = '';

// Income restrictions - ensure proper structure for Alpine.js binding
// Even if null, we need an object for the template to bind to
if (!building.incomeRestrictions) {
    building.incomeRestrictions = { amiLimit: undefined, maxIncomeByHouseholdSize: {} };
} else {
    // If incomeRestrictions exists, ensure maxIncomeByHouseholdSize is initialized
    if (!building.incomeRestrictions.maxIncomeByHouseholdSize) {
        building.incomeRestrictions.maxIncomeByHouseholdSize = {};
    }
    // Ensure amiLimit has a default value if not set
    if (building.incomeRestrictions.amiLimit === undefined) {
        building.incomeRestrictions.amiLimit = undefined;
    }
}

// Property type options
const propertyTypeOptions = Object.entries(PropertyType).map(([key, value]) => ({
    value,
    label: key.split('_').map(word => word.charAt(0) + word.slice(1).toLowerCase()).join(' ')
}));

// Utility type options
const utilityTypes = Object.values(UtilityType);

// Days of week for office hours
const daysOfWeek = Object.values(DayOfWeek);
---

<script is:inline>
// Used by Alpine.js x-data attribute
window.buildingCardData = function buildingCardData() {
    return {
        init() {
            // Parse data from data attributes with error handling
            try {
                this.building = JSON.parse(this.$el.dataset.building);
            } catch(e) {
                console.error('Failed to parse building data:', e);
                this.building = {};
            }
            
            try {
                this.units = JSON.parse(this.$el.dataset.units) || [];
            } catch(e) {
                console.error('Failed to parse units data:', e);
                this.units = [];
            }
            
            try {
                this.unitTypes = JSON.parse(this.$el.dataset.unitTypes) || [];
            } catch(e) {
                console.error('Failed to parse unitTypes data:', e);
                this.unitTypes = [];
            }
            
            this.apiURL = this.$el.dataset.apiUrl;
            this.original = JSON.parse(JSON.stringify(this.building));
            
            // Initialize units tab
            this.initUnitsTab();
        },
        original: null,
        building: null,
        units: null,
        unitTypes: null,
        apiURL: null,
        showSave: false,
        saving: false,
        activeSectionTab: 'building-info',
        errors: {},
        showAddUnitDialog: false,
        newUnit: { unitID: '', modelID: '' },
        showAddUnitTypeDialog: false,
        
        // Units tab variables (moved from nested scope to prevent reference errors)
        filteredUnits: [],
        
        // LocationMapPicker state variables
        geocoding: false,
        selectedUnits: new Set(),
        statusFilter: '',
        searchQuery: '',
        showBulkStatusDialog: false,
        showBulkRentDialog: false,
        bulkOperation: {
            loading: false,
            statusValue: '',
            rentUpdateType: 'absolute',
            rentValue: 0
        },
        
        // Validation method
        validateForm() {
            this.errors = {};
            let isValid = true;
            
            // Basic Info validation
            if (!this.building.buildingID || this.building.buildingID.trim() === '') {
                this.errors.buildingID = 'Building ID is required';
                isValid = false;
            }
            
            if (!this.building.street || this.building.street.trim() === '') {
                this.errors.street = 'Street address is required';
                isValid = false;
            }
            
            if (!this.building.city || this.building.city.trim() === '') {
                this.errors.city = 'City is required';
                isValid = false;
            }
            
            if (!this.building.state || this.building.state.trim() === '') {
                this.errors.state = 'State is required';
                isValid = false;
            }
            
            if (!this.building.zip || this.building.zip.trim() === '') {
                this.errors.zip = 'ZIP code is required';
                isValid = false;
            } else if (!/^\d{5}(-\d{4})?$/.test(this.building.zip)) {
                this.errors.zip = 'ZIP code must be in format 12345 or 12345-6789';
                isValid = false;
            }
            
            if (this.building.yearBuilt && (this.building.yearBuilt < 1800 || this.building.yearBuilt > new Date().getFullYear() + 1)) {
                this.errors.yearBuilt = `Year built must be between 1800 and ${new Date().getFullYear() + 1}`;
                isValid = false;
            }
            
            if (this.building.numberStories && (this.building.numberStories < 1 || this.building.numberStories > 100)) {
                this.errors.numberStories = 'Number of stories must be between 1 and 100';
                isValid = false;
            }
            
            if (this.building.totalUnits && (this.building.totalUnits < 1 || this.building.totalUnits > 1000)) {
                this.errors.totalUnits = 'Total units must be between 1 and 1000';
                isValid = false;
            }
            
            // Lease & Pricing validation
            if (this.building.leaseLength && (this.building.leaseLength < 1 || this.building.leaseLength > 36)) {
                this.errors.leaseLength = 'Lease length must be between 1 and 36 months';
                isValid = false;
            }
            
            if (this.building.applicationFee && this.building.applicationFee < 0) {
                this.errors.applicationFee = 'Application fee cannot be negative';
                isValid = false;
            }
            
            // Contact validation
            if (this.building.contactInfo?.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.building.contactInfo.email)) {
                this.errors.contactEmail = 'Please enter a valid email address';
                isValid = false;
            }
            
            if (this.building.contactInfo?.phone && !/^[\d\s\-\(\)\+\.]+$/.test(this.building.contactInfo.phone)) {
                this.errors.contactPhone = 'Please enter a valid phone number';
                isValid = false;
            }
            
            if (this.building.contactInfo?.propertyWebsite && !this.building.contactInfo.propertyWebsite.match(/^https?:\/\/.+/)) {
                this.errors.contactPropertyWebsite = 'Property website must start with http:// or https://';
                isValid = false;
            }
            
            if (this.building.contactInfo?.managementWebsite && !this.building.contactInfo.managementWebsite.match(/^https?:\/\/.+/)) {
                this.errors.contactManagementWebsite = 'Management website must start with http:// or https://';
                isValid = false;
            }
            
            if (this.building.tourAvailability?.tourSchedulingUrl && 
                this.building.tourAvailability.tourSchedulingUrl.trim() !== '' && 
                !this.building.tourAvailability.tourSchedulingUrl.match(/^https?:\/\/.+/)) {
                this.errors.tourSchedulingUrl = 'Tour scheduling URL must start with http:// or https://';
                isValid = false;
            }
            
            // Rent specials validation
            if (this.building.rentSpecials && this.building.rentSpecials.length > 0) {
                this.building.rentSpecials.forEach((special, index) => {
                    if (!special.title || special.title.trim() === '') {
                        this.errors[`rentSpecial${index}Title`] = 'Rent special title is required';
                        isValid = false;
                    }
                    if (special.startDate && special.endDate && new Date(special.startDate) > new Date(special.endDate)) {
                        this.errors[`rentSpecial${index}Dates`] = 'Start date must be before end date';
                        isValid = false;
                    }
                });
            }
            
            // Income restrictions validation - only validate if value exists and is not empty
            if (this.building.incomeRestrictions?.amiLimit !== null && 
                this.building.incomeRestrictions?.amiLimit !== undefined &&
                this.building.incomeRestrictions?.amiLimit !== '' &&
                (this.building.incomeRestrictions.amiLimit < 0 || this.building.incomeRestrictions.amiLimit > 200)) {
                this.errors.amiLimit = 'AMI limit must be between 0 and 200%';
                isValid = false;
            }
            
            // Screening criteria validation
            if (this.building.screeningCriteria?.minCreditScore && 
                (this.building.screeningCriteria.minCreditScore < 300 || this.building.screeningCriteria.minCreditScore > 850)) {
                this.errors.minCreditScore = 'Credit score must be between 300 and 850';
                isValid = false;
            }
            
            if (this.building.screeningCriteria?.incomeRatio && 
                (this.building.screeningCriteria.incomeRatio < 0 || this.building.screeningCriteria.incomeRatio > 10)) {
                this.errors.incomeRatio = 'Income ratio must be between 0 and 10';
                isValid = false;
            }
            
            if (this.building.screeningCriteria?.maxOccupantsPerBedroom && 
                (this.building.screeningCriteria.maxOccupantsPerBedroom < 1 || this.building.screeningCriteria.maxOccupantsPerBedroom > 5)) {
                this.errors.maxOccupantsPerBedroom = 'Max occupants per bedroom must be between 1 and 5';
                isValid = false;
            }
            
            return isValid;
        },
        
        // Methods for handling actions
        openAddUnitDialog() {
            this.newUnit = { unitID: '', modelID: '' };
            this.showAddUnitDialog = true;
        },
        
        openAddUnitTypeDialog() {
            this.showAddUnitTypeDialog = true;
        },
        
        closeAddUnitTypeDialog() {
            this.showAddUnitTypeDialog = false;
        },
        
        async addUnit() {
            if (!this.newUnit.unitID || this.newUnit.unitID.trim() === '') {
                this.$dispatch('show-toast', { message: 'Unit number is required', type: 'error' });
                return;
            }
            this.showAddUnitDialog = false;
            const unitData = {
                unitID: this.newUnit.unitID,
                buildingID: this.building.buildingID
            };
            if (this.newUnit.modelID) {
                unitData.modelID = this.newUnit.modelID;
            }
            await fetch(`${this.apiURL}buildings/${this.building.buildingID}/units`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(unitData),
            });
            window.location.reload();
        },
        
        async deleteBuilding() {
            if (!confirm('Are you sure you want to delete this building and all its units?')) return;
            await fetch(`${this.apiURL}buildings/${this.building.buildingID}`, { method: 'DELETE' });
            window.location.reload();
        },
        
        async saveBuilding() {
            if (!this.validateForm()) {
                // Show validation errors
                this.$dispatch('show-toast', { message: 'Please fix the validation errors before saving', type: 'error' });
                return;
            }
            this.saving = true;
            await fetch(`${this.apiURL}buildings/${this.building.buildingID}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(this.building),
            });
            this.original = { ...this.building };
            this.showSave = false;
            this.saving = false;
            this.$dispatch('show-toast', { message: 'Building saved successfully', type: 'success' });
        },
        
        undoChanges() {
            this.building = { ...this.original };
            this.errors = {};
        },
        
        // Get display name for active tab in mobile dropdown
        getTabDisplayName(tabKey) {
            const tabNames = {
                'building-info': 'Building Info',
                'floorplans-units': 'Floorplans & Units',
                'pricing-policies': 'Pricing & Policies',
                'marketing': 'Marketing',
                'units': 'Units'
            };
            return tabNames[tabKey] || 'Building Info';
        },
        
        // Units tab methods (moved from nested scope)
        initUnitsTab() {
            // Initialize lastUpdated for units that don't have it
            this.units.forEach(unit => {
                if (!unit.lastUpdated) {
                    unit.lastUpdated = new Date().toISOString();
                }
            });
            
            this.updateFilteredUnits();
            // Watch for changes that require re-filtering
            this.$watch('statusFilter', () => this.updateFilteredUnits());
            this.$watch('searchQuery', () => this.updateFilteredUnits());
        },
        
        updateFilteredUnits() {
            let filtered = [...(this.units || [])];
            
            // Apply status filter
            if (this.statusFilter) {
                filtered = filtered.filter(unit => unit.vacancyClass === this.statusFilter);
            }
            
            // Apply search filter
            if (this.searchQuery.trim()) {
                const query = this.searchQuery.toLowerCase();
                filtered = filtered.filter(unit => 
                    (unit.unitNumber || unit.unitID || '').toLowerCase().includes(query)
                );
            }
            
            this.filteredUnits = filtered;
        },
        
        toggleSelectAll() {
            if (this.selectedUnits.size === this.filteredUnits.length) {
                // Deselect all
                this.selectedUnits.clear();
            } else {
                // Select all filtered units
                this.selectedUnits = new Set(this.filteredUnits.map(u => u.unitID));
            }
        },
        
        isUnitSelected(unitID) {
            return this.selectedUnits.has(unitID);
        },
        
        toggleUnitSelection(unitID) {
            if (this.selectedUnits.has(unitID)) {
                this.selectedUnits.delete(unitID);
            } else {
                this.selectedUnits.add(unitID);
            }
        },
        
        getSelectedCount() {
            return this.selectedUnits.size;
        },
        
        async performBulkStatusUpdate() {
            this.bulkOperation.loading = true;
            try {
                const unitIDs = Array.from(this.selectedUnits);
                const response = await fetch(this.apiURL + 'buildings/' + this.building.buildingID + '/units/bulk-status', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        unitIDs,
                        vacancyClass: this.bulkOperation.statusValue
                    })
                });
                
                if (response.ok) {
                    // Update local data
                    this.units.forEach(unit => {
                        if (this.selectedUnits.has(unit.unitID)) {
                            unit.vacancyClass = this.bulkOperation.statusValue;
                            unit.lastUpdated = new Date().toISOString();
                        }
                    });
                    
                    this.showSuccessMessage(`${unitIDs.length} units updated successfully`);
                    this.selectedUnits.clear();
                    this.showBulkStatusDialog = false;
                    this.updateFilteredUnits();
                } else {
                    throw new Error('Bulk update failed');
                }
            } catch (error) {
                console.error('Bulk status update error:', error);
                this.showErrorMessage('Failed to update units. Please try again.');
            } finally {
                this.bulkOperation.loading = false;
            }
        },
        
        async performBulkRentUpdate() {
            this.bulkOperation.loading = true;
            try {
                const unitIDs = Array.from(this.selectedUnits);
                const response = await fetch(this.apiURL + 'buildings/' + this.building.buildingID + '/units/bulk-rent', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        unitIDs,
                        updateType: this.bulkOperation.rentUpdateType,
                        value: parseFloat(this.bulkOperation.rentValue)
                    })
                });
                
                if (response.ok) {
                    // Update local data
                    this.units.forEach(unit => {
                        if (this.selectedUnits.has(unit.unitID)) {
                            if (this.bulkOperation.rentUpdateType === 'absolute') {
                                unit.rent = parseFloat(this.bulkOperation.rentValue);
                            } else if (this.bulkOperation.rentUpdateType === 'percentage') {
                                unit.rent = Math.round(unit.rent * (1 + parseFloat(this.bulkOperation.rentValue) / 100));
                            }
                            unit.lastUpdated = new Date().toISOString();
                        }
                    });
                    
                    this.showSuccessMessage(`${unitIDs.length} units updated successfully`);
                    this.selectedUnits.clear();
                    this.showBulkRentDialog = false;
                    this.updateFilteredUnits();
                } else {
                    throw new Error('Bulk rent update failed');
                }
            } catch (error) {
                console.error('Bulk rent update error:', error);
                this.showErrorMessage('Failed to update rents. Please try again.');
            } finally {
                this.bulkOperation.loading = false;
            }
        },
        
        async toggleUnitAvailability(unit) {
            const newStatus = unit.vacancyClass === 'Occupied' ? 'Unoccupied' : 'Occupied';
            
            try {
                const response = await fetch(this.apiURL + 'buildings/' + this.building.buildingID + '/units/' + unit.unitID, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        ...unit,
                        vacancyClass: newStatus,
                        lastUpdated: new Date().toISOString()
                    })
                });
                
                if (response.ok) {
                    unit.vacancyClass = newStatus;
                    unit.lastUpdated = new Date().toISOString();
                    this.updateFilteredUnits();
                    this.showSuccessMessage(`Unit ${unit.unitNumber || unit.unitID} status updated`);
                } else {
                    throw new Error('Status update failed');
                }
            } catch (error) {
                console.error('Toggle unit availability error:', error);
                this.showErrorMessage('Failed to update unit status. Please try again.');
            }
        },
        
        // Helper functions for formatting and styling
        formatCurrency(amount) {
            if(amount === null || amount === undefined) return '$0';
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                minimumFractionDigits: 0,
                maximumFractionDigits: 0
            }).format(amount);
        },
        
        formatRelativeTime(dateString) {
            if(!dateString) return 'Never';
            const date = new Date(dateString);
            const now = new Date();
            const diffMs = now - date;
            const diffSecs = Math.floor(diffMs / 1000);
            const diffMins = Math.floor(diffSecs / 60);
            const diffHours = Math.floor(diffMins / 60);
            const diffDays = Math.floor(diffHours / 24);
            
            if(diffDays > 30) {
                return date.toLocaleDateString();
            } else if(diffDays > 0) {
                return `${diffDays} day${diffDays === 1 ? '' : 's'} ago`;
            } else if(diffHours > 0) {
                return `${diffHours} hour${diffHours === 1 ? '' : 's'} ago`;
            } else if(diffMins > 0) {
                return `${diffMins} minute${diffMins === 1 ? '' : 's'} ago`;
            } else {
                return 'Just now';
            }
        },
        
        getStatusBadgeClass(status) {
            const statusClasses = {
                'occupied': 'badge-error',
                'unoccupied': 'badge-success', 
                'notice': 'badge-warning',
                'down': 'badge-neutral'
            };
            return statusClasses[status?.toLowerCase()] || 'badge-ghost';
        },
        
        showSuccessMessage(message) {
            this.$dispatch('show-toast', { message, type: 'success' });
        },
        
        showErrorMessage(message) {
            this.$dispatch('show-toast', { message, type: 'error' });
        }
    };
}
</script>

<div
    class="building-card"
    x-data="buildingCardData()"
    x-effect="if (building) { showSave = JSON.stringify(building) !== JSON.stringify(original); }"
    :class="{'opacity-50': saving}"
    data-building={JSON.stringify(building)}
    data-units={JSON.stringify(units)}
    data-unit-types={JSON.stringify(unitTypes)}
    data-api-url={apiURL}>
    
    <!-- Header with Building Name and Actions -->
    <div class="mb-6">
        <div class="flex justify-between items-center">
            <h2 class="text-2xl font-bold" x-text="building?.buildingID || 'Loading...'"></h2>
            <Saving />
        </div>
        
        <!-- Action Buttons -->
        <div class="mt-4">
            <!-- Mobile: Stack vertically, Desktop: Horizontal with proper spacing -->
            <div class="flex flex-col sm:flex-row gap-3 sm:gap-2 sm:items-center sm:justify-between">
                <!-- Primary Actions -->
                <div class="flex flex-col sm:flex-row gap-3 sm:gap-2">
                    <button
                        class="btn btn-primary min-h-[44px]"
                        x-on:click="openAddUnitDialog()"
                        >Add Unit</button>
                    <button
                        class="btn btn-secondary min-h-[44px]"
                        x-on:click="openAddUnitTypeDialog()"
                        >Add Unit Type</button>
                    <button
                        class="btn btn-error min-h-[44px]"
                        x-on:click="deleteBuilding()"
                        >Delete Building</button>
                </div>
                
                <!-- Save/Undo Actions -->
                <div class="flex flex-col sm:flex-row gap-3 sm:gap-2" x-show="showSave">
                    <button
                        class="btn btn-outline btn-secondary min-h-[44px] order-2 sm:order-1"
                        x-on:click="undoChanges()">Undo</button>
                    <button
                        class="btn btn-primary min-h-[44px] order-1 sm:order-2"
                        x-on:click="saveBuilding()"
                        >Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs Navigation -->
    <!-- Mobile: Dropdown Navigation -->
    <div class="block sm:hidden mb-6">
        <div class="dropdown dropdown-end w-full">
            <label tabindex="0" class="btn btn-outline w-full justify-between min-h-[44px]">
                <span x-text="getTabDisplayName(activeSectionTab)">Building Info</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </label>
            <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-full border border-base-200">
                <li>
                    <button 
                        @click="activeSectionTab = 'building-info'"
                        :class="{'active': activeSectionTab === 'building-info'}"
                        class="min-h-[44px]">
                        Building Info
                    </button>
                </li>
                <li>
                    <button 
                        @click="activeSectionTab = 'floorplans-units'"
                        :class="{'active': activeSectionTab === 'floorplans-units'}"
                        class="min-h-[44px]">
                        Floorplans & Units
                    </button>
                </li>
                <li>
                    <button 
                        @click="activeSectionTab = 'pricing-policies'"
                        :class="{'active': activeSectionTab === 'pricing-policies'}"
                        class="min-h-[44px]">
                        Pricing & Policies
                    </button>
                </li>
                <li>
                    <button 
                        @click="activeSectionTab = 'marketing'"
                        :class="{'active': activeSectionTab === 'marketing'}"
                        class="min-h-[44px]">
                        Marketing
                    </button>
                </li>
                <li>
                    <button 
                        @click="activeSectionTab = 'units'"
                        :class="{'active': activeSectionTab === 'units'}"
                        class="min-h-[44px]">
                        Units
                    </button>
                </li>
            </ul>
        </div>
    </div>
    
    <!-- Desktop: Horizontal Tabs -->
    <div class="hidden sm:flex tabs tabs-boxed mb-6 flex-wrap">
        <button 
            class="tab min-h-[44px]" 
            :class="{'tab-active': activeSectionTab === 'building-info'}"
            @click="activeSectionTab = 'building-info'">
            <span class="hidden md:inline">Building Info</span>
            <span class="md:hidden">Info</span>
        </button>
        <button 
            class="tab min-h-[44px]" 
            :class="{'tab-active': activeSectionTab === 'floorplans-units'}"
            @click="activeSectionTab = 'floorplans-units'">
            <span class="hidden md:inline">Floorplans & Units</span>
            <span class="md:hidden">Floorplans</span>
        </button>
        <button 
            class="tab min-h-[44px]" 
            :class="{'tab-active': activeSectionTab === 'pricing-policies'}"
            @click="activeSectionTab = 'pricing-policies'">
            <span class="hidden md:inline">Pricing & Policies</span>
            <span class="md:hidden">Pricing</span>
        </button>
        <button 
            class="tab min-h-[44px]" 
            :class="{'tab-active': activeSectionTab === 'marketing'}"
            @click="activeSectionTab = 'marketing'">Marketing</button>
        <button 
            class="tab min-h-[44px]" 
            :class="{'tab-active': activeSectionTab === 'units'}"
            @click="activeSectionTab = 'units'">Units</button>
    </div>

    <!-- Tab Content -->
    <div class="building-tab-content">
        <!-- Building Info Tab (combines Basic Info + Contact Info + Building-level Amenities) -->
        <div x-show="activeSectionTab === 'building-info'" class="space-y-6">
            <!-- Basic Information Section -->
            <div class="card bg-base-100 shadow-lg">
                <div class="card-body p-4 sm:p-6">
                    <h3 class="card-title text-lg mb-4">Basic Information</h3>
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
                        <BaseInput
                            name="buildingID"
                            label="Building ID"
                            xModel="building.buildingID"
                            disabled={true}
                            required={true}
                        />
                        <span x-show="errors.buildingID" class="label-text-alt text-error" x-text="errors.buildingID"></span>
                        <BaseSelect
                            name="propertyType"
                            label="Property Type"
                            xModel="building.propertyType"
                            options={propertyTypeOptions}
                            placeholder="Select property type"
                        />
                    </div>
                    
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mt-4">
                <BaseInput
                    name="street"
                    label="Street Address"
                    xModel="building.street"
                    placeholder="123 Main St"
                    required={true}
                />
                <span x-show="errors.street" class="label-text-alt text-error" x-text="errors.street"></span>
                <BaseInput
                    name="city"
                    label="City"
                    xModel="building.city"
                    placeholder="San Francisco"
                    required={true}
                />
                <span x-show="errors.city" class="label-text-alt text-error" x-text="errors.city"></span>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <BaseInput
                    name="state"
                    label="State"
                    xModel="building.state"
                    placeholder="CA"
                    required={true}
                />
                <span x-show="errors.state" class="label-text-alt text-error" x-text="errors.state"></span>
                <BaseInput
                    name="zip"
                    label="ZIP Code"
                    xModel="building.zip"
                    placeholder="94102"
                    required={true}
                />
                <span x-show="errors.zip" class="label-text-alt text-error" x-text="errors.zip"></span>
            </div>
            
            <!-- Location Map -->
            <div class="mt-6">
                <LocationMapPicker
                    latModel="building.latitude"
                    lngModel="building.longitude"
                    verifiedModel="building.coordinatesVerified"
                    addressModel="building.street"
                    cityModel="building.city"
                    stateModel="building.state"
                    apiUrl={apiURL}
                    height="350px"
                />
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <BaseInput
                    name="yearBuilt"
                    label="Year Built"
                    type="number"
                    xModel="building.yearBuilt"
                    placeholder="2020"
                    min="1800"
                    max="2030"
                />
                <span x-show="errors.yearBuilt" class="label-text-alt text-error" x-text="errors.yearBuilt"></span>
                <BaseInput
                    name="numberStories"
                    label="Number of Stories"
                    type="number"
                    xModel="building.numberStories"
                    placeholder="3"
                    min="1"
                />
                <span x-show="errors.numberStories" class="label-text-alt text-error" x-text="errors.numberStories"></span>
                <BaseInput
                    name="totalUnits"
                    label="Total Units"
                    type="number"
                    xModel="building.totalUnits"
                    placeholder="24"
                    min="1"
                />
                <span x-show="errors.totalUnits" class="label-text-alt text-error" x-text="errors.totalUnits"></span>
            </div>
            
            <BaseTextarea
                name="description"
                label="Basic Description"
                xModel="building.description"
                placeholder="Brief description of the property"
                rows={3}
            />
            
            <!-- Management Contact Information -->
            <div class="card bg-base-200 mt-6">
                <div class="card-body">
                    <h3 class="card-title text-lg">Management Contact</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <BaseInput
                            name="contactName"
                            label="Contact Name"
                            xModel="building.contactInfo.name"
                            placeholder="John Doe"
                        />
                        <BaseInput
                            name="contactPhone"
                            label="Phone Number"
                            type="tel"
                            xModel="building.contactInfo.phone"
                            placeholder="(555) 123-4567"
                        />
                        <span x-show="errors.contactPhone" class="label-text-alt text-error" x-text="errors.contactPhone"></span>
                        <BaseInput
                            name="contactEmail"
                            label="Email Address"
                            type="email"
                            xModel="building.contactInfo.email"
                            placeholder="contact@property.com"
                        />
                        <span x-show="errors.contactEmail" class="label-text-alt text-error" x-text="errors.contactEmail"></span>
                    </div>
                    
                    <!-- Website Fields Section -->
                    <div class="mt-6">
                        <h4 class="text-base font-semibold mb-4 flex items-center gap-2">
                            <span>Website Information</span>
                            <div class="tooltip tooltip-right" data-tip="Property websites are used on listings to show property-specific information. Management websites link to your company's main site for corporate information.">
                                <svg class="w-4 h-4 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                        </h4>
                        
                        <div class="grid grid-cols-1 gap-4">
                            <BaseInput
                                name="contactPropertyWebsite"
                                label="Property Website"
                                type="url"
                                xModel="building.contactInfo.propertyWebsite"
                                placeholder="https://property-specific-site.com"
                                helpText="Main website for this specific property/building - used in listings"
                            />
                            <span x-show="errors.contactPropertyWebsite" class="label-text-alt text-error" x-text="errors.contactPropertyWebsite"></span>
                            
                            <BaseInput
                                name="contactManagementWebsite"
                                label="Management Company Website (Optional)"
                                type="url"
                                xModel="building.contactInfo.managementWebsite"
                                placeholder="https://your-management-company.com"
                                helpText="Your property management company's main website - for corporate information"
                            />
                            <span x-show="errors.contactManagementWebsite" class="label-text-alt text-error" x-text="errors.contactManagementWebsite"></span>
                        </div>
                        
                        <!-- Explanatory text -->
                        <div class="alert alert-info mt-4">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <div class="text-sm">
                                <p><strong>Property Website:</strong> Specific to this building/property - shown on rental listings for prospective tenants</p>
                                <p class="mt-1"><strong>Management Website:</strong> Your company's main website - used for corporate information and branding</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Office Hours -->
                    <div class="mt-6">
                        <h4 class="text-base font-semibold mb-4">Office Hours</h4>
                        <div class="flex flex-col gap-2">
                            {daysOfWeek.map(day => {
                                const xDataStr = `{ day: '${day}', isOpen: !!(building.contactInfo?.officeHours?.['${day}']), toggle() { if (!building.contactInfo) building.contactInfo = {}; if (!building.contactInfo.officeHours) building.contactInfo.officeHours = {}; if (this.isOpen) { building.contactInfo.officeHours[this.day] = { open: "09:00", close: "17:00" }; } else { delete building.contactInfo.officeHours[this.day]; } } }`;
                                return (
                                <div class="grid grid-cols-3 gap-4 items-center" x-data={xDataStr}>
                                    <div class="form-control">
                                        <label class="label cursor-pointer">
                                            <span class="label-text capitalize">{day}</span>
                                            <input 
                                                type="checkbox" 
                                                class="checkbox checkbox-primary" 
                                                x-model="isOpen"
                                                @change="toggle()"
                                            />
                                        </label>
                                    </div>
                                    <input
                                        type="time"
                                        class="input w-full"
                                        :disabled="!isOpen"
                                        :value="building.contactInfo?.officeHours?.[day]?.open || ''"
                                        @input="if (building.contactInfo?.officeHours?.[day]) building.contactInfo.officeHours[day].open = $event.target.value; else if (building.contactInfo?.officeHours) { building.contactInfo.officeHours[day] = { open: $event.target.value, close: '17:00' }; }"
                                        placeholder="09:00"
                                    />
                                    <input
                                        type="time"
                                        class="input w-full"
                                        :disabled="!isOpen"
                                        :value="building.contactInfo?.officeHours?.[day]?.close || ''"
                                        @input="if (building.contactInfo?.officeHours?.[day]) building.contactInfo.officeHours[day].close = $event.target.value; else if (building.contactInfo?.officeHours) { building.contactInfo.officeHours[day] = { open: '09:00', close: $event.target.value }; }"
                                        placeholder="17:00"
                                    />
                                </div>
                            );
                        })}
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Building Amenities -->
            <div class="card bg-base-200 mt-6">
                <div class="card-body">
                    <h3 class="card-title text-lg">Building Amenities</h3>
                    <AmenitySelector
                        name="propertyAmenities"
                        xModel="building.propertyAmenities"
                    />
                </div>
            </div>
        </div>

        <!-- Floorplans & Units Tab (integrates unit types with units list) -->
        <div x-show="activeSectionTab === 'floorplans-units'" class="space-y-6">
            <!-- Floorplans Section -->
            <div class="card bg-base-100 shadow-lg">
                <div class="card-body">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="card-title text-xl">Floorplans (Unit Types)</h3>
                        <div class="badge badge-primary badge-lg" x-text="(unitTypes?.length || 0) + ' types'"></div>
                    </div>
                    <div class="text-base-content/70 mb-4">
                        Define unit types that serve as templates for individual units. Units can inherit settings from their floorplan and override them as needed.
                    </div>
                    
                    <!-- Unit Types List -->
                    <div class="grid grid-cols-1 gap-4" data-testid="unit-types-list">
                        <template x-for="(unitType, index) in unitTypes || []" :key="unitType.modelID || ('unittype-' + index)">
                            <div class="floorplan-card border border-base-300 rounded-lg p-4 sm:p-6">
                                <!-- Header - Mobile Stack, Desktop Row -->
                                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3 mb-4">
                                    <!-- Main Info -->
                                    <div class="flex-1">
                                        <h4 class="text-lg font-semibold mb-2" x-text="unitType.modelName || 'Unnamed Model'"></h4>
                                        <div class="text-sm text-base-content/60 space-y-1">
                                            <div>ID: <span x-text="unitType.modelID"></span></div>
                                            <div x-text="(unitType.beds || 0) + ' bed, ' + (unitType.baths || 0) + ' bath'"></div>
                                            <div x-show="unitType.countAvailable" x-text="unitType.countAvailable + ' available'"></div>
                                        </div>
                                    </div>
                                    
                                    <!-- Badges - Stack vertically on mobile -->
                                    <div class="flex flex-col sm:flex-row gap-2 sm:items-center">
                                        <div class="badge badge-ghost" x-text="'Amenities: ' + (unitType.modelAmenities?.length || 0)"></div>
                                        <div class="badge badge-outline" x-show="unitType.minRent || unitType.maxRent">
                                            <span x-text="unitType.minRent && unitType.maxRent ? '$' + unitType.minRent + '-$' + unitType.maxRent : (unitType.minRent ? 'From $' + unitType.minRent : 'Up to $' + unitType.maxRent)"></span>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Inheritance Info -->
                                <div class="inheritance-chain flex items-center gap-2 mb-3 text-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-info" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                    </svg>
                                    <span class="text-base-content/70">Inherits from Building → Can be overridden by individual Units</span>
                                </div>
                                
                                <!-- Quick Stats - Responsive Grid -->
                                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 text-sm">
                                    <div x-show="unitType.minSqft || unitType.maxSqft" class="bg-base-200 rounded p-3">
                                        <div class="font-medium text-xs uppercase tracking-wide text-base-content/70 mb-1">Size</div>
                                        <div x-text="unitType.minSqft && unitType.maxSqft ? unitType.minSqft + '-' + unitType.maxSqft + ' sq ft' : (unitType.minSqft ? 'From ' + unitType.minSqft + ' sq ft' : 'Up to ' + unitType.maxSqft + ' sq ft')"></div>
                                    </div>
                                    <div x-show="unitType.deposit" class="bg-base-200 rounded p-3">
                                        <div class="font-medium text-xs uppercase tracking-wide text-base-content/70 mb-1">Deposit</div>
                                        <div x-text="'$' + (typeof unitType.deposit === 'object' ? unitType.deposit.amount : unitType.deposit)"></div>
                                    </div>
                                    <div x-show="unitType.maxOccupants" class="bg-base-200 rounded p-3">
                                        <div class="font-medium text-xs uppercase tracking-wide text-base-content/70 mb-1">Max Occupants</div>
                                        <div x-text="unitType.maxOccupants"></div>
                                    </div>
                                    <div x-show="unitType.minLeaseTerm || unitType.maxLeaseTerm" class="bg-base-200 rounded p-3">
                                        <div class="font-medium text-xs uppercase tracking-wide text-base-content/70 mb-1">Lease Term</div>
                                        <div x-text="unitType.minLeaseTerm && unitType.maxLeaseTerm ? unitType.minLeaseTerm + '-' + unitType.maxLeaseTerm + ' months' : (unitType.minLeaseTerm ? 'Min ' + unitType.minLeaseTerm + ' months' : 'Max ' + unitType.maxLeaseTerm + ' months')"></div>
                                    </div>
                                </div>
                                
                                <!-- Amenities Preview -->
                                <div x-show="unitType.modelAmenities && unitType.modelAmenities.length > 0" class="mt-3">
                                    <span class="text-sm font-medium text-base-content/70">Floorplan Amenities:</span>
                                    <div class="flex flex-wrap gap-1 mt-1">
                                        <template x-for="amenity in unitType.modelAmenities?.slice(0, 5) || []" :key="amenity">
                                            <div class="badge badge-sm badge-primary badge-outline" x-text="amenity"></div>
                                        </template>
                                        <div x-show="unitType.modelAmenities && unitType.modelAmenities.length > 5" class="badge badge-sm badge-ghost">
                                            <span x-text="'+' + (unitType.modelAmenities.length - 5) + ' more'"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </template>
                        
                        
                        <!-- Empty State -->
                        <div x-show="!unitTypes || unitTypes.length === 0" class="text-center py-8 text-base-content/60">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                            </svg>
                            <p class="text-lg mb-2 font-semibold">No floorplans defined yet</p>
                            <p class="mb-4">Create unit types to serve as templates for your units. This helps maintain consistency and makes unit management easier.</p>
                            <button @click="openAddUnitTypeDialog()" class="btn btn-primary btn-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                </svg>
                                Add Your First Floorplan
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Visual Divider -->
            <div class="divider divider-primary">
                <span class="text-lg font-medium">Individual Units</span>
            </div>
            
            <!-- Units Section -->
            <div class="card bg-base-100 shadow-lg">
                <div class="card-body">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="card-title text-xl">Units in this Building</h3>
                        <div class="badge badge-primary badge-lg" x-text="(units?.length || 0) + ' units'"></div>
                    </div>
                    <div class="text-base-content/70 mb-4">
                        Individual units can inherit settings from their assigned floorplan and override them as needed.
                    </div>
                    
                    <!-- Units List -->
                    <div class="space-y-4">
                        <template x-for="(unit, index) in units || []" :key="unit.unitID || ('unit-' + index)">
                            <div class="unit-card border border-base-300 rounded-lg p-4">
                                <div class="flex justify-between items-start mb-3">
                                    <div>
                                        <h4 class="text-lg font-semibold" x-text="'Unit ' + unit.unitID"></h4>
                                        <div class="text-sm text-base-content/60" x-show="unit.modelID">
                                            Based on: <span class="font-medium" x-text="unit.modelID"></span>
                                            <template x-for="unitType in unitTypes || []" :key="unitType.modelID">
                                                <span x-show="unitType.modelID === unit.modelID" class="ml-2 text-xs text-base-content/50">
                                                    (<span x-text="unitType.modelName"></span>)
                                                </span>
                                            </template>
                                        </div>
                                        <div class="text-sm text-base-content/60" x-show="!unit.modelID">
                                            Standalone unit (no floorplan)
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <div x-show="unit.modelID" class="badge badge-success badge-sm">Inherits from Floorplan</div>
                                        <div x-show="!unit.modelID" class="badge badge-warning badge-sm">Standalone</div>
                                    </div>
                                </div>
                                
                                <!-- Inheritance Chain -->
                                <div class="inheritance-chain flex items-center gap-2 mb-3 text-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-info" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                    </svg>
                                    <span class="text-base-content/70">
                                        Building
                                        <template x-if="unit.modelID">
                                            <span>
                                                → <span class="font-medium" x-text="unit.modelID"></span> Floorplan
                                            </span>
                                        </template>
                                        → <span class="font-medium text-primary">This Unit</span>
                                    </span>
                                </div>
                            </div>
                        </template>
                        
                        <!-- Empty State -->
                        <div x-show="!units || units.length === 0" class="text-center py-8 text-base-content/60">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z" />
                            </svg>
                            <p class="text-lg mb-2 font-semibold">No units added yet</p>
                            <p class="mb-4">Add individual units to this building. Units can inherit settings from floorplans or be configured independently.</p>
                            <button @click="openAddUnitDialog()" class="btn btn-primary btn-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                </svg>
                                Add Your First Unit
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pricing & Policies Tab (consolidated) -->
        <div x-show="activeSectionTab === 'pricing-policies'" class="space-y-6">
            
            <!-- Lease Terms & Pricing Section -->
            <div class="card bg-base-100">
                <div class="card-body">
                    <h3 class="card-title text-lg mb-4">Lease Terms & Pricing</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
                        <BaseInput
                            name="leaseLength"
                            label="Default Lease Length (months)"
                            type="number"
                            xModel="building.leaseLength"
                            placeholder="12"
                            min="1"
                            max="36"
                            helpText="Standard lease term offered"
                        />
                        <span x-show="errors.leaseLength" class="label-text-alt text-error" x-text="errors.leaseLength"></span>
                        
                        <BaseInput
                            name="applicationFee"
                            label="Application Fee"
                            type="number"
                            xModel="building.applicationFee"
                            placeholder="50"
                            min="0"
                            step="5"
                            helpText="Fee to process rental applications"
                        />
                        <span x-show="errors.applicationFee" class="label-text-alt text-error" x-text="errors.applicationFee"></span>
                        
                        <div class="form-control">
                            <label class="label cursor-pointer">
                                <span class="label-text">Accepts Online Applications</span>
                                <input 
                                    type="checkbox" 
                                    class="checkbox checkbox-primary" 
                                    x-model="building.acceptsOnlineApplications"
                                />
                            </label>
                        </div>
                    </div>
                    
                    <!-- Rental Type Section -->
                    <div class="border-t border-base-200 pt-4 mt-4">
                        <h4 class="font-semibold mb-4 flex items-center gap-2">
                            <span>Rental Type (Property Specialty)</span>
                            <div class="tooltip tooltip-right" data-tip="This affects how your property appears on listing sites like Apartments.com and Zillow">
                                <svg class="w-4 h-4 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                        </h4>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <BaseSelect
                                name="specialtyType"
                                label="Rental Type"
                                xModel="building.specialtyType"
                                options={[
                                    { value: 'market-rate', label: 'Market Rate' },
                                    { value: 'affordable', label: 'Affordable' },
                                    { value: 'student', label: 'Student' },
                                    { value: 'senior', label: 'Senior' }
                                ]}
                                placeholder="Select rental type"
                            />
                            <BaseInput
                                name="specialtySubType"
                                label="Specialty Sub-Type"
                                xModel="building.specialtySubType"
                                placeholder="e.g., 55+, 62+, graduate"
                            />
                        </div>
                        
                        <div class="form-control mb-4">
                            <label class="label cursor-pointer">
                                <span class="label-text">Rooms for Rent Available</span>
                                <input 
                                    type="checkbox" 
                                    class="toggle toggle-primary" 
                                    x-model="building.roomsForRent"
                                />
                            </label>
                        </div>
                    </div>
                    
                    <!-- Rent Specials -->
                    <div class="border-t border-base-200 pt-4 mt-4">
                        <h4 class="font-semibold mb-4">Rent Specials</h4>
                        <div x-data='{ addSpecial() { if (!$parent.building.rentSpecials) $parent.building.rentSpecials = []; $parent.building.rentSpecials.push({ id: Date.now() + Math.random(), title: "", description: "", startDate: "", endDate: "" }); }, removeSpecial(index) { $parent.building.rentSpecials.splice(index, 1); } }'>
                            <template x-for="(special, index) in building.rentSpecials || []" :key="special.id || ('special-' + index)">
                                <div class="border border-base-300 rounded-lg p-4 mb-4">
                                    <div class="flex justify-end mb-2">
                                        <button 
                                            @click="removeSpecial(index)"
                                            class="btn btn-ghost btn-sm text-error"
                                        >Remove</button>
                                    </div>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <!-- Title Input -->
                                        <label class="floating-label">
                                            <span>Title<span class="text-error">*</span></span>
                                            <input
                                                type="text"
                                                :name="'special-title-' + index"
                                                x-model="special.title"
                                                placeholder="Move-in Special"
                                                class="input w-full"
                                                :class="errors['rentSpecial' + index + 'Title'] ? 'input-error' : ''"
                                                required
                                            />
                                            <span x-show="errors['rentSpecial' + index + 'Title']" class="label-text-alt text-error" x-text="errors['rentSpecial' + index + 'Title']"></span>
                                        </label>
                                        <div class="grid grid-cols-2 gap-2">
                                            <!-- Start Date Input -->
                                            <label class="floating-label">
                                                <span>Start Date</span>
                                                <input
                                                    type="date"
                                                    :name="'special-start-' + index"
                                                    x-model="special.startDate"
                                                    class="input w-full"
                                                />
                                            </label>
                                            <!-- End Date Input -->
                                            <label class="floating-label">
                                                <span>End Date</span>
                                                <input
                                                    type="date"
                                                    :name="'special-end-' + index"
                                                    x-model="special.endDate"
                                                    class="input w-full"
                                                />
                                            </label>
                                        </div>
                                    </div>
                                    <div x-show="errors['rentSpecial' + index + 'Dates']" class="text-error text-sm mt-1" x-text="errors['rentSpecial' + index + 'Dates']"></div>
                                    <!-- Description Textarea -->
                                    <label class="floating-label textarea-label">
                                        <span>Description</span>
                                        <textarea
                                            :name="'special-desc-' + index"
                                            x-model="special.description"
                                            placeholder="Special details..."
                                            class="textarea w-full resize-vertical"
                                            rows="2"
                                        ></textarea>
                                    </label>
                                </div>
                            </template>
                            <button 
                                @click="addSpecial()"
                                class="btn btn-primary btn-sm"
                            >Add Rent Special</button>
                        </div>
                    </div>
                    
                    <!-- Income Restrictions -->
                    <div class="border-t border-base-200 pt-4 mt-4">
                        <h4 class="font-semibold mb-4">Income Restrictions</h4>
                        <div x-data="{ hasRestrictions: !!(building.incomeRestrictions?.amiLimit), initRestrictions() { if (!building.incomeRestrictions) building.incomeRestrictions = { amiLimit: null, maxIncomeByHouseholdSize: {} }; if (!building.incomeRestrictions.maxIncomeByHouseholdSize) building.incomeRestrictions.maxIncomeByHouseholdSize = {}; if (!this.hasRestrictions) { building.incomeRestrictions.amiLimit = null; } } }" x-init="initRestrictions()" x-effect="initRestrictions()">
                            <div class="form-control mb-4">
                                <label class="label cursor-pointer">
                                    <span class="label-text">Has Income Restrictions</span>
                                    <input 
                                        type="checkbox" 
                                        class="toggle toggle-primary" 
                                        x-model="hasRestrictions"
                                    />
                                </label>
                            </div>
                            <div x-show="hasRestrictions" class="space-y-4">
                                <BaseInput
                                    name="amiLimit"
                                    label="AMI Limit (%)"
                                    type="number"
                                    xModel="building.incomeRestrictions.amiLimit"
                                    placeholder="80"
                                    min="0"
                                    max="200"
                                    helpText="Area Median Income percentage limit"
                                />
                                <span x-show="errors.amiLimit" class="label-text-alt text-error" x-text="errors.amiLimit"></span>
                                <!-- Simplified income limits by household size -->
                                <div>
                                    <label class="label">Maximum Income by Household Size</label>
                                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                                        <template x-for="size in [1, 2, 3, 4]" :key="'income-size-' + size">
                                            <label class="floating-label">
                                                <span x-text="size + ' Person'"></span>
                                                <input
                                                    type="number"
                                                    :name="'income-size-' + size"
                                                    :value="building.incomeRestrictions && building.incomeRestrictions.maxIncomeByHouseholdSize ? building.incomeRestrictions.maxIncomeByHouseholdSize[size] || '' : ''"
                                                    @input="(() => { if (!building.incomeRestrictions) building.incomeRestrictions = {}; if (!building.incomeRestrictions.maxIncomeByHouseholdSize) building.incomeRestrictions.maxIncomeByHouseholdSize = {}; if ($event.target.value) { building.incomeRestrictions.maxIncomeByHouseholdSize[size] = parseFloat($event.target.value); } else { delete building.incomeRestrictions.maxIncomeByHouseholdSize[size]; } })()"
                                                    placeholder="50000"
                                                    class="input w-full"
                                                    min="0"
                                                    step="1000"
                                                />
                                            </label>
                                        </template>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Application & Fees Section -->
            <div class="card bg-base-100">
                <div class="card-body">
                    <h3 class="card-title text-lg mb-4">Application & Fees</h3>
                    
                    <!-- Utilities Included -->
                    <div class="mb-6">
                        <h4 class="font-semibold mb-4">Utilities Included</h4>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                            {utilityTypes.map(utility => (
                                <div class="form-control">
                                    <label class="label cursor-pointer">
                                        <span class="label-text capitalize">{utility.replace('-', ' ')}</span>
                                        <input 
                                            type="checkbox" 
                                            class="checkbox checkbox-primary" 
                                            x-model={`building.utilitiesIncluded['${utility}']`}
                                        />
                                    </label>
                                </div>
                            ))}
                        </div>
                    </div>
                    
                    <!-- One-Time Fees -->
                    <div class="border-t border-base-200 pt-4 mt-4 mb-6">
                        <h4 class="font-semibold mb-4">One-Time Fees</h4>
                        <FeeListEditor
                            name="oneTimeFees"
                            xModel="building.oneTimeFees"
                            feeTypes={[FeeType.SECURITY_DEPOSIT, FeeType.PET_DEPOSIT, FeeType.MOVE_IN, FeeType.KEY_DEPOSIT, FeeType.CLEANING]}
                        />
                    </div>
                    
                    <!-- Monthly Fees -->
                    <div class="border-t border-base-200 pt-4 mt-4">
                        <h4 class="font-semibold mb-4">Monthly Fees</h4>
                        <FeeListEditor
                            name="monthlyFees"
                            xModel="building.monthlyFees"
                            feeTypes={[FeeType.PET_FEE, FeeType.PARKING, FeeType.STORAGE, FeeType.ADMIN]}
                        />
                    </div>
                </div>
            </div>
            
            <!-- Policies Section -->
            <div class="card bg-base-100">
                <div class="card-body">
                    <h3 class="card-title text-lg mb-4">Policies</h3>
                    
                    <!-- Pet Policies -->
                    <div class="mb-6">
                        <h4 class="font-semibold mb-4">Pet Policies</h4>
                        <PetPolicyEditor
                            name="petPolicies"
                            xModel="building.petPolicies"
                        />
                    </div>
                    
                    <!-- Screening Criteria -->
                    <div class="border-t border-base-200 pt-4 mt-4">
                        <h4 class="font-semibold mb-4">Screening Criteria</h4>
                        <ScreeningCriteriaForm
                            name="screeningCriteria"
                            xModel="building.screeningCriteria"
                        />
                    </div>
                </div>
            </div>
        </div>

        <!-- Marketing Tab - Property presentation to prospective tenants -->
        <div x-show="activeSectionTab === 'marketing'" class="space-y-6">
            
            <!-- Property Details Section -->
            <div class="card bg-base-100 shadow-lg">
                <div class="card-body">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="card-title text-xl">Property Details & Marketing</h3>
                        <div class="badge badge-info badge-outline">How your property is presented</div>
                    </div>
                    <div class="text-base-content/70 mb-6">
                        Marketing descriptions and highlights that will be shown to prospective tenants on listing sites.
                    </div>
                    
                    <!-- Marketing Description -->
                    <div class="mb-6">
                        <BaseTextarea
                            name="marketingDescription"
                            label="Marketing Description"
                            xModel="building.marketingDescription"
                            placeholder="Experience luxury living in this stunning property featuring modern amenities, spacious layouts, and prime location..."
                            rows={6}
                            helpText="Primary description used on rental listings - highlight key selling points"
                        />
                    </div>
                    
                    <!-- Property Highlights -->
                    <div class="mb-6">
                        <h4 class="font-semibold mb-4">Property Highlights</h4>
                        <div x-data='{ addHighlight() { if (!$parent.building.propertyHighlights) $parent.building.propertyHighlights = []; $parent.building.propertyHighlights.push({ id: Date.now() + Math.random(), highlight: "" }); }, removeHighlight(index) { $parent.building.propertyHighlights.splice(index, 1); } }'>
                            <template x-for="(item, index) in building.propertyHighlights || []" :key="item.id || ('highlight-' + index)">
                                <div class="flex gap-2 items-center mb-2">
                                    <input
                                        type="text"
                                        x-model="item.highlight"
                                        placeholder="Prime downtown location"
                                        class="input input-bordered flex-1"
                                    />
                                    <button 
                                        @click="removeHighlight(index)"
                                        class="btn btn-ghost btn-sm text-error"
                                        title="Remove highlight"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </div>
                            </template>
                            <button 
                                @click="addHighlight()"
                                class="btn btn-primary btn-sm mt-2"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                </svg>
                                Add Highlight
                            </button>
                            <div class="text-sm text-base-content/60 mt-2">
                                Key selling points and features that make your property attractive to tenants
                            </div>
                        </div>
                    </div>
                    
                    <!-- Short Description for Listings -->
                    <div>
                        <BaseTextarea
                            name="shortDescription"
                            label="Short Description (Listing Summary)"
                            xModel="building.shortDescription"
                            placeholder="Modern 1-3BR apartments in prime downtown location with luxury amenities and convenient transit access."
                            rows={3}
                            helpText="Brief summary for listing previews and search results (recommended: 150-200 characters)"
                        />
                    </div>
                </div>
            </div>
            
            <!-- Media Gallery Section -->
            <div class="card bg-base-100 shadow-lg">
                <div class="card-body">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="card-title text-xl">Media Gallery</h3>
                        <div class="badge badge-primary badge-outline">Photos & Virtual Media</div>
                    </div>
                    <div class="text-base-content/70 mb-4">
                        Upload and manage photos that showcase your property to prospective tenants.
                    </div>
                    
                    <PhotoUploader
                        name="photos"
                        xModel="building.photos"
                        buildingId={building.buildingID}
                        unitId="property-photos"
                    />
                </div>
            </div>
            
            <!-- Tour Information Section -->
            <div class="card bg-base-100 shadow-lg">
                <div class="card-body">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="card-title text-xl">Tour Information</h3>
                        <div class="badge badge-success badge-outline">Scheduling & Availability</div>
                    </div>
                    <div class="text-base-content/70 mb-6">
                        Configure tour options and availability for prospective tenants.
                    </div>
                    
                    <!-- Tour Options -->
                    <div class="mb-6">
                        <h4 class="font-semibold mb-4">Available Tour Types</h4>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div class="form-control">
                                <label class="label cursor-pointer">
                                    <span class="label-text">Self-Guided Tours</span>
                                    <input 
                                        type="checkbox" 
                                        class="checkbox checkbox-primary" 
                                        x-model="building.tourAvailability.selfGuidedTours"
                                    />
                                </label>
                                <div class="label">
                                    <span class="label-text-alt text-base-content/60">Tenants can tour independently</span>
                                </div>
                            </div>
                            <div class="form-control">
                                <label class="label cursor-pointer">
                                    <span class="label-text">Virtual Tours</span>
                                    <input 
                                        type="checkbox" 
                                        class="checkbox checkbox-primary" 
                                        x-model="building.tourAvailability.virtualTours"
                                    />
                                </label>
                                <div class="label">
                                    <span class="label-text-alt text-base-content/60">Online 360° or video tours</span>
                                </div>
                            </div>
                            <div class="form-control">
                                <label class="label cursor-pointer">
                                    <span class="label-text">In-Person Tours</span>
                                    <input 
                                        type="checkbox" 
                                        class="checkbox checkbox-primary" 
                                        x-model="building.tourAvailability.inPersonTours"
                                    />
                                </label>
                                <div class="label">
                                    <span class="label-text-alt text-base-content/60">Scheduled tours with staff</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tour Scheduling -->
                    <div class="mb-6">
                        <BaseInput
                            name="tourSchedulingUrl"
                            label="Tour Scheduling URL"
                            type="url"
                            xModel="building.tourAvailability.tourSchedulingUrl"
                            placeholder="https://calendly.com/property-tours"
                            helpText="Link where tenants can schedule tours (e.g., Calendly, property website)"
                        />
                        <span x-show="errors.tourSchedulingUrl" class="label-text-alt text-error" x-text="errors.tourSchedulingUrl"></span>
                    </div>
                    
                    <!-- Tour Hours -->
                    <div>
                        <h4 class="font-semibold mb-4">Tour Availability Hours</h4>
                        <div class="text-sm text-base-content/60 mb-4">
                            Set the days and hours when tours are available. This helps tenants know when they can schedule visits.
                        </div>
                        <div class="grid gap-2">
                            {daysOfWeek.map(day => {
                                const xDataStr = `{ day: '${day}', isOpen: !!(building.tourAvailability?.tourHours?.['${day}']), toggle() { if (!building.tourAvailability) building.tourAvailability = {}; if (!building.tourAvailability.tourHours) building.tourAvailability.tourHours = {}; if (this.isOpen) { building.tourAvailability.tourHours[this.day] = { open: "09:00", close: "17:00" }; } else { delete building.tourAvailability.tourHours[this.day]; } } }`;
                                return (
                                <div class="grid grid-cols-4 gap-4 items-center py-2 border-b border-base-200 last:border-b-0" x-data={xDataStr}>
                                    <div class="form-control">
                                        <label class="label cursor-pointer justify-start gap-3">
                                            <input 
                                                type="checkbox" 
                                                class="checkbox checkbox-sm checkbox-primary" 
                                                x-model="isOpen"
                                                @change="toggle()"
                                            />
                                            <span class="label-text font-medium capitalize">{day}</span>
                                        </label>
                                    </div>
                                    <div class="text-center text-sm text-base-content/60" x-show="!isOpen">Closed</div>
                                    <input
                                        x-show="isOpen"
                                        type="time"
                                        class="input input-sm w-full"
                                        :value="building.tourAvailability?.tourHours?.[day]?.open || ''"
                                        @input="if (building.tourAvailability?.tourHours?.[day]) building.tourAvailability.tourHours[day].open = $event.target.value"
                                        placeholder="09:00"
                                    />
                                    <input
                                        x-show="isOpen"
                                        type="time"
                                        class="input input-sm w-full"
                                        :value="building.tourAvailability?.tourHours?.[day]?.close || ''"
                                        @input="if (building.tourAvailability?.tourHours?.[day]) building.tourAvailability.tourHours[day].close = $event.target.value"
                                        placeholder="17:00"
                                    />
                                </div>
                                )
                            })}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Parking and Storage - moved to hidden section for now, these will be properly integrated later -->
        <div x-show="false" class="space-y-4" style="display: none;">
            <!-- Parking Options -->
            <div class="card bg-base-200">
                <div class="card-body">
                    <h3 class="card-title text-lg">Parking Options</h3>
                    <div x-data='{ addParking() { if (!$parent.building.parkingOptions) $parent.building.parkingOptions = []; $parent.building.parkingOptions.push({ id: Date.now() + Math.random(), type: "uncovered", included: false, fee: null, spaces: 1, description: "" }); }, removeParking(index) { $parent.building.parkingOptions.splice(index, 1); } }'>
                        <template x-for="(parking, index) in building.parkingOptions || []" :key="parking.id || ('parking-' + index)">
                            <div class="border border-base-300 rounded-lg p-4 mb-4">
                                <div class="flex justify-end mb-2">
                                    <button 
                                        @click="removeParking(index)"
                                        class="btn btn-ghost btn-sm text-error"
                                    >Remove</button>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <!-- Parking Type Select -->
                                    <label class="floating-label select-label">
                                        <span>Type</span>
                                        <select
                                            :name="'parking-type-' + index"
                                            x-model="parking.type"
                                            class="select w-full"
                                        >
                                            <option value="garage">Garage</option>
                                            <option value="covered">Covered</option>
                                            <option value="uncovered">Uncovered</option>
                                            <option value="street">Street</option>
                                            <option value="none">None</option>
                                        </select>
                                    </label>
                                    <div class="form-control">
                                        <label class="label cursor-pointer">
                                            <span class="label-text">Included</span>
                                            <input 
                                                type="checkbox" 
                                                class="toggle toggle-primary" 
                                                x-model="parking.included"
                                            />
                                        </label>
                                    </div>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <!-- Monthly Fee Input -->
                                    <label class="floating-label">
                                        <span>Monthly Fee</span>
                                        <input
                                            type="number"
                                            :name="'parking-fee-' + index"
                                            x-model.number="parking.fee"
                                            placeholder="0"
                                            class="input w-full"
                                            min="0"
                                            :disabled="parking.included"
                                        />
                                    </label>
                                    <!-- Number of Spaces Input -->
                                    <label class="floating-label">
                                        <span>Number of Spaces</span>
                                        <input
                                            type="number"
                                            :name="'parking-spaces-' + index"
                                            x-model.number="parking.spaces"
                                            placeholder="1"
                                            class="input w-full"
                                            min="1"
                                        />
                                    </label>
                                </div>
                                <!-- Description Input -->
                                <label class="floating-label">
                                    <span>Description</span>
                                    <input
                                        type="text"
                                        :name="'parking-desc-' + index"
                                        x-model="parking.description"
                                        placeholder="Additional details..."
                                        class="input w-full"
                                    />
                                </label>
                            </div>
                        </template>
                        <button 
                            @click="addParking()"
                            class="btn btn-primary btn-sm"
                        >Add Parking Option</button>
                    </div>
                </div>
            </div>
            
            <!-- Storage Options -->
            <div class="card bg-base-200">
                <div class="card-body">
                    <h3 class="card-title text-lg">Storage Options</h3>
                    <div x-data='{ addStorage() { if (!$parent.building.storageOptions) $parent.building.storageOptions = []; $parent.building.storageOptions.push({ id: Date.now() + Math.random(), type: "closet", included: false, fee: null, dimensions: "", description: "" }); }, removeStorage(index) { $parent.building.storageOptions.splice(index, 1); } }'>
                        <template x-for="(storage, index) in building.storageOptions || []" :key="storage.id || ('storage-' + index)">
                            <div class="border border-base-300 rounded-lg p-4 mb-4">
                                <div class="flex justify-end mb-2">
                                    <button 
                                        @click="removeStorage(index)"
                                        class="btn btn-ghost btn-sm text-error"
                                    >Remove</button>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <!-- Storage Type Select -->
                                    <label class="floating-label select-label">
                                        <span>Type</span>
                                        <select
                                            :name="'storage-type-' + index"
                                            x-model="storage.type"
                                            class="select w-full"
                                        >
                                            <option value="closet">Closet</option>
                                            <option value="basement">Basement</option>
                                            <option value="garage">Garage</option>
                                            <option value="external-unit">External Unit</option>
                                            <option value="none">None</option>
                                        </select>
                                    </label>
                                    <div class="form-control">
                                        <label class="label cursor-pointer">
                                            <span class="label-text">Included</span>
                                            <input 
                                                type="checkbox" 
                                                class="toggle toggle-primary" 
                                                x-model="storage.included"
                                            />
                                        </label>
                                    </div>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <!-- Monthly Fee Input -->
                                    <label class="floating-label">
                                        <span>Monthly Fee</span>
                                        <input
                                            type="number"
                                            :name="'storage-fee-' + index"
                                            x-model.number="storage.fee"
                                            placeholder="0"
                                            class="input w-full"
                                            min="0"
                                            :disabled="storage.included"
                                        />
                                    </label>
                                    <!-- Dimensions Input -->
                                    <label class="floating-label">
                                        <span>Dimensions</span>
                                        <input
                                            type="text"
                                            :name="'storage-dimensions-' + index"
                                            x-model="storage.dimensions"
                                        placeholder="5x10"
                                        class="input w-full"
                                    />
                                </label>
                                </div>
                                <!-- Description Input -->
                                <label class="floating-label">
                                    <span>Description</span>
                                    <input
                                        type="text"
                                        :name="'storage-desc-' + index"
                                        x-model="storage.description"
                                        placeholder="Additional details..."
                                        class="input w-full"
                                    />
                                </label>
                            </div>
                        </template>
                        <button 
                            @click="addStorage()"
                            class="btn btn-primary btn-sm"
                        >Add Storage Option</button>
                    </div>
                </div>
            </div>
            
            <!-- Property Amenities -->
            <div class="card bg-base-200">
                <div class="card-body">
                    <h3 class="card-title text-lg">Property Amenities</h3>
                    <AmenitySelector
                        name="propertyAmenities"
                        xModel="building.propertyAmenities"
                    />
                </div>
            </div>
        </div>


        <!-- Tour Availability - moved to hidden section for now -->
        <div x-show="false" class="space-y-4" style="display: none;">
            <!-- Contact Information -->
            <div class="card bg-base-200">
                <div class="card-body">
                    <h3 class="card-title text-lg">Contact Information</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <BaseInput
                            name="contactName"
                            label="Contact Name"
                            xModel="building.contactInfo.name"
                            placeholder="John Doe"
                        />
                        <BaseInput
                            name="contactPhone"
                            label="Phone Number"
                            type="tel"
                            xModel="building.contactInfo.phone"
                            placeholder="(555) 123-4567"
                        />
                        <span x-show="errors.contactPhone" class="label-text-alt text-error" x-text="errors.contactPhone"></span>
                        <BaseInput
                            name="contactEmail"
                            label="Email Address"
                            type="email"
                            xModel="building.contactInfo.email"
                            placeholder="contact@property.com"
                        />
                        <span x-show="errors.contactEmail" class="label-text-alt text-error" x-text="errors.contactEmail"></span>
                    </div>
                    
                    <!-- Website Fields Section -->
                    <div class="mt-6">
                        <h4 class="text-base font-semibold mb-4 flex items-center gap-2">
                            <span>Website Information</span>
                            <div class="tooltip tooltip-right" data-tip="Property websites are used on listings to show property-specific information. Management websites link to your company's main site for corporate information.">
                                <svg class="w-4 h-4 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                        </h4>
                        
                        <div class="grid grid-cols-1 gap-4">
                            <BaseInput
                                name="contactPropertyWebsite"
                                label="Property Website"
                                type="url"
                                xModel="building.contactInfo.propertyWebsite"
                                placeholder="https://property-specific-site.com"
                                helpText="Main website for this specific property/building - used in listings"
                            />
                            <span x-show="errors.contactPropertyWebsite" class="label-text-alt text-error" x-text="errors.contactPropertyWebsite"></span>
                            
                            <BaseInput
                                name="contactManagementWebsite"
                                label="Management Company Website (Optional)"
                                type="url"
                                xModel="building.contactInfo.managementWebsite"
                                placeholder="https://your-management-company.com"
                                helpText="Your property management company's main website - for corporate information"
                            />
                            <span x-show="errors.contactManagementWebsite" class="label-text-alt text-error" x-text="errors.contactManagementWebsite"></span>
                        </div>
                        
                        <!-- Explanatory text -->
                        <div class="alert alert-info mt-4">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <div class="text-sm">
                                <p><strong>Property Website:</strong> Specific to this building/property - shown on rental listings for prospective tenants</p>
                                <p class="mt-1"><strong>Management Website:</strong> Your company's main website - used for corporate information and branding</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Office Hours -->
                    <div class="mt-6">
                        <h4 class="text-base font-semibold mb-4">Office Hours</h4>
                        <div class="flex flex-col gap-2">
                            {daysOfWeek.map(day => {
                                const xDataStr = `{ day: '${day}', isOpen: !!(building.contactInfo?.officeHours?.['${day}']), toggle() { if (!building.contactInfo) building.contactInfo = {}; if (!building.contactInfo.officeHours) building.contactInfo.officeHours = {}; if (this.isOpen) { building.contactInfo.officeHours[this.day] = { open: "09:00", close: "17:00" }; } else { delete building.contactInfo.officeHours[this.day]; } } }`;
                                return (
                                <div class="grid grid-cols-3 gap-4 items-center" x-data={xDataStr}>
                                    <div class="form-control">
                                        <label class="label cursor-pointer">
                                            <span class="label-text capitalize">{day}</span>
                                            <input 
                                                type="checkbox" 
                                                class="checkbox checkbox-primary" 
                                                x-model="isOpen"
                                                @change="toggle()"
                                            />
                                        </label>
                                    </div>
                                    <input
                                        type="time"
                                        class="input w-full"
                                        :disabled="!isOpen"
                                        :value="building.contactInfo?.officeHours?.[day]?.open || ''"
                                        @input="if (building.contactInfo?.officeHours?.[day]) building.contactInfo.officeHours[day].open = $event.target.value; else if (building.contactInfo?.officeHours) { building.contactInfo.officeHours[day] = { open: $event.target.value, close: '17:00' }; }"
                                        placeholder="09:00"
                                    />
                                    <input
                                        type="time"
                                        class="input w-full"
                                        :disabled="!isOpen"
                                        :value="building.contactInfo?.officeHours?.[day]?.close || ''"
                                        @input="if (building.contactInfo?.officeHours?.[day]) building.contactInfo.officeHours[day].close = $event.target.value; else if (building.contactInfo?.officeHours) { building.contactInfo.officeHours[day] = { open: '09:00', close: $event.target.value }; }"
                                        placeholder="17:00"
                                    />
                                </div>
                            )})}
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Tour Availability -->
            <div class="card bg-base-200">
                <div class="card-body">
                    <h3 class="card-title text-lg">Tour Availability</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                        <div class="form-control">
                            <label class="label cursor-pointer">
                                <span class="label-text">Self-Guided Tours</span>
                                <input 
                                    type="checkbox" 
                                    class="checkbox checkbox-primary" 
                                    x-model="building.tourAvailability.selfGuidedTours"
                                />
                            </label>
                        </div>
                        <div class="form-control">
                            <label class="label cursor-pointer">
                                <span class="label-text">Virtual Tours</span>
                                <input 
                                    type="checkbox" 
                                    class="checkbox checkbox-primary" 
                                    x-model="building.tourAvailability.virtualTours"
                                />
                            </label>
                        </div>
                        <div class="form-control">
                            <label class="label cursor-pointer">
                                <span class="label-text">In-Person Tours</span>
                                <input 
                                    type="checkbox" 
                                    class="checkbox checkbox-primary" 
                                    x-model="building.tourAvailability.inPersonTours"
                                />
                            </label>
                        </div>
                    </div>
                    
                    <BaseInput
                        name="tourSchedulingUrl"
                        label="Tour Scheduling URL"
                        type="url"
                        xModel="building.tourAvailability.tourSchedulingUrl"
                        placeholder="https://calendly.com/property-tours"
                    />
                    <span x-show="errors.tourSchedulingUrl" class="label-text-alt text-error" x-text="errors.tourSchedulingUrl"></span>
                    
                    <!-- Tour Hours -->
                    <div class="mt-6">
                        <h4 class="text-base font-semibold mb-4">Tour Hours</h4>
                        <div class="flex flex-col gap-2">
                            {daysOfWeek.map(day => {
                                const xDataStr = `{ day: '${day}', isOpen: !!(building.tourAvailability?.tourHours?.['${day}']), toggle() { if (!building.tourAvailability) building.tourAvailability = {}; if (!building.tourAvailability.tourHours) building.tourAvailability.tourHours = {}; if (this.isOpen) { building.tourAvailability.tourHours[this.day] = { open: "09:00", close: "17:00" }; } else { delete building.tourAvailability.tourHours[this.day]; } } }`;
                                return (
                                <div class="grid grid-cols-3 gap-4 items-center" x-data={xDataStr}>
                                    <div class="form-control">
                                        <label class="label cursor-pointer">
                                            <span class="label-text capitalize">{day}</span>
                                            <input 
                                                type="checkbox" 
                                                class="checkbox checkbox-primary" 
                                                x-model="isOpen"
                                                @change="toggle()"
                                            />
                                        </label>
                                    </div>
                                    <input
                                        type="time"
                                        class="input w-full"
                                        :disabled="!isOpen"
                                        :value="building.tourAvailability?.tourHours?.[day]?.open || ''"
                                        @input="if (building.tourAvailability?.tourHours?.[day]) building.tourAvailability.tourHours[day].open = $event.target.value"
                                        placeholder="09:00"
                                    />
                                    <input
                                        type="time"
                                        class="input w-full"
                                        :disabled="!isOpen"
                                        :value="building.tourAvailability?.tourHours?.[day]?.close || ''"
                                        @input="if (building.tourAvailability?.tourHours?.[day]) building.tourAvailability.tourHours[day].close = $event.target.value"
                                        placeholder="17:00"
                                    />
                                </div>
                            )})}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Property Photos - now handled in Marketing tab -->
        <div x-show="false" class="space-y-4" style="display: none;">
            <div class="card bg-base-200">
                <div class="card-body">
                    <h3 class="card-title text-lg">Property Photos</h3>
                    <PhotoUploader
                        name="photos"
                        xModel="building.photos"
                        buildingId={building.buildingID}
                        unitId="property-photos"
                    />
                </div>
            </div>
        </div>

        <!-- Units Tab -->
        <div x-show="activeSectionTab === 'units'" class="space-y-4">
            <!-- Quick Actions Toolbar -->
            <div class="card bg-base-100 shadow-xl" data-testid="units-quick-actions">
                <div class="card-body p-4 sm:p-6">
                    <div class="flex flex-col gap-4">
                        <!-- Top row: Selection Controls -->
                        <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
                            <!-- Select All Checkbox -->
                            <label class="flex items-center gap-3 cursor-pointer min-h-[44px]">
                                <input 
                                    type="checkbox" 
                                    class="checkbox checkbox-primary w-5 h-5" 
                                    data-testid="bulk-select-all"
                                    :checked="selectedUnits.size === filteredUnits.length && filteredUnits.length > 0"
                                    :indeterminate="selectedUnits.size > 0 && selectedUnits.size < filteredUnits.length"
                                    @change="toggleSelectAll()"
                                />
                                <span class="font-medium">Select All</span>
                            </label>
                            
                            <!-- Selection Counter -->
                            <div x-show="selectedUnits.size > 0" class="badge badge-primary text-sm py-2 px-3" data-testid="selection-counter">
                                <span x-text="selectedUnits.size"></span> units selected
                            </div>
                        </div>
                        
                        <!-- Bottom row: Bulk Actions (Stack vertically on mobile, horizontal on larger screens) -->
                        <div class="flex flex-col sm:flex-row gap-3">
                            <button 
                                class="btn btn-outline btn-primary min-h-[44px] flex-1 sm:flex-none"
                                data-testid="bulk-status-update"
                                :disabled="selectedUnits.size === 0 || bulkOperation.loading"
                                @click="showBulkStatusDialog = true"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span>Update Status</span>
                            </button>
                            
                            <button 
                                class="btn btn-outline btn-secondary min-h-[44px] flex-1 sm:flex-none"
                                data-testid="bulk-rent-update"
                                :disabled="selectedUnits.size === 0 || bulkOperation.loading"
                                @click="showBulkRentDialog = true"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
                                </svg>
                                <span>Update Rent</span>
                            </button>
                        </div>
                        
                        <!-- Loading indicator -->
                        <div x-show="bulkOperation.loading" class="flex items-center justify-center py-2">
                            <div class="loading loading-spinner loading-sm" data-testid="bulk-operation-loading"></div>
                            <span class="ml-2 text-sm">Processing...</span>
                        </div>
                    </div>
                </div>
                
                <!-- Filters and Search Section (separate card on mobile for better organization) -->
                <div class="card bg-base-100 shadow-xl mt-4">
                    <div class="card-body p-4">
                        <div class="flex flex-col sm:flex-row gap-4 sm:items-center">
                            <!-- Status Filter -->
                            <div class="form-control w-full sm:w-auto">
                                <label class="label pb-1">
                                    <span class="label-text text-sm font-medium">Filter by Status</span>
                                </label>
                                <select 
                                    class="select select-bordered w-full sm:w-48 min-h-[44px]" 
                                    data-testid="filter-status"
                                    x-model="statusFilter"
                                >
                                    <option value="">All Statuses</option>
                                    <option value="Occupied">Occupied Only</option>
                                    <option value="Unoccupied">Available Only</option>
                                    <option value="Notice">Notice Given</option>
                                    <option value="Down">Down/Maintenance</option>
                                </select>
                            </div>
                            
                            <!-- Search -->
                            <div class="form-control w-full sm:w-auto">
                                <label class="label pb-1">
                                    <span class="label-text text-sm font-medium">Search Units</span>
                                </label>
                                <div class="input-group">
                                    <input 
                                        type="text" 
                                        placeholder="Search unit number..." 
                                        class="input input-bordered w-full sm:w-64 min-h-[44px]"
                                        data-testid="search-unit-number"
                                        x-model="searchQuery"
                                    />
                                    <button class="btn btn-square min-h-[44px] min-w-[44px]">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                    </div>
                </div>
            </div>
            
            <!-- Units List -->
            <div class="space-y-3">
                <template x-for="unit in filteredUnits" :key="unit.unitID">
                    <div class="card bg-base-100 shadow-lg hover:shadow-xl transition-shadow" :data-testid="'unit-' + unit.unitID">
                        <div class="card-body p-4">
                            <div class="flex items-center justify-between">
                                <!-- Left: Selection checkbox and unit info -->
                                <div class="flex items-center gap-4">
                                    <input 
                                        type="checkbox" 
                                        class="checkbox checkbox-primary" 
                                        :data-testid="'unit-checkbox-' + unit.unitID"
                                        :checked="isUnitSelected(unit.unitID)"
                                        @change="toggleUnitSelection(unit.unitID)"
                                    />
                                    
                                    <div class="flex flex-col">
                                        <h4 class="font-bold text-lg" x-text="'Unit ' + (unit.unitNumber || unit.unitID)"></h4>
                                        <div class="flex items-center gap-2 text-sm text-base-content/70">
                                            <span x-text="unit.beds + ' bed, ' + unit.baths + ' bath'"></span>
                                            <span x-show="unit.sqft">• <span x-text="unit.sqft"></span> sq ft</span>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Center: Status and availability toggle -->
                                <div class="flex items-center gap-3">
                                    <div class="badge badge-lg" :class="getStatusBadgeClass(unit.vacancyClass)" :data-testid="'unit-status-' + unit.unitID">
                                        <span x-text="unit.vacancyClass || 'Unknown'"></span>
                                    </div>
                                    
                                    <!-- Quick availability toggle -->
                                    <div class="form-control">
                                        <label class="cursor-pointer label gap-2">
                                            <span class="label-text text-xs">Available</span>
                                            <input 
                                                type="checkbox" 
                                                class="toggle toggle-success toggle-sm"
                                                :data-testid="'availability-toggle-' + unit.unitID"
                                                :checked="unit.vacancyClass === 'Unoccupied'"
                                                :disabled="unit.savingField === 'vacancyClass'"
                                                @change="toggleUnitAvailability(unit)"
                                            />
                                        </label>
                                    </div>
                                </div>
                                
                                <!-- Right: Rent and actions -->
                                <div class="flex items-center gap-4">
                                    <!-- Inline rent editing -->
                                    <div class="flex flex-col items-end">
                                        <div x-show="!unit.editingRent" class="flex items-center gap-2">
                                            <span 
                                                class="font-bold text-lg cursor-pointer hover:bg-base-200 px-2 py-1 rounded"
                                                :data-testid="'inline-rent-' + unit.unitID"
                                                @click="unit.editingRent = true; $nextTick(() => $el.nextElementSibling.focus())"
                                            >
                                                <span :data-testid="'unit-rent-' + unit.unitID" x-text="formatCurrency(unit.rent)"></span>
                                            </span>
                                        </div>
                                        
                                        <input 
                                            x-show="unit.editingRent"
                                            type="number"
                                            class="input input-bordered input-sm w-24"
                                            :data-testid="'rent-input-' + unit.unitID"
                                            :value="unit.rent"
                                            min="0"
                                            max="25000"
                                            @blur="unit.editingRent = false"
                                            @keyup.enter="updateUnitRent(unit, $event.target.value)"
                                            @keyup.escape="unit.editingRent = false"
                                        />
                                        
                                        <div class="text-xs text-base-content/50" :data-testid="'last-updated-' + unit.unitID">
                                            <span x-text="formatRelativeTime(unit.lastUpdated)"></span>
                                        </div>
                                    </div>
                                    
                                    <!-- Saving indicator -->
                                    <div x-show="unit.savingField" class="loading loading-spinner loading-sm" :data-testid="'saving-indicator-' + unit.unitID"></div>
                                    
                                    <!-- Edit button to open full UnitCard -->
                                    <button class="btn btn-sm btn-ghost" @click="$dispatch('edit-unit', unit)">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </template>
                
                <!-- No units message -->
                <div x-show="filteredUnits.length === 0" class="card bg-base-200">
                    <div class="card-body text-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H3m2 0h2M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                        </svg>
                        <h3 class="text-lg font-medium mt-2">No units found</h3>
                        <p class="text-base-content/70">
                            <span x-show="statusFilter || searchQuery">Try adjusting your filters or search terms.</span>
                            <span x-show="!statusFilter && !searchQuery">Add some units to get started.</span>
                        </p>
                    </div>
                </div>
            </div>
            
            <!-- Bulk Status Update Dialog -->
            <dialog class="modal" :class="{'modal-open': showBulkStatusDialog}" data-testid="bulk-status-dialog">
                <div class="modal-box">
                    <h3 class="font-bold text-lg">Update Status for Selected Units</h3>
                    <p class="py-4">Change the status for <span class="font-semibold" x-text="selectedUnits.size"></span> selected units:</p>
                    
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">New Status</span>
                        </label>
                        <select class="select select-bordered" data-testid="bulk-status-select" x-model="bulkOperation.statusValue">
                            <option value="">Select status...</option>
                            <option value="Occupied">Occupied - Currently rented</option>
                            <option value="Unoccupied">Unoccupied - Available for rent</option>
                            <option value="Notice">Notice - Tenant gave notice</option>
                            <option value="Down">Down - Maintenance/renovation</option>
                        </select>
                    </div>
                    
                    <div class="modal-action">
                        <button class="btn" @click="showBulkStatusDialog = false">Cancel</button>
                        <button 
                            class="btn btn-primary" 
                            data-testid="bulk-status-confirm"
                            :disabled="!bulkOperation.statusValue || bulkOperation.loading"
                            @click="performBulkStatusUpdate()"
                        >
                            <span x-show="bulkOperation.loading" class="loading loading-spinner loading-sm"></span>
                            Update Status
                        </button>
                    </div>
                </div>
            </dialog>
            
            <!-- Bulk Rent Update Dialog -->
            <dialog class="modal" :class="{'modal-open': showBulkRentDialog}" data-testid="bulk-rent-dialog">
                <div class="modal-box">
                    <h3 class="font-bold text-lg">Update Rent for Selected Units</h3>
                    <p class="py-4">Update rent for <span class="font-semibold" x-text="selectedUnits.size"></span> selected units:</p>
                    
                    <div class="space-y-4">
                        <div class="form-control">
                            <label class="label">
                                <span class="label-text">Update Type</span>
                            </label>
                            <select class="select select-bordered" data-testid="rent-update-type" x-model="bulkOperation.rentUpdateType">
                                <option value="absolute">Set to specific amount</option>
                                <option value="percentage">Percentage increase</option>
                            </select>
                        </div>
                        
                        <div class="form-control">
                            <label class="label">
                                <span class="label-text">
                                    <span x-show="bulkOperation.rentUpdateType === 'absolute'">New Rent Amount ($)</span>
                                    <span x-show="bulkOperation.rentUpdateType === 'percentage'">Increase Percentage (%)</span>
                                </span>
                            </label>
                            <input 
                                type="number" 
                                class="input input-bordered"
                                data-testid="rent-update-value"
                                x-model="bulkOperation.rentValue"
                                :min="bulkOperation.rentUpdateType === 'absolute' ? 0 : -100"
                                :max="bulkOperation.rentUpdateType === 'absolute' ? 25000 : 1000"
                                :placeholder="bulkOperation.rentUpdateType === 'absolute' ? 'Enter rent amount' : 'Enter percentage (e.g., 10 for 10% increase)'"
                            />
                            <div x-show="bulkOperation.rentValue && bulkOperation.rentUpdateType === 'percentage'" class="text-sm text-base-content/70 mt-1">
                                Example: A $1,200 unit would become <span x-text="formatCurrency(1200 * (1 + bulkOperation.rentValue / 100))"></span>
                            </div>
                        </div>
                        
                        <!-- Validation errors -->
                        <div x-show="bulkOperation.rentValue < 0" class="alert alert-error" data-testid="rent-validation-error">
                            <span>Rent must be greater than 0</span>
                        </div>
                        <div x-show="bulkOperation.rentValue > 25000 && bulkOperation.rentUpdateType === 'absolute'" class="alert alert-error" data-testid="rent-validation-error">
                            <span>Rent must be less than $25,000</span>
                        </div>
                    </div>
                    
                    <div class="modal-action">
                        <button class="btn" @click="showBulkRentDialog = false">Cancel</button>
                        <button 
                            class="btn btn-primary" 
                            data-testid="bulk-rent-confirm"
                            :disabled="!bulkOperation.rentValue || bulkOperation.rentValue < 0 || (bulkOperation.rentUpdateType === 'absolute' && bulkOperation.rentValue > 25000) || bulkOperation.loading"
                            @click="performBulkRentUpdate()"
                        >
                            <span x-show="bulkOperation.loading" class="loading loading-spinner loading-sm"></span>
                            Update Rent
                        </button>
                    </div>
                </div>
            </dialog>
        </div>
    </div> <!-- End of building-tab-content -->
    
    <!-- Add Unit Dialog -->
    <dialog class="modal" :open="showAddUnitDialog">
        <div class="modal-box">
            <h3 class="font-bold text-lg mb-4">Add New Unit</h3>
            
            <div class="form-control mb-4">
                <label class="label">
                    <span class="label-text">Unit Number <span class="text-error">*</span></span>
                </label>
                <input
                    type="text"
                    placeholder="101"
                    class="input input-bordered"
                    x-model="newUnit.unitID"
                    @keyup.enter="addUnit()"
                />
            </div>
            
            <div class="form-control mb-4">
                <label class="label">
                    <span class="label-text">Unit Type (Model)</span>
                </label>
                <select
                    class="select select-bordered"
                    x-model="newUnit.modelID"
                >
                    <option value="">No Model (Standalone Unit)</option>
                    <template x-for="(unitType, index) in unitTypes || []" :key="unitType.modelID || ('unittype-' + index)">
                        <option :value="unitType.modelID" x-text="(unitType.modelName || 'Unknown') + ' (' + (unitType.beds || 0) + ' bed, ' + (unitType.baths || 0) + ' bath)'"></option>
                    </template>
                </select>
                <label class="label">
                    <span class="label-text-alt">Optional: Select to inherit properties from this unit type</span>
                </label>
            </div>
            
            <div class="modal-action">
                <button 
                    class="btn btn-ghost"
                    @click="showAddUnitDialog = false"
                >Cancel</button>
                <button 
                    class="btn btn-primary"
                    @click="addUnit()"
                >Add Unit</button>
            </div>
        </div>
        <form method="dialog" class="modal-backdrop">
            <button @click="showAddUnitDialog = false">close</button>
        </form>
    </dialog>
    
    <!-- Add Unit Type Dialog -->
    <dialog class="modal" :open="showAddUnitTypeDialog">
        <div class="modal-box max-w-4xl">
            <div class="flex justify-between items-center mb-4">
                <h3 class="font-bold text-lg">Add New Unit Type</h3>
                <button class="btn btn-ghost btn-sm" @click="closeAddUnitTypeDialog()">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            
            <div x-show="showAddUnitTypeDialog" class="w-full">
                <UnitTypeForm 
                    buildingID={building.buildingID} 
                    onSuccess="$parent.closeAddUnitTypeDialog(); window.location.reload();"
                />
            </div>
        </div>
        <form method="dialog" class="modal-backdrop">
            <button @click="closeAddUnitTypeDialog()">close</button>
        </form>
    </dialog>
</div>

