---
import { getBuilding } from '../../data/buildings';
import { getUnits } from '../../data/units';
import UnitCard from './UnitCard.astro';
import { Resource } from 'sst';

const { buildingID } = Astro.props as { buildingID: string };

const building = await getBuilding(buildingID);
const units = await getUnits(buildingID);

const apiURL = Resource.API.url;
const xData = JSON.stringify({
    original: building,
    building,
    units,
    apiURL,
    showSave: false,
});
---

<div
    class="building-card border rounded shadow p-4"
    x-data={xData}
    x-effect="showSave = JSON.stringify(building) !== JSON.stringify(original)"
>
    <h2 class="font-bold text-xl mb-4">Building {buildingID}</h2>
    <form class="space-y-2">
        <label class="block">
            Street
            <input
                name="street"
                class="border p-1 w-full"
                x-model="building.street"
            />
        </label>
        <label class="block">
            City
            <input
                name="city"
                class="border p-1 w-full"
                x-model="building.city"
            />
        </label>
        <label class="block">
            State
            <input
                name="state"
                class="border p-1 w-full"
                x-model="building.state"
            />
        </label>
        <label class="block">
            Zip
            <input
                name="zip"
                class="border p-1 w-full"
                x-model="building.zip"
            />
        </label>
        <label class="block">
            Description
            <input
                name="description"
                class="border p-1 w-full"
                x-model="building.description"
            />
        </label>
    </form>
    <div class="mt-2 space-x-2">
        <button
            type="button"
            class="save bg-blue-600 text-white px-2 py-1 rounded"
            x-show="showSave"
            x-on:click="await fetch(`${apiURL}buildings/${building.buildingID}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', },
                body: JSON.stringify(building),
            })
            original = { ...building };
            showSave = false;
            "
            >Save</button
        >
        <button
            type="button"
            class="undo bg-gray-300 px-2 py-1 rounded"
            x-show="showSave"
            x-on:click="building={...original}">Undo</button
        >
        <button
            type="button"
            class="delete bg-red-600 text-white px-2 py-1 rounded"
            x-on:click="if (!confirm('Are you sure you want to delete this building and all its units?')) return;
            await fetch(`${apiURL}buildings/${building.buildingID}`, { method: 'DELETE' });
            window.location.href = `/buildings`;
            "
            >Delete Building</button
        >
        <button
            type="button"
            class="add bg-green-600 text-white px-2 py-1 rounded"
            x-on:click="const id = prompt('New unit number?');
            if (!id) return;
            await fetch(`${apiURL}buildings/${building.buildingID}/units`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ unitID: id, buildingID: building.buildingID }),
            });
            window.location.reload();
            ">Add Unit</button
        >
    </div>
    <div class="mt-4 space-y-4">
        {
            units.map((u) => (
                <UnitCard buildingID={buildingID} unitID={u.unitID} />
            ))
        }
    </div>
</div>
