---
import { getBuilding } from "../../data/buildings";
import { getUnits } from "../../data/units";
import UnitCard from "./UnitCard.astro";

const { buildingID } = Astro.props as { buildingID: string };

const building = await getBuilding(buildingID);
const units = await getUnits(buildingID);

const buildingJson = JSON.stringify(building);
---

<div
    class="building-card border rounded shadow p-4"
    data-building={buildingID}
    x-data="{
        showSave: false,
        original: ${buildingJson},
        current: ${buildingJson},
        init() {
            this.$watch('current', () => {
                this.showSave = JSON.stringify(this.original) !== JSON.stringify(this.current);
            });
        },
        async save() {
            await fetch(`/api/buildings/${buildingID}/units/BUILDING`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(this.current),
            });
            this.original = this.current;
            this.showSave = false;
        },
        undo() {
            this.current = this.original;
            this.showSave = false;
        },
        async deleteBuilding() {
            if (!confirm('Delete this building and all units?')) return;
            await fetch(`/api/buildings/${buildingID}`, { method: 'DELETE' });
            this.$el.remove();
        },
        async addUnit() {
            const id = prompt('New unit number?');
            if (!id) return;
            await fetch(`/api/buildings/${buildingID}/units/${id}`, { method: 'POST' });
            location.reload();
        }
    }"
>
    <h2 class="font-bold text-xl mb-4">Building {buildingID}</h2>
    <form class="space-y-2">
        <label class="block">
            Street
            <input name="street" class="border p-1 w-full" x-model="current.street" />
        </label>
        <label class="block">
            City
            <input name="city" class="border p-1 w-full" x-model="current.city" />
        </label>
        <label class="block">
            State
            <input name="state" class="border p-1 w-full" x-model="current.state" />
        </label>
        <label class="block">
            Zip
            <input name="zip" class="border p-1 w-full" x-model="current.zip" />
        </label>
        <label class="block">
            Description
            <input name="description" class="border p-1 w-full" x-model="current.description" />
        </label>
    </form>
    <div class="mt-2 space-x-2">
        <button type="button" class="save bg-blue-600 text-white px-2 py-1 rounded" x-show="showSave" x-on:click="save">Save</button>
        <button type="button" class="undo bg-gray-300 px-2 py-1 rounded" x-show="showSave" x-on:click="undo">Undo</button>
        <button type="button" class="delete bg-red-600 text-white px-2 py-1 rounded" x-on:click="deleteBuilding">Delete Building</button>
        <button type="button" class="add bg-green-600 text-white px-2 py-1 rounded" x-on:click="addUnit">Add Unit</button>
    </div>
    <div class="mt-4 space-y-4">
        {units
            .filter((u) => u.unitID !== 'BUILDING')
            .map((u) => <UnitCard buildingID={buildingID} unitID={u.unitID} />)}
    </div>
</div>
