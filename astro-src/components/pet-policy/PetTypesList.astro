---
export interface Props {
    disabled?: boolean
}

const { disabled = false } = Astro.props;
---

<div class="card bg-base-200">
    <div class="card-body">
        <h3 class="card-title text-base">Allowed Pet Types</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
            <template x-for="petType in petTypes" :key="petType.value">
                <label class="label cursor-pointer justify-start gap-2">
                    <input
                      type="checkbox"
                      class="checkbox checkbox-primary"
                      x-on:change="togglePetType(petType.value)"
                      :checked="isPetTypeSelected(petType.value)"
                        disabled={disabled}
                    />
                    <span class="label-text" x-text="petType.label"></span>
                </label>
            </template>
        </div>

        <!-- Pet Types Summary -->
        <div x-show="selectedPetTypes && selectedPetTypes.length > 0" class="mt-4">
            <div class="text-sm text-base-content/70">
                <span x-text="'Selected: ' + (selectedPetTypes || []).length + ' pet type' + ((selectedPetTypes || []).length === 1 ? '' : 's')"></span>
            </div>
        </div>
    </div>
</div>
