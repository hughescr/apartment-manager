---
import type { BreedRestrictionsProps } from '../../lib/pet-policy/petPolicyTypes';

type Props = BreedRestrictionsProps;

const {
    xModel,
    disabled = false,
    showCommonBreeds = true
} = Astro.props;
---

<div class="card bg-base-200">
    <div class="card-body">
        <h3 class="card-title text-base">Breed Restrictions</h3>

        <!-- Current Restrictions -->
        <div x-show={`${xModel}.breedRestrictions && ${xModel}.breedRestrictions.length > 0`} class="mb-4">
            <div class="text-sm font-medium mb-2">Current Restrictions:</div>
            <div class="flex flex-wrap gap-2">
                <template x-for={`(breed, index) in ${xModel}.breedRestrictions`} :key="breed">
                    <div class="badge badge-warning gap-2">
                        <span x-text="breed"></span>
                        <button
                          type="button"
                          x-on:click="removeBreedRestriction(index)"
                          class="btn btn-ghost btn-xs"
                          disabled={disabled}
                        >
                            ×
                        </button>
                    </div>
                </template>
            </div>
        </div>

        {showCommonBreeds && (
            <div>
                <!-- Quick Add Common Breeds -->
                <button
                  type="button"
                  x-on:click="showBreedRestrictions = !showBreedRestrictions"
                  class="btn btn-sm btn-ghost"
                  disabled={disabled}
                >
                    <span x-text="showBreedRestrictions ? 'Hide' : 'Show'"></span>
{' '}
Common Breed Restrictions
                </button>

                <div x-show="showBreedRestrictions" x-transition class="mt-4">
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
                        <template x-for="breed in commonBreeds" :key="breed">
                            <label class="label cursor-pointer justify-start gap-2">
                                <input
                                  type="checkbox"
                                  class="checkbox checkbox-sm"
                                  x-on:change="toggleCommonBreed(breed)"
                                  checked="isBreedRestricted(breed)"
                                  disabled={disabled}
                                />
                                <span class="label-text text-sm" x-text="breed"></span>
                            </label>
                        </template>
                    </div>
                </div>
            </div>
        )}

        <!-- Custom Breed Input -->
        <div class="form-control mt-4">
            <label class="label">
                <span class="label-text">Add Custom Breed Restriction</span>
            </label>
            <div class="join">
                <input
                  type="text"
                  x-model="newBreedRestriction"
                  placeholder="Enter breed name"
                  class="input input-bordered join-item flex-1"
                  disabled={disabled}
                  x-on:keyup.enter="addBreedRestriction(newBreedRestriction)"
                />
                <button
                  type="button"
                  x-on:click="addBreedRestriction(newBreedRestriction)"
                  class="btn btn-primary join-item"
                  disabled={disabled}
                >
                    Add
                </button>
            </div>
        </div>

        <!-- Breed Restrictions Help -->
        <div class="text-xs text-base-content/70 mt-2">
            Enter specific breeds that are not allowed. Common restrictions include aggressive breeds or breeds prohibited by insurance.
        </div>
    </div>
</div>
