---
import type { PetTypeEditorProps } from '../../lib/pet-policy/petPolicyTypes';

export interface Props extends PetTypeEditorProps {}

const { 
    petTypeIndex,
    disabled = false
} = Astro.props;

const modelPath = `${Astro.slots?.default ? 'modelName' : '$root'}[${Astro.slots?.default ? 'modelName' : '$root.modelName'}].petTypes[${petTypeIndex}]`;
---

<div class="card bg-base-200 border border-base-300">
    <div class="card-body">
        <div class="flex items-center justify-between mb-4">
            <h4 class="text-base font-semibold">Pet Type Configuration #{petTypeIndex + 1}</h4>
            <button
                type="button"
                x-on:click={`removePetTypePolicy(${petTypeIndex})`}
                class="btn btn-ghost btn-sm text-error"
                disabled={disabled}
            >
                Remove
            </button>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Pet Type Selection -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Pet Type <span class="text-error">*</span></span>
                </label>
                <select
                    x-model={`${modelPath}.type`}
                    class="select select-bordered"
                    disabled={disabled}
                >
                    <option value="dog">Dog</option>
                    <option value="cat">Cat</option>
                    <option value="bird">Bird</option>
                    <option value="fish">Fish</option>
                    <option value="small-animal">Small Animal</option>
                </select>
            </div>
            
            <!-- Weight Limit -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Weight Limit (lbs)</span>
                </label>
                <input
                    type="number"
                    x-model={`${modelPath}.weightLimit`}
                    class="input input-bordered"
                    placeholder="e.g., 50"
                    min="0"
                    max="200"
                    disabled={disabled}
                />
            </div>
            
            <!-- Count Limit -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Count Limit</span>
                </label>
                <input
                    type="number"
                    x-model={`${modelPath}.countLimit`}
                    class="input input-bordered"
                    placeholder="e.g., 2"
                    min="1"
                    max="10"
                    disabled={disabled}
                />
            </div>
            
            <!-- Monthly Fee -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Monthly Fee</span>
                </label>
                <div class="join">
                    <span class="join-item btn btn-disabled btn-sm">$</span>
                    <input
                        type="number"
                        x-model={`${modelPath}.fee`}
                        class="input input-bordered join-item flex-1"
                        placeholder="e.g., 50"
                        min="0"
                        max="500"
                        step="5"
                        disabled={disabled}
                    />
                </div>
            </div>
            
            <!-- Deposit -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Deposit</span>
                </label>
                <div class="join">
                    <span class="join-item btn btn-disabled btn-sm">$</span>
                    <input
                        type="number"
                        x-model={`${modelPath}.deposit`}
                        class="input input-bordered join-item flex-1"
                        placeholder="e.g., 500"
                        min="0"
                        max="5000"
                        step="25"
                        disabled={disabled}
                    />
                </div>
            </div>
        </div>
        
        <!-- Breed Restrictions for this pet type -->
        <div class="mt-4">
            <label class="label">
                <span class="label-text">Breed Restrictions (for this pet type)</span>
            </label>
            
            <!-- Current breed restrictions -->
            <div x-show={`${modelPath}.breedRestrictions && ${modelPath}.breedRestrictions.length > 0`} class="mb-2">
                <div class="flex flex-wrap gap-2">
                    <template x-for={`(breed, breedIndex) in ${modelPath}.breedRestrictions || []`} :key={`'breed-${petTypeIndex}-' + breedIndex`}>
                        <div class="badge badge-warning gap-2">
                            <span x-text="breed"></span>
                            <button
                                type="button"
                                x-on:click={`removeBreedRestrictionFromPetType(${petTypeIndex}, breedIndex)`}
                                class="btn btn-ghost btn-xs"
                                disabled={disabled}
                            >
                                ×
                            </button>
                        </div>
                    </template>
                </div>
            </div>
            
            <!-- Add breed restriction input -->
            <div class="join" x-data="{ newBreed: '' }">
                <input
                    type="text"
                    x-model="newBreed"
                    placeholder="Enter breed name (e.g., Pit Bull, German Shepherd)"
                    class="input input-bordered join-item flex-1"
                    disabled={disabled}
                    @keyup.enter={`addBreedRestrictionToPetType(${petTypeIndex}, newBreed); newBreed = ''`}
                />
                <button
                    type="button"
                    x-on:click={`addBreedRestrictionToPetType(${petTypeIndex}, newBreed); newBreed = ''`}
                    class="btn btn-primary join-item"
                    disabled={disabled}
                >
                    Add
                </button>
            </div>
            
            <div class="text-xs text-base-content/70 mt-1">
                Enter breed names separated by commas, or add them one at a time
            </div>
        </div>
        
        <!-- Pet Type Summary -->
        <div class="mt-4 p-3 bg-base-100 rounded text-sm">
            <div class="font-medium mb-1">Summary:</div>
            <div class="grid grid-cols-2 gap-2 text-xs">
                <div>Type:</div>
                <div x-text={`${modelPath}.type || 'Not set'`}></div>
                <template x-if={`${modelPath}.weightLimit`}>
                    <div>Weight Limit:</div>
                </template>
                <template x-if={`${modelPath}.weightLimit`}>
                    <div x-text={`${modelPath}.weightLimit + ' lbs'`}></div>
                </template>
                <template x-if={`${modelPath}.countLimit`}>
                    <div>Count Limit:</div>
                </template>
                <template x-if={`${modelPath}.countLimit`}>
                    <div x-text={`${modelPath}.countLimit`}></div>
                </template>
                <template x-if={`${modelPath}.fee`}>
                    <div>Monthly Fee:</div>
                </template>
                <template x-if={`${modelPath}.fee`}>
                    <div x-text={`'$' + ${modelPath}.fee`}></div>
                </template>
                <template x-if={`${modelPath}.deposit`}>
                    <div>Deposit:</div>
                </template>
                <template x-if={`${modelPath}.deposit`}>
                    <div x-text={`'$' + ${modelPath}.deposit`}></div>
                </template>
            </div>
        </div>
    </div>
</div>