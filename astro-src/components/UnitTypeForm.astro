---
// astro-src/components/UnitTypeForm.astro
import { Resource } from "sst";
import type { UnitTypeData } from "../../src/types";
import { BaseInput, BaseTextarea, AmenitySelector } from "./forms";

const { buildingID, onSuccess } = Astro.props as { 
    buildingID: string;
    onSuccess?: string; // JavaScript code to execute on success
};

const apiURL = Resource.API.url;

const xData = {
    apiURL: apiURL,
    buildingID: buildingID,
    saving: false,
    showForm: false,
    errors: {},
    
    unitType: {
        buildingID: buildingID,
        modelID: '',
        modelName: '',
        countAvailable: null,
        dateAvailable: '',
        beds: 1,
        baths: 1,
        maxOccupants: null,
        minRent: null,
        maxRent: null,
        perPersonRent: null,
        minSqft: null,
        maxSqft: null,
        deposit: null,
        minLeaseTerm: null,
        maxLeaseTerm: null,
        modelAmenities: []
    },

    resetForm() {
        this.unitType = {
            buildingID: this.buildingID,
            modelID: '',
            modelName: '',
            countAvailable: null,
            dateAvailable: '',
            beds: 1,
            baths: 1,
            maxOccupants: null,
            minRent: null,
            maxRent: null,
            perPersonRent: null,
            minSqft: null,
            maxSqft: null,
            deposit: null,
            minLeaseTerm: null,
            maxLeaseTerm: null,
            modelAmenities: []
        };
        this.errors = {};
    },

    validateForm() {
        this.errors = {};
        
        if (!this.unitType.modelID || this.unitType.modelID.trim() === '') {
            this.errors.modelID = 'Model ID is required';
        }
        
        if (!this.unitType.modelName || this.unitType.modelName.trim() === '') {
            this.errors.modelName = 'Model Name is required';
        }
        
        if (this.unitType.beds < 0 || this.unitType.beds > 10) {
            this.errors.beds = 'Beds must be between 0 and 10';
        }
        
        if (this.unitType.baths < 0 || this.unitType.baths > 10) {
            this.errors.baths = 'Baths must be between 0 and 10';
        }
        
        if (this.unitType.minRent && this.unitType.maxRent && this.unitType.minRent > this.unitType.maxRent) {
            this.errors.rent = 'Minimum rent cannot be greater than maximum rent';
        }
        
        if (this.unitType.minSqft && this.unitType.maxSqft && this.unitType.minSqft > this.unitType.maxSqft) {
            this.errors.sqft = 'Minimum square footage cannot be greater than maximum';
        }
        
        if (this.unitType.minLeaseTerm && this.unitType.maxLeaseTerm && this.unitType.minLeaseTerm > this.unitType.maxLeaseTerm) {
            this.errors.lease = 'Minimum lease term cannot be greater than maximum';
        }
        
        return Object.keys(this.errors).length === 0;
    },

    async saveUnitType() {
        if (!this.validateForm()) {
            return;
        }

        this.saving = true;
        try {
            // Clean up null values
            const dataToSend = Object.fromEntries(
                Object.entries(this.unitType).filter(([_, v]) => v !== null && v !== '')
            );
            
            const response = await fetch(this.apiURL + 'buildings/' + this.buildingID + '/unit-types', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dataToSend),
            });
            
            if (response.ok) {
                this.resetForm();
                this.showForm = false;
                if (window.unitTypeFormOnSuccess) {
                    window.unitTypeFormOnSuccess();
                } else {
                    window.location.reload();
                }
            } else {
                const errorData = await response.json();
                console.error('Save failed:', errorData);
                this.errors.submit = errorData.error || 'Failed to create unit type';
            }
        } catch (error) {
            console.error('Network error during save:', error);
            this.errors.submit = 'Network error. Please try again.';
        } finally {
            this.saving = false;
        }
    },

    toggleForm() {
        this.showForm = !this.showForm;
        if (!this.showForm) {
            this.resetForm();
        }
    }
};
---

{onSuccess && (
    <script define:vars={{ onSuccess }}>
        window.unitTypeFormOnSuccess = function() {
            eval(onSuccess);
        };
    </script>
)}

<div x-data={JSON.stringify(xData)} class="unit-type-form">
    <!-- Toggle Button -->
    <button 
        class="btn btn-primary"
        x-on:click="toggleForm()"
        x-show="!showForm"
    >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Unit Type
    </button>

    <!-- Form Modal/Card -->
    <div x-show="showForm" x-transition class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <h3 class="card-title text-xl mb-4">Create New Unit Type</h3>
            
            <!-- Error Summary -->
            <div x-show="errors.submit" class="alert alert-error mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span x-text="errors.submit"></span>
            </div>

            <!-- Basic Information -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <BaseInput
                    name="modelID"
                    label="Model ID"
                    xModel="unitType.modelID"
                    placeholder="e.g., A1, B2, STUDIO"
                    required={true}
                    error="errors.modelID"
                    helpText="Unique identifier for this unit type"
                />
                <BaseInput
                    name="modelName"
                    label="Model Name"
                    xModel="unitType.modelName"
                    placeholder="e.g., Classic Studio, Deluxe 2BR"
                    required={true}
                    error="errors.modelName"
                />
            </div>

            <!-- Availability -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <BaseInput
                    name="countAvailable"
                    label="Units Available"
                    type="number"
                    xModel="unitType.countAvailable"
                    placeholder="0"
                    min="0"
                />
                <BaseInput
                    name="dateAvailable"
                    label="Available From"
                    type="date"
                    xModel="unitType.dateAvailable"
                />
            </div>

            <!-- Unit Configuration -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <BaseInput
                    name="beds"
                    label="Bedrooms"
                    type="number"
                    xModel="unitType.beds"
                    required={true}
                    min="0"
                    max="10"
                    error="errors.beds"
                />
                <BaseInput
                    name="baths"
                    label="Bathrooms"
                    type="number"
                    xModel="unitType.baths"
                    required={true}
                    min="0"
                    max="10"
                    step="0.5"
                    error="errors.baths"
                />
                <BaseInput
                    name="maxOccupants"
                    label="Max Occupants"
                    type="number"
                    xModel="unitType.maxOccupants"
                    placeholder="Not specified"
                    min="1"
                    max="20"
                />
            </div>

            <!-- Pricing Section -->
            <div class="divider">Pricing</div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div>
                    <label class="label">
                        <span class="label-text">Rent Range</span>
                    </label>
                    <div class="flex gap-2 items-center">
                        <BaseInput
                            name="minRent"
                            xModel="unitType.minRent"
                            type="number"
                            placeholder="Min"
                            min="0"
                            class="flex-1"
                        />
                        <span>-</span>
                        <BaseInput
                            name="maxRent"
                            xModel="unitType.maxRent"
                            type="number"
                            placeholder="Max"
                            min="0"
                            class="flex-1"
                        />
                    </div>
                    <div x-show="errors.rent" class="text-error text-sm mt-1" x-text="errors.rent"></div>
                </div>
                
                <BaseInput
                    name="deposit"
                    label="Security Deposit"
                    type="number"
                    xModel="unitType.deposit"
                    placeholder="Not specified"
                    min="0"
                />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <BaseInput
                    name="perPersonRent"
                    label="Per Person Rent (for shared units)"
                    type="number"
                    xModel="unitType.perPersonRent"
                    placeholder="Not applicable"
                    min="0"
                    helpText="Used for units with roommate matching"
                />
            </div>

            <!-- Unit Details Section -->
            <div class="divider">Unit Details</div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div>
                    <label class="label">
                        <span class="label-text">Square Footage Range</span>
                    </label>
                    <div class="flex gap-2 items-center">
                        <BaseInput
                            name="minSqft"
                            xModel="unitType.minSqft"
                            type="number"
                            placeholder="Min"
                            min="0"
                            class="flex-1"
                        />
                        <span>-</span>
                        <BaseInput
                            name="maxSqft"
                            xModel="unitType.maxSqft"
                            type="number"
                            placeholder="Max"
                            min="0"
                            class="flex-1"
                        />
                    </div>
                    <div x-show="errors.sqft" class="text-error text-sm mt-1" x-text="errors.sqft"></div>
                </div>
                
                <div>
                    <label class="label">
                        <span class="label-text">Lease Terms (months)</span>
                    </label>
                    <div class="flex gap-2 items-center">
                        <BaseInput
                            name="minLeaseTerm"
                            xModel="unitType.minLeaseTerm"
                            type="number"
                            placeholder="Min"
                            min="1"
                            max="24"
                            class="flex-1"
                        />
                        <span>-</span>
                        <BaseInput
                            name="maxLeaseTerm"
                            xModel="unitType.maxLeaseTerm"
                            type="number"
                            placeholder="Max"
                            min="1"
                            max="24"
                            class="flex-1"
                        />
                    </div>
                    <div x-show="errors.lease" class="text-error text-sm mt-1" x-text="errors.lease"></div>
                </div>
            </div>

            <!-- Model Amenities -->
            <div class="divider">Default Amenities</div>
            <div class="mb-6">
                <AmenitySelector
                    name="modelAmenities"
                    label="Select default amenities for all units of this type"
                    xModel="unitType.modelAmenities"
                    helpText="These amenities will be the default for all units created with this model"
                />
            </div>

            <!-- Form Actions -->
            <div class="card-actions justify-end">
                <button 
                    class="btn btn-ghost"
                    x-on:click="toggleForm()"
                    :disabled="saving"
                >
                    Cancel
                </button>
                <button 
                    class="btn btn-primary"
                    x-on:click="saveUnitType()"
                    :disabled="saving"
                    :class="{'loading': saving}"
                >
                    <span x-show="!saving">Create Unit Type</span>
                    <span x-show="saving">Creating...</span>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Smooth transitions */
    [x-transition] {
        transition: all 0.3s ease;
    }
    
    /* Form styling */
    .unit-type-form {
        @apply mb-6;
    }
    
    /* Divider styling */
    .divider {
        @apply my-6 font-semibold text-base-content/70;
    }
    
    /* Ensure number inputs don't show spinners */
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    
    input[type="number"] {
        -moz-appearance: textfield;
    }
</style>