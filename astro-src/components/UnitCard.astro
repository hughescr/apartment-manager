---
// astro-src/components/UnitCard.astro
import Saving from "./Saving.astro";
import { Resource } from "sst";

const { unit } = Astro.props as { unit: any }; // Will define a proper type later

const apiURL = Resource.API.url;

const xDataString = `{
    unit: ${JSON.stringify(unit)},
    originalUnit: ${JSON.stringify(unit)}, // Deep copy for original state
    apiURL: "${apiURL}",
    saving: false, // Stores the name of the field being saved

    isDirty() {
        return JSON.stringify(this.unit) !== JSON.stringify(this.originalUnit);
    },

    async saveUnit(myThis) {
        myThis = this || myThis; // Allow passing 'this' context
        if (!myThis.isDirty()) { return; }

        this.saving = true;
        try {
            const response = await fetch(myThis.apiURL + 'buildings/' + myThis.unit.buildingID + '/units/' + myThis.unit.unitID, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(myThis.unit),
            });
            if (response.ok) {
                myThis.originalUnit = { ...myThis.unit };
            } else {
                console.error('Save failed:', response.statusText);
                // Revert to original value on save failure
                myThis.unit = { ...myThis.originalUnit };
            }
        } catch (error) {
            console.error('Network error during save:', error);
            // Revert to original value on network error
            myThis.unit = { ...myThis.originalUnit };
        } finally {
            myThis.saving = false;
        }
    },

    async deleteUnit() {
        if (!confirm('Are you sure you want to delete this unit?')) return;
        try {
            const response = await fetch(this.apiURL + 'buildings/' + this.unit.buildingID + '/units/' + this.unit.unitID, { method: 'DELETE' });
            if (response.ok) {
                // Reload the page or remove the row from the DOM
                window.location.reload(); // Simplest for now
            } else {
                console.error('Delete failed:', response.statusText);
            }
        } catch (error) {
            console.error('Network error during delete:', error);
        }
    }
}`;
---
<li x-data={xDataString} class="list-row pt-2 border relative" :class="{'opacity-50': saving}">
    <div>
        <div class="uppercase font-semibold">Unit</div>
        <input type="text" x-model="unit.unitID" class="max-w-15 input input-ghost input-lg" disabled/>
    </div>
    <div>
        <div class="uppercase font-semibold">Description</div>
        <textarea class="textarea text-xs w-full" placeholder="Description" x-text="unit.description" x-on:blur="() => saveUnit(this)"/>
    </div>
    <div>
        <div class="uppercase font-semibold">Beds</div>
        <input x-model.number="unit.beds" class="max-w-15 input input-ghost input-lg validator" min="0" max="10" x-on:blur="() => saveUnit(this)"/>
    </div>
    <div>
        <div class="uppercase font-semibold">Baths</div>
        <input x-model.number="unit.baths" class="max-w-15 input input-ghost input-lg validator" min="0" max="10" x-on:blur="() => saveUnit(this)"/>
    </div>
    <div>
        <div class="uppercase font-semibold">Sqft.</div>
        <input x-model.number="unit.sqft" class="max-w-20 input input-ghost input-lg validator" min="50" max="10000" x-on:blur="() => saveUnit(this)"/>
    </div>
    <div>
        <div class="uppercase font-semibold">Monthly Rent ($)</div>
        <input x-model.number="unit.rent" class="max-w-20 input input-ghost input-lg validator" min="10" max="25000" x-on:blur="() => saveUnit(this)"/>
    </div>
    <div>
        <div class="uppercase font-semibold">Occupied?</div>
        <label class="toggle text-base-content mt-3">
            <input type="checkbox" x-model.number="unit.occupied"  x-init="$watch('unit.occupied', () => saveUnit(this))"/>
            <svg aria-label="disabled" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18" />
                <path d="m6 6 12 12" />
            </svg>
            <svg aria-label="enabled" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <g stroke-linejoin="round" stroke-linecap="round" stroke-width="4" fill="none" stroke="currentColor">
                    <path d="M20 6 9 17l-5-5" />
                </g>
            </svg>
        </label>
    </div>
    <div>
        <div class="uppercase font-semibold">Available From</div>
        <input type="date" x-model="unit.availableDate" class="max-w-36 input input-ghost input-lg validator" min="2025-01-01" max="2028-01-01" x-on:blur="() => saveUnit(this)"/>
    </div>
    <button class="btn btn-error" x-on:click="deleteUnit()">Delete</button>
    <Saving />
</li>
