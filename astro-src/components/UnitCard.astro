---
// astro-src/components/UnitCard.astro
import Saving from "./Saving.astro";
import { Resource } from "sst";
import type { UnitData, UnitTypeData } from "../../src/types";
import { AmenitySelector, PhotoUploader } from "./forms";

const { unit, unitTypes = [] } = Astro.props as { unit: UnitData; unitTypes: UnitTypeData[] };

const apiURL = Resource.API.url;


// Initialize missing properties
if (!unit.unitAmenities) unit.unitAmenities = [];
if (!unit.photos) unit.photos = [];
if (!unit.websiteStatus) unit.websiteStatus = {};
if (!unit.listingIds) unit.listingIds = {};
---

<script is:inline>
function unitCardData() {
    return {
        unit: null,
        originalUnit: null,
        unitTypes: null,
        selectedUnitType: null,
        apiURL: null,
        saving: false, // Stores the name of the field being saved
        errors: {},
        expandedSections: {
            details: false,
            amenities: false,
            photos: false,
            websites: false
        },
        
        init() {
            // Parse data from data attributes
            this.unit = JSON.parse(this.$el.dataset.unit);
            this.unitTypes = JSON.parse(this.$el.dataset.unitTypes);
            this.apiURL = this.$el.dataset.apiUrl;
            this.originalUnit = JSON.parse(JSON.stringify(this.unit));
            
            // Initialize unit amenities if not present
            if (!this.unit.unitAmenities) this.unit.unitAmenities = [];
            if (!this.unit.photos) this.unit.photos = [];
            if (!this.unit.websiteStatus) this.unit.websiteStatus = {};
            if (!this.unit.listingIds) this.unit.listingIds = {};
            
            // Find and set the selected unit type
            if (this.unit.modelID) {
                this.selectedUnitType = this.unitTypes.find(ut => ut.modelID === this.unit.modelID) || null;
            }
        },

        isDirty() {
            return JSON.stringify(this.unit) !== JSON.stringify(this.originalUnit);
        },
        
        isInherited(fieldName) {
            if (!this.selectedUnitType) return false;
            
            // Check if the field value is null/undefined/empty in the unit
            const unitValue = this.unit[fieldName];
            const isEmptyValue = unitValue === null || unitValue === undefined || unitValue === '';
            
            // Check if the unit type has a value for this field
            const modelFieldMap = {
                'beds': 'beds',
                'baths': 'baths',
                'sqft': ['minSqft', 'maxSqft'],
                'rent': ['minRent', 'maxRent'],
                'maxOccupants': 'maxOccupants',
                'perPersonRent': 'perPersonRent',
                'deposit': 'deposit',
                'minLeaseTerm': 'minLeaseTerm',
                'maxLeaseTerm': 'maxLeaseTerm'
            };
            
            const modelField = modelFieldMap[fieldName];
            if (!modelField) return false;
            
            if (Array.isArray(modelField)) {
                return isEmptyValue && modelField.some(f => this.selectedUnitType[f] !== null && this.selectedUnitType[f] !== undefined);
            }
            
            return isEmptyValue && this.selectedUnitType[modelField] !== null && this.selectedUnitType[modelField] !== undefined;
        },
        
        getInheritedValue(fieldName) {
            if (!this.selectedUnitType) return null;
            
            const modelFieldMap = {
                'beds': 'beds',
                'baths': 'baths',
                'sqft': ['minSqft', 'maxSqft'],
                'rent': ['minRent', 'maxRent'],
                'maxOccupants': 'maxOccupants',
                'perPersonRent': 'perPersonRent',
                'deposit': 'deposit',
                'minLeaseTerm': 'minLeaseTerm',
                'maxLeaseTerm': 'maxLeaseTerm'
            };
            
            const modelField = modelFieldMap[fieldName];
            if (!modelField) return null;
            
            if (Array.isArray(modelField)) {
                const [min, max] = modelField.map(f => this.selectedUnitType[f]);
                if (min !== null && max !== null) return `${min}-${max}`;
                if (min !== null) return `${min}+`;
                if (max !== null) return `Up to ${max}`;
                return null;
            }
            
            return this.selectedUnitType[modelField];
        },
        
        getEffectiveValue(fieldName) {
            const unitValue = this.unit[fieldName];
            if (unitValue !== null && unitValue !== undefined && unitValue !== '') {
                return unitValue;
            }
            return this.getInheritedValue(fieldName);
        },
        
        getEffectiveAmenities() {
            // If unit has amenities defined, use them (override)
            if (this.unit.unitAmenities && this.unit.unitAmenities.length > 0) {
                return this.unit.unitAmenities;
            }
            // Otherwise, use model amenities if available
            if (this.selectedUnitType && 'modelAmenities' in this.selectedUnitType && this.selectedUnitType.modelAmenities) {
                return this.selectedUnitType.modelAmenities;
            }
            return [];
        },
        
        onModelChange() {
            this.unit.modelID = this.selectedUnitType ? this.selectedUnitType.modelID : undefined;
            // Trigger save when model changes
            this.saveUnit(this);
        },

        validateForm() {
            this.errors = {};
            
            // Validate unit number (required)
            if (!this.unit.unitNumber || this.unit.unitNumber.trim() === '') {
                this.errors.unitNumber = 'Unit number is required';
            }
            
            // Validate beds (0-10)
            if (this.unit.beds !== null && this.unit.beds !== undefined) {
                if (this.unit.beds < 0 || this.unit.beds > 10) {
                    this.errors.beds = 'Beds must be between 0 and 10';
                }
            }
            
            // Validate baths (0-10)
            if (this.unit.baths !== null && this.unit.baths !== undefined) {
                if (this.unit.baths < 0 || this.unit.baths > 10) {
                    this.errors.baths = 'Baths must be between 0 and 10';
                }
            }
            
            // Validate sqft (> 0)
            if (this.unit.sqft !== null && this.unit.sqft !== undefined) {
                if (this.unit.sqft <= 0) {
                    this.errors.sqft = 'Square footage must be greater than 0';
                }
                if (this.unit.sqft > 10000) {
                    this.errors.sqft = 'Square footage must be less than 10,000';
                }
            }
            
            // Validate rent (> 0)
            if (this.unit.rent !== null && this.unit.rent !== undefined) {
                if (this.unit.rent <= 0) {
                    this.errors.rent = 'Rent must be greater than 0';
                }
                if (this.unit.rent > 25000) {
                    this.errors.rent = 'Rent must be less than $25,000';
                }
            }
            
            // Validate maxOccupants (1-20)
            if (this.unit.maxOccupants !== null && this.unit.maxOccupants !== undefined) {
                if (this.unit.maxOccupants < 1 || this.unit.maxOccupants > 20) {
                    this.errors.maxOccupants = 'Max occupants must be between 1 and 20';
                }
            }
            
            // Validate perPersonRent (>= 0)
            if (this.unit.perPersonRent !== null && this.unit.perPersonRent !== undefined) {
                if (this.unit.perPersonRent < 0) {
                    this.errors.perPersonRent = 'Per person rent must be 0 or greater';
                }
            }
            
            // Validate deposit (>= 0)
            if (this.unit.deposit !== null && this.unit.deposit !== undefined) {
                if (this.unit.deposit < 0) {
                    this.errors.deposit = 'Deposit must be 0 or greater';
                }
            }
            
            // Validate lease terms
            if (this.unit.minLeaseTerm !== null && this.unit.minLeaseTerm !== undefined) {
                if (this.unit.minLeaseTerm < 1 || this.unit.minLeaseTerm > 24) {
                    this.errors.minLeaseTerm = 'Min lease term must be between 1 and 24 months';
                }
            }
            
            if (this.unit.maxLeaseTerm !== null && this.unit.maxLeaseTerm !== undefined) {
                if (this.unit.maxLeaseTerm < 1 || this.unit.maxLeaseTerm > 24) {
                    this.errors.maxLeaseTerm = 'Max lease term must be between 1 and 24 months';
                }
            }
            
            // Validate lease term logic
            if (this.unit.minLeaseTerm && this.unit.maxLeaseTerm && this.unit.minLeaseTerm > this.unit.maxLeaseTerm) {
                this.errors.leaseTerm = 'Minimum lease term cannot be greater than maximum';
            }
            
            // Validate available date
            if (this.unit.availableDate) {
                const availDate = new Date(this.unit.availableDate);
                const minDate = new Date('2025-01-01');
                const maxDate = new Date('2028-01-01');
                
                if (availDate < minDate || availDate > maxDate) {
                    this.errors.availableDate = 'Available date must be between 2025 and 2028';
                }
            }
            
            // Validate rent special dates
            if (this.unit.unitRentSpecial) {
                if (this.unit.unitRentSpecial.startDate && this.unit.unitRentSpecial.endDate) {
                    const startDate = new Date(this.unit.unitRentSpecial.startDate);
                    const endDate = new Date(this.unit.unitRentSpecial.endDate);
                    
                    if (startDate > endDate) {
                        this.errors.rentSpecial = 'Special start date must be before end date';
                    }
                }
                
                // If any rent special field is filled, title is required
                if ((this.unit.unitRentSpecial.description || this.unit.unitRentSpecial.startDate || this.unit.unitRentSpecial.endDate) 
                    && (!this.unit.unitRentSpecial.title || this.unit.unitRentSpecial.title.trim() === '')) {
                    this.errors.rentSpecialTitle = 'Special title is required when adding a rent special';
                }
            }
            
            return Object.keys(this.errors).length === 0;
        },

        clearFieldError(fieldName) {
            delete this.errors[fieldName];
        },

        async saveUnit(myThis) {
            myThis = this || myThis; // Allow passing 'this' context
            if (!myThis.isDirty()) { return; }

            if (!myThis.validateForm()) {
                console.error('Validation failed:', myThis.errors);
                return;
            }

            this.saving = true;
            try {
                const response = await fetch(myThis.apiURL + 'buildings/' + myThis.unit.buildingID + '/units/' + myThis.unit.unitID, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(myThis.unit),
                });
                if (response.ok) {
                    myThis.originalUnit = { ...myThis.unit };
                    myThis.errors = {}; // Clear all errors on successful save
                } else {
                    const errorData = await response.json();
                    console.error('Save failed:', errorData);
                    myThis.errors.submit = errorData.error || 'Failed to save unit';
                    // Revert to original value on save failure
                    myThis.unit = { ...myThis.originalUnit };
                }
            } catch (error) {
                console.error('Network error during save:', error);
                myThis.errors.submit = 'Network error. Please try again.';
                // Revert to original value on network error
                myThis.unit = { ...myThis.originalUnit };
            } finally {
                myThis.saving = false;
            }
        },

        async deleteUnit() {
            if (!confirm('Are you sure you want to delete this unit?')) return;
            try {
                const response = await fetch(this.apiURL + 'buildings/' + this.unit.buildingID + '/units/' + this.unit.unitID, { method: 'DELETE' });
                if (response.ok) {
                    // Reload the page or remove the row from the DOM
                    window.location.reload(); // Simplest for now
                } else {
                    console.error('Delete failed:', response.statusText);
                }
            } catch (error) {
                console.error('Network error during delete:', error);
            }
        },
        
        formatCurrency(value) {
            if (!value) return '';
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                minimumFractionDigits: 0,
                maximumFractionDigits: 0
            }).format(value);
        },
        
        toggleSection(section) {
            this.expandedSections[section] = !this.expandedSections[section];
        }
    };
}
</script>

<li x-data="unitCardData()" x-init="init(); $watch('unit', () => saveUnit(this))" class="card bg-base-100 shadow-xl mb-4" :class="{'opacity-50': saving}" data-unit={JSON.stringify(unit)} data-unit-types={JSON.stringify(unitTypes)} data-api-url={apiURL}>
    <div class="card-body">
        <!-- Error Summary -->
        <div x-show="Object.keys(errors).length > 0" class="alert alert-error mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
                <span x-show="errors.submit" x-text="errors.submit"></span>
                <span x-show="!errors.submit">Please fix the validation errors below before saving.</span>
            </div>
        </div>
        
        <!-- Header with Unit Number and Model Selection -->
        <div class="flex justify-between items-start mb-4">
            <div class="flex-1">
                <div class="flex items-center gap-4">
                    <div>
                        <label class="label"><span class="label-text font-semibold">Unit # <span class="text-error">*</span></span></label>
                        <input 
                            type="text" 
                            x-model.lazy="unit.unitNumber" 
                            class="input input-bordered input-lg font-bold"
                            :class="{'input-error': errors.unitNumber}"
                            placeholder="Unit Number"
                        />
                        <div x-show="errors.unitNumber" class="text-error text-sm mt-1" x-text="errors.unitNumber"></div>
                    </div>
                    <div class="flex-1">
                        <label class="label"><span class="label-text font-semibold">Model/Type</span></label>
                        <select 
                            x-model="selectedUnitType"
                            x-on:change="onModelChange()"
                            class="select select-bordered w-full"
                        >
                            <option :value="null">No Model (Standalone Unit)</option>
                            <template x-for="unitType in unitTypes" :key="unitType.modelID">
                                <option 
                                    :value="unitType"
                                    :selected="unit.modelID === unitType.modelID"
                                    x-text="unitType.modelName + ' (' + unitType.beds + ' bed, ' + unitType.baths + ' bath)'"
                                ></option>
                            </template>
                        </select>
                    </div>
                </div>
                <div class="text-sm text-base-content/70 mt-1">
                    Unit ID: <span x-text="unit?.unitID || 'Loading...'"></span>
                    <span x-show="selectedUnitType" class="ml-2">
                        | Model: <span x-text="selectedUnitType?.modelName"></span>
                    </span>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <Saving />
                <button class="btn btn-error btn-sm" x-on:click="deleteUnit()">Delete</button>
            </div>
        </div>

        <!-- Main Details Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-6">
            <!-- Configuration -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Beds</span>
                    <span x-show="isInherited('beds')" class="badge badge-info badge-xs">inherited</span>
                </label>
                <div class="relative">
                    <input 
                        type="number" 
                        x-model.number.lazy="unit.beds" 
                        class="input input-bordered w-full"
                        :class="{'input-ghost': isInherited('beds'), 'input-error': errors.beds}"
                        min="0" max="10"
                        :placeholder="getInheritedValue('beds') || 'Not set'"
                    />
                    <span x-show="isInherited('beds')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-base-content/50">
                        <span x-text="getInheritedValue('beds')"></span>
                    </span>
                </div>
                <div x-show="errors.beds" class="text-error text-sm mt-1" x-text="errors.beds"></div>
            </div>
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Baths</span>
                    <span x-show="isInherited('baths')" class="badge badge-info badge-xs">inherited</span>
                </label>
                <div class="relative">
                    <input 
                        type="number" 
                        x-model.number.lazy="unit.baths" 
                        class="input input-bordered w-full"
                        :class="{'input-ghost': isInherited('baths'), 'input-error': errors.baths}"
                        min="0" max="10" step="0.5"
                        :placeholder="getInheritedValue('baths') || 'Not set'"
                    />
                    <span x-show="isInherited('baths')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-base-content/50">
                        <span x-text="getInheritedValue('baths')"></span>
                    </span>
                </div>
                <div x-show="errors.baths" class="text-error text-sm mt-1" x-text="errors.baths"></div>
            </div>
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Sqft</span>
                    <span x-show="isInherited('sqft')" class="badge badge-info badge-xs">inherited</span>
                </label>
                <div class="relative">
                    <input 
                        type="number" 
                        x-model.number.lazy="unit.sqft" 
                        class="input input-bordered w-full"
                        :class="{'input-ghost': isInherited('sqft'), 'input-error': errors.sqft}"
                        min="50" max="10000"
                        :placeholder="getInheritedValue('sqft') || 'Not set'"
                    />
                    <span x-show="isInherited('sqft')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-base-content/50">
                        <span x-text="getInheritedValue('sqft')"></span>
                    </span>
                </div>
                <div x-show="errors.sqft" class="text-error text-sm mt-1" x-text="errors.sqft"></div>
            </div>
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Monthly Rent ($)</span>
                    <span x-show="isInherited('rent')" class="badge badge-info badge-xs">inherited</span>
                </label>
                <div class="relative">
                    <input 
                        type="number" 
                        x-model.number.lazy="unit.rent" 
                        class="input input-bordered w-full"
                        :class="{'input-ghost': isInherited('rent'), 'input-error': errors.rent}"
                        min="10" max="25000"
                        :placeholder="getInheritedValue('rent') || 'Not set'"
                    />
                    <span x-show="isInherited('rent')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-base-content/50">
                        <span x-text="getInheritedValue('rent')"></span>
                    </span>
                </div>
                <div x-show="errors.rent" class="text-error text-sm mt-1" x-text="errors.rent"></div>
            </div>
            
            <!-- Occupancy -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Max Occupants</span>
                    <span x-show="isInherited('maxOccupants')" class="badge badge-info badge-xs">inherited</span>
                </label>
                <div class="relative">
                    <input 
                        type="number" 
                        x-model.number.lazy="unit.maxOccupants" 
                        class="input input-bordered w-full"
                        :class="{'input-ghost': isInherited('maxOccupants'), 'input-error': errors.maxOccupants}"
                        min="1" max="20"
                        :placeholder="getInheritedValue('maxOccupants') || 'Not set'"
                    />
                    <span x-show="isInherited('maxOccupants')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-base-content/50">
                        <span x-text="getInheritedValue('maxOccupants')"></span>
                    </span>
                </div>
                <div x-show="errors.maxOccupants" class="text-error text-sm mt-1" x-text="errors.maxOccupants"></div>
            </div>
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Per Person Rent</span>
                    <span x-show="isInherited('perPersonRent')" class="badge badge-info badge-xs">inherited</span>
                </label>
                <div class="relative">
                    <input 
                        type="number" 
                        x-model.number.lazy="unit.perPersonRent" 
                        class="input input-bordered w-full"
                        :class="{'input-ghost': isInherited('perPersonRent'), 'input-error': errors.perPersonRent}"
                        min="0"
                        :placeholder="getInheritedValue('perPersonRent') || 'Not set'"
                    />
                    <span x-show="isInherited('perPersonRent')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-base-content/50">
                        <span x-text="getInheritedValue('perPersonRent')"></span>
                    </span>
                </div>
                <div x-show="errors.perPersonRent" class="text-error text-sm mt-1" x-text="errors.perPersonRent"></div>
            </div>
            
            <!-- Financial -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Deposit</span>
                    <span x-show="isInherited('deposit')" class="badge badge-info badge-xs">inherited</span>
                </label>
                <div class="relative">
                    <input 
                        type="number" 
                        x-model.number.lazy="unit.deposit" 
                        class="input input-bordered w-full"
                        :class="{'input-ghost': isInherited('deposit'), 'input-error': errors.deposit}"
                        min="0"
                        :placeholder="getInheritedValue('deposit') || 'Not set'"
                    />
                    <span x-show="isInherited('deposit')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-base-content/50">
                        <span x-text="getInheritedValue('deposit')"></span>
                    </span>
                </div>
                <div x-show="errors.deposit" class="text-error text-sm mt-1" x-text="errors.deposit"></div>
            </div>
            
            <!-- Availability -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Occupied?</span>
                </label>
                <label class="toggle">
                    <input type="checkbox" x-model.boolean.lazy="unit.occupied"/>
                    <svg aria-label="disabled" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                        <path d="M18 6 6 18" />
                        <path d="m6 6 12 12" />
                    </svg>
                    <svg aria-label="enabled" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5">
                        <g stroke-linejoin="round" stroke-linecap="round" stroke-width="4" fill="none" stroke="currentColor">
                            <path d="M20 6 9 17l-5-5" />
                        </g>
                    </svg>
                </label>
            </div>
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Available From</span>
                </label>
                <input 
                    type="date" 
                    x-model.lazy="unit.availableDate" 
                    class="input input-bordered w-full"
                    :class="{'input-error': errors.availableDate}"
                    min="2025-01-01" max="2028-01-01"
                />
                <div x-show="errors.availableDate" class="text-error text-sm mt-1" x-text="errors.availableDate"></div>
            </div>
            
            <!-- Lease Terms -->
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Min Lease (months)</span>
                    <span x-show="isInherited('minLeaseTerm')" class="badge badge-info badge-xs">inherited</span>
                </label>
                <div class="relative">
                    <input 
                        type="number" 
                        x-model.number.lazy="unit.minLeaseTerm" 
                        class="input input-bordered w-full"
                        :class="{'input-ghost': isInherited('minLeaseTerm'), 'input-error': errors.minLeaseTerm || errors.leaseTerm}"
                        min="1" max="24"
                        :placeholder="getInheritedValue('minLeaseTerm') || 'Not set'"
                    />
                    <span x-show="isInherited('minLeaseTerm')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-base-content/50">
                        <span x-text="getInheritedValue('minLeaseTerm')"></span>
                    </span>
                </div>
                <div x-show="errors.minLeaseTerm" class="text-error text-sm mt-1" x-text="errors.minLeaseTerm"></div>
                <div x-show="errors.leaseTerm" class="text-error text-sm mt-1" x-text="errors.leaseTerm"></div>
            </div>
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Max Lease (months)</span>
                    <span x-show="isInherited('maxLeaseTerm')" class="badge badge-info badge-xs">inherited</span>
                </label>
                <div class="relative">
                    <input 
                        type="number" 
                        x-model.number.lazy="unit.maxLeaseTerm" 
                        class="input input-bordered w-full"
                        :class="{'input-ghost': isInherited('maxLeaseTerm'), 'input-error': errors.maxLeaseTerm}"
                        min="1" max="24"
                        :placeholder="getInheritedValue('maxLeaseTerm') || 'Not set'"
                    />
                    <span x-show="isInherited('maxLeaseTerm')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-base-content/50">
                        <span x-text="getInheritedValue('maxLeaseTerm')"></span>
                    </span>
                </div>
                <div x-show="errors.maxLeaseTerm" class="text-error text-sm mt-1" x-text="errors.maxLeaseTerm"></div>
            </div>
        </div>
        
        <!-- Descriptions -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Internal Description</span>
                </label>
                <textarea 
                    x-model.lazy="unit.description" 
                    class="textarea textarea-bordered w-full"
                    rows="3"
                    placeholder="Internal notes about this unit"
                ></textarea>
            </div>
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text font-semibold">Marketing Description</span>
                </label>
                <textarea 
                    x-model.lazy="unit.unitDescription" 
                    class="textarea textarea-bordered w-full"
                    rows="3"
                    placeholder="Unit-specific marketing description for listings"
                ></textarea>
            </div>
        </div>
        
        
        <!-- Unit Rent Special -->
        <div class="form-control mb-6">
            <label class="label">
                <span class="label-text font-semibold">Unit Rent Special</span>
            </label>
            <div class="border border-base-300 rounded-lg p-4" :class="{'border-error': errors.rentSpecial || errors.rentSpecialTitle}">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-2">
                    <div>
                        <input 
                            type="text"
                            :value="unit.unitRentSpecial?.title || ''"
                            x-on:change="if (unit && !unit.unitRentSpecial) unit.unitRentSpecial = {}; if (unit) unit.unitRentSpecial.title = $event.target.value"
                            class="input input-bordered w-full"
                            :class="{'input-error': errors.rentSpecialTitle}"
                            placeholder="Special Title (e.g., 'First Month Free')"
                        />
                        <div x-show="errors.rentSpecialTitle" class="text-error text-sm mt-1" x-text="errors.rentSpecialTitle"></div>
                    </div>
                    <div class="flex gap-2">
                        <input 
                            type="date"
                            :value="unit.unitRentSpecial?.startDate || ''"
                            x-on:change="if (unit && !unit.unitRentSpecial) unit.unitRentSpecial = {}; if (unit) unit.unitRentSpecial.startDate = $event.target.value"
                            class="input input-bordered flex-1"
                            :class="{'input-error': errors.rentSpecial}"
                            placeholder="Start Date"
                        />
                        <input 
                            type="date"
                            :value="unit.unitRentSpecial?.endDate || ''"
                            x-on:change="if (unit && !unit.unitRentSpecial) unit.unitRentSpecial = {}; if (unit) unit.unitRentSpecial.endDate = $event.target.value"
                            class="input input-bordered flex-1"
                            :class="{'input-error': errors.rentSpecial}"
                            placeholder="End Date"
                        />
                    </div>
                </div>
                <textarea 
                    :value="unit.unitRentSpecial?.description || ''"
                    x-on:change="if (unit && !unit.unitRentSpecial) unit.unitRentSpecial = {}; if (unit) unit.unitRentSpecial.description = $event.target.value"
                    class="textarea textarea-bordered w-full"
                    rows="2"
                    placeholder="Special Description"
                ></textarea>
                <div x-show="errors.rentSpecial" class="text-error text-sm mt-1" x-text="errors.rentSpecial"></div>
            </div>
        </div>
        
        <!-- Unit Amenities Section -->
        <div class="collapse collapse-arrow bg-base-200 mb-2">
            <input type="checkbox" x-model="expandedSections.amenities" />
            <div class="collapse-title text-lg font-medium">
                Unit Amenities
                <span class="badge badge-primary badge-sm ml-2" x-text="getEffectiveAmenities().length"></span>
                <span x-show="unit.unitAmenities && unit.unitAmenities.length > 0" class="badge badge-warning badge-sm ml-1">overridden</span>
                <span x-show="(!unit.unitAmenities || unit.unitAmenities.length === 0) && selectedUnitType?.modelAmenities?.length > 0" class="badge badge-info badge-sm ml-1">inherited</span>
            </div>
            <div class="collapse-content">
                <div class="pt-4">
                    <div x-show="selectedUnitType && selectedUnitType.modelAmenities && selectedUnitType.modelAmenities.length > 0" class="alert alert-info mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span>This unit inherits amenities from its model. Add amenities here to override the model defaults.</span>
                    </div>
                    <AmenitySelector
                        name="unitAmenities"
                        label="Unit-specific amenities (overrides model amenities)"
                        xModel="unit.unitAmenities"
                        showLabel={false}
                    />
                </div>
            </div>
        </div>
        
        <!-- Photos Section -->
        <div class="collapse collapse-arrow bg-base-200 mb-2">
            <input type="checkbox" x-model="expandedSections.photos" />
            <div class="collapse-title text-lg font-medium">
                Photos
                <span class="badge badge-primary badge-sm ml-2" x-text="unit.photos?.length || 0"></span>
            </div>
            <div class="collapse-content">
                <div class="pt-4">
                    <PhotoUploader
                        name="photos"
                        label="Unit photos"
                        xModel="unit.photos"
                        buildingId={unit.buildingID}
                        unitId={unit.unitID}
                    />
                </div>
            </div>
        </div>
        
        <!-- Website Status & Listing IDs Section -->
        <div class="collapse collapse-arrow bg-base-200">
            <input type="checkbox" x-model="expandedSections.websites" />
            <div class="collapse-title text-lg font-medium">
                Website Status & Listings
                <span class="badge badge-primary badge-sm ml-2" x-text="Object.keys(unit.websiteStatus || {}).length"></span>
            </div>
            <div class="collapse-content">
                <div class="pt-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Website Status -->
                        <div>
                            <h4 class="font-semibold mb-2">Website Status</h4>
                            <div class="flex flex-col gap-2">
                                <template x-for="site in ['apartments.com', 'zillow.com', 'rent.com', 'craigslist.org']" :key="site">
                                    <div class="form-control">
                                        <label class="label">
                                            <span class="label-text" x-text="site"></span>
                                        </label>
                                        <select 
                                            x-model="unit.websiteStatus[site]"
                                            x-on:change="if (!unit.websiteStatus) unit.websiteStatus = {}; saveUnit(this)"
                                            class="select select-bordered select-sm w-full"
                                        >
                                            <option value="">Not Listed</option>
                                            <option value="active">Active</option>
                                            <option value="inactive">Inactive</option>
                                            <option value="pending">Pending</option>
                                            <option value="error">Error</option>
                                        </select>
                                    </div>
                                </template>
                            </div>
                        </div>
                        
                        <!-- Listing IDs -->
                        <div>
                            <h4 class="font-semibold mb-2">Listing IDs/URLs</h4>
                            <div class="flex flex-col gap-2">
                                <template x-for="site in ['apartments.com', 'zillow.com', 'rent.com', 'craigslist.org']" :key="site">
                                    <div class="form-control">
                                        <label class="label">
                                            <span class="label-text" x-text="site"></span>
                                        </label>
                                        <input 
                                            type="text"
                                            x-model.lazy="unit.listingIds[site]"
                                            x-on:change="if (!unit.listingIds) unit.listingIds = {};"
                                            class="input input-bordered input-sm w-full"
                                            placeholder="External ID or URL"
                                        />
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</li>

<style>
    /* Ensure smooth transitions */
    .collapse-content {
        transition: all 0.3s ease;
    }
    
    /* Style for inherited value indicator */
    .input-ghost {
        background-color: transparent;
    }
    
    /* Hide number input spinners */
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    
    input[type="number"] {
        -moz-appearance: textfield;
    }
</style>
