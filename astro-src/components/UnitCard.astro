---
import { getUnit } from '../../data/units';
import { Resource } from 'sst';

const { buildingID, unitID } = Astro.props as {
    buildingID: string;
    unitID: string;
};

const unit = await getUnit(buildingID, unitID);
const apiURL = Resource.API.url;
const xData = JSON.stringify({
    original: unit,
    unit,
    apiURL,
    showSave: false,
});
---

<div
    class="unit-card border rounded shadow p-4 mb-4"
    x-data={xData}
    x-effect="showSave = JSON.stringify(unit) !== JSON.stringify(original)"
>
    <h3 class="font-bold text-lg mb-2">Unit {unitID}</h3>
    <form class="space-y-2">
        <label class="block">
            Description
            <input
                name="description"
                class="border p-1 w-full"
                x-model="unit.description"
            />
        </label>
        <label class="block">
            Beds
            <input
                type="number"
                name="beds"
                class="border p-1 w-full"
                x-model.number="unit.beds"
            />
        </label>
        <label class="block">
            Baths
            <input
                type="number"
                name="baths"
                class="border p-1 w-full"
                x-model.number="unit.baths"
            />
        </label>
        <label class="block">
            Sqft
            <input
                type="number"
                name="sqft"
                class="border p-1 w-full"
                x-model.number="unit.sqft"
            />
        </label>
        <label class="block">
            Monthly Rent
            <input
                type="number"
                name="rent"
                class="border p-1 w-full"
                x-model.number="unit.rent"
            />
        </label>
        <label class="inline-flex items-center gap-2">
            <input type="checkbox" name="occupied" x-model="unit.occupied" />
            Occupied
        </label>
        <label class="block">
            Available Date
            <input
                type="date"
                name="availableDate"
                class="border p-1 w-full"
                x-model="unit.availableDate"
            />
        </label>
    </form>
    <div class="mt-2 space-x-2">
        <button
            type="button"
            class="save bg-blue-600 text-white px-2 py-1 rounded"
            x-show="showSave"
            x-on:click="await fetch(`${apiURL}buildings/${unit.buildingID}/units/${unit.unitID}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(unit),
            })
            original = { ...unit };
            showSave = false;
            ">Save</button>
        <button
            type="button"
            class="undo bg-gray-300 px-2 py-1 rounded"
            x-show="showSave"
            x-on:click="unit={...original}">Undo</button>
        <button
            type="button"
            class="delete bg-red-600 text-white px-2 py-1 rounded"
            x-on:click="if (!confirm('Are you sure you want to delete this unit?')) return;
            await fetch(`${apiURL}buildings/${unit.buildingID}/units/${unit.unitID}`, { method: 'DELETE' })
            window.location.reload();
            ">Delete</button>
    </div>
</div>
