---
import { getUnit } from "../../data/units";
import type { UnitData } from "../types";

const { buildingID, unitID } = Astro.props as {
    buildingID: string;
    unitID: string;
};

const unit: UnitData | undefined = await getUnit(buildingID, unitID);
const unitJson = JSON.stringify(unit);
---

<div
    class="unit-card border rounded shadow p-4 mb-4"
    data-building={buildingID}
    data-unit={unitID}
    x-data=`{
        showSave: false,
        original: ${unitJson},
        current: ${unitJson},
        init() {
            this.$watch('current', () => {
                this.showSave = JSON.stringify(this.original) !== JSON.stringify(this.current);
            });
        },
        async save() {
            await fetch(`/api/buildings/${buildingID}/units/${unitID}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(this.current),
            });
            this.original = this.current;
            this.showSave = false;
        },
        undo() {
            this.current = this.original;
            this.showSave = false;
        },
        async deleteUnit() {
            if (!confirm('Delete this unit?')) return;
            await fetch(`/api/buildings/${buildingID}/units/${unitID}`, { method: 'DELETE' });
            this.$el.remove();
        }
    }`
>
    <h3 class="font-bold text-lg mb-2">Unit {unitID}</h3>
    <form class="space-y-2">
        <label class="block">
            Description
            <input name="unitDescription" class="border p-1 w-full" x-model="current.unitDescription" />
        </label>
        <label class="block">
            Beds
            <input type="number" name="beds" class="border p-1 w-full" x-model.number="current.beds" />
        </label>
        <label class="block">
            Baths
            <input type="number" name="baths" class="border p-1 w-full" x-model.number="current.baths" />
        </label>
        <label class="block">
            Sqft
            <input type="number" name="sqft" class="border p-1 w-full" x-model.number="current.sqft" />
        </label>
        <label class="block">
            Monthly Rent
            <input type="number" name="rent" class="border p-1 w-full" x-model.number="current.rent" />
        </label>
        <label class="inline-flex items-center gap-2">
            <input type="checkbox" name="occupied" x-model="current.occupied" />
            Occupied
        </label>
        <label class="block">
            Available Date
            <input type="date" name="availableDate" class="border p-1 w-full" x-model="current.availableDate" />
        </label>
    </form>
    <div class="mt-2 space-x-2">
        <button type="button" class="save bg-blue-600 text-white px-2 py-1 rounded" x-show="showSave" x-on:click="save">Save</button>
        <button type="button" class="undo bg-gray-300 px-2 py-1 rounded" x-show="showSave" x-on:click="undo">Undo</button>
        <button type="button" class="delete bg-red-600 text-white px-2 py-1 rounded" x-on:click="deleteUnit">Delete</button>
    </div>
</div>
