                                <span>
                                    This unit has custom amenities that override inherited values.
                                    <button type="button" class="btn btn-ghost btn-xs ml-2" x-on:click="resetToInheritedAmenities()">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                        </svg>
                                        Reset to Inherited
                                    </button>
                                </span>
                            </template>
                            
                            <!-- Unit inherits from floorplan -->
                            <template x-if="getAmenityInheritanceSource() === 'floorplan'">
                                <span>
                                    This unit inherits <span x-text="selectedUnitType?.modelAmenities?.length || 0"></span> amenities from its floorplan. Add amenities here to customize this unit.
                                </span>
                            </template>
                            
                            <!-- Unit inherits from building -->
                            <template x-if="getAmenityInheritanceSource() === 'building'">
                                <span>
                                    This unit inherits <span x-text="buildingAmenities?.length || 0"></span> amenities from the building (no floorplan amenities). Add amenities here to customize this unit.
                                </span>
                            </template>
                            
                            <!-- No amenities at any level -->
                            <template x-if="getAmenityInheritanceSource() === 'none'">
                                <span>
                                    No amenities are defined at the building or floorplan level. Add amenities here to customize this unit.
                                </span>
                            </template>
                        </div>
                    </div>
                    
                    <!-- Inheritance Chain Display -->
                    <div class="mb-4">
                        <div class="text-sm font-semibold mb-2">Inheritance Chain:</div>
                        <div class="flex items-center gap-2 text-sm">
                            <!-- Building Level -->
                            <div class="flex items-center gap-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H3m2 0h2M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                                </svg>
                                <span class="font-medium">Building</span>
                                <span class="badge badge-xs" :class="buildingAmenities?.length > 0 ? 'badge-success' : 'badge-ghost'" x-text="buildingAmenities?.length || 0"></span>
                            </div>
                            
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                            
                            <!-- Floorplan Level -->
                            <div class="flex items-center gap-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                </svg>
                                <span class="font-medium">Floorplan</span>
                                <span class="badge badge-xs" :class="selectedUnitType?.modelAmenities?.length > 0 ? 'badge-success' : 'badge-ghost'" x-text="selectedUnitType?.modelAmenities?.length || 0"></span>
                                <span x-show="!selectedUnitType" class="text-xs text-base-content/50">(none selected)</span>
                            </div>
                            
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                            
                            <!-- Unit Level -->
                            <div class="flex items-center gap-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2 2z" />
                                </svg>
                                <span class="font-medium">Unit</span>
                                <span class="badge badge-xs" :class="unit.unitAmenities?.length > 0 ? 'badge-warning' : 'badge-ghost'" x-text="unit.unitAmenities?.length || 0"></span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Inherited Amenities Display -->
                    <div x-show="(!unit.unitAmenities || unit.unitAmenities.length === 0) && getEffectiveAmenities().length > 0" class="mb-4">
                        <div class="text-sm text-base-content/70 mb-2">
                            <span class="font-semibold">Currently Active Amenities</span>
                            <template x-if="getAmenityInheritanceSource() === 'floorplan'">
                                <span> (inherited from floorplan):</span>
                            </template>
                            <template x-if="getAmenityInheritanceSource() === 'building'">
                                <span> (inherited from building):</span>
                            </template>
                            <span x-text="getEffectiveAmenities().length"></span> amenities
                        </div>
                        <div class="flex flex-wrap gap-2">
                            <template x-for="amenity in getEffectiveAmenities()" :key="amenity.name + amenity.category">
                                <div class="badge badge-lg gap-2" :class="{'badge-info': getAmenityInheritanceSource() === 'floorplan', 'badge-ghost': getAmenityInheritanceSource() === 'building'}">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12" />
                                    </svg>
                                    <span x-text="amenity.name"></span>
                                </div>
                            </template>
                        </div>
                    </div>
                    
                    <AmenitySelector
                        name="unitAmenities"
                        label="Unit-specific amenities (overrides inherited amenities)"
                        xModel="unit.unitAmenities"
                        showLabel={false}
                    />
                </div>
            </div>
        </div>
        
        <!-- Photos Section -->
        <div class="collapse collapse-arrow bg-base-200 mb-2">
            <input type="checkbox" x-model="expandedSections.photos" />
            <div class="collapse-title text-lg font-medium">
                Photos
                <span class="badge badge-primary badge-sm ml-2" x-text="unit.photos?.length || 0"></span>
            </div>
            <div class="collapse-content">
                <div class="pt-4">
                    <PhotoUploader
                        name="photos"
                        label="Unit photos"
                        xModel="unit.photos"
                        buildingId={unit.buildingID}
                        unitId={unit.unitID}
                    />
                </div>
            </div>
        </div>
        
        <!-- Website Status & Listing IDs Section -->
        <div class="collapse collapse-arrow bg-base-200">
            <input type="checkbox" x-model="expandedSections.websites" />
            <div class="collapse-title text-lg font-medium">
                Feed Inclusion & References
                <span class="badge badge-primary badge-sm ml-2" x-text="Object.keys(unit.feedInclusion || {}).length"></span>
            </div>
            <div class="collapse-content">
                <div class="pt-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Website Status -->
                        <div>
                            <h4 class="font-semibold mb-2">Website Status</h4>
                            <div class="flex flex-col gap-2">
                                <template x-for="site in ['apartments.com', 'zillow.com', 'rent.com', 'craigslist.org']" :key="site">
                                    <div class="form-control">
                                        <label class="label">
                                            <span class="label-text" x-text="site"></span>
                                        </label>
                                        <select 
                                            x-model="unit.feedInclusion[site]"
                                            x-on:change="if (!unit.feedInclusion) unit.feedInclusion = {}; saveUnit(this)"
                                            class="select select-bordered select-sm w-full"
                                        >
                                            <option value="">Not Listed</option>
                                            <option value="active">Active</option>
                                            <option value="inactive">Inactive</option>
                                            <option value="pending">Pending</option>
                                            <option value="error">Error</option>
                                        </select>
                                    </div>
                                </template>
                            </div>
                        </div>
                        
                        <!-- Listing IDs -->
                        <div>
                            <h4 class="font-semibold mb-2">Listing IDs/URLs</h4>
                            <div class="flex flex-col gap-2">
                                <template x-for="site in ['apartments.com', 'zillow.com', 'rent.com', 'craigslist.org']" :key="site">
                                    <div class="form-control">
                                        <label class="label">
                                            <span class="label-text" x-text="site"></span>
                                        </label>
                                        <input 
                                            type="text"
                                            x-model.lazy="unit.manualReferences[site]"
                                            x-on:change="if (!unit.manualReferences) unit.manualReferences = {};"
                                            class="input input-bordered input-sm w-full"
                                            placeholder="External ID or URL"
                                        />
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</li>

<style>
    /* Ensure smooth transitions */
    .collapse-content {
        transition: all 0.3s ease;
    }
    
    /* Style for inherited value indicator */
    .input-ghost {
        background-color: transparent;
        border-style: dashed;
        opacity: 0.7;
    }
    
    .input-ghost:focus {
        opacity: 1;
        border-style: solid;
    }
    
    /* Badge styling for inheritance indicators */
    .badge-ghost {
        background-color: transparent;
        border: 1px dashed currentColor;
        opacity: 0.7;
    }
    
    /* Inheritance chain styling */
    .inheritance-chain {
        padding: 0.5rem;
        border-radius: 0.5rem;
        background: linear-gradient(90deg, 
            hsl(var(--b2)) 0%, 
            hsl(var(--b3)) 50%, 
            hsl(var(--b2)) 100%);
    }
    
    /* Hide number input spinners */
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    
    input[type="number"] {
        -moz-appearance: textfield;
    }
    
    /* Smooth transitions for inheritance indicators */
    [x-transition] {
        transition: all 0.2s ease;
    }
</style>
