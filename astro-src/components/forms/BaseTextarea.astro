---
import _ from 'lodash';

export interface Props {
    name: string
    label?: string
    placeholder?: string
    required?: boolean
    disabled?: boolean
    readonly?: boolean
    xModel: string
    value?: string
    rows?: number
    cols?: number
    maxlength?: number
    minlength?: number
    'class'?: string
    textareaClass?: string
    error?: string
    helpText?: string
    showLabel?: boolean
    floatingLabel?: boolean
    resize?: 'none' | 'both' | 'horizontal' | 'vertical'
    showCharacterCount?: boolean
    characterCountInside?: boolean
}

const {
    name,
    label,
    placeholder,
    required = false,
    disabled = false,
    readonly = false,
    xModel,
    value,
    rows = 4,
    cols,
    maxlength,
    minlength,
    'class': className = '',
    textareaClass = '',
    error,
    helpText,
    showLabel = true,
    floatingLabel = false,
    resize = 'vertical',
    showCharacterCount = false,
    characterCountInside = false,
} = Astro.props;

// Determine if we should show the label
const shouldShowLabel = showLabel && label;

// Build textarea classes
const resizeClassMap = {
    none: 'resize-none',
    both: 'resize',
    horizontal: 'resize-x',
    vertical: 'resize-y'
};

const textareaClasses = _.compact([
    'textarea',
    'w-full',
    error ? 'textarea-error' : '',
    resizeClassMap[resize],
    characterCountInside && maxlength ? 'pb-8' : '', // Extra padding for character count
    textareaClass
]).join(' ');

// Container classes
const containerClasses = _.compact([
    'form-control',
    className
]).join(' ');
---

<div class={containerClasses}>
    {shouldShowLabel && !floatingLabel && (
        <label class="label">
            <span class="label-text">
                {label}
                {required && <span class="text-error">*</span>}
            </span>
        </label>
    )}

    <div class="relative">
        {floatingLabel
? (
            <label class="floating-label textarea-label">
                {shouldShowLabel && (
                    <span>
                        {label}
                        {required && <span class="text-error">*</span>}
                    </span>
                )}
                <textarea
                  name={name}
                  placeholder={placeholder || label}
                  class={textareaClasses}
                  required={required}
                  disabled={disabled}
                  readonly={readonly}
                  x-model={xModel}
                  rows={rows}
                  cols={cols}
                  maxlength={maxlength}
                  minlength={minlength}
                >
{value}
                </textarea>
            </label>
        )
: (
            <textarea
              name={name}
              placeholder={placeholder}
              class={textareaClasses}
              required={required}
              disabled={disabled}
              readonly={readonly}
              x-model={xModel}
              rows={rows}
              cols={cols}
              maxlength={maxlength}
              minlength={minlength}
            >
{value}
            </textarea>
        )}

        <!-- Character count inside textarea -->
        {characterCountInside && showCharacterCount && maxlength && (
            <div class="absolute bottom-2 right-3 text-xs font-mono text-base-content/60 bg-base-100/80 px-2 py-1 rounded">
                <span x-text={`(${xModel} || '').length`}>0</span>
                <span class="text-base-content/40">/{maxlength}</span>
            </div>
        )}
    </div>

    <!-- Character count outside textarea -->
    {!characterCountInside && showCharacterCount && maxlength && (
        <div class="label">
            <div class="label-text-alt"></div>
            <span
              class="label-text-alt font-mono"
              x-bind:class="{
                'text-warning': (${xModel} || '').length > ${maxlength * 0.9},
                'text-error': (${xModel} || '').length > ${maxlength}
            }"
            >
                <span x-text={`(${xModel} || '').length`}>0</span>
/
{maxlength}
            </span>
        </div>
    )}

    {(error || helpText) && (
        <label class="label">
            <span class={`label-text-alt ${error ? 'text-error' : ''}`}>
                {error || helpText}
            </span>
        </label>
    )}
</div>


