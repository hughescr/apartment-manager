---

export interface Props {
    name: string
    label?: string
    placeholder?: string
    required?: boolean
    disabled?: boolean
    readonly?: boolean
    xModel: string
    value?: string | number
    min?: string | number
    max?: string | number
    step?: string | number
    'class'?: string
    error?: string
    helpText?: string
    showLabel?: boolean
}

const {
    name,
    label,
    placeholder = '0.00',
    required = false,
    disabled = false,
    readonly = false,
    xModel,
    value,
    min = 0,
    max,
    step = 0.01,
    'class': className = '',
    error,
    helpText,
    showLabel = true,
} = Astro.props;

// Determine if we should show the label
const shouldShowLabel = showLabel && label;

// Container classes
const containerClasses = [
    'form-control',
    className
].filter(Boolean).join(' ');

// Build wrapper classes for the input container
const wrapperClasses = [
    'input',
    'input-bordered',
    'flex',
    'items-center',
    'gap-2',
    error ? 'input-error' : '',
    disabled ? 'opacity-50 cursor-not-allowed' : ''
].filter(Boolean).join(' ');
---

<div class={containerClasses}>
    {shouldShowLabel && (
        <label class="label">
            <span class="label-text">
                {label}
                {required && <span class="text-error">*</span>}
            </span>
        </label>
    )}

    <label class={wrapperClasses}>
        <span class="text-base-content/70">$</span>
        <input
          type="number"
          name={name}
          placeholder={placeholder}
          class="grow bg-transparent border-0 outline-none"
          required={required}
          disabled={disabled}
          readonly={readonly}
          x-model.number={xModel}
          value={value}
          min={min}
          max={max}
          step={step}
        />
    </label>

    {(error || helpText) && (
        <label class="label">
            <span class={`label-text-alt ${error ? 'text-error' : ''}`}>
                {error || helpText}
            </span>
        </label>
    )}
</div>

<style>

    /* Remove spinner buttons in Chrome, Safari, Edge */
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Remove spinner buttons in Firefox */
    input[type="number"] {
        -moz-appearance: textfield;
    }

    /* Ensure proper focus handling */
    .focus-within\:outline-primary:focus-within {
        outline-color: var(--fallback-p, oklch(var(--p)));
    }

</style>
