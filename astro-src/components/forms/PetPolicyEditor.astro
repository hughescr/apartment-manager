---
import type { PetPolicyComponentProps } from '../../lib/pet-policy/petPolicyTypes';
import PetPolicyProvider from '../pet-policy/PetPolicyProvider.astro';
import PetTypesList from '../pet-policy/PetTypesList.astro';
import BreedRestrictions from '../pet-policy/BreedRestrictions.astro';
import PetFeeManager from '../pet-policy/PetFeeManager.astro';
import PetPolicyAdvancedSettings from '../pet-policy/PetPolicyAdvancedSettings.astro';

export interface Props extends PetPolicyComponentProps {}

const {
    name,
    label = 'Pet Policy',
    xModel,
    petPolicy: _petPolicy, // Unused parameter, kept for interface compatibility
    required = false,
    disabled = false,
    'class': className = '',
    error,
    showLabel = true,
} = Astro.props;
---

<!-- Use the modular PetPolicyProvider with slot-based architecture -->
<PetPolicyProvider
  name={name}
  label={label}
  xModel={xModel}
  required={required}
  disabled={disabled}
  class={className}
  error={error}
  showLabel={showLabel}
>
    <!-- Pet Types List -->
    <PetTypesList
      slot="pet-types-list"
      disabled={disabled}
    />

    <!-- Breed Restrictions -->
    <BreedRestrictions
      slot="breed-restrictions"
      xModel={xModel}
      disabled={disabled}
    />

    <!-- Pet Fee Manager -->
    <PetFeeManager
      slot="pet-fee-manager"
      name={name}
      xModel={xModel}
      disabled={disabled}
    />

    <!-- Advanced Settings -->
    <PetPolicyAdvancedSettings
      slot="advanced-settings"
      xModel={xModel}
      disabled={disabled}
    />
</PetPolicyProvider>
