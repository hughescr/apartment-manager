---
import type { PetPolicy } from '../../../src/types';
import { PetType } from '../../../src/types';
import BaseInput from './BaseInput.astro';
import BaseTextarea from './BaseTextarea.astro';

export interface Props {
    name: string;
    label?: string;
    xModel: string;
    petPolicy?: PetPolicy;
    required?: boolean;
    disabled?: boolean;
    class?: string;
    error?: string;
    showLabel?: boolean;
}

const {
    name,
    label = 'Pet Policy',
    xModel,
    petPolicy: _petPolicy, // Unused parameter, kept for interface compatibility
    required = false,
    disabled = false,
    class: className = '',
    error,
    showLabel = true,
} = Astro.props;

// Container classes
const containerClasses = [
    'pet-policy-editor',
    className
].filter(Boolean).join(' ');

// Pet type options for display
const petTypeOptions = [
    { value: PetType.DOG, label: 'Dogs' },
    { value: PetType.CAT, label: 'Cats' },
    { value: PetType.BIRD, label: 'Birds' },
    { value: PetType.FISH, label: 'Fish' },
    { value: PetType.SMALL_ANIMAL, label: 'Small Animals (rabbits, hamsters, etc.)' },
];

// Common breed restrictions
const commonBreedRestrictions = [
    'Pit Bull', 'Rottweiler', 'German Shepherd', 'Doberman', 'Akita',
    'Chow Chow', 'Great Dane', 'Mastiff', 'Husky'
];

// We'll inject this directly as JavaScript code to avoid TypeScript issues with dynamic properties
const xDataString = `{
    modelName: '${xModel}',
    petTypes: ${JSON.stringify(petTypeOptions)},
    commonBreeds: ${JSON.stringify(commonBreedRestrictions)},
    showBreedRestrictions: false,
    newBreedRestriction: '',
    showAdvancedSettings: false,
    
    init() {
        // Initialize with default structure if not set
        if (!this[this.modelName]) {
            this[this.modelName] = {
                allowed: false,
                types: [],
                maxCount: undefined,
                weightLimit: undefined,
                breedRestrictions: [],
                deposit: undefined,
                monthlyFee: undefined,
                oneTimeFee: undefined,
                notes: '',
                petTypes: []
            };
        }
        
        // Ensure petTypes array exists for advanced settings
        if (!this[this.modelName].petTypes) {
            this[this.modelName].petTypes = [];
        }
    },
    
    get petsAllowed() {
        return this[this.modelName]?.allowed || false;
    },
    
    set petsAllowed(value) {
        if (!this[this.modelName]) {
            this[this.modelName] = {};
        }
        this[this.modelName].allowed = value;
        
        // Clear pet-related fields if pets are not allowed
        if (!value) {
            this[this.modelName].types = [];
            this[this.modelName].maxCount = undefined;
            this[this.modelName].weightLimit = undefined;
            this[this.modelName].breedRestrictions = [];
            this[this.modelName].deposit = undefined;
            this[this.modelName].monthlyFee = undefined;
            this[this.modelName].oneTimeFee = undefined;
        }
    },
    
    togglePetType(type) {
        if (!this[this.modelName]) {
            this[this.modelName] = { allowed: true };
        }
        if (!this[this.modelName].types) {
            this[this.modelName].types = [];
        }
        
        const index = this[this.modelName].types.indexOf(type);
        if (index >= 0) {
            this[this.modelName].types.splice(index, 1);
        } else {
            this[this.modelName].types.push(type);
        }
    },
    
    isPetTypeSelected(type) {
        return this[this.modelName]?.types?.includes(type) || false;
    },
    
    addBreedRestriction(breed) {
        if (!this[this.modelName]) {
            this[this.modelName] = { allowed: true };
        }
        if (!this[this.modelName].breedRestrictions) {
            this[this.modelName].breedRestrictions = [];
        }
        
        const trimmedBreed = breed.trim();
        if (trimmedBreed && !this[this.modelName].breedRestrictions.includes(trimmedBreed)) {
            this[this.modelName].breedRestrictions.push(trimmedBreed);
        }
        this.newBreedRestriction = '';
    },
    
    removeBreedRestriction(index) {
        if (this[this.modelName]?.breedRestrictions) {
            this[this.modelName].breedRestrictions.splice(index, 1);
        }
    },
    
    toggleCommonBreed(breed) {
        if (!this[this.modelName]) {
            this[this.modelName] = { allowed: true };
        }
        if (!this[this.modelName].breedRestrictions) {
            this[this.modelName].breedRestrictions = [];
        }
        
        const index = this[this.modelName].breedRestrictions.indexOf(breed);
        if (index >= 0) {
            this[this.modelName].breedRestrictions.splice(index, 1);
        } else {
            this[this.modelName].breedRestrictions.push(breed);
        }
    },
    
    isBreedRestricted(breed) {
        return this[this.modelName]?.breedRestrictions?.includes(breed) || false;
    },
    
    get totalPetCost() {
        const deposit = this[this.modelName]?.deposit || 0;
        const oneTime = this[this.modelName]?.oneTimeFee || 0;
        const monthly = this[this.modelName]?.monthlyFee || 0;
        return {
            upfront: deposit + oneTime,
            monthly: monthly,
            annual: monthly * 12
        };
    },
    
    // Advanced per-pet-type policy methods
    addPetTypePolicy() {
        if (!this[this.modelName]) {
            this[this.modelName] = { allowed: true, petTypes: [] };
        }
        if (!this[this.modelName].petTypes) {
            this[this.modelName].petTypes = [];
        }
        
        this[this.modelName].petTypes.push({
            type: 'dog',
            weightLimit: undefined,
            countLimit: undefined,
            fee: undefined,
            deposit: undefined,
            breedRestrictions: []
        });
    },
    
    removePetTypePolicy(index) {
        if (this[this.modelName]?.petTypes) {
            this[this.modelName].petTypes.splice(index, 1);
        }
    },
    
    addBreedRestrictionToPetType(petTypeIndex, breed) {
        const petTypePolicy = this[this.modelName]?.petTypes?.[petTypeIndex];
        if (!petTypePolicy) return;
        
        if (!petTypePolicy.breedRestrictions) {
            petTypePolicy.breedRestrictions = [];
        }
        
        const trimmedBreed = breed.trim();
        if (trimmedBreed && !petTypePolicy.breedRestrictions.includes(trimmedBreed)) {
            petTypePolicy.breedRestrictions.push(trimmedBreed);
        }
    },
    
    removeBreedRestrictionFromPetType(petTypeIndex, breedIndex) {
        const petTypePolicy = this[this.modelName]?.petTypes?.[petTypeIndex];
        if (petTypePolicy?.breedRestrictions) {
            petTypePolicy.breedRestrictions.splice(breedIndex, 1);
        }
    },
    
    get hasAdvancedPetTypes() {
        return this[this.modelName]?.petTypes?.length > 0;
    },
    
    get advancedPetTypesSummary() {
        const petTypes = this[this.modelName]?.petTypes || [];
        if (petTypes.length === 0) return 'No advanced pet types configured';
        
        const typeNames = petTypes.map(p => p.type.charAt(0).toUpperCase() + p.type.slice(1));
        return typeNames.join(', ') + ' (' + petTypes.length + ' type' + (petTypes.length > 1 ? 's' : '') + ')';
    }
}`;
---

<div class={containerClasses} x-data={xDataString} x-init="init()">
    {showLabel && (
        <div class="label">
            <span class="label-text text-lg font-semibold">
                {label}
                {required && <span class="text-error">*</span>}
            </span>
        </div>
    )}
    
    <!-- Pets Allowed Toggle -->
    <div class="form-control mb-6">
        <label class="label cursor-pointer justify-start gap-3">
            <input
                type="checkbox"
                class="toggle toggle-primary toggle-lg"
                x-model="petsAllowed"
                disabled={disabled}
            />
            <span class="label-text text-lg font-medium">Pets Allowed</span>
        </label>
    </div>
    
    <!-- Pet Policy Details (shown when pets are allowed) -->
    <div x-show="petsAllowed" x-transition class="space-y-6">
        <!-- Pet Types -->
        <div class="card bg-base-200">
            <div class="card-body">
                <h3 class="card-title text-base">Allowed Pet Types</h3>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
                    <template x-for="petType in petTypes" :key="petType.value">
                        <label class="label cursor-pointer justify-start gap-2">
                            <input
                                type="checkbox"
                                class="checkbox checkbox-primary"
                                x-on:change="togglePetType(petType.value)"
                                :checked="isPetTypeSelected(petType.value)"
                                disabled={disabled}
                            />
                            <span class="label-text" x-text="petType.label"></span>
                        </label>
                    </template>
                </div>
            </div>
        </div>
        
        <!-- Pet Limits -->
        <div class="card bg-base-200">
            <div class="card-body">
                <h3 class="card-title text-base">Pet Limits</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <BaseInput
                        name={name + '_maxCount'}
                        label="Maximum Number of Pets"
                        type="number"
                        xModel={`${xModel}.maxCount`}
                        min="1"
                        max="10"
                        placeholder="e.g., 2"
                        disabled={disabled}
                    />
                    <BaseInput
                        name={name + '_weightLimit'}
                        label="Weight Limit (lbs)"
                        type="number"
                        xModel={`${xModel}.weightLimit`}
                        min="0"
                        max="200"
                        placeholder="e.g., 50"
                        disabled={disabled}
                    />
                </div>
            </div>
        </div>
        
        <!-- Breed Restrictions -->
        <div class="card bg-base-200">
            <div class="card-body">
                <h3 class="card-title text-base">Breed Restrictions</h3>
                
                <!-- Current Restrictions -->
                <div x-show={`${xModel}.breedRestrictions && ${xModel}.breedRestrictions.length > 0`} class="mb-4">
                    <div class="text-sm font-medium mb-2">Current Restrictions:</div>
                    <div class="flex flex-wrap gap-2">
                        <template x-for={`(breed, index) in ${xModel}.breedRestrictions`} :key="breed">
                            <div class="badge badge-warning gap-2">
                                <span x-text="breed"></span>
                                <button
                                    type="button"
                                    x-on:click="removeBreedRestriction(index)"
                                    class="btn btn-ghost btn-xs"
                                    disabled={disabled}
                                >
                                    ×
                                </button>
                            </div>
                        </template>
                    </div>
                </div>
                
                <!-- Quick Add Common Breeds -->
                <button
                    type="button"
                    x-on:click="showBreedRestrictions = !showBreedRestrictions"
                    class="btn btn-sm btn-ghost"
                    disabled={disabled}
                >
                    <span x-text="showBreedRestrictions ? 'Hide' : 'Show'"></span> Common Breed Restrictions
                </button>
                
                <div x-show="showBreedRestrictions" x-transition class="mt-4">
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
                        <template x-for="breed in commonBreeds" :key="breed">
                            <label class="label cursor-pointer justify-start gap-2">
                                <input
                                    type="checkbox"
                                    class="checkbox checkbox-sm"
                                    x-on:change="toggleCommonBreed(breed)"
                                    :checked="isBreedRestricted(breed)"
                                    disabled={disabled}
                                />
                                <span class="label-text text-sm" x-text="breed"></span>
                            </label>
                        </template>
                    </div>
                </div>
                
                <!-- Custom Breed Input -->
                <div class="form-control mt-4">
                    <label class="label">
                        <span class="label-text">Add Custom Breed Restriction</span>
                    </label>
                    <div class="join">
                        <input
                            type="text"
                            x-model="newBreedRestriction"
                            placeholder="Enter breed name"
                            class="input input-bordered join-item flex-1"
                            disabled={disabled}
                            x-on:keyup.enter="addBreedRestriction(newBreedRestriction)"
                        />
                        <button
                            type="button"
                            x-on:click="addBreedRestriction(newBreedRestriction)"
                            class="btn btn-primary join-item"
                            disabled={disabled}
                        >
                            Add
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Pet Fees -->
        <div class="card bg-base-200">
            <div class="card-body">
                <h3 class="card-title text-base">Pet Fees</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <BaseInput
                        name={name + '_deposit'}
                        label="Pet Deposit (Refundable)"
                        type="number"
                        xModel={`${xModel}.deposit`}
                        min="0"
                        max="5000"
                        placeholder="e.g., 500"
                        helpText="Refundable security deposit"
                        disabled={disabled}
                    />
                    <BaseInput
                        name={name + '_oneTimeFee'}
                        label="One-Time Pet Fee"
                        type="number"
                        xModel={`${xModel}.oneTimeFee`}
                        min="0"
                        max="5000"
                        placeholder="e.g., 250"
                        helpText="Non-refundable fee"
                        disabled={disabled}
                    />
                    <BaseInput
                        name={name + '_monthlyFee'}
                        label="Monthly Pet Rent"
                        type="number"
                        xModel={`${xModel}.monthlyFee`}
                        min="0"
                        max="500"
                        placeholder="e.g., 50"
                        helpText="Per pet per month"
                        disabled={disabled}
                    />
                </div>
                
                <!-- Fee Summary -->
                <div x-show="totalPetCost.upfront > 0 || totalPetCost.monthly > 0" class="mt-4 p-4 bg-base-100 rounded-lg">
                    <div class="text-sm font-medium mb-2">Fee Summary:</div>
                    <div class="grid grid-cols-2 gap-2 text-sm">
                        <div>Upfront Cost:</div>
                        <div class="font-semibold">$<span x-text="totalPetCost.upfront.toFixed(2)"></span></div>
                        <div>Monthly Cost:</div>
                        <div class="font-semibold">$<span x-text="totalPetCost.monthly.toFixed(2)"></span></div>
                        <div>Annual Cost:</div>
                        <div class="font-semibold">$<span x-text="totalPetCost.annual.toFixed(2)"></span></div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Advanced Pet Settings -->
        <div class="card bg-base-300">
            <div class="card-body">
                <div class="flex items-center justify-between">
                    <h3 class="card-title text-base">Advanced Pet Settings</h3>
                    <button
                        type="button"
                        x-on:click="showAdvancedSettings = !showAdvancedSettings"
                        class="btn btn-sm btn-ghost"
                        disabled={disabled}
                    >
                        <span x-text="showAdvancedSettings ? 'Hide' : 'Show'"></span>
                        <svg class="w-4 h-4 ml-1 transition-transform" :class="{'rotate-180': showAdvancedSettings}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </button>
                </div>
                
                <!-- Summary when collapsed -->
                <div x-show="!showAdvancedSettings && hasAdvancedPetTypes" class="text-sm text-base-content/70 mt-2">
                    <strong>Current Settings:</strong> <span x-text="advancedPetTypesSummary"></span>
                </div>
                
                <!-- Advanced settings content -->
                <div x-show="showAdvancedSettings" x-transition class="mt-4 space-y-4">
                    <div class="alert alert-info text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <div>
                            <p><strong>Advanced Settings:</strong> Configure specific rules for each pet type. These override the basic settings above.</p>
                            <p class="mt-1"><strong>Basic Settings:</strong> Apply to all pets unless overridden by advanced settings.</p>
                        </div>
                    </div>
                    
                    <!-- Pet Type Policies -->
                    <template x-for="(petTypePolicy, index) in ${xModel}.petTypes || []" :key="'pet-type-' + index">
                        <div class="card bg-base-200 border border-base-300">
                            <div class="card-body">
                                <div class="flex items-center justify-between mb-4">
                                    <h4 class="text-base font-semibold">Pet Type Configuration</h4>
                                    <button
                                        type="button"
                                        x-on:click="removePetTypePolicy(index)"
                                        class="btn btn-ghost btn-sm text-error"
                                        disabled={disabled}
                                    >
                                        Remove
                                    </button>
                                </div>
                                
                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                                    <!-- Pet Type Selection -->
                                    <div class="form-control">
                                        <label class="label">
                                            <span class="label-text">Pet Type <span class="text-error">*</span></span>
                                        </label>
                                        <select
                                            x-model="petTypePolicy.type"
                                            class="select select-bordered"
                                            disabled={disabled}
                                        >
                                            <option value="dog">Dog</option>
                                            <option value="cat">Cat</option>
                                            <option value="bird">Bird</option>
                                            <option value="fish">Fish</option>
                                            <option value="small-animal">Small Animal</option>
                                        </select>
                                    </div>
                                    
                                    <!-- Weight Limit -->
                                    <div class="form-control">
                                        <label class="label">
                                            <span class="label-text">Weight Limit (lbs)</span>
                                        </label>
                                        <input
                                            type="number"
                                            x-model.number="petTypePolicy.weightLimit"
                                            class="input input-bordered"
                                            placeholder="e.g., 50"
                                            min="0"
                                            max="200"
                                            disabled={disabled}
                                        />
                                    </div>
                                    
                                    <!-- Count Limit -->
                                    <div class="form-control">
                                        <label class="label">
                                            <span class="label-text">Count Limit</span>
                                        </label>
                                        <input
                                            type="number"
                                            x-model.number="petTypePolicy.countLimit"
                                            class="input input-bordered"
                                            placeholder="e.g., 2"
                                            min="1"
                                            max="10"
                                            disabled={disabled}
                                        />
                                    </div>
                                    
                                    <!-- Monthly Fee -->
                                    <div class="form-control">
                                        <label class="label">
                                            <span class="label-text">Monthly Fee</span>
                                        </label>
                                        <input
                                            type="number"
                                            x-model.number="petTypePolicy.fee"
                                            class="input input-bordered"
                                            placeholder="e.g., 50"
                                            min="0"
                                            max="500"
                                            disabled={disabled}
                                        />
                                    </div>
                                    
                                    <!-- Deposit -->
                                    <div class="form-control">
                                        <label class="label">
                                            <span class="label-text">Deposit</span>
                                        </label>
                                        <input
                                            type="number"
                                            x-model.number="petTypePolicy.deposit"
                                            class="input input-bordered"
                                            placeholder="e.g., 500"
                                            min="0"
                                            max="5000"
                                            disabled={disabled}
                                        />
                                    </div>
                                </div>
                                
                                <!-- Breed Restrictions for this pet type -->
                                <div class="mt-4">
                                    <label class="label">
                                        <span class="label-text">Breed Restrictions (for this pet type)</span>
                                    </label>
                                    
                                    <!-- Current breed restrictions -->
                                    <div x-show="petTypePolicy.breedRestrictions && petTypePolicy.breedRestrictions.length > 0" class="mb-2">
                                        <div class="flex flex-wrap gap-2">
                                            <template x-for="(breed, breedIndex) in petTypePolicy.breedRestrictions || []" :key="'breed-' + index + '-' + breedIndex">
                                                <div class="badge badge-warning gap-2">
                                                    <span x-text="breed"></span>
                                                    <button
                                                        type="button"
                                                        x-on:click="removeBreedRestrictionFromPetType(index, breedIndex)"
                                                        class="btn btn-ghost btn-xs"
                                                        disabled={disabled}
                                                    >
                                                        ×
                                                    </button>
                                                </div>
                                            </template>
                                        </div>
                                    </div>
                                    
                                    <!-- Add breed restriction input -->
                                    <div class="join" x-data="{ newBreed: '' }">
                                        <input
                                            type="text"
                                            x-model="newBreed"
                                            placeholder="Enter breed name (e.g., Pit Bull, German Shepherd)"
                                            class="input input-bordered join-item flex-1"
                                            disabled={disabled}
                                            @keyup.enter="addBreedRestrictionToPetType(index, newBreed); newBreed = ''"
                                        />
                                        <button
                                            type="button"
                                            x-on:click="addBreedRestrictionToPetType(index, newBreed); newBreed = ''"
                                            class="btn btn-primary join-item"
                                            disabled={disabled}
                                        >
                                            Add
                                        </button>
                                    </div>
                                    
                                    <div class="text-xs text-base-content/70 mt-1">
                                        Enter breed names separated by commas, or add them one at a time
                                    </div>
                                </div>
                            </div>
                        </div>
                    </template>
                    
                    <!-- Add Pet Type Button -->
                    <button
                        type="button"
                        x-on:click="addPetTypePolicy()"
                        class="btn btn-primary btn-sm"
                        disabled={disabled}
                    >
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                        </svg>
                        Add Pet Type
                    </button>
                    
                    <!-- Usage Examples -->
                    <div class="alert alert-warning text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <div>
                            <p><strong>Example:</strong> Allow dogs up to 50lbs with $75/month fee, and cats with no weight limit and $25/month fee.</p>
                            <p class="mt-1"><strong>Breed Restrictions:</strong> Enter specific breeds to restrict (e.g., "Pit Bull", "Rottweiler")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Additional Notes -->
        <BaseTextarea
            name={name + '_notes'}
            label="Additional Pet Policy Notes"
            xModel={`${xModel}.notes`}
            rows={3}
            placeholder="Any additional pet policy information..."
            disabled={disabled}
        />
    </div>
    
    <!-- Hidden input for form submission -->
    <input type="hidden" name={name} x-bind:value={`JSON.stringify(${xModel} || {})`} />
    
    <!-- Form Error -->
    {error && (
        <label class="label">
            <span class="label-text-alt text-error">{error}</span>
        </label>
    )}
</div>

<style>
    .pet-policy-editor {
        /* Custom styles if needed */
    }
</style>