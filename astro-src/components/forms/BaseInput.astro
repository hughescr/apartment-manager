---
import _ from 'lodash';

export interface Props {
    name: string
    label?: string
    placeholder?: string
    type?: 'text' | 'number' | 'email' | 'tel' | 'url' | 'date' | 'time' | 'datetime-local'
    required?: boolean
    disabled?: boolean
    readonly?: boolean
    xModel: string
    value?: string | number
    min?: string | number
    max?: string | number
    step?: string | number
    pattern?: string
    autocomplete?: string
    'class'?: string
    error?: string
    helpText?: string
    oninput?: string
    showLabel?: boolean
    floatingLabel?: boolean
    inputClass?: string
    inputSize?: 'xs' | 'sm' | 'md' | 'lg' | 'full'
}

const {
    name,
    label,
    placeholder,
    type = 'text',
    required = false,
    disabled = false,
    readonly = false,
    xModel,
    value,
    min,
    max,
    step,
    pattern,
    autocomplete,
    'class': className = '',
    inputClass = '',
    error,
    helpText,
    oninput,
    showLabel = true,
    floatingLabel = false,
    inputSize = 'full',
} = Astro.props;

// Determine if we should show the label
const shouldShowLabel = showLabel && label;

// Map inputSize to width classes only - keep consistent font size
const getSizeClasses = (size: string) => {
    switch(size) {
        case 'xs': return ['w-20'];
        case 'sm': return ['w-32'];
        case 'md': return ['w-48'];
        case 'lg': return ['w-64'];
        case 'full':
        default: return ['w-full'];
    }
};

const sizeClasses = getSizeClasses(inputSize);

const inputClasses = _.compact([
    'input',
    ...sizeClasses,
    error ? 'input-error border-error focus:border-error' : 'focus:border-primary',
    'transition-colors duration-200',
    inputClass
]).join(' ');

const containerClasses = _.compact([
    'form-control',
    className
]).join(' ');
---

<div class={containerClasses}>
    {shouldShowLabel && !floatingLabel && (
        <label class="label">
            <span class="label-text">
                {label}
                {required && <span class="text-error font-bold text-sm">*</span>}
            </span>
        </label>
    )}

    {floatingLabel
        ? (
            <label class="floating-label">
                {shouldShowLabel && (
                    <span>
                        {label}
                        {required && <span class="text-error font-bold text-sm">*</span>}
                    </span>
                )}
                <input
                  type={type}
                  name={name}
                  placeholder={placeholder || label}
                  class={inputClasses}
                  required={required}
                  disabled={disabled}
                  readonly={readonly}
                  {...(type === 'number' ? { 'x-model.number': xModel } : { 'x-model': xModel })}
                  value={value}
                  min={min}
                  max={max}
                  step={step}
                  pattern={pattern}
                  autocomplete={autocomplete}
                  @input={oninput}
                />
            </label>
        )
        : (
            <input
              type={type}
              name={name}
              placeholder={placeholder}
              class={inputClasses}
              required={required}
              disabled={disabled}
              readonly={readonly}
              {...(type === 'number' ? { 'x-model.number': xModel } : { 'x-model': xModel })}
              value={value}
              min={min}
              max={max}
              step={step}
              pattern={pattern}
              autocomplete={autocomplete}
              @input={oninput}
            />
        )}
    {(error || helpText) && (
        <label class="label">
            <span class={`label-text-alt flex items-center gap-1 ${error ? 'text-error font-medium' : 'text-base-content/70'}`}>
                {error && (
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                )}
                {error || helpText}
            </span>
        </label>
    )}
</div>


