---
import _ from 'lodash';
export interface Props {
    /** Alpine.js x-model for latitude binding */
    latModel: string
    /** Alpine.js x-model for longitude binding */
    lngModel: string
    /** Alpine.js x-model for coordinatesVerified binding */
    verifiedModel?: string
    /** Address fields for geocoding - Alpine.js expressions */
    addressModel?: string
    cityModel?: string
    stateModel?: string
    /** Initial center coordinates if not provided by models */
    defaultLat?: number
    defaultLng?: number
    /** Height of the map container */
    height?: string
    /** API URL for geocoding endpoint */
    apiUrl: string
    /** CSS classes for the container */
    'class'?: string
    /** Help text to display */
    helpText?: string
    /** Show coordinates display */
    showCoordinates?: boolean
}

const {
    latModel,
    lngModel,
    verifiedModel,
    addressModel,
    cityModel,
    stateModel,
    defaultLat = 39.8283, // US geographic center
    defaultLng = -98.5795,
    height = '300px',
    apiUrl,
    'class': className = '',
    helpText = 'Drag the pin to set the exact building location. Click "Use Address Location" to geocode the address.',
    showCoordinates = true,
} = Astro.props;

const containerClasses = _.compact([
    'location-map-picker',
    className
]).join(' ');
---

<div class={containerClasses}>
    <!-- Location Section Card -->
    <div class="card bg-base-200">
        <div class="card-body p-4 sm:p-6">
            <h3 class="card-title text-lg mb-4">Building Location</h3>

            <!-- Alpine.js Component Container - encompasses all interactive elements -->
            <div
              x-data={`locationMapData('${latModel}', '${lngModel}', '${verifiedModel}', ${defaultLat}, ${defaultLng}, '${apiUrl}', ${JSON.stringify({ addressModel, cityModel, stateModel })})`}
              x-init="initMapWhenReady()"
            >
                <!-- Map Container -->
                <div class="w-full max-w-4xl mx-auto mb-4">
                    <div
                      class="map-container border border-base-300 rounded-lg overflow-hidden bg-base-100 shadow-sm"
                      style={`height: ${height}`}
                      x-ref="mapElement"
                      id="location-map-container"
                    >
                        <!-- Map will be initialized here -->
                        <div x-show="!mapInitialized" class="flex items-center justify-center h-full text-base-content/60">
                            <div class="text-center">
                                <div class="loading loading-spinner loading-lg mb-2"></div>
                                <div>Loading map...</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Map Controls & Info Section - Below Map -->
                <div class="bg-base-100 rounded-lg p-4 border border-base-300">
                    <!-- Coordinates Display with Status -->
                    {showCoordinates && (
                        <div class="mb-4">
                            <div class="flex flex-wrap items-center gap-4 text-xs">
                                <div>
                                    <span class="font-medium text-base-content/70">Latitude:</span>
                                    <span x-text={`${latModel} ? ${latModel}.toFixed(6) : 'Not set'`} class="font-mono font-medium ml-2"></span>
                                </div>
                                <div>
                                    <span class="font-medium text-base-content/70">Longitude:</span>
                                    <span x-text={`${lngModel} ? ${lngModel}.toFixed(6) : 'Not set'`} class="font-mono font-medium ml-2"></span>
                                </div>
                                {verifiedModel && (
                                    <div class="flex items-center gap-1">
                                        <div class="badge badge-sm" :class={`${verifiedModel} ? 'badge-success' : 'badge-info'`}>
                                            <span x-show={verifiedModel}>✓ Manually Positioned</span>
                                            <span x-show={`!${verifiedModel}`}>📍 Auto-Geocoded</span>
                                        </div>
                                        <div class="dropdown dropdown-hover dropdown-left">
                                            <label tabindex="0" class="cursor-help">
                                                <svg class="w-3 h-3 text-base-content/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                </svg>
                                            </label>
                                            <div tabindex="0" class="dropdown-content z-[1] card card-compact w-72 p-3 shadow-lg bg-base-100 border border-base-300">
                                                <div class="text-xs space-y-1">
                                                    <p x-show={verifiedModel} class="text-success">
                                                        <strong>Manually Positioned:</strong>
{' '}
You've placed the pin exactly where the building is located.
                                                    </p>
                                                    <p x-show={`!${verifiedModel}`}>
                                                        <strong>Auto-Geocoded:</strong>
{' '}
Location was estimated from the address. Click on the map to place the pin exactly where your building is.
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                )}
                            </div>
                        </div>
                    )}

                    <!-- Controls Row -->
                    <div class="flex flex-wrap gap-2 mb-3">
                        <button
                          type="button"
                          class="btn btn-sm btn-outline btn-primary"
                          x-show={addressModel ? `${addressModel} && ${addressModel}.trim()` : 'false'}
                          @click="geocodeAddress()"
                          :disabled="geocoding"
                            id="geocode-address-btn"
                        >
                            <span x-show="!geocoding">📍 Use Address Location</span>
                            <span x-show="geocoding" class="loading loading-spinner loading-xs"></span>
                            <span x-show="geocoding">Geocoding...</span>
                        </button>

                        <button
                          type="button"
                          class="btn btn-sm btn-outline"
                          @click="centerOnMarker()"
                          x-show={`${latModel} && ${lngModel}`}
                          id="center-on-marker-btn"
                        >
                            🎯 Center on Pin
                        </button>
                    </div>

                    <!-- Instructions -->
                    <div class="border-t border-base-200 pt-3">
                        <div class="text-sm text-base-content/70">
                            💡 {helpText || 'Click on the map to set the exact building location. Use the buttons above to geocode the address or center the view.'}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Type declarations for Alpine.js magic properties and global variables
declare global {
    interface Window {
        locationMapData: typeof locationMapData
        L: typeof import('leaflet')
    }
}

// Alpine.js context with magic properties
interface AlpineContext {
    $el: HTMLElement
    $refs: { mapElement: HTMLElement }
    $dispatch: (event: string, data?: unknown) => void
    $nextTick: () => Promise<void>
    $watch: (property: string, callback: (newValue: unknown) => void) => () => void
    $root?: { activeSectionTab?: string }
    [key: string]: unknown // Allow dynamic property access for x-model bindings
}

// LocationMapPicker Alpine.js context interface
interface LocationMapContext extends AlpineContext {
    map: import('leaflet').Map | null
    marker: import('leaflet').Marker | null
    geocoding: boolean
    mapInitialized: boolean
    getNestedProperty(path: string): unknown
    setNestedProperty(path: string, value: unknown): void
    initMap(): Promise<void>
    addMarker(lat: number, lng: number): void
    setMarker(lat: number, lng: number): void
    centerOnMarker(): void
    geocodeAddress(): Promise<void>
    handleTabVisibility(): void
    initMapWhenReady(): Promise<void>
    destroy(): void
}

// Address models configuration
interface AddressModels {
    addressModel?: string
    cityModel?: string
    stateModel?: string
}

// Leaflet Map Component for Alpine.js
function locationMapData(
    latModel: string,
    lngModel: string,
    verifiedModel: string | null | undefined,
    defaultLat: number,
    defaultLng: number,
    apiUrl: string,
    addressModels: AddressModels
): LocationMapContext {
    return {
        map: null as import('leaflet').Map | null, // Leaflet map instance
        marker: null as import('leaflet').Marker | null, // Leaflet marker instance
        geocoding: false,
        mapInitialized: false,
        $el: null as unknown as HTMLElement, // Alpine.js magic property
        $refs: { mapElement: null as unknown as HTMLElement },
        $dispatch: null as unknown as (event: string, data?: unknown) => void, // Alpine.js magic property
        $nextTick: null as unknown as () => Promise<void>,
        $watch: null as unknown as (property: string, callback: (newValue: unknown) => void) => () => void,
        $root: undefined as { activeSectionTab?: string } | undefined,

        // Helper function to get nested property value
        getNestedProperty(path: string): unknown {
            if(!path) {
                return undefined;
            }
            const parts = path.split('.');
            let current: Record<string, unknown> = this as Record<string, unknown>;
            for(const part of parts) {
                if(current == null) {
                    return undefined;
                }
                current = current[part] as Record<string, unknown>;
            }
            return current;
        },

        // Helper function to set nested property value
        setNestedProperty(path: string, value: unknown): void {
            if(!path) {
                return;
            }
            const parts = path.split('.');
            const lastPart = parts[parts.length - 1];
            const initialParts = parts.slice(0, -1);
            if(!lastPart) {
                return;
            }

            let current: Record<string, unknown> = this as Record<string, unknown>;
            for(const part of initialParts) {
                if(current[part] == null) {
                    current[part] = {};
                }
                current = current[part] as Record<string, unknown>;
            }
            current[lastPart] = value;
        },

        async initMapWhenReady() {
            // Check if we're in a tab system
            const isInTab = (this as LocationMapContext).$root && (this as LocationMapContext).$root!.activeSectionTab !== undefined;

            if(isInTab && (this as LocationMapContext).$root!.activeSectionTab !== 'building-info') {
                // Map is in a hidden tab, waiting for tab to be visible
                const unwatch = (this as LocationMapContext).$watch('$root.activeSectionTab', async (newTab: unknown) => {
                    if(newTab === 'building-info') {
                        // Tab is now visible, initializing map
                        unwatch(); // Stop watching
                        await (this as LocationMapContext).initMap();
                    }
                });
            } else {
                // Initialize immediately if not in a tab or if already visible
                await (this as LocationMapContext).initMap();
            }
        },

        async initMap() {
            // Prevent multiple initialization
            if(this.mapInitialized || this.map) {
                return;
            }

            // Import Leaflet dynamically
            if(typeof window !== 'undefined') {
                // Import Leaflet CSS
                if(!document.querySelector('link[href*="leaflet.css"]')) {
                    const link = document.createElement('link');
                    link.rel = 'stylesheet';
                    link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
                    document.head.appendChild(link);
                }

                // Import Leaflet JS
                const LeafletModule = await import('leaflet');
                window.L = LeafletModule;

                // Use Alpine's $nextTick to ensure DOM is ready
                await (this as LocationMapContext).$nextTick();

                // Initialize map
                const _lat = ((this as LocationMapContext).getNestedProperty(latModel) as number) || defaultLat;
                const _lng = ((this as LocationMapContext).getNestedProperty(lngModel) as number) || defaultLng;

                // Use x-ref to get the map element
                const mapElement = (this as LocationMapContext).$refs.mapElement;
                if(!mapElement) {
                    return;
                }

                // Ensure the container has dimensions before initializing
                const rect = mapElement.getBoundingClientRect();

                // If container has no dimensions, force them
                if(rect.width === 0 || rect.height === 0) {
                    mapElement.style.minHeight = '350px';
                    mapElement.style.width = '100%';
                    await new Promise(resolve => requestAnimationFrame(resolve));
                }

                this.map = LeafletModule.map(mapElement, {
                    center: [_lat, _lng],
                    zoom: (this as LocationMapContext).getNestedProperty(latModel) && (this as LocationMapContext).getNestedProperty(lngModel) ? 16 : 4,
                    zoomControl: true,
                });

                // Add OpenStreetMap tiles
                LeafletModule.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                    maxZoom: 19,
                }).addTo((this.map as import('leaflet').Map));

                // Add marker if coordinates exist
                if((this as LocationMapContext).getNestedProperty(latModel) && (this as LocationMapContext).getNestedProperty(lngModel)) {
                    (this as LocationMapContext).addMarker(
                        (this as LocationMapContext).getNestedProperty(latModel) as number,
                        (this as LocationMapContext).getNestedProperty(lngModel) as number
                    );
                }

                // Add click handler to add/move marker
                (this.map as import('leaflet').Map).on('click', (e: import('leaflet').LeafletMouseEvent) => {
                    (this as LocationMapContext).setMarker(e.latlng.lat, e.latlng.lng);
                });

                // Mark map as initialized to hide loading text
                this.mapInitialized = true;

                // Multiple invalidateSize calls with increasing delays for robustness
                const refreshMap = () => {
                    if(this.map) {
                        (this.map as import('leaflet').Map).invalidateSize();
                    }
                };

                // Immediate refresh after Alpine's next tick
                await (this as LocationMapContext).$nextTick();
                refreshMap();

                // Quick refresh after a short delay
                setTimeout(refreshMap, 100);
                setTimeout(refreshMap, 300);
                setTimeout(refreshMap, 1000);

                // Set up tab visibility handler
                (this as LocationMapContext).handleTabVisibility();

                // Also refresh on window resize
                window.addEventListener('resize', () => refreshMap());
            }
        },

        addMarker(lat: number, lng: number) {
            if(typeof window !== 'undefined' && window.L) {
                const L = window.L;

                // Remove existing marker
                if(this.marker) {
                    (this.map as import('leaflet').Map).removeLayer(this.marker);
                }

                // Add new draggable marker
                this.marker = L.marker([lat, lng], { draggable: true })
                    .addTo(this.map as import('leaflet').Map);

                // Handle marker drag
                (this.marker as import('leaflet').Marker).on('dragend', (e: import('leaflet').DragEndEvent) => {
                    const position = (e.target as import('leaflet').Marker).getLatLng();
                    (this as LocationMapContext).setMarker(position.lat, position.lng);
                });

                // Add popup
                (this.marker as import('leaflet').Marker).bindPopup(`
                    <div class="text-center">
                        <div class="font-medium">Building Location</div>
                        <div class="text-xs text-base-content/70 mt-1">
                            ${lat.toFixed(6)}, ${lng.toFixed(6)}
                        </div>
                        <div class="text-xs mt-2">
                            <em>Drag pin to adjust location</em>
                        </div>
                    </div>
                `);
            }
        },

        setMarker(lat: number, lng: number) {
            // Update the Alpine.js models
            (this as LocationMapContext).setNestedProperty(latModel, lat);
            (this as LocationMapContext).setNestedProperty(lngModel, lng);
            if(verifiedModel) {
                (this as LocationMapContext).setNestedProperty(verifiedModel, true); // Mark as verified when manually set
            }

            // Add or update marker
            (this as LocationMapContext).addMarker(lat, lng);

            // Update popup content
            if(this.marker) {
                (this.marker as import('leaflet').Marker).setPopupContent(`
                    <div class="text-center">
                        <div class="font-medium">Building Location</div>
                        <div class="text-xs text-base-content/70 mt-1">
                            ${lat.toFixed(6)}, ${lng.toFixed(6)}
                        </div>
                        <div class="text-xs mt-2">
                            <em>Drag pin to adjust location</em>
                        </div>
                    </div>
                `);
            }
        },

        centerOnMarker() {
            if(this.map && (this as LocationMapContext).getNestedProperty(latModel) && (this as LocationMapContext).getNestedProperty(lngModel)) {
                (this.map as import('leaflet').Map).setView([
                    (this as LocationMapContext).getNestedProperty(latModel) as number,
                    (this as LocationMapContext).getNestedProperty(lngModel) as number
                ], 16);
                if(this.marker) {
                    (this.marker as import('leaflet').Marker).openPopup();
                }
            }
        },

        async geocodeAddress() {
            if(!addressModels.addressModel) {
                return;
            }

            this.geocoding = true;

            try {
                const address = (this as LocationMapContext).getNestedProperty(addressModels.addressModel!);
                const city = addressModels.cityModel ? (this as LocationMapContext).getNestedProperty(addressModels.cityModel) : undefined;
                const state = addressModels.stateModel ? (this as LocationMapContext).getNestedProperty(addressModels.stateModel) : undefined;

                if(!address || !address.toString().trim()) {
                    (this as LocationMapContext).$dispatch('show-toast', {
                        message: 'Please enter an address first',
                        type: 'error'
                    });
                    return;
                }

                const requestBody = {
                    address: address.toString().trim(),
                    ...(city ? { city: city.toString().trim() } : {}),
                    ...(state ? { state: state.toString().trim() } : {})
                };

                const response = await fetch(`${apiUrl}geocoding`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(requestBody),
                });

                const data = await response.json();

                if(data.success && data.result) {
                    // Set coordinates
                    (this as LocationMapContext).setMarker(data.result.lat, data.result.lng);

                    // Center map on new location
                    (this.map as import('leaflet').Map)?.setView([data.result.lat, data.result.lng], 16);

                    // Mark as geocoded (not manually verified)
                    if(verifiedModel) {
                        (this as LocationMapContext).setNestedProperty(verifiedModel!, false);
                    }

                    (this as LocationMapContext).$dispatch('show-toast', {
                        message: `Address geocoded: ${data.result.displayName || 'Location found'}`,
                        type: 'success'
                    });
                } else {
                    (this as LocationMapContext).$dispatch('show-toast', {
                        message: data.error || 'Could not find coordinates for this address',
                        type: 'error'
                    });
                }
            } catch{
                (this as LocationMapContext).$dispatch('show-toast', {
                    message: 'Failed to geocode address. Please try again.',
                    type: 'error'
                });
            } finally {
                this.geocoding = false;
            }
        },

        handleTabVisibility() {
            // Watch for tab changes and refresh map when visible
            (this as LocationMapContext).$watch('$root.activeSectionTab', async (newTab: unknown) => {
                if(newTab === 'building-info' && this.map) {
                    // Use Alpine's nextTick first
                    await (this as LocationMapContext).$nextTick();

                    // Multiple refreshes for robustness
                    (this.map as import('leaflet').Map).invalidateSize();

                    setTimeout(() => {
                        if(this.map) {
                            (this.map as import('leaflet').Map).invalidateSize();
                        }
                    }, 100);

                    setTimeout(() => {
                        if(this.map) {
                            (this.map as import('leaflet').Map).invalidateSize();
                            // Also re-center if we have coordinates
                            if((this as LocationMapContext).getNestedProperty(latModel) && (this as LocationMapContext).getNestedProperty(lngModel)) {
                                (this.map as import('leaflet').Map).setView([
                                    (this as LocationMapContext).getNestedProperty(latModel) as number,
                                    (this as LocationMapContext).getNestedProperty(lngModel) as number
                                ]);
                            }
                        }
                    }, 300);
                }
            });

            // Also handle visibility changes (for modals, hidden tabs, etc.)
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if(entry.isIntersecting && this.map) {
                        setTimeout(() => {
                            if(this.map) {
                                (this.map as import('leaflet').Map).invalidateSize();
                            }
                        }, 100);
                    }
                });
            });

            const mapElement = (this as LocationMapContext).$refs.mapElement;
            if(mapElement) {
                observer.observe(mapElement);
            }
        },

        // Clean up when component is destroyed
        destroy() {
            if(this.map) {
                (this.map as import('leaflet').Map).remove();
                this.map = null;
            }
        }
    };
}

// Make the function globally available
if(typeof window !== 'undefined') {
    window.locationMapData = locationMapData;
}
</script>

<style>

.location-map-picker {
    /* Custom styles for the map picker */
}

.map-container {
    position: relative;
    z-index: 1;
    min-height: 350px; /* Ensure minimum height */
    width: 100%; /* Ensure full width */
}

/* Ensure Leaflet container fills the parent */
.map-container .leaflet-container {
    height: 100%;
    width: 100%;
}

/* Override Leaflet's z-index to work with DaisyUI modals */
.leaflet-control-container {
    z-index: 1000 !important;
}

.leaflet-popup {
    z-index: 1001 !important;
}

/* Custom marker popup styles */
.leaflet-popup-content-wrapper {
    border-radius: 0.5rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

/* Prevent scroll conflicts with map */
.map-container {
    /* Add visual affordance that this is an interactive area */
    cursor: grab;
}

.map-container:hover {
    /* Subtle shadow increase on hover to indicate interactivity */
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

/* When map is being interacted with */
.map-container:active,
.map-container.leaflet-grab {
    cursor: grabbing;
}

/* Responsive adjustments */
@media (max-width: 640px) {
    .location-map-picker .map-container {
        height: 250px !important;
        /* On mobile, slightly reduce max-width to ensure margins for scrolling */
        max-width: calc(100vw - 2rem);
    }

    .location-map-picker .grid-cols-2 {
        grid-template-columns: 1fr;
    }

    .location-map-picker .flex {
        flex-direction: column;
    }

    .location-map-picker .btn {
        width: 100%;
    }
}

@media (min-width: 1024px) {
    /* On large screens, ensure map doesn't exceed reasonable width */
    .location-map-picker .max-w-4xl {
        max-width: 56rem; /* 896px */
    }
}

</style>
