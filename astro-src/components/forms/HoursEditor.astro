---
import _ from 'lodash';
import { DayOfWeek } from '../../types';

export interface Props {
    /** The Alpine.js model path for the hours object (e.g., 'building.contactInfo.officeHours') */
    xModel: string
    /** Title displayed at the top of the editor */
    title?: string
    /** Whether to show copy functionality (copy to next day, copy to all below, etc.) */
    showCopyActions?: boolean
    /** Whether to show bulk action buttons (Set All 9-5, Clear All) */
    showBulkActions?: boolean
    /** Default open time for bulk actions */
    defaultOpenTime?: string
    /** Default close time for bulk actions */
    defaultCloseTime?: string
    /** Compact layout with smaller inputs and spacing */
    compact?: boolean
    /** CSS classes to apply to the container */
    'class'?: string
    /** Help text displayed below the editor */
    helpText?: string
}

const {
    xModel,
    title = 'Hours',
    showCopyActions = true,
    showBulkActions = true,
    defaultOpenTime = '09:00',
    defaultCloseTime = '17:00',
    compact = false,
    'class': containerClass = '',
    helpText
} = Astro.props;

// Days of week for hours
const daysOfWeek = _.values(DayOfWeek);

// Create the parent path for initialization
const parentPath = _.split(xModel, '.').slice(0, -1).join('.');

// Generate unique component ID for Alpine.js scope
// Used in x-id attribute below
const componentId = `hours_editor_${Math.random().toString(36).slice(2, 11)}`;
---

<div
  class={`hours-editor ${containerClass}`}
  x-data={`hoursEditor('${xModel}', '${parentPath}')`}
  x-id={`['${componentId}']`}
>
    <div class={`flex items-center justify-between ${compact ? 'mb-2' : 'mb-4'}`}>
        <h4 class={`font-semibold ${compact ? 'text-sm' : 'text-base'}`}>{title}</h4>
        {showBulkActions && (
            <div class="flex gap-2">
                <button
                  type="button"
                  class={`btn btn-ghost ${compact ? 'btn-xs' : 'btn-sm'}`}
                  @click={`setAllDays('${defaultOpenTime}', '${defaultCloseTime}')`}
                  title={`Set all days to ${defaultOpenTime}-${defaultCloseTime}`}
                >
                    Set All
{' '}
{defaultOpenTime}
-
{defaultCloseTime}
                </button>
                <button
                  type="button"
                  class={`btn btn-ghost ${compact ? 'btn-xs' : 'btn-sm'}`}
                  @click="clearAllDays()"
                  title="Clear all days"
                >
                    Clear All
                </button>
            </div>
        )}
    </div>

    <div class={`space-y-1 ${compact ? 'max-w-xl' : 'max-w-2xl'}`}>
        {_.map(daysOfWeek, (day, index) => (
            <div class={`flex items-center gap-3 p-2 rounded-lg hover:bg-base-200/50 transition-colors ${compact ? 'py-1' : ''}`}>
                <!-- Checkbox -->
                <input
                  type="checkbox"
                  class={`checkbox checkbox-primary ${compact ? 'checkbox-sm' : ''}`}
                  :checked={`isDayOpen('${day}')`}
                    x-on:change={`toggleDay('${day}')`}
                />

                <!-- Day name - fixed width -->
                <span class={`w-20 font-medium capitalize ${compact ? 'text-sm' : 'text-sm'}`}>{day}</span>

                <!-- Time inputs -->
                <div class={`flex items-center gap-2 ${compact ? 'flex-1' : ''}`}>
                    <input
                      type="time"
                      class={`input ${compact ? 'input-sm w-24' : 'input-sm w-28'}`}
                      :disabled={`!isDayOpen('${day}')`}
                      :value={`getDayTime('${day}', 'open')`}
                        x-on:input={`setDayTime('${day}', 'open', $event.target.value)`}
                        placeholder={defaultOpenTime}
                    />
                    <span class="text-xs text-base-content/60">to</span>
                    <input
                      type="time"
                      class={`input ${compact ? 'input-sm w-24' : 'input-sm w-28'}`}
                      :disabled={`!isDayOpen('${day}')`}
                      :value={`getDayTime('${day}', 'close')`}
                        x-on:input={`setDayTime('${day}', 'close', $event.target.value)`}
                        placeholder={defaultCloseTime}
                    />
                </div>

                <!-- Copy actions -->
                {showCopyActions && (
                    <div class="flex gap-1 ml-auto">
                        {/* Copy to next day button */}
                        {index < daysOfWeek.length - 1 && (
                            <div class="tooltip tooltip-top" :data-tip={`isDayOpen('${day}') ? 'Copy ${day}'s hours to ${daysOfWeek[index + 1]} only' : ''`}>
                                <button
                                  type="button"
                                  class="btn btn-xs btn-ghost"
                                  :disabled={`!isDayOpen('${day}')`}
                                    x-on:click={`copyToDay('${day}', '${daysOfWeek[index + 1]}')`}
                                >
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                                    </svg>
                                </button>
                            </div>
                        )}

                        {/* Copy to all below button */}
                        {index < daysOfWeek.length - 1 && (
                            <div class="tooltip tooltip-top" :data-tip={`isDayOpen('${day}') ? 'Apply ${day}'s hours to all remaining days' : ''`}>
                                <button
                                  type="button"
                                  class="btn btn-xs btn-ghost"
                                  :disabled={`!isDayOpen('${day}')`}
                                    x-on:click={`copyToAllBelow('${day}', ${index})`}
                                >
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 13l-7 7-7-7m14-8l-7 7-7-7"></path>
                                    </svg>
                                </button>
                            </div>
                        )}

                        {/* Apply to weekdays/weekends button */}
                        <div class="dropdown dropdown-end">
                            <div class="tooltip tooltip-top" :data-tip={`isDayOpen('${day}') ? 'More copy options' : ''`}>
                                <label
                                  tabindex="0"
                                  class="btn btn-xs btn-ghost"

                                >
                                    •••
                                </label>
                            </div>
                            <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-48">
                                <li>
<a @click={`copyToWeekdays('${day}')`}>Apply to Weekdays</a>
                                </li>
                                <li>
<a @click={`copyToWeekends('${day}')`}>Apply to Weekends</a>
                                </li>
                                <li>
<a @click={`copyToAll('${day}')`}>Apply to All Days</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                )}
            </div>
        ))}
    </div>

    <!-- Helper text -->
    {(helpText || showCopyActions) && (
        <div class={`text-xs text-base-content/60 ${compact ? 'mt-2' : 'mt-4'}`}>
            {helpText || (showCopyActions && 'Tip: Use the arrow buttons to copy hours to other days, or the ••• menu for bulk actions')}
        </div>
    )}
</div>

<script>
// Define types for hours data structure
interface DayHours {
    open: string
    close: string
}

type HoursData = Record<string, DayHours>;

// Hours Editor Alpine.js component
function hoursEditor(modelPath: string, parentPath: string) {
    const daysOfWeek = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'];

    return {
        // Helper to get nested property value
        getNestedProperty(path: string): unknown {
            const keys = path.split('.');
            let value = this as Record<string, unknown>;
            keys.forEach((key) => {
                value = value?.[key] as Record<string, unknown>;
            });
            return value;
        },

        // Helper to set nested property value
        setNestedProperty(path: string, value: unknown): void {
            const keys = path.split('.');
            let obj = this as Record<string, unknown>;

            // Initialize parent if needed
            if(parentPath && !this.getNestedProperty(parentPath)) {
                const parentKeys = parentPath.split('.');
                let parent = obj;
                parentKeys.forEach((key) => {
                    if(!parent[key]) {
                        parent[key] = {};
                    }
                    parent = parent[key] as Record<string, unknown>;
                });
            }

            // Navigate to the parent of the final key
            for(let i = 0; i < keys.length - 1; i++) {
                if(!obj[keys[i]]) {
                    obj[keys[i]] = {};
                }
                obj = obj[keys[i]] as Record<string, unknown>;
            }

            // Set the final value
            obj[keys[keys.length - 1]] = value;
        },

        isDayOpen(day: string): boolean {
            const hours = this.getNestedProperty(modelPath) as HoursData | null | undefined;
            return !!(hours && hours[day]);
        },

        toggleDay(day: string) {
            const hours = (this.getNestedProperty(modelPath) || {}) as HoursData;
            if(hours[day]) {
                delete hours[day];
            } else {
                hours[day] = { open: '09:00', close: '17:00' };
            }
            this.setNestedProperty(modelPath, hours);
        },

        getDayTime(day: string, type: 'open' | 'close'): string {
            const hours = this.getNestedProperty(modelPath) as HoursData | null | undefined;
            return hours?.[day]?.[type] || '';
        },

        setDayTime(day: string, type: 'open' | 'close', value: string) {
            let hours = this.getNestedProperty(modelPath) as HoursData;
            if(!hours) {
                hours = {};
                this.setNestedProperty(modelPath, hours);
            }
            if(!hours[day]) {
                hours[day] = { open: '09:00', close: '17:00' };
            }
            hours[day][type] = value;
        },

        copyToDay(fromDay: string, toDay: string) {
            const hours = this.getNestedProperty(modelPath) as HoursData | null | undefined;
            if(hours?.[fromDay]) {
                hours[toDay] = { ...hours[fromDay] };
            }
        },

        copyToAllBelow(fromDay: string, fromIndex: number) {
            const hours = this.getNestedProperty(modelPath) as HoursData | null | undefined;
            if(hours?.[fromDay]) {
                for(let i = fromIndex + 1; i < daysOfWeek.length; i++) {
                    hours[daysOfWeek[i]] = { ...hours[fromDay] };
                }
            }
        },

        copyToWeekdays(fromDay: string) {
            const hours = this.getNestedProperty(modelPath) as HoursData | null | undefined;
            if(hours?.[fromDay]) {
                const weekdays = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday'];
                weekdays.forEach((day) => {
                    hours[day] = { ...hours[fromDay] };
                });
            }
        },

        copyToWeekends(fromDay: string) {
            const hours = this.getNestedProperty(modelPath) as HoursData | null | undefined;
            if(hours?.[fromDay]) {
                hours.saturday = { ...hours[fromDay] };
                hours.sunday = { ...hours[fromDay] };
            }
        },

        copyToAll(fromDay: string) {
            const hours = this.getNestedProperty(modelPath) as HoursData | null | undefined;
            if(hours?.[fromDay]) {
                daysOfWeek.forEach((day) => {
                    hours[day] = { ...hours[fromDay] };
                });
            }
        },

        setAllDays(open: string, close: string) {
            const hours = (this.getNestedProperty(modelPath) || {}) as HoursData;
            daysOfWeek.forEach((day) => {
                hours[day] = { open, close };
            });
            this.setNestedProperty(modelPath, hours);
        },

        clearAllDays() {
            this.setNestedProperty(modelPath, {});
        }
    };
}

// Make available globally for Alpine.js
declare global {
    interface Window {
        hoursEditor: typeof hoursEditor
    }
}

if(typeof window !== 'undefined') {
    window.hoursEditor = hoursEditor;
}
</script>
