---
/**
 * HoursEditor Component Usage Examples
 * 
 * This file demonstrates different configurations of the HoursEditor component
 * for various use cases in the apartment manager application.
 */

import HoursEditorComponent from './HoursEditor.astro';
---

<!-- Example 1: Full-featured Office Hours Editor -->
<div class="space-y-8 p-6">
    <div>
        <h3 class="text-lg font-semibold mb-4">Example 1: Office Hours (Full Features)</h3>
        <div class="border border-base-300 rounded-lg p-4">
            <HoursEditorComponent
                xModel="building.contactInfo.officeHours"
                title="Office Hours"
                showCopyActions={true}
                showBulkActions={true}
                defaultOpenTime="09:00"
                defaultCloseTime="17:00"
                helpText="Use copy buttons to quickly set consistent hours across multiple days."
            />
        </div>
    </div>

    <!-- Example 2: Compact Tour Hours Editor -->
    <div>
        <h3 class="text-lg font-semibold mb-4">Example 2: Tour Hours (Compact)</h3>
        <div class="border border-base-300 rounded-lg p-4">
            <HoursEditorComponent
                xModel="building.tourAvailability.tourHours"
                title="Tour Availability Hours"
                showCopyActions={false}
                showBulkActions={true}
                defaultOpenTime="10:00"
                defaultCloseTime="18:00"
                compact={true}
                helpText="Set tour hours to let prospective tenants know when they can schedule visits."
            />
        </div>
    </div>

    <!-- Example 3: Minimal Hours Editor -->
    <div>
        <h3 class="text-lg font-semibold mb-4">Example 3: Simple Hours (Minimal)</h3>
        <div class="border border-base-300 rounded-lg p-4">
            <HoursEditorComponent
                xModel="amenity.poolHours"
                title="Pool Hours"
                showCopyActions={false}
                showBulkActions={false}
                defaultOpenTime="06:00"
                defaultCloseTime="22:00"
                compact={true}
                helpText="Basic hours configuration without bulk actions."
            />
        </div>
    </div>

    <!-- Example 4: Business Hours with Custom Times -->
    <div>
        <h3 class="text-lg font-semibold mb-4">Example 4: Business Hours (Custom Defaults)</h3>
        <div class="border border-base-300 rounded-lg p-4">
            <HoursEditorComponent
                xModel="business.operatingHours"
                title="Operating Hours"
                showCopyActions={true}
                showBulkActions={true}
                defaultOpenTime="08:00"
                defaultCloseTime="20:00"
                class="max-w-3xl"
                helpText="Extended hours with 8 AM to 8 PM default."
            />
        </div>
    </div>

    <!-- Usage Instructions -->
    <div class="mt-8">
        <h3 class="text-lg font-semibold mb-4">Component Configuration Options</h3>
        <div class="overflow-x-auto">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        <th>Property</th>
                        <th>Type</th>
                        <th>Default</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>xModel</code></td>
                        <td>string</td>
                        <td>required</td>
                        <td>Alpine.js model path for the hours object</td>
                    </tr>
                    <tr>
                        <td><code>title</code></td>
                        <td>string</td>
                        <td>"Hours"</td>
                        <td>Title displayed at the top</td>
                    </tr>
                    <tr>
                        <td><code>showCopyActions</code></td>
                        <td>boolean</td>
                        <td>true</td>
                        <td>Enable copy buttons (next day, all below, weekdays/weekends)</td>
                    </tr>
                    <tr>
                        <td><code>showBulkActions</code></td>
                        <td>boolean</td>
                        <td>true</td>
                        <td>Show "Set All" and "Clear All" buttons</td>
                    </tr>
                    <tr>
                        <td><code>defaultOpenTime</code></td>
                        <td>string</td>
                        <td>"09:00"</td>
                        <td>Default opening time for bulk actions</td>
                    </tr>
                    <tr>
                        <td><code>defaultCloseTime</code></td>
                        <td>string</td>
                        <td>"17:00"</td>
                        <td>Default closing time for bulk actions</td>
                    </tr>
                    <tr>
                        <td><code>compact</code></td>
                        <td>boolean</td>
                        <td>false</td>
                        <td>Use smaller inputs and reduced spacing</td>
                    </tr>
                    <tr>
                        <td><code>class</code></td>
                        <td>string</td>
                        <td>""</td>
                        <td>Additional CSS classes for the container</td>
                    </tr>
                    <tr>
                        <td><code>helpText</code></td>
                        <td>string</td>
                        <td>auto</td>
                        <td>Custom help text (overrides default copy instructions)</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 
Example data structure expected by the component:
{
  "monday": { "open": "09:00", "close": "17:00" },
  "tuesday": { "open": "09:00", "close": "17:00" },
  "wednesday": { "open": "09:00", "close": "17:00" },
  // ... other days, or omitted if closed
}
-->