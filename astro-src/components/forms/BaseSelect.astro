---
import _ from 'lodash';

export interface SelectOption {
    value: string | number
    label: string
    disabled?: boolean
}

export interface Props {
    name: string
    label?: string
    placeholder?: string
    required?: boolean
    disabled?: boolean
    xModel: string
    options: SelectOption[] | string[]
    value?: string | number
    'class'?: string
    selectClass?: string
    error?: string
    helpText?: string
    showLabel?: boolean
    floatingLabel?: boolean
    onchange?: string
    multiple?: boolean
    size?: number
}

const {
    name,
    label,
    placeholder,
    required = false,
    disabled = false,
    xModel,
    options,
    value,
    'class': className = '',
    selectClass = '',
    error,
    helpText,
    showLabel = true,
    floatingLabel = true,
    onchange,
    multiple = false,
    size,
} = Astro.props;

// Normalize options to SelectOption format
const normalizedOptions: SelectOption[] = options
    ? _.map(options, (opt: SelectOption | string) =>
        (_.isString(opt)
            ? { value: opt, label: opt }
            : opt as SelectOption)
    )
    : [];
// Determine if we should show the label
const shouldShowLabel = showLabel && label;
const labelClass = floatingLabel ? 'floating-label select-label' : 'label';

const selectClasses = _.compact([
    'select',
    'w-full',
    error ? 'select-error' : '',
    selectClass
]).join(' ');

const containerClasses = _.compact([
    labelClass,
    className
]).join(' ');
---

<label class={containerClasses}>
    {shouldShowLabel && !floatingLabel && (
        <span class="label-text">
            {label}
            {required && <span class="text-error">*</span>}
        </span>
    )}
    <select
      name={name}
      class={selectClasses}
      required={required}
      disabled={disabled}
      x-model={xModel}
      multiple={multiple}
      size={size}
      @change={onchange}
    >
        {shouldShowLabel && floatingLabel && (
            <span>
                {label}
                {required && <span class="text-error">*</span>}
            </span>
        )}
        {placeholder && !multiple && (
            <option value="" disabled selected={!value}>
                {placeholder}
            </option>
        )}
        {_.map(normalizedOptions, option => (
            <option
              value={option.value}
              disabled={option.disabled}
              selected={value === option.value}
            >
                {option.label}
            </option>
        ))}
    </select>
    {(error || helpText) && (
        <span class={`label-text-alt ${error ? 'text-error' : ''}`}>
            {error || helpText}
        </span>
    )}
</label>


