---
// Example component demonstrating usage of the form components
import _ from 'lodash';
import BaseInput from './BaseInput.astro';
import BaseSelect from './BaseSelect.astro';
import BaseTextarea from './BaseTextarea.astro';
import PhotoUploader from './PhotoUploader.astro';
import { PropertyType, UtilityType } from '../../../src/types';

// Example data structure for form
const xData = JSON.stringify({
    formData: {
        name: '',
        propertyType: PropertyType.APARTMENT,
        bedrooms: null,
        description: '',
        utilities: [],
        photos: []
    },
    errors: {},

    async submitForm() {
        // Form submission logic here
    }
});

// Select options
const propertyTypeOptions = _.map(Object.entries(PropertyType), ([key, value]) => ({
    value,
    label: _.toUpper(_.replace(_.toLower(_.replace(key, /_/g, ' ')), /\b\w/g, l => l))
}));

const utilityOptions = _.map(Object.entries(UtilityType), ([key, value]) => ({
    value,
    label: _.toUpper(_.replace(_.toLower(_.replace(key, /_/g, ' ')), /\b\w/g, l => l))
}));
---

<div class="max-w-2xl mx-auto p-6" x-data={xData}>
    <h2 class="text-2xl font-bold mb-6">Form Components Example</h2>

    <form x-on:submit.prevent="submitForm" class="space-y-6">
        <!-- Text Input Example -->
        <BaseInput
          name="name"
          label="Property Name"
          placeholder="Enter property name"
          xModel="formData.name"
          required={true}
          helpText="This will be displayed as the main title"
          floatingLabel={true}
        />

        <!-- Number Input Example -->
        <BaseInput
          name="bedrooms"
          label="Number of Bedrooms"
          type="number"
          xModel="formData.bedrooms"
          min="0"
          max="10"
          required={true}
          floatingLabel={true}
        />

        <!-- Select Example -->
        <BaseSelect
          name="propertyType"
          label="Property Type"
          xModel="formData.propertyType"
          options={propertyTypeOptions}
          required={true}
          floatingLabel={true}
          helpText="Select the type of property"
        />

        <!-- Multi-Select Example -->
        <BaseSelect
          name="utilities"
          label="Utilities Included"
          xModel="formData.utilities"
          options={utilityOptions}
          multiple={true}
          size={5}
          floatingLabel={false}
          helpText="Hold Ctrl/Cmd to select multiple"
        />

        <!-- Textarea Example -->
        <BaseTextarea
          name="description"
          label="Property Description"
          xModel="formData.description"
          rows={6}
          maxlength={1000}
          floatingLabel={true}
          helpText="Describe the property features and amenities"
        />

        <!-- Photo Uploader Example -->
        <PhotoUploader
          name="photos"
          label="Property Photos"
          xModel="formData.photos"
          maxFiles={20}
          maxFileSize={10}
          helpText="Upload up to 20 photos (max 10MB each)"
          buildingId="example-building-id"
          unitId="example-unit-id"
        />

        <!-- Form Actions -->
        <div class="flex gap-4 pt-4">
            <button type="submit" class="btn btn-primary">
                Save Property
            </button>
            <button type="button" class="btn btn-ghost" x-on:click="formData = { name: '', propertyType: '${PropertyType.APARTMENT}', bedrooms: null, description: '', utilities: [], photos: [] }">
                Reset
            </button>
        </div>

        <!-- Debug: Show form data -->
        <div class="mt-8 p-4 bg-base-200 rounded-lg">
            <h3 class="font-bold mb-2">Form Data (Debug):</h3>
            <pre x-text="JSON.stringify(formData, null, 2)" class="text-sm"></pre>
        </div>
    </form>
</div>
