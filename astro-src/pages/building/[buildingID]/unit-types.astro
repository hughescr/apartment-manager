---
// Example page showing how to use the UnitType components
import Layout from "../../../layouts/Layout.astro";
import { BuildingsApiService } from "../../../lib/buildings/services/buildingsApiService";
import { UnitTypesApiService } from "../../../lib/unitTypes/services/unitTypesApiService";
import UnitTypeCard from "../../../components/UnitTypeCard.astro";
import UnitTypeForm from "../../../components/UnitTypeForm.astro";
import ModelAmenitiesManager from "../../../components/ModelAmenitiesManager.astro";
import { Resource } from "sst";

const { buildingID } = Astro.params;

if (!buildingID) {
    return Astro.redirect("/404");
}

// Initialize API services
const apiURL = Resource.API.url;
const buildingsService = new BuildingsApiService(apiURL);
const unitTypesService = new UnitTypesApiService(apiURL);

let building: any = undefined;
let unitTypes: any[] = [];
let error: string | null = null;

try {
    // Load building data via API
    const buildingResponse = await buildingsService.getBuilding(buildingID);
    if (!buildingResponse.success || !buildingResponse.data) {
        return Astro.redirect("/404");
    }
    building = buildingResponse.data;

    // Load unit types data via API
    const unitTypesResponse = await unitTypesService.getUnitTypes(buildingID);
    if (unitTypesResponse.success && unitTypesResponse.data) {
        unitTypes = unitTypesResponse.data;
    } else {
        error = unitTypesResponse.error || "Failed to load unit types";
        unitTypes = [];
    }
} catch (e) {
    error = "Failed to load building data";
    building = undefined;
}

// TypeScript now knows building is defined if we reach this point
if (!building) {
    return Astro.redirect("/404");
}
---

<Layout title={`Unit Types - ${building.buildingName || building.buildingID}`}>
    <div class="container mx-auto px-4 py-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold mb-2">Unit Types for {building.buildingName || building.buildingID}</h1>
            <div class="text-base-content/70">
                {building.street}, {building.city}, {building.state} {building.zip}
            </div>
        </div>

        <!-- Error Display -->
        {error && (
            <div class="alert alert-error mb-6" data-testid="error-message">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 w-6 h-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{error}</span>
            </div>
        )}

        <!-- Add New Unit Type -->
        <UnitTypeForm buildingID={buildingID} />

        <!-- Unit Type Cards -->
        <div class="space-y-6 mb-8" data-testid="unit-types-list">
            {unitTypes.length === 0 ? (
                <div class="alert alert-info" data-testid="empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span>No unit types defined yet. Create your first unit type above!</span>
                </div>
            ) : (
                unitTypes.map((unitType) => (
                    <UnitTypeCard unitType={unitType} buildingAmenities={building.propertyAmenities || []} />
                ))
            )}
        </div>

        <!-- Model Amenities Manager -->
        {unitTypes.length > 0 && (
            <ModelAmenitiesManager unitTypes={unitTypes} buildingID={buildingID} />
        )}
    </div>
</Layout>