---
import Layout from '../layouts/Layout.astro';
import BuildingsComponent from '../components/BuildingsComponent.astro';

---

<Layout title='Apartment Manager'>
    <main>
        <div class='flex justify-between items-center'>
            <h1>Buildings</h1>
            <a
                href='/buildings/add'
                class='bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded'
                >Add Building</a
            >
        </div>
        <BuildingsComponent />
    </main>
</Layout>
