import { merge } from 'lodash';
import type {
    SiteMapper,
    MappedBuilding,
    MappedUnitType,
    MappedUnit,
    ValidationResult,
    MappingContext,
    UnitMappingContext,
    FieldMappingConfig
} from '../types.js';
import type {
    BuildingData,
    UnitTypeData,
    UnitData,
    PropertyType,
    UtilityType,
    FeeType,
    PetType,
    ParkingType,
    AmenityCategory
} from '../../types/index.js';
import { inheritanceResolver } from '../inheritance-resolver.js';
import {
    createEnumTransformer,
    createDateFormatter,
    createPriceFormatter,
    transformAmenities,
    transformFees,
    transformPhotoUrls,
    categorizeFees
} from '../transformers/index.js';
import fieldMappingsV2 from '../field-mappings-v2.json';

/**
 * Template mapper implementation for a new rental site.
 * 
 * TO IMPLEMENT A NEW SITE:
 * 1. Copy this file and rename it to your site name (e.g., 'rentals-com.ts')
 * 2. Update the class name and site information
 * 3. Determine if your site uses a three-tier model (Building → Models → Units)
 *    or a flat model (just Units with building info)
 * 4. Update the field mappings in field-mappings-v2.json with your site's selectors
 * 5. Implement the validation rules specific to your site
 * 6. Add any site-specific transformations
 * 7. Register your mapper in src/mappers/sites/index.ts
 * 8. Write comprehensive tests for your mapper
 */
export class TemplateSiteMapper implements SiteMapper {
    // TODO: Update these with your site information
    readonly siteId = 'template_site';
    readonly siteName = 'Template Site';

    private readonly fieldMappings: FieldMappingConfig;

    constructor(customFieldMappings?: Partial<FieldMappingConfig>) {
        this.fieldMappings = merge({}, fieldMappingsV2, customFieldMappings);
    }

    /**
     * Map building data to your site's format.
     * 
     * IMPLEMENTATION NOTES:
     * - Transform property types using createEnumTransformer
     * - Convert fees to site-specific format
     * - Handle utilities based on site requirements
     * - Transform photos if needed
     */
    mapBuilding(building: BuildingData, _context?: MappingContext): MappedBuilding {
        const propertyTypeTransformer = createEnumTransformer<PropertyType>(
            'propertyType',
            this.siteId
        );

        const { oneTime, monthly, deposits } = categorizeFees(
            building.oneTimeFees,
            building.monthlyFees
        );

        // TODO: Implement site-specific transformations
        
        return {
            externalId: building.buildingID,
            name: building.buildingID, // TODO: Add display name support
            address: {
                street: building.street || '',
                city: building.city || '',
                state: building.state || '',
                zip: building.zip || ''
            },
            propertyType: building.propertyType 
                ? propertyTypeTransformer(building.propertyType)
                : 'Apartment',
            yearBuilt: building.yearBuilt,
            totalUnits: building.totalUnits,
            description: building.propertyDescription || building.description,
            photos: transformPhotoUrls(building.photos, this.siteId),
            leaseTerms: {
                minMonths: building.leaseLength,
                maxMonths: building.leaseLength,
                defaultMonths: building.leaseLength || 12
            },
            fees: [
                ...transformFees(oneTime, this.siteId),
                ...transformFees(monthly, this.siteId),
                ...transformFees(deposits, this.siteId)
            ],
            utilities: {}, // TODO: Transform utilities
            parking: [], // TODO: Transform parking
            petPolicy: undefined, // TODO: Transform pet policy
            amenities: transformAmenities(building.propertyAmenities, this.siteId),
            contactInfo: building.contactInfo,
            tourOptions: building.tourAvailability,
            applicationFee: building.applicationFee,
            rentSpecials: building.rentSpecials,
            incomeRestrictions: building.incomeRestrictions,
            screeningCriteria: building.screeningCriteria
        };
    }

    /**
     * Map unit type (model) data to your site's format.
     * 
     * IMPLEMENTATION NOTES:
     * - Skip this if your site doesn't support unit types/models
     * - Return minimal data if models are not used
     */
    mapUnitType(
        unitType: UnitTypeData,
        _building: BuildingData,
        _context?: MappingContext
    ): MappedUnitType {
        const dateFormatter = createDateFormatter('MM/DD/YYYY'); // TODO: Check date format
        
        return {
            externalId: unitType.modelID,
            modelName: unitType.modelName,
            beds: unitType.beds,
            baths: unitType.baths,
            sqft: {
                min: unitType.minSqft,
                max: unitType.maxSqft
            },
            rent: {
                min: unitType.minRent,
                max: unitType.maxRent
            },
            deposit: unitType.deposit,
            maxOccupants: unitType.maxOccupants,
            countAvailable: unitType.countAvailable,
            dateAvailable: dateFormatter(unitType.dateAvailable),
            amenities: transformAmenities(unitType.modelAmenities, this.siteId),
            photos: [] // Models typically don't have their own photos
        };
    }

    /**
     * Map unit data to your site's format.
     * 
     * IMPLEMENTATION NOTES:
     * - Use inheritanceResolver.resolveUnitValues for three-tier sites
     * - Use inheritanceResolver.flattenForSingleTier for flat sites
     * - Merge amenities appropriately
     * - Handle all required fields
     */
    mapUnit(unitContext: UnitMappingContext): MappedUnit {
        const { unit, unitType, building } = unitContext;
        
        // TODO: Choose the appropriate inheritance strategy
        // For three-tier sites:
        const resolved = inheritanceResolver.resolveUnitValues(unit, unitType, building);
        
        // For flat sites:
        // const resolved = inheritanceResolver.flattenForSingleTier(unit, unitType, building);
        
        const dateFormatter = createDateFormatter('MM/DD/YYYY'); // TODO: Check date format
        
        return {
            externalId: unit.unitID,
            unitNumber: unit.unitNumber || unit.unitID,
            modelName: unitType?.modelName,
            beds: resolved.beds || 0,
            baths: resolved.baths || 0,
            sqft: resolved.sqft,
            rent: resolved.rent || 0,
            deposit: resolved.deposit,
            dateAvailable: dateFormatter(resolved.availableDate),
            description: resolved.unitDescription || resolved.description,
            maxOccupants: resolved.maxOccupants,
            leaseTerms: {
                minMonths: resolved.minLeaseTerm,
                maxMonths: resolved.maxLeaseTerm
            },
            amenities: transformAmenities(resolved.unitAmenities, this.siteId),
            photos: transformPhotoUrls(resolved.photos, this.siteId),
            rentSpecial: resolved.unitRentSpecial
        };
    }

    /**
     * Validate building data for your site's requirements.
     * 
     * IMPLEMENTATION NOTES:
     * - Check all required fields
     * - Validate field formats (ZIP codes, phone numbers, etc.)
     * - Return clear error messages
     */
    validateBuilding(building: BuildingData): ValidationResult {
        const errors: Array<{ field: string; message: string }> = [];
        
        // TODO: Add your site's validation rules
        if(!building.street) {
            errors.push({ field: 'street', message: 'Street address is required' });
        }
        if(!building.city) {
            errors.push({ field: 'city', message: 'City is required' });
        }
        if(!building.state) {
            errors.push({ field: 'state', message: 'State is required' });
        }
        if(!building.zip) {
            errors.push({ field: 'zip', message: 'ZIP code is required' });
        }
        
        // Add more validation as needed
        
        return {
            isValid: errors.length === 0,
            errors
        };
    }

    /**
     * Validate unit type data for your site's requirements.
     * 
     * IMPLEMENTATION NOTES:
     * - Skip if your site doesn't use unit types
     * - Validate model-specific requirements
     */
    validateUnitType(unitType: UnitTypeData): ValidationResult {
        const errors: Array<{ field: string; message: string }> = [];
        
        // TODO: Add your site's validation rules for unit types
        
        return {
            isValid: errors.length === 0,
            errors
        };
    }

    /**
     * Validate unit data for your site's requirements.
     * 
     * IMPLEMENTATION NOTES:
     * - Check required fields based on inheritance model
     * - Validate unit-specific data
     */
    validateUnit(unit: UnitData): ValidationResult {
        const errors: Array<{ field: string; message: string }> = [];
        
        // TODO: Add your site's validation rules for units
        
        return {
            isValid: errors.length === 0,
            errors
        };
    }

    // Add any private helper methods below
    // Example:
    // private transformParkingForSite(building: BuildingData): ... {
    //     // Site-specific parking transformation
    // }
}