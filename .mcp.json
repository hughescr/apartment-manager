{
    "mcpServers": {
        "language-server": {
            "command": "${HOME}/go/bin/mcp-language-server",
            "args": ["--workspace", ".", "--lsp", "bunx", "--", "--bun", "typescript-language-server@latest", "--stdio"]
        },
        "eslint": {
            "command": "npx",
            "args": ["https://gitpkg.vercel.app/eslint/rewrite/packages/mcp?main"]
        },
        "tmux": {
            "command": "bunx",
            "args": ["--bun", "github:hughescr/persistent-shell-mcp#main"]
        }
    }
}
