{
    "mcpServers": {
        "language-server": {
            "command": "${HOME}/go/bin/mcp-language-server",
            "args": ["--workspace", ".", "--lsp", "./node_modules/.bin/typescript-language-server", "--", "--stdio"]
        },
        "eslint": {
            "command": "bunx",
            "args": ["--bun", "@eslint/mcp@latest"]
        },
        "tmux": {
            "command": "bunx",
            "args": ["--bun", "github:hughescr/persistent-shell-mcp#main"]
        }
    }
}
