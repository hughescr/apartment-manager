{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Deploy to live site",
            "type": "process",
            "command": "${workspaceFolder}/node_modules/.bin/serverless",
            "args": [
                "deploy",
                "--param",
                "domain=apartments.rungie.com",
                "--param",
                "ZoneID=Z1VXUCOF8PCGCR"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "clear": true,
                "close": true
            },
            "problemMatcher": []
        }
    ]
}
