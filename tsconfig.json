{
    "compilerOptions": {
        "lib": [
            "ESNext"
        ],
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "allowJs": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "typeRoots": [
            "./node_modules/@types"
        ],
        "types": [
            "node",
            "bun",
            "jest"
        ]
    },
    "types": [
        "sst-env.d.ts", ".astro/types.d.ts"
    ],
    "exclude": [
        "node_modules",
        "site-build",
        "sst.config.ts",
        ".sst",
        ".astro"
    ]
}
