{
    "enableAllProjectMcpServers": true,

    "permissions": {
        "allow": [
            "Bash(bun test:*)",
            "mcp__browser",
            "mcp__eslint",
            "mcp__language-server",
            "mcp__tmux"
        ],
        "deny": []
    },

    "hooks": {
        "SubagentStop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "eslint --fix --max-warnings=0 --cache 1>&2 || exit 2"
                    }
                ]
            }
        ]
    }
}
