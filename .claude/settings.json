{
    "permissions": {
        "allow": [
            "mcp__playwright__browser_navigate",
            "mcp__playwright__browser_snapshot",
            "mcp__playwright__browser_click",
            "mcp__playwright__browser_close",
            "mcp__eslint__lint"
        ],
        "deny": []
    },
    "hooks": {
        "pre_message": [
            {
                "id": "eslint-autofix",
                "description": "Run ESLint auto-fix on all modified *.ts/astro files before Claude drafts a commit message.",
                "command": ["mcp", "eslint", "lint", "--fix"]
            }
        ]
    }
}
