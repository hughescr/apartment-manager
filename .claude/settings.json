{
    "enableAllProjectMcpServers": true,

    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "(eslint --fix --cache --max-warnings 1||exit 2)"
                    },
                    {
                        "type": "command",
                        "command": "tsc"
                    }
                ]
            }
        ]
    },

    "permissions": {
        "allow": [
            "mcp__browser",
            "mcp__web-fetch",
            "mcp_search",
            "mcp_time",
            "mcp_Context7",
            "mcp__eslint",
            "mcp__language-server"
        ],
        "deny": []
    }
}
